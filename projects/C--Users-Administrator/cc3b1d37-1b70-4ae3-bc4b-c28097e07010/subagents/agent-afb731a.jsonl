{"parentUuid":"ff4b7269-988c-4e65-9a26-091d468e8206","isSidechain":true,"userType":"external","cwd":"C:\\Users\\Administrator","sessionId":"cc3b1d37-1b70-4ae3-bc4b-c28097e07010","version":"2.1.49","gitBranch":"HEAD","agentId":"afb731a","slug":"humming-wibbling-umbrella","type":"user","message":{"role":"user","content":[{"tool_use_id":"tooluse_tKbcxdvyCnNqADjcxPYbRS","type":"tool_result","content":"     1→#!/usr/bin/env python3\n     2→# -*- coding: utf-8 -*-\n     3→\"\"\"Universal media downloader for video sites and podcasts.\n     4→\n     5→This script is designed to be called by AnyGen as a deterministic helper.\n     6→It relies on yt-dlp, which supports many video sites (YouTube/Bilibili/Douyin, etc.)\n     7→AND can often download podcast audio when the page exposes a direct audio URL.\n     8→\n     9→Examples:\n    10→  # Download best video+audio (mp4)\n    11→  python scripts/download_media.py \"https://www.youtube.com/watch?v=xxxx\"\n    12→\n    13→  # Download audio only (mp3)\n    14→  python scripts/download_media.py --audio-only --audio-format mp3 \"https://www.xiaoyuzhoufm.com/episode/xxxx\"\n    15→\n    16→  # Download with subtitles (auto-detect all available)\n    17→  python scripts/download_media.py --subtitles \"https://www.youtube.com/watch?v=xxxx\"\n    18→\n    19→  # Download with Chinese subtitles only\n    20→  python scripts/download_media.py --subtitles --sub-lang \"zh\" \"https://www.youtube.com/watch?v=xxxx\"\n    21→\n    22→  # Use cookies when needed (e.g., Douyin/Bilibili/YouTube age-gated)\n    23→  python scripts/download_media.py --cookies \"/path/to/cookies.txt\" \"<URL>\"\n    24→\n    25→Output:\n    26→  - Prints the final saved filepath (absolute) as the last line: SAVED_FILEPATH=<path>\n    27→\"\"\"\n    28→\n    29→from __future__ import annotations\n    30→\n    31→import argparse\n    32→import os\n    33→import shlex\n    34→import subprocess\n    35→import sys\n    36→from pathlib import Path\n    37→\n    38→# Default output directory: relative to skill root\n    39→SCRIPT_DIR = Path(__file__).parent.parent\n    40→DEFAULT_OUT_DIR = SCRIPT_DIR / \"downloads\"\n    41→\n    42→\n    43→def run(cmd: list[str]) -> tuple[int, str]:\n    44→    p = subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True)\n    45→    return p.returncode, p.stdout\n    46→\n    47→\n    48→def main() -> int:\n    49→    parser = argparse.ArgumentParser(description=\"Download video/audio by URL using yt-dlp\")\n    50→    parser.add_argument(\"url\", help=\"Video or podcast episode URL\")\n    51→\n    52→    parser.add_argument(\n    53→        \"--out-dir\",\n    54→        default=str(DEFAULT_OUT_DIR),\n    55→        help=f\"Output directory (default: {DEFAULT_OUT_DIR})\",\n    56→    )\n    57→    parser.add_argument(\n    58→        \"--cookies\",\n    59→        default=\"\",\n    60→        help=\"Path to cookies.txt (Netscape format). Useful when 403/login required.\",\n    61→    )\n    62→    parser.add_argument(\n    63→        \"--proxy\",\n    64→        default=\"\",\n    65→        help=\"Proxy URL, e.g. socks5://127.0.0.1:7890 or http://127.0.0.1:7890\",\n    66→    )\n    67→\n    68→    parser.add_argument(\n    69→        \"--audio-only\",\n    70→        action=\"store_true\",\n    71→        help=\"Extract audio only (no video). For podcasts, this is usually what you want.\",\n    72→    )\n    73→    parser.add_argument(\n    74→        \"--audio-format\",\n    75→        default=\"mp3\",\n    76→        help=\"Audio format when --audio-only is set (default: mp3)\",\n    77→    )\n    78→\n    79→    parser.add_argument(\n    80→        \"--subtitles\",\n    81→        action=\"store_true\",\n    82→        help=\"Download subtitles if available.\",\n    83→    )\n    84→    parser.add_argument(\n    85→        \"--sub-lang\",\n    86→        default=\"all\",\n    87→        help=\"Subtitle language(s) to download (default: all, e.g., 'zh,en')\",\n    88→    )\n    89→\n    90→    args = parser.parse_args()\n    91→\n    92→    out_dir = Path(args.out_dir).expanduser().resolve()\n    93→    out_dir.mkdir(parents=True, exist_ok=True)\n    94→\n    95→    # Output template: keep title short + id to avoid collisions\n    96→    outtmpl = str(out_dir / \"%(title).120B_%(id)s.%(ext)s\")\n    97→\n    98→    cmd = [\n    99→        \"yt-dlp\",\n   100→        \"--no-playlist\",\n   101→        \"--js-runtimes\",\n   102→        \"node\",\n   103→        \"-o\",\n   104→        outtmpl,\n   105→        \"--print\",\n   106→        \"after_move:filepath\",\n   107→    ]\n   108→\n   109→    if args.cookies:\n   110→        cookies_path = Path(args.cookies).expanduser().resolve()\n   111→        if not cookies_path.exists():\n   112→            raise FileNotFoundError(f\"cookies file not found: {cookies_path}\")\n   113→        cmd.extend([\"--cookies\", str(cookies_path)])\n   114→\n   115→    if args.proxy:\n   116→        cmd.extend([\"--proxy\", args.proxy])\n   117→\n   118→    if args.audio_only:\n   119→        cmd.extend([\n   120→            \"--extract-audio\",\n   121→            \"--audio-format\",\n   122→            args.audio_format,\n   123→            \"--audio-quality\",\n   124→            \"0\",\n   125→        ])\n   126→    else:\n   127→        # Prefer mp4 for convenience (may still be webm depending on source)\n   128→        cmd.extend([\"--merge-output-format\", \"mp4\"])\n   129→\n   130→    if args.subtitles:\n   131→        cmd.extend([\n   132→            \"--write-sub\",\n   133→            \"--sub-langs\",\n   134→            args.sub_lang,\n   135→        ])\n   136→\n   137→    cmd.append(args.url)\n   138→\n   139→    rc, out = run(cmd)\n   140→\n   141→    # Echo full yt-dlp output for debugging.\n   142→    sys.stdout.write(out)\n   143→\n   144→    if rc != 0:\n   145→        sys.stderr.write(\"\\n[download_media] yt-dlp failed. Command was:\\n\")\n   146→        sys.stderr.write(\"  \" + \" \".join(shlex.quote(c) for c in cmd) + \"\\n\")\n   147→        return rc\n   148→\n   149→    # yt-dlp prints the moved file path via --print after_move:filepath.\n   150→    # Usually the last non-empty line.\n   151→    lines = [ln.strip() for ln in out.splitlines() if ln.strip()]\n   152→    saved = \"\"\n   153→    if lines:\n   154→        cand = lines[-1]\n   155→        if os.path.exists(cand):\n   156→            saved = cand\n   157→\n   158→    if saved:\n   159→        sys.stdout.write(f\"\\nSAVED_FILEPATH={saved}\\n\")\n   160→    else:\n   161→        # Fallback: pick newest file in out_dir\n   162→        files = sorted([p for p in out_dir.glob('*') if p.is_file()], key=lambda p: p.stat().st_mtime, reverse=True)\n   163→        if files:\n   164→            saved = str(files[0])\n   165→            sys.stdout.write(f\"\\nSAVED_FILEPATH={saved}\\n\")\n   166→        else:\n   167→            sys.stdout.write(\"\\nSAVED_FILEPATH=\\n\")\n   168→\n   169→    return 0\n   170→\n   171→\n   172→if __name__ == \"__main__\":\n   173→    raise SystemExit(main())\n   174→"}]},"uuid":"410349cf-9b5d-4fee-9561-b047159b9674","timestamp":"2026-02-25T11:11:05.521Z","sourceToolAssistantUUID":"ff4b7269-988c-4e65-9a26-091d468e8206"}
