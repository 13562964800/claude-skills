e: 1.05em;\n   171→        }\n   172→        \n   173→        .warning {\n   174→            color: #e74c3c;\n   175→            font-weight: bold;\n   176→        }\n   177→        \n   178→        .law-clause {\n   179→            font-family: 'Courier New', Consolas, monospace;\n   180→            background-color: #f8f9fa;\n   181→            padding: 2px 6px;\n   182→            border-radius: 4px;\n   183→            font-size: 0.9em;\n   184→            color: #c7254e;\n   185→            border-left: 3px solid #c7254e;\n   186→        }\n   187→        \n   188→        .note {\n   189→            background-color: #fffde7;\n   190→            padding: 20px;\n   191→            border-radius: 8px;\n   192→            margin-top: 30px;\n   193→            border-left: 5px solid #ffd54f;\n   194→        }\n   195→        \n   196→        .note h3 {\n   197→            color: #f57c00;\n   198→            margin-bottom: 10px;\n   199→        }\n   200→        \n   201→        .note ul {\n   202→            padding-left: 20px;\n   203→            margin-top: 10px;\n   204→        }\n   205→        \n   206→        .note li {\n   207→            margin-bottom: 8px;\n   208→        }\n   209→        \n   210→        .highlight {\n   211→            background-color: #fffacd;\n   212→            animation: highlight 2s ease;\n   213→        }\n   214→        \n   215→        @keyframes highlight {\n   216→            0% { background-color: #fffacd; }\n   217→            100% { background-color: transparent; }\n   218→        }\n   219→        \n   220→        footer {\n   221→            text-align: center;\n   222→            margin-top: 40px;\n   223→            padding: 20px;\n   224→            color: #7f8c8d;\n   225→            font-size: 0.9em;\n   226→            border-top: 1px solid #eee;\n   227→        }\n   228→        \n   229→        @media (max-width: 768px) {\n   230→            .container {\n   231→                padding: 10px;\n   232→            }\n   233→            \n   234→            h1 {\n   235→                font-size: 1.8em;\n   236→            }\n   237→            \n   238→            .filter-btn {\n   239→                padding: 6px 15px;\n   240→                font-size: 0.85em;\n   241→            }\n   242→            \n   243→            th, td {\n   244→                padding: 12px 10px;\n   245→                font-size: 0.9em;\n   246→            }\n   247→        }\n   248→        \n   249→        .copy-btn {\n   250→            background: #2ecc71;\n   251→            color: white;\n   252→            border: none;\n   253→            padding: 8px 15px;\n   254→            border-radius: 4px;\n   255→            cursor: pointer;\n   256→            margin-left: 10px;\n   257→            transition: background 0.3s;\n   258→        }\n   259→        \n   260→        .copy-btn:hover {\n   261→            background: #27ae60;\n   262→        }\n   263→    </style>\n   264→</head>\n   265→<body>\n   266→    <div class=\"container\">\n   267→        <header>\n   268→            <h1>📋 全面法律期限规定汇总表</h1>\n   269→            <p class=\"subtitle\">基于《民法典》、《民事诉讼法》、《劳动合同法》等法律法规整理</p>\n   270→            \n   271→            <div class=\"search-box\">\n   272→                <input type=\"text\" id=\"searchInput\" placeholder=\"搜索法律期限、权利名称或关键词...\">\n   273→            </div>\n   274→            \n   275→            <div class=\"filters\">\n   276→                <button class=\"filter-btn active\" data-filter=\"all\">全部期限</button>\n   277→                <button class=\"filter-btn\" data-filter=\"civil\">民事实体</button>\n   278→                <button class=\"filter-btn\" data-filter=\"procedure\">诉讼程序</button>\n   279→                <button class=\"filter-btn\" data-filter=\"labor\">劳动法</button>\n   280→                <button class=\"filter-btn\" data-filter=\"commercial\">商法</button>\n   281→                <button class=\"filter-btn\" data-filter=\"economic\">经济法</button>\n   282→                <button class=\"filter-btn\" data-filter=\"warning\">高风险期限</button>\n   283→            </div>\n   284→        </header>\n   285→        \n   286→        <div class=\"table-container\">\n   287→            <table id=\"deadlineTable\">\n   288→                <thead>\n   289→                    <tr>\n   290→                        <th>法律门类/权利名称</th>\n   291→                        <th>关键期限长度</th>\n   292→                        <th>起算点与核心规定</th>\n   293→                        <th>法律后果与风险提示</th>\n   294→                        <th>主要法律依据</th>\n   295→                    </tr>\n   296→                </thead>\n   297→                <tbody>\n   298→                    <!-- 第一部分：劳动法、劳动合同法与社会保障法 -->\n   299→                    <tr class=\"category-row\" data-category=\"labor\">\n   300→                        <td colspan=\"5\">第一部分：劳动法、劳动合同法与社会保障法</td>\n   301→                    </tr>\n   302→                    <tr class=\"deadline-item\" data-category=\"labor\">\n   303→                        <td class=\"sub-category\">劳动争议仲裁时效</td>\n   304→                        <td class=\"time-limit\">1年</td>\n   305→                        <td><span class=\"law-clause\">《劳动争议调解仲裁法》第27条</span><br>自当事人知道或应当知道其权利被侵害之日起<strong>1年</strong>内提出仲裁申请。劳动关系存续期间因拖欠劳动报酬发生争议的，不受此限，但应在劳动关系终止之日起<strong>1年</strong>内提出。</td>\n   306→                        <td class=\"warning\">超过仲裁时效申请仲裁，仲裁委员会可能不予受理。时效可因主张权利、同意履行等中断并重新计算。</td>\n   307→                        <td>《劳动争议调解仲裁法》第27条</td>\n   308→                    </tr>\n   309→                    <tr class=\"deadline-item\" data-category=\"labor\">\n   310→                        <td>未签劳动合同二倍工资差额</td>\n   311→                        <td class=\"time-limit\">最多11个月<br>（时效1年）</td>\n   312→                        <td><span class=\"law-clause\">《劳动合同法》第82条<br>《劳动合同法实施条例》第6、7条</span><br>用工之日起超过一个月不满一年未签，应支付二倍工资，支付时间最长不超过<strong>11个月</strong>。用工满一年未签，视为已订立无固定期限合同。<br>仲裁时效从主张权利之日倒推一年计算。</td>\n   313→                        <td>权利有双重期限限制：实体权利最长11个月，程序上受1年仲裁时效约束，需尽早主张。</td>\n   314→                        <td>《劳动合同法》第82条</td>\n   315→                    </tr>\n   316→                    <tr class=\"deadline-item\" data-category=\"labor\">\n   317→                        <td>劳动者单方解除权（预告解除）</td>\n   318→                        <td class=\"time-limit\">30日/3日<br>（通知期）</td>\n   319→                        <td><span class=\"law-clause\">《劳动合同法》第37条</span><br>劳动者提前<strong>30日</strong>书面通知可解除合同；试用期内提前<strong>3日</strong>通知。</td>\n   320→                        <td>此为法律赋予劳动者的预告期，期满后劳动关系解除。劳动者违法解除造成损失的，需赔偿。</td>\n   321→                        <td>《劳动合同法》第37条</td>\n   322→                    </tr>\n   323→                    <tr class=\"deadline-item\" data-category=\"labor\">\n   324→                        <td>用人单位单方解除通知工会</td>\n   325→                        <td class=\"time-limit\">事先通知</td>\n   326→                        <td><span class=\"law-clause\">《劳动合同法》第43条</span><br>用人单位单方解除劳动合同，应当事先将理由通知工会。工会有权提出意见。</td>\n   327→                        <td>未履行通知工会程序即解除，可能被认定为违法解除，需支付赔偿金（2N）。司法实践允许事后补正。</td>\n   328→                        <td>《劳动合同法》第43条</td>\n   329→                    </tr>\n   330→                    <tr class=\"deadline-item\" data-category=\"labor\">\n   331→                        <td>工伤认定申请</td>\n   332→                        <td class=\"time-limit\">单位30日<br>个人1年</td>\n   333→                        <td><span class=\"law-clause\">《工伤保险条例》第17条</span><br>单位应自事故伤害发生之日或被诊断、鉴定为职业病之日起<strong>30日</strong>内提出。<br>用人单位未提，工伤职工或其近亲属、工会可在事故伤害发生之日或被诊断、鉴定为职业病之日起<strong>1年</strong>内提出。</td>\n   334→                        <td class=\"warning\">超过1年申请，人社部门可能不予受理，导致无法享受工伤待遇。</td>\n   335→                        <td>《工伤保险条例》第17条</td>\n   336→                    </tr>\n   337→                    \n   338→                    <!-- 第二部分：商法（公司法、证券法、票据法等） -->\n   339→                    <tr class=\"category-row\" data-category=\"commercial\">\n   340→                        <td colspan=\"5\">第二部分：商法（公司法、证券法、票据法等）</td>\n   341→                    </tr>\n   342→                    <tr class=\"deadline-item\" data-category=\"commercial\">\n   343→                        <td class=\"sub-category\">股东知情权诉讼</td>\n   344→                        <td class=\"time-limit\">无明确期限<br>（但受诉讼时效约束）</td>\n   345→                        <td><span class=\"law-clause\">《公司法》第33条、第97条</span><br>股东有权查阅、复制章程、决议、财报等。被拒绝后可请求法院要求提供查阅。法律未规定行使期限。</td>\n   346→                        <td>权利持续存在，但需在知道权利被侵害后的诉讼时效（3年）内起诉。</td>\n   347→                        <td>《公司法》第33、97条</td>\n   348→                    </tr>\n   349→                    <tr class=\"deadline-item\" data-category=\"commercial warning\">\n   350→                        <td>公司决议撤销之诉（程序瑕疵）</td>\n   351→                        <td class=\"time-limit\">60日</td>\n   352→                        <td><span class=\"law-clause\">《公司法》第22条</span><br>股东（会）/董事（会）召集程序、表决方式违法/违章，或内容违章，股东可自决议作出之日起<strong>60日</strong>内请求法院撤销。</td>\n   353→                        <td class=\"warning\">此为除斥期间，逾期未起诉，撤销权消灭。</td>\n   354→                        <td>《公司法》第22条</td>\n   355→                    </tr>\n   356→                    <tr class=\"deadline-item\" data-category=\"commercial\">\n   357→                        <td>异议股东股份回购请求权</td>\n   358→                        <td class=\"time-limit\">90日</td>\n   359→                        <td><span class=\"law-clause\">《公司法》第74条、第142条</span><br>对股东会特定决议投反对票的股东，可请求公司以合理价格回购股份。自决议通过之日起<strong>60日</strong>内协商，<strong>90日</strong>内起诉。</td>\n   360→                        <td>90日内达不成协议，股东需在决议通过后90日内提起诉讼。</td>\n   361→                        <td>《公司法》第74、142条</td>\n   362→                    </tr>\n   363→                    <tr class=\"deadline-item\" data-category=\"commercial warning\">\n   364→                        <td>票据权利时效</td>\n   365→                        <td class=\"time-limit\">2年/6个月/3个月</td>\n   366→                        <td><span class=\"law-clause\">《票据法》第17条</span><br>1. 对出票人/承兑人：汇票/本票自到期日起<strong>2年</strong>，即付汇票/本票自出票日起<strong>2年</strong>。<br>2. 对支票出票人：自出票日起<strong>6个月</strong>。<br>3. 追索权：自被拒绝承兑/付款之日起<strong>6个月</strong>。<br>4. 再追索权：自清偿日/被诉之日起<strong>3个月</strong>。</td>\n   367→                        <td class=\"warning\">超过票据权利时效，持票人丧失票据权利，但仍享有民事利益返还请求权（适用3年诉讼时效）。</td>\n   368→                        <td>《票据法》第17条</td>\n   369→                    </tr>\n   370→                    \n   371→                    <!-- 第三部分：经济法（反垄断、消费者权益保护等） -->\n   372→                    <tr class=\"category-row\" data-category=\"economic\">\n   373→                        <td colspan=\"5\">第三部分：经济法（反垄断、消费者权益保护等）</td>\n   374→                    </tr>\n   375→                    <tr class=\"deadline-item\" data-category=\"economic\">\n   376→                        <td class=\"sub-category\">消费者七日无理由退货</td>\n   377→                        <td class=\"time-limit\">7日</td>\n   378→                        <td><span class=\"law-clause\">《消费者权益保护法》第25条</span><br>经营者采用网络、电视、电话、邮购等方式销售商品，消费者自收到商品之日起<strong>7日</strong>内退货，且无需说明理由（定作、鲜活易腐等除外）。</td>\n   379→                        <td>经营者应自收到退回商品之日起7日内返还价款。此为法定的\"冷静期\"。</td>\n   380→                        <td>《消费者权益保护法》第25条</td>\n   381→                    </tr>\n   382→                    <tr class=\"deadline-item\" data-category=\"economic\">\n   383→                        <td>产品缺陷损害赔偿责任（诉讼时效）</td>\n   384→                        <td class=\"time-limit\">2年<br>（最长10年/明示安全期）</td>\n   385→                        <td><span class=\"law-clause\">《产品质量法》第45条</span><br>因产品存在缺陷造成损害要求赔偿的诉讼时效为<strong>2年</strong>，自知道或应当知道权利受损及生产者/销售者时起算。<br>损害赔偿请求权，在造成损害的缺陷产品交付最初消费者满<strong>10年</strong>丧失；未超过明示的安全使用期的除外。</td>\n   386→                        <td>此为特殊时效规定，短于普通3年诉讼时效。10年为最长权利保护期。</td>\n   387→                        <td>《产品质量法》第45条</td>\n   388→                    </tr>\n   389→                    <tr class=\"deadline-item\" data-category=\"economic warning\">\n   390→                        <td>经营者集中反垄断申报（等待期）</td>\n   391→                        <td class=\"time-limit\">事前申报<br>（初审30日）</td>\n   392→                        <td><span class=\"law-clause\">《反垄断法》第26条</span><br>达到申报标准的集中，应<strong>事先</strong>申报。<br>执法机构应自收到完整申报材料之日起<strong>30日</strong>内进行初步审查（第一阶段），决定是否进一步审查。</td>\n   393→                        <td class=\"warning\">\"抢跑\"（应报未报即实施集中）面临高额罚款（最高上一年度销售额10%），可能被责令恢复原状。</td>\n   394→                        <td>《反垄断法》第21、26条</td>\n   395→                    </tr>\n   396→                    \n   397→                    <!-- 第四部分：民事实体权利除斥期间与形成权行使期限 -->\n   398→                    <tr class=\"category-row\" data-category=\"civil\">\n   399→                        <td colspan=\"5\">第四部分：民事实体权利除斥期间与形成权行使期限（权利存续期，不适用中止中断）</td>\n   400→                    </tr>\n   401→                    <tr class=\"deadline-item\" data-category=\"civil warning\">\n   402→                        <td>民事法律行为撤销权</td>\n   403→                        <td class=\"time-limit\">1年 / 90日<br>（最长5年）</td>\n   404→                        <td><span class=\"law-clause\">《民法典》第152条</span><br>自知道或应当知道撤销事由之日起<strong>1年</strong>内行使。<br>因胁迫产生撤销权的，自胁迫行为终止之日起<strong>1年</strong>内行使。<br>重大误解当事人自知道或应当知道撤销事由之日起<strong>90日</strong>内行使。<br>自民事法律行为发生之日起<strong>5年</strong>内没有行使的，撤销权消灭。</td>\n   405→                        <td class=\"warning\">逾期不行使，撤销权<strong>绝对消灭</strong>，法律行为确定有效。此为除斥期间，需主动主张。</td>\n   406→                        <td>《民法典》第152条</td>\n   407→                    </tr>\n   408→                    <tr class=\"deadline-item\" data-category=\"civil warning\">\n   409→                        <td>债权人撤销权</td>\n   410→                        <td class=\"time-limit\">1年<br>（最长5年）</td>\n   411→                        <td><span class=\"law-clause\">《民法典》第541条</span><br>自债权人知道或应当知道撤销事由之日起<strong>1年</strong>内行使。<br>自债务人的行为发生之日起<strong>5年</strong>内没有行使的，撤销权消灭。</td>\n   412→                        <td class=\"warning\">逾期不行使，撤销权消灭。需通过诉讼方式行使。</td>\n   413→                        <td>《民法典》第538-542条</td>\n   414→                    </tr>\n   415→                    <tr class=\"deadline-item\" data-category=\"civil warning\">\n   416→                        <td>保证期间</td>\n   417→                        <td class=\"time-limit\">约定优先，无约定或约定不明为6个月</td>\n   418→                        <td><span class=\"law-clause\">《民法典》第692条</span><br>债权人与保证人可以约定保证期间。没有约定或约定不明确的，保证期间为主债务履行期限届满之日起<strong>6个月</strong>。<br>约定\"保证人承担保证责任直至主债务本息还清时为止\"等类似内容的，视为约定不明，保证期间为<strong>6个月</strong>。</td>\n   419→                        <td class=\"warning\">保证期间是确定保证人是否承担责任的\"生死线\"。债权人在此期间内未向保证人主张权利（一般保证需起诉/仲裁），保证责任免除。</td>\n   420→                        <td>《民法典》第692、693条</td>\n   421→                    </tr>\n   422→                    <tr class=\"deadline-item\" data-category=\"civil warning\">\n   423→                        <td>建设工程价款优先受偿权</td>\n   424→                        <td class=\"time-limit\">18个月</td>\n   425→                        <td><span class=\"law-clause\">《民法典》第807条<br>《最高人民法院关于审理建设工程施工合同纠纷案件适用法律问题的解释（一）》第41条</span><br>自发包人应当给付建设工程价款之日起算。最长不超过<strong>18个月</strong>。</td>\n   426→                        <td class=\"warning\">性质为法定担保物权，但行使有严格期限。逾期未主张（需通过诉讼或仲裁等方式明确请求），权利消灭。</td>\n   427→                        <td>《民法典》第807条<br>《建设工程施工合同司法解释一》第41条</td>\n   428→                    </tr>\n   429→                    \n   430→                    <!-- 第五部分：诉讼、仲裁与执行程序 -->\n   431→                    <tr class=\"category-row\" data-category=\"procedure\">\n   432→                        <td colspan=\"5\">第五部分：诉讼、仲裁与执行程序</td>\n   433→                    </tr>\n   434→                    <tr class=\"deadline-item\" data-category=\"procedure warning\">\n   435→                        <td>管辖权异议期</td>\n   436→                        <td class=\"time-limit\">15日</td>\n   437→                        <td><span class=\"law-clause\">《民事诉讼法》第130条</span><br>被告在<strong>提交答辩状期间</strong>提出。答辩期为收到起诉状副本后15日内。</td>\n   438→                        <td class=\"warning\">逾期提出，法院不予审查。此为不变期间。</td>\n   439→                        <td>《民事诉讼法》第130条</td>\n   440→                    </tr>\n   441→                    <tr class=\"deadline-item\" data-category=\"procedure\">\n   442→                        <td>增加、变更诉讼请求/提出反诉</td>\n   443→                        <td class=\"time-limit\">举证期限届满前（原则）</td>\n   444→                        <td><span class=\"law-clause\">《最高人民法院关于适用&lt;民事诉讼法&gt;的解释》第232条</span><br>原则在案件受理后，<strong>举证期限届满前</strong>提出。<br>法庭辩论结束前，对方同意或法院认为可以合并审理的，也可准许。</td>\n   445→                        <td>逾期提出可能导致法院不予准许，需另案处理，增加讼累。</td>\n   446→                        <td>《民诉法解释》第232条</td>\n   447→                    </tr>\n   448→                    <tr class=\"deadline-item\" data-category=\"procedure\">\n   449→                        <td>支付令异议期</td>\n   450→                        <td class=\"time-limit\">15日</td>\n   451→                        <td><span class=\"law-clause\">《民事诉讼法》第221条</span><br>债务人应当自收到支付令之日起<strong>15日</strong>内清偿债务，或向法院提出书面异议。</td>\n   452→                        <td>15日内不提书面异议或异议不成立，支付令生效，可申请强制执行。提出有效书面异议，支付令失效，转入诉讼程序。</td>\n   453→                        <td>《民事诉讼法》第221条</td>\n   454→                    </tr>\n   455→                    <tr class=\"deadline-item\" data-category=\"procedure warning\">\n   456→                        <td>仲裁裁决撤销申请</td>\n   457→                        <td class=\"time-limit\">6个月</td>\n   458→                        <td><span class=\"law-clause\">《仲裁法》第59条</span><br>当事人提出证据证明裁决有法定撤销情形的，可自收到裁决书之日起<strong>6个月</strong>内向仲裁委所在地中级法院申请撤销。</td>\n   459→                        <td class=\"warning\">逾期未申请，撤销权消灭。</td>\n   460→                        <td>《仲裁法》第59条</td>\n   461→                    </tr>\n   462→                    <tr class=\"deadline-item\" data-category=\"procedure\">\n   463→                        <td>公示催告申报权利期</td>\n   464→                        <td class=\"time-limit\">不少于60日</td>\n   465→                        <td><span class=\"law-clause\">《民事诉讼法》第225条</span><br>法院决定受理公示催告申请后，应同时通知支付人止付，并在<strong>3日</strong>内发出公告，催促利害关系人申报权利。公示催告期间由法院定，但不得少于<strong>60日</strong>。</td>\n   466→                        <td>利害关系人应在公示催告期间申报权利。无人申报的，法院根据申请作出除权判决，宣告票据无效。</td>\n   467→                        <td>《民事诉讼法》第225条</td>\n   468→                    </tr>\n   469→                </tbody>\n   470→            </table>\n   471→        </div>\n   472→        \n   473→        <div class=\"note\">\n   474→            <h3>⚠️ 重要使用说明与风险提示</h3>\n   475→            <ul>\n   476→                <li><strong>法律动态性</strong>：本表格基于现行有效法律法规（截至2026年2月）归纳整理。法律适用具有高度专业性，具体案件中期限的起算、中断、中止、延长等需严格依据最新法律、司法解释及个案事实进行精确计算。</li>\n   477→                <li><strong>专业管理建议</strong>：强烈建议将本表格作为建立内部\"法律期限清单\"的基础，并嵌入专业的案件管理软件或日历系统，设置分级预警（如提前30天、15天、7天、3天）与人工复核机制。</li>\n   478→                <li><strong>高风险期限</strong>：标记为<span style=\"color: #e74c3c; font-weight: bold;\">红色警告</span>的期限为除斥期间、不变期间或过期将导致实体权利丧失的高风险期限，需特别关注。</li>\n   479→                <li><strong>分类筛选</strong>：使用页面顶部的分类按钮可以按法律门类筛选相关期限，使用搜索框可以快速查找特定内容。</li>\n   480→                <li><strong>免责声明</strong>：本汇总表仅供参考，不构成正式法律意见。具体法律事务请咨询专业律师。</li>\n   481→            </ul>\n   482→        </div>\n   483→        \n   484→        <footer>\n   485→            <p>© 2026 法律期限管理系统 | 数据仅供参考，请以官方最新法律法规为准</p>\n   486→            <p style=\"margin-top: 10px; font-size: 0.8em;\">本页面包含劳动法、商法、经济法、民法、诉讼法等多个法律门类的关键期限规定</p>\n   487→        </footer>\n   488→    </div>\n   489→\n   490→    <script>\n   491→        // 搜索功能\n   492→        document.getElementById('searchInput').addEventListener('input', function(e) {\n   493→            const searchTerm = e.target.value.toLowerCase();\n   494→            const rows = document.querySelectorAll('.deadline-item');\n   495→            \n   496→            rows.forEach(row => {\n   497→                const text = row.textContent.toLowerCase();\n   498→                if (text.includes(searchTerm)) {\n   499→                    row.style.display = '';\n   500→                    // 添加高亮效果\n   501→                    row.classList.add('highlight');\n   502→                    setTimeout(() => {\n   503→                        row.classList.remove('highlight');\n   504→                    }, 2000);\n   505→                } else {\n   506→                    row.style.display = 'none';\n   507→                }\n   508→            });\n   509→            \n   510→            // 保持分类行显示\n   511→            document.querySelectorAll('.category-row').forEach(row => {\n   512→                row.style.display = '';\n   513→            });\n   514→        });\n   515→        \n   516→        // 筛选功能\n   517→        document.querySelectorAll('.filter-btn').forEach(button => {\n   518→            button.addEventListener('click', function() {\n   519→                const filter = this.getAttribute('data-filter');\n   520→                \n   521→                // 更新活动按钮\n   522→                document.querySelectorAll('.filter-btn').forEach(btn => {\n   523→                    btn.classList.remove('active');\n   524→                });\n   525→                this.classList.add('active');\n   526→                \n   527→                // 显示所有行\n   528→                const allRows = document.querySelectorAll('tbody tr');\n   529→                allRows.forEach(row => {\n   530→                    row.style.display = '';\n   531→                });\n   532→                \n   533→                // 如果选择\"全部\"，不进行筛选\n   534→                if (filter === 'all') {\n   535→                    return;\n   536→                }\n   537→                \n   538→                // 筛选行\n   539→                allRows.forEach(row => {\n   540→                    if (row.classList.contains('category-row')) {\n   541→                        // 分类行：检查其data-category是否包含筛选条件\n   542→                        const category = row.getAttribute('data-category');\n   543→                        if (category && category.includes(filter)) {\n   544→                            row.style.display = '';\n   545→                        } else {\n   546→                            // 如果不是当前筛选的分类，但下面有符合条件的项目，也显示\n   547→                            let hasVisibleItems = false;\n   548→                            let nextRow = row.nextElementSibling;\n   549→                            \n   550→                            while (nextRow && !nextRow.classList.contains('category-row')) {\n   551→                                if (nextRow.classList.contains('deadline-item')) {\n   552→                                    const itemCategories = nextRow.getAttribute('data-category');\n   553→                                    if (itemCategories && itemCategories.includes(filter)) {\n   554→                                        hasVisibleItems = true;\n   555→                                        break;\n   556→                                    }\n   557→                                }\n   558→                                nextRow = nextRow.nextElementSibling;\n   559→                            }\n   560→                            \n   561→                            row.style.display = hasVisibleItems ? '' : 'none';\n   562→                        }\n   563→                    } else if (row.classList.contains('deadline-item')) {\n   564→                        // 期限项目行：检查其data-category是否包含筛选条件\n   565→                        const categories = row.getAttribute('data-category');\n   566→                        if (categories && categories.includes(filter)) {\n   567→                            row.style.display = '';\n   568→                        } else {\n   569→                            row.style.display = 'none';\n   570→                        }\n   571→                    }\n   572→                });\n   573→            });\n   574→        });\n   575→        \n   576→        // 页面加载时显示所有内容\n   577→        document.addEventListener('DOMContentLoaded', function() {\n   578→            console.log('法律期限汇总表已加载完成，共包含 ' + document.querySelectorAll('.deadline-item').length + ' 个法律期限项目。');\n   579→        });\n   580→    </script>\n   581→</body>\n   582→</html>\n   583→"}]},"uuid":"bb93cf7d-60c4-4e92-94aa-204019503567","timestamp":"2026-02-14T06:42:18.945Z","toolUseResult":{"type":"text","file":{"filePath":"C:/Users/Administrator/Desktop/全面法律期限汇总表格.html","content":"<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>全面法律期限规定汇总表</title>\n    <style>\n        * {\n            box-sizing: border-box;\n            margin: 0;\n            padding: 0;\n        }\n        \n        body {\n            font-family: 'Microsoft YaHei', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n            line-height: 1.6;\n            color: #333;\n            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);\n            min-height: 100vh;\n            padding: 20px;\n        }\n        \n        .container {\n            max-width: 1400px;\n            margin: 0 auto;\n            padding: 20px;\n        }\n        \n        header {\n            text-align: center;\n            margin-bottom: 30px;\n            padding: 20px;\n            background: white;\n            border-radius: 10px;\n            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);\n        }\n        \n        h1 {\n            color: #2c3e50;\n            margin-bottom: 10px;\n            font-size: 2.2em;\n        }\n        \n        .subtitle {\n            color: #7f8c8d;\n            font-size: 1.1em;\n            margin-bottom: 20px;\n        }\n        \n        .filters {\n            display: flex;\n            justify-content: center;\n            gap: 15px;\n            margin-top: 15px;\n            flex-wrap: wrap;\n        }\n        \n        .filter-btn {\n            padding: 8px 20px;\n            background: #3498db;\n            color: white;\n            border: none;\n            border-radius: 20px;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            font-size: 0.9em;\n        }\n        \n        .filter-btn:hover {\n            background: #2980b9;\n            transform: translateY(-2px);\n        }\n        \n        .filter-btn.active {\n            background: #2c3e50;\n        }\n        \n        .search-box {\n            margin: 20px auto;\n            max-width: 600px;\n        }\n        \n        #searchInput {\n            width: 100%;\n            padding: 12px 20px;\n            border: 2px solid #ddd;\n            border-radius: 25px;\n            font-size: 1em;\n            transition: border-color 0.3s;\n        }\n        \n        #searchInput:focus {\n            outline: none;\n            border-color: #3498db;\n        }\n        \n        .table-container {\n            background: white;\n            border-radius: 10px;\n            overflow: hidden;\n            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);\n            margin-bottom: 30px;\n            overflow-x: auto;\n        }\n        \n        table {\n            width: 100%;\n            border-collapse: collapse;\n            min-width: 1200px;\n        }\n        \n        thead {\n            background: linear-gradient(135deg, #2c3e50 0%, #4a6491 100%);\n            color: white;\n        }\n        \n        th {\n            padding: 18px 15px;\n            text-align: left;\n            font-weight: 600;\n            font-size: 0.95em;\n            border-right: 1px solid rgba(255, 255, 255, 0.1);\n        }\n        \n        th:last-child {\n            border-right: none;\n        }\n        \n        th:nth-child(1) { width: 18%; }\n        th:nth-child(2) { width: 12%; }\n        th:nth-child(3) { width: 35%; }\n        th:nth-child(4) { width: 25%; }\n        th:nth-child(5) { width: 10%; }\n        \n        tbody tr {\n            border-bottom: 1px solid #eee;\n            transition: background-color 0.2s;\n        }\n        \n        tbody tr:hover {\n            background-color: #f8f9fa;\n        }\n        \n        td {\n            padding: 16px 15px;\n            vertical-align: top;\n            border-right: 1px solid #eee;\n        }\n        \n        td:last-child {\n            border-right: none;\n        }\n        \n        .category-row {\n            background-color: #2980b9 !important;\n            color: white;\n            font-weight: bold;\n            font-size: 1.1em;\n        }\n        \n        .sub-category {\n            background-color: #e3f2fd !important;\n            font-weight: bold;\n            color: #1565c0;\n        }\n        \n        .time-limit {\n            color: #27ae60;\n            font-weight: bold;\n            font-size: 1.05em;\n        }\n        \n        .warning {\n            color: #e74c3c;\n            font-weight: bold;\n        }\n        \n        .law-clause {\n            font-family: 'Courier New', Consolas, monospace;\n            background-color: #f8f9fa;\n            padding: 2px 6px;\n            border-radius: 4px;\n            font-size: 0.9em;\n            color: #c7254e;\n            border-left: 3px solid #c7254e;\n        }\n        \n        .note {\n            background-color: #fffde7;\n            padding: 20px;\n            border-radius: 8px;\n            margin-top: 30px;\n            border-left: 5px solid #ffd54f;\n        }\n        \n        .note h3 {\n            color: #f57c00;\n            margin-bottom: 10px;\n        }\n        \n        .note ul {\n            padding-left: 20px;\n            margin-top: 10px;\n        }\n        \n        .note li {\n            margin-bottom: 8px;\n        }\n        \n        .highlight {\n            background-color: #fffacd;\n            animation: highlight 2s ease;\n        }\n        \n        @keyframes highlight {\n            0% { background-color: #fffacd; }\n            100% { background-color: transparent; }\n        }\n        \n        footer {\n            text-align: center;\n            margin-top: 40px;\n            padding: 20px;\n            color: #7f8c8d;\n            font-size: 0.9em;\n            border-top: 1px solid #eee;\n        }\n        \n        @media (max-width: 768px) {\n            .container {\n                padding: 10px;\n            }\n            \n            h1 {\n                font-size: 1.8em;\n            }\n            \n            .filter-btn {\n                padding: 6px 15px;\n                font-size: 0.85em;\n            }\n            \n            th, td {\n                padding: 12px 10px;\n                font-size: 0.9em;\n            }\n        }\n        \n        .copy-btn {\n            background: #2ecc71;\n            color: white;\n            border: none;\n            padding: 8px 15px;\n            border-radius: 4px;\n            cursor: pointer;\n            margin-left: 10px;\n            transition: background 0.3s;\n        }\n        \n        .copy-btn:hover {\n            background: #27ae60;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <header>\n            <h1>📋 全面法律期限规定汇总表</h1>\n            <p class=\"subtitle\">基于《民法典》、《民事诉讼法》、《劳动合同法》等法律法规整理</p>\n            \n            <div class=\"search-box\">\n                <input type=\"text\" id=\"searchInput\" placeholder=\"搜索法律期限、权利名称或关键词...\">\n            </div>\n            \n            <div class=\"filters\">\n                <button class=\"filter-btn active\" data-filter=\"all\">全部期限</button>\n                <button class=\"filter-btn\" data-filter=\"civil\">民事实体</button>\n                <button class=\"filter-btn\" data-filter=\"procedure\">诉讼程序</button>\n                <button class=\"filter-btn\" data-filter=\"labor\">劳动法</button>\n                <button class=\"filter-btn\" data-filter=\"commercial\">商法</button>\n                <button class=\"filter-btn\" data-filter=\"economic\">经济法</button>\n                <button class=\"filter-btn\" data-filter=\"warning\">高风险期限</button>\n            </div>\n        </header>\n        \n        <div class=\"table-container\">\n            <table id=\"deadlineTable\">\n                <thead>\n                    <tr>\n                        <th>法律门类/权利名称</th>\n                        <th>关键期限长度</th>\n                        <th>起算点与核心规定</th>\n                        <th>法律后果与风险提示</th>\n                        <th>主要法律依据</th>\n                    </tr>\n                </thead>\n                <tbody>\n                    <!-- 第一部分：劳动法、劳动合同法与社会保障法 -->\n                    <tr class=\"category-row\" data-category=\"labor\">\n                        <td colspan=\"5\">第一部分：劳动法、劳动合同法与社会保障法</td>\n                    </tr>\n                    <tr class=\"deadline-item\" data-category=\"labor\">\n                        <td class=\"sub-category\">劳动争议仲裁时效</td>\n                        <td class=\"time-limit\">1年</td>\n                        <td><span class=\"law-clause\">《劳动争议调解仲裁法》第27条</span><br>自当事人知道或应当知道其权利被侵害之日起<strong>1年</strong>内提出仲裁申请。劳动关系存续期间因拖欠劳动报酬发生争议的，不受此限，但应在劳动关系终止之日起<strong>1年</strong>内提出。</td>\n                        <td class=\"warning\">超过仲裁时效申请仲裁，仲裁委员会可能不予受理。时效可因主张权利、同意履行等中断并重新计算。</td>\n                        <td>《劳动争议调解仲裁法》第27条</td>\n                    </tr>\n                    <tr class=\"deadline-item\" data-category=\"labor\">\n                        <td>未签劳动合同二倍工资差额</td>\n                        <td class=\"time-limit\">最多11个月<br>（时效1年）</td>\n                        <td><span class=\"law-clause\">《劳动合同法》第82条<br>《劳动合同法实施条例》第6、7条</span><br>用工之日起超过一个月不满一年未签，应支付二倍工资，支付时间最长不超过<strong>11个月</strong>。用工满一年未签，视为已订立无固定期限合同。<br>仲裁时效从主张权利之日倒推一年计算。</td>\n                        <td>权利有双重期限限制：实体权利最长11个月，程序上受1年仲裁时效约束，需尽早主张。</td>\n                        <td>《劳动合同法》第82条</td>\n                    </tr>\n                    <tr class=\"deadline-item\" data-category=\"labor\">\n                        <td>劳动者单方解除权（预告解除）</td>\n                        <td class=\"time-limit\">30日/3日<br>（通知期）</td>\n                        <td><span class=\"law-clause\">《劳动合同法》第37条</span><br>劳动者提前<strong>30日</strong>书面通知可解除合同；试用期内提前<strong>3日</strong>通知。</td>\n                        <td>此为法律赋予劳动者的预告期，期满后劳动关系解除。劳动者违法解除造成损失的，需赔偿。</td>\n                        <td>《劳动合同法》第37条</td>\n                    </tr>\n                    <tr class=\"deadline-item\" data-category=\"labor\">\n                        <td>用人单位单方解除通知工会</td>\n                        <td class=\"time-limit\">事先通知</td>\n                        <td><span class=\"law-clause\">《劳动合同法》第43条</span><br>用人单位单方解除劳动合同，应当事先将理由通知工会。工会有权提出意见。</td>\n                        <td>未履行通知工会程序即解除，可能被认定为违法解除，需支付赔偿金（2N）。司法实践允许事后补正。</td>\n                        <td>《劳动合同法》第43条</td>\n                    </tr>\n                    <tr class=\"deadline-item\" data-category=\"labor\">\n                        <td>工伤认定申请</td>\n                        <td class=\"time-limit\">单位30日<br>个人1年</td>\n                        <td><span class=\"law-clause\">《工伤保险条例》第17条</span><br>单位应自事故伤害发生之日或被诊断、鉴定为职业病之日起<strong>30日</strong>内提出。<br>用人单位未提，工伤职工或其近亲属、工会可在事故伤害发生之日或被诊断、鉴定为职业病之日起<strong>1年</strong>内提出。</td>\n                        <td class=\"warning\">超过1年申请，人社部门可能不予受理，导致无法享受工伤待遇。</td>\n                        <td>《工伤保险条例》第17条</td>\n                    </tr>\n                    \n                    <!-- 第二部分：商法（公司法、证券法、票据法等） -->\n                    <tr class=\"category-row\" data-category=\"commercial\">\n                        <td colspan=\"5\">第二部分：商法（公司法、证券法、票据法等）</td>\n                    </tr>\n                    <tr class=\"deadline-item\" data-category=\"commercial\">\n                        <td class=\"sub-category\">股东知情权诉讼</td>\n                        <td class=\"time-limit\">无明确期限<br>（但受诉讼时效约束）</td>\n                        <td><span class=\"law-clause\">《公司法》第33条、第97条</span><br>股东有权查阅、复制章程、决议、财报等。被拒绝后可请求法院要求提供查阅。法律未规定行使期限。</td>\n                        <td>权利持续存在，但需在知道权利被侵害后的诉讼时效（3年）内起诉。</td>\n                        <td>《公司法》第33、97条</td>\n                    </tr>\n                    <tr class=\"deadline-item\" data-category=\"commercial warning\">\n                        <td>公司决议撤销之诉（程序瑕疵）</td>\n                        <td class=\"time-limit\">60日</td>\n                        <td><span class=\"law-clause\">《公司法》第22条</span><br>股东（会）/董事（会）召集程序、表决方式违法/违章，或内容违章，股东可自决议作出之日起<strong>60日</strong>内请求法院撤销。</td>\n                        <td class=\"warning\">此为除斥期间，逾期未起诉，撤销权消灭。</td>\n                        <td>《公司法》第22条</td>\n                    </tr>\n                    <tr class=\"deadline-item\" data-category=\"commercial\">\n                        <td>异议股东股份回购请求权</td>\n                        <td class=\"time-limit\">90日</td>\n                        <td><span class=\"law-clause\">《公司法》第74条、第142条</span><br>对股东会特定决议投反对票的股东，可请求公司以合理价格回购股份。自决议通过之日起<strong>60日</strong>内协商，<strong>90日</strong>内起诉。</td>\n                        <td>90日内达不成协议，股东需在决议通过后90日内提起诉讼。</td>\n                        <td>《公司法》第74、142条</td>\n                    </tr>\n                    <tr class=\"deadline-item\" data-category=\"commercial warning\">\n                        <td>票据权利时效</td>\n                        <td class=\"time-limit\">2年/6个月/3个月</td>\n                        <td><span class=\"law-clause\">《票据法》第17条</span><br>1. 对出票人/承兑人：汇票/本票自到期日起<strong>2年</strong>，即付汇票/本票自出票日起<strong>2年</strong>。<br>2. 对支票出票人：自出票日起<strong>6个月</strong>。<br>3. 追索权：自被拒绝承兑/付款之日起<strong>6个月</strong>。<br>4. 再追索权：自清偿日/被诉之日起<strong>3个月</strong>。</td>\n                        <td class=\"warning\">超过票据权利时效，持票人丧失票据权利，但仍享有民事利益返还请求权（适用3年诉讼时效）。</td>\n                        <td>《票据法》第17条</td>\n                    </tr>\n                    \n                    <!-- 第三部分：经济法（反垄断、消费者权益保护等） -->\n                    <tr class=\"category-row\" data-category=\"economic\">\n                        <td colspan=\"5\">第三部分：经济法（反垄断、消费者权益保护等）</td>\n                    </tr>\n                    <tr class=\"deadline-item\" data-category=\"economic\">\n                        <td class=\"sub-category\">消费者七日无理由退货</td>\n                        <td class=\"time-limit\">7日</td>\n                        <td><span class=\"law-clause\">《消费者权益保护法》第25条</span><br>经营者采用网络、电视、电话、邮购等方式销售商品，消费者自收到商品之日起<strong>7日</strong>内退货，且无需说明理由（定作、鲜活易腐等除外）。</td>\n                        <td>经营者应自收到退回商品之日起7日内返还价款。此为法定的\"冷静期\"。</td>\n                        <td>《消费者权益保护法》第25条</td>\n                    </tr>\n                    <tr class=\"deadline-item\" data-category=\"economic\">\n                        <td>产品缺陷损害赔偿责任（诉讼时效）</td>\n                        <td class=\"time-limit\">2年<br>（最长10年/明示安全期）</td>\n                        <td><span class=\"law-clause\">《产品质量法》第45条</span><br>因产品存在缺陷造成损害要求赔偿的诉讼时效为<strong>2年</strong>，自知道或应当知道权利受损及生产者/销售者时起算。<br>损害赔偿请求权，在造成损害的缺陷产品交付最初消费者满<strong>10年</strong>丧失；未超过明示的安全使用期的除外。</td>\n                        <td>此为特殊时效规定，短于普通3年诉讼时效。10年为最长权利保护期。</td>\n                        <td>《产品质量法》第45条</td>\n                    </tr>\n                    <tr class=\"deadline-item\" data-category=\"economic warning\">\n                        <td>经营者集中反垄断申报（等待期）</td>\n                        <td class=\"time-limit\">事前申报<br>（初审30日）</td>\n                        <td><span class=\"law-clause\">《反垄断法》第26条</span><br>达到申报标准的集中，应<strong>事先</strong>申报。<br>执法机构应自收到完整申报材料之日起<strong>30日</strong>内进行初步审查（第一阶段），决定是否进一步审查。</td>\n                        <td class=\"warning\">\"抢跑\"（应报未报即实施集中）面临高额罚款（最高上一年度销售额10%），可能被责令恢复原状。</td>\n                        <td>《反垄断法》第21、26条</td>\n                    </tr>\n                    \n                    <!-- 第四部分：民事实体权利除斥期间与形成权行使期限 -->\n                    <tr class=\"category-row\" data-category=\"civil\">\n                        <td colspan=\"5\">第四部分：民事实体权利除斥期间与形成权行使期限（权利存续期，不适用中止中断）</td>\n                    </tr>\n                    <tr class=\"deadline-item\" data-category=\"civil warning\">\n                        <td>民事法律行为撤销权</td>\n                        <td class=\"time-limit\">1年 / 90日<br>（最长5年）</td>\n                        <td><span class=\"law-clause\">《民法典》第152条</span><br>自知道或应当知道撤销事由之日起<strong>1年</strong>内行使。<br>因胁迫产生撤销权的，自胁迫行为终止之日起<strong>1年</strong>内行使。<br>重大误解当事人自知道或应当知道撤销事由之日起<strong>90日</strong>内行使。<br>自民事法律行为发生之日起<strong>5年</strong>内没有行使的，撤销权消灭。</td>\n                        <td class=\"warning\">逾期不行使，撤销权<strong>绝对消灭</strong>，法律行为确定有效。此为除斥期间，需主动主张。</td>\n                        <td>《民法典》第152条</td>\n                    </tr>\n                    <tr class=\"deadline-item\" data-category=\"civil warning\">\n                        <td>债权人撤销权</td>\n                        <td class=\"time-limit\">1年<br>（最长5年）</td>\n                        <td><span class=\"law-clause\">《民法典》第541条</span><br>自债权人知道或应当知道撤销事由之日起<strong>1年</strong>内行使。<br>自债务人的行为发生之日起<strong>5年</strong>内没有行使的，撤销权消灭。</td>\n                        <td class=\"warning\">逾期不行使，撤销权消灭。需通过诉讼方式行使。</td>\n                        <td>《民法典》第538-542条</td>\n                    </tr>\n                    <tr class=\"deadline-item\" data-category=\"civil warning\">\n                        <td>保证期间</td>\n                        <td class=\"time-limit\">约定优先，无约定或约定不明为6个月</td>\n                        <td><span class=\"law-clause\">《民法典》第692条</span><br>债权人与保证人可以约定保证期间。没有约定或约定不明确的，保证期间为主债务履行期限届满之日起<strong>6个月</strong>。<br>约定\"保证人承担保证责任直至主债务本息还清时为止\"等类似内容的，视为约定不明，保证期间为<strong>6个月</strong>。</td>\n                        <td class=\"warning\">保证期间是确定保证人是否承担责任的\"生死线\"。债权人在此期间内未向保证人主张权利（一般保证需起诉/仲裁），保证责任免除。</td>\n                        <td>《民法典》第692、693条</td>\n                    </tr>\n                    <tr class=\"deadline-item\" data-category=\"civil warning\">\n                        <td>建设工程价款优先受偿权</td>\n                        <td class=\"time-limit\">18个月</td>\n                        <td><span class=\"law-clause\">《民法典》第807条<br>《最高人民法院关于审理建设工程施工合同纠纷案件适用法律问题的解释（一）》第41条</span><br>自发包人应当给付建设工程价款之日起算。最长不超过<strong>18个月</strong>。</td>\n                        <td class=\"warning\">性质为法定担保物权，但行使有严格期限。逾期未主张（需通过诉讼或仲裁等方式明确请求），权利消灭。</td>\n                        <td>《民法典》第807条<br>《建设工程施工合同司法解释一》第41条</td>\n                    </tr>\n                    \n                    <!-- 第五部分：诉讼、仲裁与执行程序 -->\n                    <tr class=\"category-row\" data-category=\"procedure\">\n                        <td colspan=\"5\">第五部分：诉讼、仲裁与执行程序</td>\n                    </tr>\n                    <tr class=\"deadline-item\" data-category=\"procedure warning\">\n                        <td>管辖权异议期</td>\n                        <td class=\"time-limit\">15日</td>\n                        <td><span class=\"law-clause\">《民事诉讼法》第130条</span><br>被告在<strong>提交答辩状期间</strong>提出。答辩期为收到起诉状副本后15日内。</td>\n                        <td class=\"warning\">逾期提出，法院不予审查。此为不变期间。</td>\n                        <td>《民事诉讼法》第130条</td>\n                    </tr>\n                    <tr class=\"deadline-item\" data-category=\"procedure\">\n                        <td>增加、变更诉讼请求/提出反诉</td>\n                        <td class=\"time-limit\">举证期限届满前（原则）</td>\n                        <td><span class=\"law-clause\">《最高人民法院关于适用&lt;民事诉讼法&gt;的解释》第232条</span><br>原则在案件受理后，<strong>举证期限届满前</strong>提出。<br>法庭辩论结束前，对方同意或法院认为可以合并审理的，也可准许。</td>\n                        <td>逾期提出可能导致法院不予准许，需另案处理，增加讼累。</td>\n                        <td>《民诉法解释》第232条</td>\n                    </tr>\n                    <tr class=\"deadline-item\" data-category=\"procedure\">\n                        <td>支付令异议期</td>\n                        <td class=\"time-limit\">15日</td>\n                        <td><span class=\"law-clause\">《民事诉讼法》第221条</span><br>债务人应当自收到支付令之日起<strong>15日</strong>内清偿债务，或向法院提出书面异议。</td>\n                        <td>15日内不提书面异议或异议不成立，支付令生效，可申请强制执行。提出有效书面异议，支付令失效，转入诉讼程序。</td>\n                        <td>《民事诉讼法》第221条</td>\n                    </tr>\n                    <tr class=\"deadline-item\" data-category=\"procedure warning\">\n                        <td>仲裁裁决撤销申请</td>\n                        <td class=\"time-limit\">6个月</td>\n                        <td><span class=\"law-clause\">《仲裁法》第59条</span><br>当事人提出证据证明裁决有法定撤销情形的，可自收到裁决书之日起<strong>6个月</strong>内向仲裁委所在地中级法院申请撤销。</td>\n                        <td class=\"warning\">逾期未申请，撤销权消灭。</td>\n                        <td>《仲裁法》第59条</td>\n                    </tr>\n                    <tr class=\"deadline-item\" data-category=\"procedure\">\n                        <td>公示催告申报权利期</td>\n                        <td class=\"time-limit\">不少于60日</td>\n                        <td><span class=\"law-clause\">《民事诉讼法》第225条</span><br>法院决定受理公示催告申请后，应同时通知支付人止付，并在<strong>3日</strong>内发出公告，催促利害关系人申报权利。公示催告期间由法院定，但不得少于<strong>60日</strong>。</td>\n                        <td>利害关系人应在公示催告期间申报权利。无人申报的，法院根据申请作出除权判决，宣告票据无效。</td>\n                        <td>《民事诉讼法》第225条</td>\n                    </tr>\n                </tbody>\n            </table>\n        </div>\n        \n        <div class=\"note\">\n            <h3>⚠️ 重要使用说明与风险提示</h3>\n            <ul>\n                <li><strong>法律动态性</strong>：本表格基于现行有效法律法规（截至2026年2月）归纳整理。法律适用具有高度专业性，具体案件中期限的起算、中断、中止、延长等需严格依据最新法律、司法解释及个案事实进行精确计算。</li>\n                <li><strong>专业管理建议</strong>：强烈建议将本表格作为建立内部\"法律期限清单\"的基础，并嵌入专业的案件管理软件或日历系统，设置分级预警（如提前30天、15天、7天、3天）与人工复核机制。</li>\n                <li><strong>高风险期限</strong>：标记为<span style=\"color: #e74c3c; font-weight: bold;\">红色警告</span>的期限为除斥期间、不变期间或过期将导致实体权利丧失的高风险期限，需特别关注。</li>\n                <li><strong>分类筛选</strong>：使用页面顶部的分类按钮可以按法律门类筛选相关期限，使用搜索框可以快速查找特定内容。</li>\n                <li><strong>免责声明</strong>：本汇总表仅供参考，不构成正式法律意见。具体法律事务请咨询专业律师。</li>\n            </ul>\n        </div>\n        \n        <footer>\n            <p>© 2026 法律期限管理系统 | 数据仅供参考，请以官方最新法律法规为准</p>\n            <p style=\"margin-top: 10px; font-size: 0.8em;\">本页面包含劳动法、商法、经济法、民法、诉讼法等多个法律门类的关键期限规定</p>\n        </footer>\n    </div>\n\n    <script>\n        // 搜索功能\n        document.getElementById('searchInput').addEventListener('input', function(e) {\n            const searchTerm = e.target.value.toLowerCase();\n            const rows = document.querySelectorAll('.deadline-item');\n            \n            rows.forEach(row => {\n                const text = row.textContent.toLowerCase();\n                if (text.includes(searchTerm)) {\n                    row.style.display = '';\n                    // 添加高亮效果\n                    row.classList.add('highlight');\n                    setTimeout(() => {\n                        row.classList.remove('highlight');\n                    }, 2000);\n                } else {\n                    row.style.display = 'none';\n                }\n            });\n            \n            // 保持分类行显示\n            document.querySelectorAll('.category-row').forEach(row => {\n                row.style.display = '';\n            });\n        });\n        \n        // 筛选功能\n        document.querySelectorAll('.filter-btn').forEach(button => {\n            button.addEventListener('click', function() {\n                const filter = this.getAttribute('data-filter');\n                \n                // 更新活动按钮\n                document.querySelectorAll('.filter-btn').forEach(btn => {\n                    btn.classList.remove('active');\n                });\n                this.classList.add('active');\n                \n                // 显示所有行\n                const allRows = document.querySelectorAll('tbody tr');\n                allRows.forEach(row => {\n                    row.style.display = '';\n                });\n                \n                // 如果选择\"全部\"，不进行筛选\n                if (filter === 'all') {\n                    return;\n                }\n                \n                // 筛选行\n                allRows.forEach(row => {\n                    if (row.classList.contains('category-row')) {\n                        // 分类行：检查其data-category是否包含筛选条件\n                        const category = row.getAttribute('data-category');\n                        if (category && category.includes(filter)) {\n                            row.style.display = '';\n                        } else {\n                            // 如果不是当前筛选的分类，但下面有符合条件的项目，也显示\n                            let hasVisibleItems = false;\n                            let nextRow = row.nextElementSibling;\n                            \n                            while (nextRow && !nextRow.classList.contains('category-row')) {\n                                if (nextRow.classList.contains('deadline-item')) {\n                                    const itemCategories = nextRow.getAttribute('data-category');\n                                    if (itemCategories && itemCategories.includes(filter)) {\n                                        hasVisibleItems = true;\n                                        break;\n                                    }\n                                }\n                                nextRow = nextRow.nextElementSibling;\n                            }\n                            \n                            row.style.display = hasVisibleItems ? '' : 'none';\n                        }\n                    } else if (row.classList.contains('deadline-item')) {\n                        // 期限项目行：检查其data-category是否包含筛选条件\n                        const categories = row.getAttribute('data-category');\n                        if (categories && categories.includes(filter)) {\n                            row.style.display = '';\n                        } else {\n                            row.style.display = 'none';\n                        }\n                    }\n                });\n            });\n        });\n        \n        // 页面加载时显示所有内容\n        document.addEventListener('DOMContentLoaded', function() {\n            console.log('法律期限汇总表已加载完成，共包含 ' + document.querySelectorAll('.deadline-item').length + ' 个法律期限项目。');\n        });\n    </script>\n</body>\n</html>\n","numLines":583,"startLine":1,"totalLines":583}},"sourceToolAssistantUUID":"e3eb6734-ea56-4080-a856-fecf2094b9d7"}
