{"parentUuid":"4bf35262-4b73-4c84-b588-c0895611dd50","isSidechain":false,"userType":"external","cwd":"C:\\Users\\Administrator","sessionId":"eae4a14a-5b77-4724-9c03-ee86b42fb6ee","version":"2.1.41","gitBranch":"HEAD","slug":"wobbly-swinging-feather","type":"user","message":{"role":"user","content":[{"tool_use_id":"tooluse_BePxtRYZ8AriG4G0RUq88P","type":"tool_result","content":"<!DOCTYPE html>\r\n<html lang=\"zh-CN\">\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <title>法律期限速查系统</title>\r\n    <style>\r\n        * { box-sizing: border-box; margin: 0; padding: 0; }\r\n        body {\r\n            font-family: 'Microsoft YaHei', sans-serif;\r\n            background: #0f172a;\r\n            color: #e2e8f0;\r\n            min-height: 100vh;\r\n        }\r\n        .app { max-width: 1400px; margin: 0 auto; padding: 20px; }\r\n\r\n        /* 顶部 */\r\n        .header {\r\n            text-align: center;\r\n            padding: 30px 20px 20px;\r\n            background: linear-gradient(135deg, #1e293b, #334155);\r\n            border-radius: 16px;\r\n            margin-bottom: 20px;\r\n            border: 1px solid #475569;\r\n        }\r\n        .header h1 { font-size: 2em; color: #38bdf8; margin-bottom: 6px; }\r\n        .header p { color: #94a3b8; font-size: 0.95em; }\r\n\r\n        /* 搜索栏 */\r\n        .search-area {\r\n            display: flex; gap: 12px; margin: 20px 0;\r\n            flex-wrap: wrap; align-items: center;\r\n        }\r\n        #searchInput {\r\n            flex: 1; min-width: 250px;\r\n            padding: 14px 20px;\r\n            background: #1e293b;\r\n            border: 2px solid #475569;\r\n            border-radius: 12px;\r\n            color: #f1f5f9;\r\n            font-size: 1.05em;\r\n            transition: border-color .3s;\r\n        }\r\n        #searchInput:focus { outline: none; border-color: #38bdf8; }\r\n        #searchInput::placeholder { color: #64748b; }\r\n\r\n        /* 筛选按钮 */\r\n        .filters { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 20px; }\r\n        .fbtn {\r\n            padding: 8px 18px;\r\n            background: #1e293b;\r\n            color: #94a3b8;\r\n            border: 1px solid #475569;\r\n            border-radius: 20px;\r\n            cursor: pointer;\r\n            font-size: 0.9em;\r\n            transition: all .2s;\r\n        }\r\n        .fbtn:hover { border-color: #38bdf8; color: #38bdf8; }\r\n        .fbtn.active { background: #38bdf8; color: #0f172a; border-color: #38bdf8; font-weight: 600; }\r\n        .fbtn.warn-btn.active { background: #ef4444; border-color: #ef4444; color: #fff; }\r\n\r\n        /* 统计栏 */\r\n        .stats {\r\n            display: flex; gap: 12px; margin-bottom: 20px; flex-wrap: wrap;\r\n        }\r\n        .stat-card {\r\n            flex: 1; min-width: 140px;\r\n            background: #1e293b;\r\n            border: 1px solid #475569;\r\n            border-radius: 12px;\r\n            padding: 16px;\r\n            text-align: center;\r\n        }\r\n        .stat-card .num { font-size: 2em; font-weight: 700; color: #38bdf8; }\r\n        .stat-card .label { font-size: 0.85em; color: #94a3b8; margin-top: 4px; }\r\n        .stat-card.warn .num { color: #ef4444; }\r\n\r\n        /* 期限长度筛选 */\r\n        .duration-filters { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 20px; }\r\n        .dbtn {\r\n            padding: 6px 14px;\r\n            background: transparent;\r\n            color: #94a3b8;\r\n            border: 1px dashed #475569;\r\n            border-radius: 16px;\r\n            cursor: pointer;\r\n            font-size: 0.85em;\r\n            transition: all .2s;\r\n        }\r\n        .dbtn:hover { border-color: #a78bfa; color: #a78bfa; }\r\n        .dbtn.active { background: #a78bfa; color: #0f172a; border-style: solid; border-color: #a78bfa; font-weight: 600; }\r\n\r\n        /* 卡片列表 */\r\n        .cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(420px, 1fr)); gap: 16px; }\r\n        .card {\r\n            background: #1e293b;\r\n            border: 1px solid #334155;\r\n            border-radius: 14px;\r\n            padding: 20px;\r\n            transition: all .3s;\r\n            cursor: pointer;\r\n            position: relative;\r\n            overflow: hidden;\r\n        }\r\n        .card:hover { border-color: #38bdf8; transform: translateY(-2px); box-shadow: 0 8px 25px rgba(56,189,248,.1); }\r\n        .card.warn-card { border-left: 4px solid #ef4444; }\r\n        .card .cat-tag {\r\n            display: inline-block;\r\n            padding: 3px 10px;\r\n            border-radius: 10px;\r\n            font-size: 0.75em;\r\n            font-weight: 600;\r\n            margin-bottom: 10px;\r\n        }\r\n        .cat-labor .cat-tag { background: #164e63; color: #22d3ee; }\r\n        .cat-commercial .cat-tag { background: #1e3a5f; color: #60a5fa; }\r\n        .cat-economic .cat-tag { background: #365314; color: #a3e635; }\r\n        .cat-civil .cat-tag { background: #4a1d96; color: #c4b5fd; }\r\n        .cat-procedure .cat-tag { background: #78350f; color: #fbbf24; }\r\n        .cat-criminal .cat-tag { background: #4a0e0e; color: #fca5a5; }\r\n        .cat-admin .cat-tag { background: #134e4a; color: #5eead4; }\r\n\r\n        .card .title { font-size: 1.15em; font-weight: 700; color: #f1f5f9; margin-bottom: 8px; }\r\n        .card .duration {\r\n            display: inline-block;\r\n            padding: 4px 12px;\r\n            background: rgba(56,189,248,.15);\r\n            color: #38bdf8;\r\n            border-radius: 8px;\r\n            font-weight: 700;\r\n            font-size: 1.05em;\r\n            margin-bottom: 10px;\r\n        }\r\n        .card.warn-card .duration { background: rgba(239,68,68,.15); color: #ef4444; }\r\n        .card .warn-badge {\r\n            position: absolute; top: 12px; right: 12px;\r\n            background: #ef4444; color: #fff;\r\n            padding: 2px 8px; border-radius: 6px;\r\n            font-size: 0.7em; font-weight: 700;\r\n        }\r\n        .card .desc { color: #94a3b8; font-size: 0.9em; line-height: 1.7; margin-bottom: 8px; }\r\n        .card .law-ref {\r\n            font-size: 0.8em; color: #64748b;\r\n            border-top: 1px solid #334155;\r\n            padding-top: 8px; margin-top: 8px;\r\n        }\r\n\r\n        /* 展开详情 */\r\n        .card .detail { display: none; margin-top: 12px; }\r\n        .card.expanded .detail { display: block; }\r\n        .card .detail .risk {\r\n            background: rgba(239,68,68,.08);\r\n            border-left: 3px solid #ef4444;\r\n            padding: 10px 14px;\r\n            border-radius: 0 8px 8px 0;\r\n            color: #fca5a5;\r\n            font-size: 0.88em;\r\n            line-height: 1.7;\r\n        }\r\n        .card .expand-hint { color: #475569; font-size: 0.8em; text-align: right; margin-top: 6px; }\r\n\r\n        /* 无结果 */\r\n        .no-result {\r\n            text-align: center; padding: 60px 20px;\r\n            color: #64748b; font-size: 1.1em;\r\n            display: none;\r\n        }\r\n\r\n        /* 回到顶部 */\r\n        #backTop {\r\n            position: fixed; bottom: 30px; right: 30px;\r\n            width: 46px; height: 46px;\r\n            background: #38bdf8; color: #0f172a;\r\n            border: none; border-radius: 50%;\r\n            font-size: 1.3em; cursor: pointer;\r\n            display: none; z-index: 99;\r\n            box-shadow: 0 4px 15px rgba(56,189,248,.3);\r\n        }\r\n\r\n        @media (max-width: 500px) {\r\n            .cards { grid-template-columns: 1fr; }\r\n            .header h1 { font-size: 1.5em; }\r\n        }\r\n    </style>\r\n</head>\r\n<body>\r\n<div class=\"app\">\r\n    <div class=\"header\">\r\n        <h1>⚡ 法律期限速查系统</h1>\r\n        <p>涵盖民法 · 民事诉讼 · 刑事诉讼 · 行政法 · 劳动法 · 商法 · 经济法 关键期限 | 点击卡片查看详情</p>\r\n    </div>\r\n\r\n    <div class=\"search-area\">\r\n        <input type=\"text\" id=\"searchInput\" placeholder=\"输入关键词搜索：如 撤销、工伤、仲裁、15日、3年...\">\r\n    </div>\r\n\r\n    <div class=\"filters\" id=\"catFilters\">\r\n        <button class=\"fbtn active\" data-cat=\"all\">全部</button>\r\n        <button class=\"fbtn\" data-cat=\"civil\">民事实体</button>\r\n        <button class=\"fbtn\" data-cat=\"procedure\">民事诉讼</button>\r\n        <button class=\"fbtn\" data-cat=\"criminal\">刑事诉讼</button>\r\n        <button class=\"fbtn\" data-cat=\"admin\">行政法</button>\r\n        <button class=\"fbtn\" data-cat=\"labor\">劳动法</button>\r\n        <button class=\"fbtn\" data-cat=\"commercial\">商法</button>\r\n        <button class=\"fbtn\" data-cat=\"economic\">经济法</button>\r\n        <button class=\"fbtn warn-btn\" data-cat=\"warning\">⚠ 高风险</button>\r\n    </div>\r\n\r\n    <div class=\"duration-filters\" id=\"durFilters\">\r\n        <span style=\"color:#64748b;font-size:.85em;line-height:2\">按期限长度：</span>\r\n        <button class=\"dbtn active\" data-dur=\"all\">全部</button>\r\n        <button class=\"dbtn\" data-dur=\"short\">≤15日</button>\r\n        <button class=\"dbtn\" data-dur=\"medium\">1-6个月</button>\r\n        <button class=\"dbtn\" data-dur=\"long\">1-3年</button>\r\n        <button class=\"dbtn\" data-dur=\"vlong\">3年以上</button>\r\n    </div>\r\n\r\n    <div class=\"stats\" id=\"stats\"></div>\r\n    <div class=\"cards\" id=\"cardList\"></div>\r\n    <div class=\"no-result\" id=\"noResult\">😔 没有找到匹配的期限条目，试试其他关键词？</div>\r\n</div>\r\n<button id=\"backTop\" onclick=\"window.scrollTo({top:0,behavior:'smooth'})\">↑</button>\r\n\r\n<script>\r\nconst DATA = [\r\n    // 劳动法\r\n    { name:\"劳动争议仲裁时效\", cat:\"labor\", warn:true, dur:\"long\",\r\n      time:\"1年\", desc:\"自当事人知道或应当知道其权利被侵害之日起1年内提出仲裁申请。劳动关系存续期间因拖欠劳动报酬发生争议的，不受此限，但应在劳动关系终止之日起1年内提出。\",\r\n      risk:\"超过仲裁时效申请仲裁，仲裁委员会可能不予受理。时效可因主张权利、同意履行等中断并重新计算。\",\r\n      law:\"《劳动争议调解仲裁法》第27条\" },\r\n    { name:\"未签劳动合同二倍工资差额\", cat:\"labor\", warn:false, dur:\"long\",\r\n      time:\"最多11个月（时效1年）\", desc:\"用工之日起超过一个月不满一年未签，应支付二倍工资，支付时间最长不超过11个月。用工满一年未签，视为已订立无固定期限合同。仲裁时效从主张权利之日倒推一年计算。\",\r\n      risk:\"权利有双重期限限制：实体权利最长11个月，程序上受1年仲裁时效约束，需尽早主张。\",\r\n      law:\"《劳动合同法》第82条\" },\r\n    { name:\"劳动者单方解除权（预告解除）\", cat:\"labor\", warn:false, dur:\"short\",\r\n      time:\"30日 / 试用期3日\", desc:\"劳动者提前30日书面通知可解除合同；试用期内提前3日通知。\",\r\n      risk:\"此为法律赋予劳动者的预告期，期满后劳动关系解除。劳动者违法解除造成损失的，需赔偿。\",\r\n      law:\"《劳动合同法》第37条\" },\r\n    { name:\"用人单位单方解除通知工会\", cat:\"labor\", warn:false, dur:\"short\",\r\n      time:\"事先通知\", desc:\"用人单位单方解除劳动合同，应当事先将理由通知工会。工会有权提出意见。\",\r\n      risk:\"未履行通知工会程序即解除，可能被认定为违法解除，需支付赔偿金（2N）。司法实践允许事后补正。\",\r\n      law:\"《劳动合同法》第43条\" },\r\n    { name:\"工伤认定申请\", cat:\"labor\", warn:true, dur:\"long\",\r\n      time:\"单位30日 / 个人1年\", desc:\"单位应自事故伤害发生之日或被诊断、鉴定为职业病之日起30日内提出。用人单位未提，工伤职工或其近亲属、工会可在1年内提出。\",\r\n      risk:\"超过1年申请，人社部门可能不予受理，导致无法享受工伤待遇。\",\r\n      law:\"《工伤保险条例》第17条\" },\r\n    // 商法\r\n    { name:\"股东知情权诉讼\", cat:\"commercial\", warn:false, dur:\"long\",\r\n      time:\"无明确期限（受3年诉讼时效约束）\", desc:\"股东有权查阅、复制章程、决议、财报等。被拒绝后可请求法院要求提供查阅。法律未规定行使期限。\",\r\n      risk:\"权利持续存在，但需在知道权利被侵害后的诉讼时效（3年）内起诉。\",\r\n      law:\"《公司法》第33、97条\" },\r\n    { name:\"公司决议撤销之诉（程序瑕疵）\", cat:\"commercial\", warn:true, dur:\"medium\",\r\n      time:\"60日\", desc:\"股东（会）/董事（会）召集程序、表决方式违法/违章，或内容违章，股东可自决议作出之日起60日内请求法院撤销。\",\r\n      risk:\"此为除斥期间，逾期未起诉，撤销权消灭。\",\r\n      law:\"《公司法》第22条\" },\r\n    { name:\"异议股东股份回购请求权\", cat:\"commercial\", warn:false, dur:\"medium\",\r\n      time:\"60日协商 / 90日起诉\", desc:\"对股东会特定决议投反对票的股东，可请求公司以合理价格回购股份。自决议通过之日起60日内协商，90日内起诉。\",\r\n      risk:\"90日内达不成协议，股东需在决议通过后90日内提起诉讼。\",\r\n      law:\"《公司法》第74、142条\" },\r\n    { name:\"票据权利时效\", cat:\"commercial\", warn:true, dur:\"long\",\r\n      time:\"2年 / 6个月 / 3个月\", desc:\"对出票人/承兑人：汇票/本票自到期日起2年。对支票出票人：自出票日起6个月。追索权：自被拒绝承兑/付款之日起6个月。再追索权：自清偿日/被诉之日起3个月。\",\r\n      risk:\"超过票据权利时效，持票人丧失票据权利，但仍享有民事利益返还请求权（适用3年诉讼时效）。\",\r\n      law:\"《票据法》第17条\" },\r\n    // 经济法\r\n    { name:\"消费者七日无理由退货\", cat:\"economic\", warn:false, dur:\"short\",\r\n      time:\"7日\", desc:\"经营者采用网络、电视、电话、邮购等方式销售商品，消费者自收到商品之日起7日内退货，且无需说明理由（定作、鲜活易腐等除外）。\",\r\n      risk:\"经营者应自收到退回商品之日起7日内返还价款。此为法定的\"冷静期\"。\",\r\n      law:\"《消费者权益保护法》第25条\" },\r\n    { name:\"产品缺陷损害赔偿责任\", cat:\"economic\", warn:false, dur:\"long\",\r\n      time:\"2年（最长10年）\", desc:\"因产品存在缺陷造成损害要求赔偿的诉讼时效为2年，自知道或应当知道权利受损及生产者/销售者时起算。损害赔偿请求权，在缺陷产品交付最初消费者满10年丧失。\",\r\n      risk:\"此为特殊时效规定，短于普通3年诉讼时效。10年为最长权利保护期。\",\r\n      law:\"《产品质量法》第45条\" },\r\n    { name:\"经营者集中反垄断申报\", cat:\"economic\", warn:true, dur:\"short\",\r\n      time:\"事前申报（初审30日）\", desc:\"达到申报标准的集中，应事先申报。执法机构应自收到完整申报材料之日起30日内进行初步审查，决定是否进一步审查。\",\r\n      risk:\"\"抢跑\"（应报未报即实施集中）面临高额罚款（最高上一年度销售额10%），可能被责令恢复原状。\",\r\n      law:\"《反垄断法》第21、26条\" },\r\n    // 民事实体\r\n    { name:\"民事法律行为撤销权\", cat:\"civil\", warn:true, dur:\"long\",\r\n      time:\"1年 / 90日（最长5年）\", desc:\"自知道或应当知道撤销事由之日起1年内行使。因胁迫产生撤销权的，自胁迫行为终止之日起1年内行使。重大误解当事人自知道或应当知道撤销事由之日起90日内行使。自民事法律行为发生之日起5年内没有行使的，撤销权消灭。\",\r\n      risk:\"逾期不行使，撤销权绝对消灭，法律行为确定有效。此为除斥期间，需主动主张。\",\r\n      law:\"《民法典》第152条\" },\r\n    { name:\"债权人撤销权\", cat:\"civil\", warn:true, dur:\"long\",\r\n      time:\"1年（最长5年）\", desc:\"自债权人知道或应当知道撤销事由之日起1年内行使。自债务人的行为发生之日起5年内没有行使的，撤销权消灭。\",\r\n      risk:\"逾期不行使，撤销权消灭。需通过诉讼方式行使。\",\r\n      law:\"《民法典》第538-542条\" },\r\n    { name:\"保证期间\", cat:\"civil\", warn:true, dur:\"medium\",\r\n      time:\"约定优先，无约定为6个月\", desc:\"债权人与保证人可以约定保证期间。没有约定或约定不明确的，保证期间为主债务履行期限届满之日起6个月。约定\"保证人承担保证责任直至主债务本息还清时为止\"等类似内容的，视为约定不明，保证期间为6个月。\",\r\n      risk:\"保证期间是确定保证人是否承担责任的\"生死线\"。债权人在此期间内未向保证人主张权利（一般保证需起诉/仲裁），保证责任免除。\",\r\n      law:\"《民法典》第692、693条\" },\r\n    { name:\"建设工程价款优先受偿权\", cat:\"civil\", warn:true, dur:\"long\",\r\n      time:\"18个月\", desc:\"自发包人应当给付建设工程价款之日起算。最长不超过18个月。\",\r\n      risk:\"性质为法定担保物权，但行使有严格期限。逾期未主张（需通过诉讼或仲裁等方式明确请求），权利消灭。\",\r\n      law:\"《民法典》第807条；《建设工程施工合同司法解释一》第41条\" },\r\n    // 诉讼程序\r\n    { name:\"管辖权异议期\", cat:\"procedure\", warn:true, dur:\"short\",\r\n      time:\"15日\", desc:\"被告在提交答辩状期间提出。答辩期为收到起诉状副本后15日内。\",\r\n      risk:\"逾期提出，法院不予审查。此为不变期间。\",\r\n      law:\"《民事诉讼法》第130条\" },\r\n    { name:\"增加、变更诉讼请求/提出反诉\", cat:\"procedure\", warn:false, dur:\"short\",\r\n      time:\"举证期限届满前\", desc:\"原则在案件受理后，举证期限届满前提出。法庭辩论结束前，对方同意或法院认为可以合并审理的，也可准许。\",\r\n      risk:\"逾期提出可能导致法院不予准许，需另案处理，增加讼累。\",\r\n      law:\"《民诉法解释》第232条\" },\r\n    { name:\"支付令异议期\", cat:\"procedure\", warn:false, dur:\"short\",\r\n      time:\"15日\", desc:\"债务人应当自收到支付令之日起15日内清偿债务，或向法院提出书面异议。\",\r\n      risk:\"15日内不提书面异议或异议不成立，支付令生效，可申请强制执行。提出有效书面异议，支付令失效，转入诉讼程序。\",\r\n      law:\"《民事诉讼法》第221条\" },\r\n    { name:\"仲裁裁决撤销申请\", cat:\"procedure\", warn:true, dur:\"medium\",\r\n      time:\"6个月\", desc:\"当事人提出证据证明裁决有法定撤销情形的，可自收到裁决书之日起6个月内向仲裁委所在地中级法院申请撤销。\",\r\n      risk:\"逾期未申请，撤销权消灭。\",\r\n      law:\"《仲裁法》第59条\" },\r\n    { name:\"公示催告申报权利期\", cat:\"procedure\", warn:false, dur:\"medium\",\r\n      time:\"不少于60日\", desc:\"法院决定受理公示催告申请后，应同时通知支付人止付，并在3日内发出公告，催促利害关系人申报权利。公示催告期间由法院定，但不得少于60日。\",\r\n      risk:\"利害关系人应在公示催告期间申报权利。无人申报的，法院根据申请作出除权判决，宣告票据无效。\",\r\n      law:\"《民事诉讼法》第225条\" },\r\n];\r\n\r\nconst CAT_NAMES = { labor:\"劳动法\", commercial:\"商法\", economic:\"经济法\", civil:\"民事实体\", procedure:\"诉讼程序\" };\r\nconst DUR_NAMES = { short:\"≤15日\", medium:\"1-6个月\", long:\"1-3年\", vlong:\"3年以上\" };\r\n\r\nlet curCat = \"all\", curDur = \"all\", curSearch = \"\";\r\n\r\nfunction render() {\r\n    const filtered = DATA.filter(d => {\r\n        if (curCat === \"warning\") { if (!d.warn) return false; }\r\n        else if (curCat !== \"all\" && d.cat !== curCat) return false;\r\n        if (curDur !== \"all\" && d.dur !== curDur) return false;\r\n        if (curSearch) {\r\n            const s = curSearch.toLowerCase();\r\n            const t = (d.name + d.time + d.desc + d.risk + d.law).toLowerCase();\r\n            if (!t.includes(s)) return false;\r\n        }\r\n        return true;\r\n    });\r\n\r\n    // 统计\r\n    const total = filtered.length;\r\n    const warnCount = filtered.filter(d => d.warn).length;\r\n    const catCount = new Set(filtered.map(d => d.cat)).size;\r\n    document.getElementById('stats').innerHTML = `\r\n        <div class=\"stat-card\"><div class=\"num\">${total}</div><div class=\"label\">匹配条目</div></div>\r\n        <div class=\"stat-card warn\"><div class=\"num\">${warnCount}</div><div class=\"label\">高风险项</div></div>\r\n        <div class=\"stat-card\"><div class=\"num\">${catCount}</div><div class=\"label\">涉及门类</div></div>\r\n    `;\r\n\r\n    // 卡片\r\n    const list = document.getElementById('cardList');\r\n    const noRes = document.getElementById('noResult');\r\n    if (!filtered.length) { list.innerHTML = ''; noRes.style.display = 'block'; return; }\r\n    noRes.style.display = 'none';\r\n\r\n    list.innerHTML = filtered.map((d, i) => `\r\n        <div class=\"card cat-${d.cat} ${d.warn ? 'warn-card' : ''}\" onclick=\"this.classList.toggle('expanded')\">\r\n            ${d.warn ? '<div class=\"warn-badge\">⚠ 高风险</div>' : ''}\r\n            <div class=\"cat-tag\">${CAT_NAMES[d.cat]}</div>\r\n            <div class=\"title\">${highlight(d.name)}</div>\r\n            <div class=\"duration\">${highlight(d.time)}</div>\r\n            <div class=\"desc\">${highlight(truncate(d.desc, 80))}</div>\r\n            <div class=\"detail\">\r\n                <div class=\"desc\" style=\"margin-bottom:10px\">${highlight(d.desc)}</div>\r\n                <div class=\"risk\">${highlight(d.risk)}</div>\r\n                <div class=\"law-ref\">📖 ${highlight(d.law)}</div>\r\n            </div>\r\n            <div class=\"expand-hint\">点击展开/收起详情 ▾</div>\r\n        </div>\r\n    `).join('');\r\n}\r\n\r\nfunction truncate(s, n) { return s.length > n ? s.slice(0, n) + '...' : s; }\r\n\r\nfunction highlight(text) {\r\n    if (!curSearch) return text;\r\n    const re = new RegExp('(' + curSearch.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&') + ')', 'gi');\r\n    return text.replace(re, '<mark style=\"background:#fbbf24;color:#0f172a;border-radius:2px;padding:0 2px\">$1</mark>');\r\n}\r\n\r\n// 事件绑定\r\ndocument.getElementById('searchInput').addEventListener('input', e => { curSearch = e.target.value.trim(); render(); });\r\n\r\ndocument.getElementById('catFilters').addEventListener('click', e => {\r\n    if (!e.target.classList.contains('fbtn')) return;\r\n    document.querySelectorAll('#catFilters .fbtn').forEach(b => b.classList.remove('active'));\r\n    e.target.classList.add('active');\r\n    curCat = e.target.dataset.cat;\r\n    render();\r\n});\r\n\r\ndocument.getElementById('durFilters').addEventListener('click', e => {\r\n    if (!e.target.classList.contains('dbtn')) return;\r\n    document.querySelectorAll('#durFilters .dbtn').forEach(b => b.classList.remove('active'));\r\n    e.target.classList.add('active');\r\n    curDur = e.target.dataset.dur;\r\n    render();\r\n});\r\n\r\nwindow.addEventListener('scroll', () => {\r\n    document.getElementById('backTop').style.display = window.scrollY > 300 ? 'block' : 'none';\r\n});\r\n\r\n// 键盘快捷键：按 / 聚焦搜索\r\ndocument.addEventListener('keydown', e => {\r\n    if (e.key === '/' && document.activeElement !== document.getElementById('searchInput')) {\r\n        e.preventDefault();\r\n        document.getElementById('searchInput').focus();\r\n    }\r\n});\r\n\r\nrender();\r\n</script>\r\n</body>\r\n</html>","is_error":false}]},"uuid":"05bb06a9-daa0-44a4-9fa0-77d23b0ac3a8","timestamp":"2026-02-14T07:39:12.513Z","toolUseResult":{"stdout":"<!DOCTYPE html>\r\n<html lang=\"zh-CN\">\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <title>法律期限速查系统</title>\r\n    <style>\r\n        * { box-sizing: border-box; margin: 0; padding: 0; }\r\n        body {\r\n            font-family: 'Microsoft YaHei', sans-serif;\r\n            background: #0f172a;\r\n            color: #e2e8f0;\r\n            min-height: 100vh;\r\n        }\r\n        .app { max-width: 1400px; margin: 0 auto; padding: 20px; }\r\n\r\n        /* 顶部 */\r\n        .header {\r\n            text-align: center;\r\n            padding: 30px 20px 20px;\r\n            background: linear-gradient(135deg, #1e293b, #334155);\r\n            border-radius: 16px;\r\n            margin-bottom: 20px;\r\n            border: 1px solid #475569;\r\n        }\r\n        .header h1 { font-size: 2em; color: #38bdf8; margin-bottom: 6px; }\r\n        .header p { color: #94a3b8; font-size: 0.95em; }\r\n\r\n        /* 搜索栏 */\r\n        .search-area {\r\n            display: flex; gap: 12px; margin: 20px 0;\r\n            flex-wrap: wrap; align-items: center;\r\n        }\r\n        #searchInput {\r\n            flex: 1; min-width: 250px;\r\n            padding: 14px 20px;\r\n            background: #1e293b;\r\n            border: 2px solid #475569;\r\n            border-radius: 12px;\r\n            color: #f1f5f9;\r\n            font-size: 1.05em;\r\n            transition: border-color .3s;\r\n        }\r\n        #searchInput:focus { outline: none; border-color: #38bdf8; }\r\n        #searchInput::placeholder { color: #64748b; }\r\n\r\n        /* 筛选按钮 */\r\n        .filters { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 20px; }\r\n        .fbtn {\r\n            padding: 8px 18px;\r\n            background: #1e293b;\r\n            color: #94a3b8;\r\n            border: 1px solid #475569;\r\n            border-radius: 20px;\r\n            cursor: pointer;\r\n            font-size: 0.9em;\r\n            transition: all .2s;\r\n        }\r\n        .fbtn:hover { border-color: #38bdf8; color: #38bdf8; }\r\n        .fbtn.active { background: #38bdf8; color: #0f172a; border-color: #38bdf8; font-weight: 600; }\r\n        .fbtn.warn-btn.active { background: #ef4444; border-color: #ef4444; color: #fff; }\r\n\r\n        /* 统计栏 */\r\n        .stats {\r\n            display: flex; gap: 12px; margin-bottom: 20px; flex-wrap: wrap;\r\n        }\r\n        .stat-card {\r\n            flex: 1; min-width: 140px;\r\n            background: #1e293b;\r\n            border: 1px solid #475569;\r\n            border-radius: 12px;\r\n            padding: 16px;\r\n            text-align: center;\r\n        }\r\n        .stat-card .num { font-size: 2em; font-weight: 700; color: #38bdf8; }\r\n        .stat-card .label { font-size: 0.85em; color: #94a3b8; margin-top: 4px; }\r\n        .stat-card.warn .num { color: #ef4444; }\r\n\r\n        /* 期限长度筛选 */\r\n        .duration-filters { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 20px; }\r\n        .dbtn {\r\n            padding: 6px 14px;\r\n            background: transparent;\r\n            color: #94a3b8;\r\n            border: 1px dashed #475569;\r\n            border-radius: 16px;\r\n            cursor: pointer;\r\n            font-size: 0.85em;\r\n            transition: all .2s;\r\n        }\r\n        .dbtn:hover { border-color: #a78bfa; color: #a78bfa; }\r\n        .dbtn.active { background: #a78bfa; color: #0f172a; border-style: solid; border-color: #a78bfa; font-weight: 600; }\r\n\r\n        /* 卡片列表 */\r\n        .cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(420px, 1fr)); gap: 16px; }\r\n        .card {\r\n            background: #1e293b;\r\n            border: 1px solid #334155;\r\n            border-radius: 14px;\r\n            padding: 20px;\r\n            transition: all .3s;\r\n            cursor: pointer;\r\n            position: relative;\r\n            overflow: hidden;\r\n        }\r\n        .card:hover { border-color: #38bdf8; transform: translateY(-2px); box-shadow: 0 8px 25px rgba(56,189,248,.1); }\r\n        .card.warn-card { border-left: 4px solid #ef4444; }\r\n        .card .cat-tag {\r\n            display: inline-block;\r\n            padding: 3px 10px;\r\n            border-radius: 10px;\r\n            font-size: 0.75em;\r\n            font-weight: 600;\r\n            margin-bottom: 10px;\r\n        }\r\n        .cat-labor .cat-tag { background: #164e63; color: #22d3ee; }\r\n        .cat-commercial .cat-tag { background: #1e3a5f; color: #60a5fa; }\r\n        .cat-economic .cat-tag { background: #365314; color: #a3e635; }\r\n        .cat-civil .cat-tag { background: #4a1d96; color: #c4b5fd; }\r\n        .cat-procedure .cat-tag { background: #78350f; color: #fbbf24; }\r\n        .cat-criminal .cat-tag { background: #4a0e0e; color: #fca5a5; }\r\n        .cat-admin .cat-tag { background: #134e4a; color: #5eead4; }\r\n\r\n        .card .title { font-size: 1.15em; font-weight: 700; color: #f1f5f9; margin-bottom: 8px; }\r\n        .card .duration {\r\n            display: inline-block;\r\n            padding: 4px 12px;\r\n            background: rgba(56,189,248,.15);\r\n            color: #38bdf8;\r\n            border-radius: 8px;\r\n            font-weight: 700;\r\n            font-size: 1.05em;\r\n            margin-bottom: 10px;\r\n        }\r\n        .card.warn-card .duration { background: rgba(239,68,68,.15); color: #ef4444; }\r\n        .card .warn-badge {\r\n            position: absolute; top: 12px; right: 12px;\r\n            background: #ef4444; color: #fff;\r\n            padding: 2px 8px; border-radius: 6px;\r\n            font-size: 0.7em; font-weight: 700;\r\n        }\r\n        .card .desc { color: #94a3b8; font-size: 0.9em; line-height: 1.7; margin-bottom: 8px; }\r\n        .card .law-ref {\r\n            font-size: 0.8em; color: #64748b;\r\n            border-top: 1px solid #334155;\r\n            padding-top: 8px; margin-top: 8px;\r\n        }\r\n\r\n        /* 展开详情 */\r\n        .card .detail { display: none; margin-top: 12px; }\r\n        .card.expanded .detail { display: block; }\r\n        .card .detail .risk {\r\n            background: rgba(239,68,68,.08);\r\n            border-left: 3px solid #ef4444;\r\n            padding: 10px 14px;\r\n            border-radius: 0 8px 8px 0;\r\n            color: #fca5a5;\r\n            font-size: 0.88em;\r\n            line-height: 1.7;\r\n        }\r\n        .card .expand-hint { color: #475569; font-size: 0.8em; text-align: right; margin-top: 6px; }\r\n\r\n        /* 无结果 */\r\n        .no-result {\r\n            text-align: center; padding: 60px 20px;\r\n            color: #64748b; font-size: 1.1em;\r\n            display: none;\r\n        }\r\n\r\n        /* 回到顶部 */\r\n        #backTop {\r\n            position: fixed; bottom: 30px; right: 30px;\r\n            width: 46px; height: 46px;\r\n            background: #38bdf8; color: #0f172a;\r\n            border: none; border-radius: 50%;\r\n            font-size: 1.3em; cursor: pointer;\r\n            display: none; z-index: 99;\r\n            box-shadow: 0 4px 15px rgba(56,189,248,.3);\r\n        }\r\n\r\n        @media (max-width: 500px) {\r\n            .cards { grid-template-columns: 1fr; }\r\n            .header h1 { font-size: 1.5em; }\r\n        }\r\n    </style>\r\n</head>\r\n<body>\r\n<div class=\"app\">\r\n    <div class=\"header\">\r\n        <h1>⚡ 法律期限速查系统</h1>\r\n        <p>涵盖民法 · 民事诉讼 · 刑事诉讼 · 行政法 · 劳动法 · 商法 · 经济法 关键期限 | 点击卡片查看详情</p>\r\n    </div>\r\n\r\n    <div class=\"search-area\">\r\n        <input type=\"text\" id=\"searchInput\" placeholder=\"输入关键词搜索：如 撤销、工伤、仲裁、15日、3年...\">\r\n    </div>\r\n\r\n    <div class=\"filters\" id=\"catFilters\">\r\n        <button class=\"fbtn active\" data-cat=\"all\">全部</button>\r\n        <button class=\"fbtn\" data-cat=\"civil\">民事实体</button>\r\n        <button class=\"fbtn\" data-cat=\"procedure\">民事诉讼</button>\r\n        <button class=\"fbtn\" data-cat=\"criminal\">刑事诉讼</button>\r\n        <button class=\"fbtn\" data-cat=\"admin\">行政法</button>\r\n        <button class=\"fbtn\" data-cat=\"labor\">劳动法</button>\r\n        <button class=\"fbtn\" data-cat=\"commercial\">商法</button>\r\n        <button class=\"fbtn\" data-cat=\"economic\">经济法</button>\r\n        <button class=\"fbtn warn-btn\" data-cat=\"warning\">⚠ 高风险</button>\r\n    </div>\r\n\r\n    <div class=\"duration-filters\" id=\"durFilters\">\r\n        <span style=\"color:#64748b;font-size:.85em;line-height:2\">按期限长度：</span>\r\n        <button class=\"dbtn active\" data-dur=\"all\">全部</button>\r\n        <button class=\"dbtn\" data-dur=\"short\">≤15日</button>\r\n        <button class=\"dbtn\" data-dur=\"medium\">1-6个月</button>\r\n        <button class=\"dbtn\" data-dur=\"long\">1-3年</button>\r\n        <button class=\"dbtn\" data-dur=\"vlong\">3年以上</button>\r\n    </div>\r\n\r\n    <div class=\"stats\" id=\"stats\"></div>\r\n    <div class=\"cards\" id=\"cardList\"></div>\r\n    <div class=\"no-result\" id=\"noResult\">😔 没有找到匹配的期限条目，试试其他关键词？</div>\r\n</div>\r\n<button id=\"backTop\" onclick=\"window.scrollTo({top:0,behavior:'smooth'})\">↑</button>\r\n\r\n<script>\r\nconst DATA = [\r\n    // 劳动法\r\n    { name:\"劳动争议仲裁时效\", cat:\"labor\", warn:true, dur:\"long\",\r\n      time:\"1年\", desc:\"自当事人知道或应当知道其权利被侵害之日起1年内提出仲裁申请。劳动关系存续期间因拖欠劳动报酬发生争议的，不受此限，但应在劳动关系终止之日起1年内提出。\",\r\n      risk:\"超过仲裁时效申请仲裁，仲裁委员会可能不予受理。时效可因主张权利、同意履行等中断并重新计算。\",\r\n      law:\"《劳动争议调解仲裁法》第27条\" },\r\n    { name:\"未签劳动合同二倍工资差额\", cat:\"labor\", warn:false, dur:\"long\",\r\n      time:\"最多11个月（时效1年）\", desc:\"用工之日起超过一个月不满一年未签，应支付二倍工资，支付时间最长不超过11个月。用工满一年未签，视为已订立无固定期限合同。仲裁时效从主张权利之日倒推一年计算。\",\r\n      risk:\"权利有双重期限限制：实体权利最长11个月，程序上受1年仲裁时效约束，需尽早主张。\",\r\n      law:\"《劳动合同法》第82条\" },\r\n    { name:\"劳动者单方解除权（预告解除）\", cat:\"labor\", warn:false, dur:\"short\",\r\n      time:\"30日 / 试用期3日\", desc:\"劳动者提前30日书面通知可解除合同；试用期内提前3日通知。\",\r\n      risk:\"此为法律赋予劳动者的预告期，期满后劳动关系解除。劳动者违法解除造成损失的，需赔偿。\",\r\n      law:\"《劳动合同法》第37条\" },\r\n    { name:\"用人单位单方解除通知工会\", cat:\"labor\", warn:false, dur:\"short\",\r\n      time:\"事先通知\", desc:\"用人单位单方解除劳动合同，应当事先将理由通知工会。工会有权提出意见。\",\r\n      risk:\"未履行通知工会程序即解除，可能被认定为违法解除，需支付赔偿金（2N）。司法实践允许事后补正。\",\r\n      law:\"《劳动合同法》第43条\" },\r\n    { name:\"工伤认定申请\", cat:\"labor\", warn:true, dur:\"long\",\r\n      time:\"单位30日 / 个人1年\", desc:\"单位应自事故伤害发生之日或被诊断、鉴定为职业病之日起30日内提出。用人单位未提，工伤职工或其近亲属、工会可在1年内提出。\",\r\n      risk:\"超过1年申请，人社部门可能不予受理，导致无法享受工伤待遇。\",\r\n      law:\"《工伤保险条例》第17条\" },\r\n    // 商法\r\n    { name:\"股东知情权诉讼\", cat:\"commercial\", warn:false, dur:\"long\",\r\n      time:\"无明确期限（受3年诉讼时效约束）\", desc:\"股东有权查阅、复制章程、决议、财报等。被拒绝后可请求法院要求提供查阅。法律未规定行使期限。\",\r\n      risk:\"权利持续存在，但需在知道权利被侵害后的诉讼时效（3年）内起诉。\",\r\n      law:\"《公司法》第33、97条\" },\r\n    { name:\"公司决议撤销之诉（程序瑕疵）\", cat:\"commercial\", warn:true, dur:\"medium\",\r\n      time:\"60日\", desc:\"股东（会）/董事（会）召集程序、表决方式违法/违章，或内容违章，股东可自决议作出之日起60日内请求法院撤销。\",\r\n      risk:\"此为除斥期间，逾期未起诉，撤销权消灭。\",\r\n      law:\"《公司法》第22条\" },\r\n    { name:\"异议股东股份回购请求权\", cat:\"commercial\", warn:false, dur:\"medium\",\r\n      time:\"60日协商 / 90日起诉\", desc:\"对股东会特定决议投反对票的股东，可请求公司以合理价格回购股份。自决议通过之日起60日内协商，90日内起诉。\",\r\n      risk:\"90日内达不成协议，股东需在决议通过后90日内提起诉讼。\",\r\n      law:\"《公司法》第74、142条\" },\r\n    { name:\"票据权利时效\", cat:\"commercial\", warn:true, dur:\"long\",\r\n      time:\"2年 / 6个月 / 3个月\", desc:\"对出票人/承兑人：汇票/本票自到期日起2年。对支票出票人：自出票日起6个月。追索权：自被拒绝承兑/付款之日起6个月。再追索权：自清偿日/被诉之日起3个月。\",\r\n      risk:\"超过票据权利时效，持票人丧失票据权利，但仍享有民事利益返还请求权（适用3年诉讼时效）。\",\r\n      law:\"《票据法》第17条\" },\r\n    // 经济法\r\n    { name:\"消费者七日无理由退货\", cat:\"economic\", warn:false, dur:\"short\",\r\n      time:\"7日\", desc:\"经营者采用网络、电视、电话、邮购等方式销售商品，消费者自收到商品之日起7日内退货，且无需说明理由（定作、鲜活易腐等除外）。\",\r\n      risk:\"经营者应自收到退回商品之日起7日内返还价款。此为法定的\"冷静期\"。\",\r\n      law:\"《消费者权益保护法》第25条\" },\r\n    { name:\"产品缺陷损害赔偿责任\", cat:\"economic\", warn:false, dur:\"long\",\r\n      time:\"2年（最长10年）\", desc:\"因产品存在缺陷造成损害要求赔偿的诉讼时效为2年，自知道或应当知道权利受损及生产者/销售者时起算。损害赔偿请求权，在缺陷产品交付最初消费者满10年丧失。\",\r\n      risk:\"此为特殊时效规定，短于普通3年诉讼时效。10年为最长权利保护期。\",\r\n      law:\"《产品质量法》第45条\" },\r\n    { name:\"经营者集中反垄断申报\", cat:\"economic\", warn:true, dur:\"short\",\r\n      time:\"事前申报（初审30日）\", desc:\"达到申报标准的集中，应事先申报。执法机构应自收到完整申报材料之日起30日内进行初步审查，决定是否进一步审查。\",\r\n      risk:\"\"抢跑\"（应报未报即实施集中）面临高额罚款（最高上一年度销售额10%），可能被责令恢复原状。\",\r\n      law:\"《反垄断法》第21、26条\" },\r\n    // 民事实体\r\n    { name:\"民事法律行为撤销权\", cat:\"civil\", warn:true, dur:\"long\",\r\n      time:\"1年 / 90日（最长5年）\", desc:\"自知道或应当知道撤销事由之日起1年内行使。因胁迫产生撤销权的，自胁迫行为终止之日起1年内行使。重大误解当事人自知道或应当知道撤销事由之日起90日内行使。自民事法律行为发生之日起5年内没有行使的，撤销权消灭。\",\r\n      risk:\"逾期不行使，撤销权绝对消灭，法律行为确定有效。此为除斥期间，需主动主张。\",\r\n      law:\"《民法典》第152条\" },\r\n    { name:\"债权人撤销权\", cat:\"civil\", warn:true, dur:\"long\",\r\n      time:\"1年（最长5年）\", desc:\"自债权人知道或应当知道撤销事由之日起1年内行使。自债务人的行为发生之日起5年内没有行使的，撤销权消灭。\",\r\n      risk:\"逾期不行使，撤销权消灭。需通过诉讼方式行使。\",\r\n      law:\"《民法典》第538-542条\" },\r\n    { name:\"保证期间\", cat:\"civil\", warn:true, dur:\"medium\",\r\n      time:\"约定优先，无约定为6个月\", desc:\"债权人与保证人可以约定保证期间。没有约定或约定不明确的，保证期间为主债务履行期限届满之日起6个月。约定\"保证人承担保证责任直至主债务本息还清时为止\"等类似内容的，视为约定不明，保证期间为6个月。\",\r\n      risk:\"保证期间是确定保证人是否承担责任的\"生死线\"。债权人在此期间内未向保证人主张权利（一般保证需起诉/仲裁），保证责任免除。\",\r\n      law:\"《民法典》第692、693条\" },\r\n    { name:\"建设工程价款优先受偿权\", cat:\"civil\", warn:true, dur:\"long\",\r\n      time:\"18个月\", desc:\"自发包人应当给付建设工程价款之日起算。最长不超过18个月。\",\r\n      risk:\"性质为法定担保物权，但行使有严格期限。逾期未主张（需通过诉讼或仲裁等方式明确请求），权利消灭。\",\r\n      law:\"《民法典》第807条；《建设工程施工合同司法解释一》第41条\" },\r\n    // 诉讼程序\r\n    { name:\"管辖权异议期\", cat:\"procedure\", warn:true, dur:\"short\",\r\n      time:\"15日\", desc:\"被告在提交答辩状期间提出。答辩期为收到起诉状副本后15日内。\",\r\n      risk:\"逾期提出，法院不予审查。此为不变期间。\",\r\n      law:\"《民事诉讼法》第130条\" },\r\n    { name:\"增加、变更诉讼请求/提出反诉\", cat:\"procedure\", warn:false, dur:\"short\",\r\n      time:\"举证期限届满前\", desc:\"原则在案件受理后，举证期限届满前提出。法庭辩论结束前，对方同意或法院认为可以合并审理的，也可准许。\",\r\n      risk:\"逾期提出可能导致法院不予准许，需另案处理，增加讼累。\",\r\n      law:\"《民诉法解释》第232条\" },\r\n    { name:\"支付令异议期\", cat:\"procedure\", warn:false, dur:\"short\",\r\n      time:\"15日\", desc:\"债务人应当自收到支付令之日起15日内清偿债务，或向法院提出书面异议。\",\r\n      risk:\"15日内不提书面异议或异议不成立，支付令生效，可申请强制执行。提出有效书面异议，支付令失效，转入诉讼程序。\",\r\n      law:\"《民事诉讼法》第221条\" },\r\n    { name:\"仲裁裁决撤销申请\", cat:\"procedure\", warn:true, dur:\"medium\",\r\n      time:\"6个月\", desc:\"当事人提出证据证明裁决有法定撤销情形的，可自收到裁决书之日起6个月内向仲裁委所在地中级法院申请撤销。\",\r\n      risk:\"逾期未申请，撤销权消灭。\",\r\n      law:\"《仲裁法》第59条\" },\r\n    { name:\"公示催告申报权利期\", cat:\"procedure\", warn:false, dur:\"medium\",\r\n      time:\"不少于60日\", desc:\"法院决定受理公示催告申请后，应同时通知支付人止付，并在3日内发出公告，催促利害关系人申报权利。公示催告期间由法院定，但不得少于60日。\",\r\n      risk:\"利害关系人应在公示催告期间申报权利。无人申报的，法院根据申请作出除权判决，宣告票据无效。\",\r\n      law:\"《民事诉讼法》第225条\" },\r\n];\r\n\r\nconst CAT_NAMES = { labor:\"劳动法\", commercial:\"商法\", economic:\"经济法\", civil:\"民事实体\", procedure:\"诉讼程序\" };\r\nconst DUR_NAMES = { short:\"≤15日\", medium:\"1-6个月\", long:\"1-3年\", vlong:\"3年以上\" };\r\n\r\nlet curCat = \"all\", curDur = \"all\", curSearch = \"\";\r\n\r\nfunction render() {\r\n    const filtered = DATA.filter(d => {\r\n        if (curCat === \"warning\") { if (!d.warn) return false; }\r\n        else if (curCat !== \"all\" && d.cat !== curCat) return false;\r\n        if (curDur !== \"all\" && d.dur !== curDur) return false;\r\n        if (curSearch) {\r\n            const s = curSearch.toLowerCase();\r\n            const t = (d.name + d.time + d.desc + d.risk + d.law).toLowerCase();\r\n            if (!t.includes(s)) return false;\r\n        }\r\n        return true;\r\n    });\r\n\r\n    // 统计\r\n    const total = filtered.length;\r\n    const warnCount = filtered.filter(d => d.warn).length;\r\n    const catCount = new Set(filtered.map(d => d.cat)).size;\r\n    document.getElementById('stats').innerHTML = `\r\n        <div class=\"stat-card\"><div class=\"num\">${total}</div><div class=\"label\">匹配条目</div></div>\r\n        <div class=\"stat-card warn\"><div class=\"num\">${warnCount}</div><div class=\"label\">高风险项</div></div>\r\n        <div class=\"stat-card\"><div class=\"num\">${catCount}</div><div class=\"label\">涉及门类</div></div>\r\n    `;\r\n\r\n    // 卡片\r\n    const list = document.getElementById('cardList');\r\n    const noRes = document.getElementById('noResult');\r\n    if (!filtered.length) { list.innerHTML = ''; noRes.style.display = 'block'; return; }\r\n    noRes.style.display = 'none';\r\n\r\n    list.innerHTML = filtered.map((d, i) => `\r\n        <div class=\"card cat-${d.cat} ${d.warn ? 'warn-card' : ''}\" onclick=\"this.classList.toggle('expanded')\">\r\n            ${d.warn ? '<div class=\"warn-badge\">⚠ 高风险</div>' : ''}\r\n            <div class=\"cat-tag\">${CAT_NAMES[d.cat]}</div>\r\n            <div class=\"title\">${highlight(d.name)}</div>\r\n            <div class=\"duration\">${highlight(d.time)}</div>\r\n            <div class=\"desc\">${highlight(truncate(d.desc, 80))}</div>\r\n            <div class=\"detail\">\r\n                <div class=\"desc\" style=\"margin-bottom:10px\">${highlight(d.desc)}</div>\r\n                <div class=\"risk\">${highlight(d.risk)}</div>\r\n                <div class=\"law-ref\">📖 ${highlight(d.law)}</div>\r\n            </div>\r\n            <div class=\"expand-hint\">点击展开/收起详情 ▾</div>\r\n        </div>\r\n    `).join('');\r\n}\r\n\r\nfunction truncate(s, n) { return s.length > n ? s.slice(0, n) + '...' : s; }\r\n\r\nfunction highlight(text) {\r\n    if (!curSearch) return text;\r\n    const re = new RegExp('(' + curSearch.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&') + ')', 'gi');\r\n    return text.replace(re, '<mark style=\"background:#fbbf24;color:#0f172a;border-radius:2px;padding:0 2px\">$1</mark>');\r\n}\r\n\r\n// 事件绑定\r\ndocument.getElementById('searchInput').addEventListener('input', e => { curSearch = e.target.value.trim(); render(); });\r\n\r\ndocument.getElementById('catFilters').addEventListener('click', e => {\r\n    if (!e.target.classList.contains('fbtn')) return;\r\n    document.querySelectorAll('#catFilters .fbtn').forEach(b => b.classList.remove('active'));\r\n    e.target.classList.add('active');\r\n    curCat = e.target.dataset.cat;\r\n    render();\r\n});\r\n\r\ndocument.getElementById('durFilters').addEventListener('click', e => {\r\n    if (!e.target.classList.contains('dbtn')) return;\r\n    document.querySelectorAll('#durFilters .dbtn').forEach(b => b.classList.remove('active'));\r\n    e.target.classList.add('active');\r\n    curDur = e.target.dataset.dur;\r\n    render();\r\n});\r\n\r\nwindow.addEventListener('scroll', () => {\r\n    document.getElementById('backTop').style.display = window.scrollY > 300 ? 'block' : 'none';\r\n});\r\n\r\n// 键盘快捷键：按 / 聚焦搜索\r\ndocument.addEventListener('keydown', e => {\r\n    if (e.key === '/' && document.activeElement !== document.getElementById('searchInput')) {\r\n        e.preventDefault();\r\n        document.getElementById('searchInput').focus();\r\n    }\r\n});\r\n\r\nrender();\r\n</script>\r\n</body>\r\n</html>\r","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false},"sourceToolAssistantUUID":"4bf35262-4b73-4c84-b588-c0895611dd50"}
