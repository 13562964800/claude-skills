{"parentUuid":"33b0f692-0516-494c-a769-519f3e192de4","isSidechain":true,"userType":"external","cwd":"C:\\Users\\Administrator\\AI科普画册","sessionId":"8abe27fc-5ecd-40ad-b0f3-9f8bab760ce8","version":"2.1.63","gitBranch":"HEAD","agentId":"a902c38aadf2fbb05","slug":"fizzy-giggling-whisper","message":{"content":[{"id":"tooluse_jQY7aqjNlSA3Ltfs4UDZlH","input":{"file_path":"C:\\Users\\Administrator\\AI科普画册\\generate_clean_docx.py","content":"#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n\"\"\"\n生成纯净的Word文档，跳过所有SVG代码块\n\"\"\"\n\nimport re\nfrom pathlib import Path\nfrom docx import Document\nfrom docx.shared import Pt, Inches, RGBColor\nfrom docx.enum.text import WD_ALIGN_PARAGRAPH\n\ndef clean_svg_blocks(content):\n    \"\"\"完全移除SVG代码块\"\"\"\n    # 移除<svg>...</svg>块（包括多行）\n    content = re.sub(r'<svg[^>]*>.*?</svg>', '', content, flags=re.DOTALL)\n    return content\n\ndef parse_markdown_to_docx(md_file, output_file, images_dir):\n    \"\"\"解析Markdown并生成Word文档\"\"\"\n\n    # 读取markdown文件\n    with open(md_file, 'r', encoding='utf-8') as f:\n        content = f.read()\n\n    # 清理SVG代码块\n    content = clean_svg_blocks(content)\n\n    # 创建Word文档\n    doc = Document()\n\n    # 设置默认字体\n    style = doc.styles['Normal']\n    style.font.name = '微软雅黑'\n    style.font.size = Pt(11)\n\n    # 按行处理\n    lines = content.split('\\n')\n    i = 0\n\n    while i < len(lines):\n        line = lines[i].strip()\n\n        # 跳过空行\n        if not line:\n            i += 1\n            continue\n\n        # 一级标题\n        if line.startswith('# '):\n            p = doc.add_heading(line[2:], level=1)\n            p.alignment = WD_ALIGN_PARAGRAPH.CENTER\n\n        # 二级标题\n        elif line.startswith('## '):\n            doc.add_heading(line[3:], level=2)\n\n        # 三级标题\n        elif line.startswith('### '):\n            doc.add_heading(line[4:], level=3)\n\n        # 四级标题\n        elif line.startswith('#### '):\n            doc.add_heading(line[5:], level=4)\n\n        # 分隔线\n        elif line.startswith('---'):\n            doc.add_paragraph('─' * 50)\n\n        # 处理【插图】标记\n        elif '【插图】' in line or '【封面插图】' in line:\n            # 添加插图说明\n            p = doc.add_paragraph(line)\n            p.runs[0].font.bold = True\n            p.runs[0].font.color.rgb = RGBColor(0, 102, 204)\n\n            # 收集插图描述（可能多行）\n            i += 1\n            description_lines = []\n            while i < len(lines):\n                next_line = lines[i].strip()\n                if not next_line or next_line.startswith('#') or next_line.startswith('**') or next_line.startswith('---'):\n                    break\n                if next_line.startswith('-') or next_line.startswith('*'):\n                    description_lines.append(next_line)\n                i += 1\n\n            # 添加描述\n            for desc in description_lines:\n                doc.add_paragraph(desc, style='List Bullet')\n\n            # 尝试插入对应的PNG图片\n            # 从插图说明中提取图片编号\n            match = re.search(r'插图(\\d+-\\d+)', line)\n            if match:\n                img_name = f\"插图{match.group(1)}.png\"\n                img_path = images_dir / img_name\n                if img_path.exists():\n                    try:\n                        doc.add_picture(str(img_path), width=Inches(5))\n                        last_paragraph = doc.paragraphs[-1]\n                        last_paragraph.alignment = WD_ALIGN_PARAGRAPH.CENTER\n                    except Exception as e:\n                        print(f\"无法插入图片 {img_name}: {e}\")\n\n            continue\n\n        # 粗体文本（**文本**）\n        elif line.startswith('**') and line.endswith('**'):\n            p = doc.add_paragraph()\n            run = p.add_run(line[2:-2])\n            run.bold = True\n\n        # 列表项\n        elif line.startswith('- ') or line.startswith('* '):\n            doc.add_paragraph(line[2:], style='List Bullet')\n\n        # 普通段落\n        else:\n            # 跳过包含SVG残留的行\n            if '<svg' in line or '</svg>' in line or 'xmlns=' in line:\n                i += 1\n                continue\n            doc.add_paragraph(line)\n\n        i += 1\n\n    # 保存文档\n    doc.save(output_file)\n    print(f\"✓ 纯净Word文档已生成: {output_file}\")\n\nif __name__ == '__main__':\n    # 文件路径\n    base_dir = Path(r'C:\\Users\\Administrator\\AI科普画册')\n    md_file = base_dir / 'AI前沿知识儿童科普画册-带全部插图.md'\n    output_file = base_dir / 'AI科普画册-纯净版.docx'\n    images_dir = base_dir / 'images'\n\n    # 生成文档\n    parse_markdown_to_docx(md_file, output_file, images_dir)\n"},"name":"Write","type":"tool_use"}],"id":"msg_8857d64dffe14cc385e296c352da0bc6","model":"claude-sonnet-4-6","role":"assistant","stop_reason":"tool_use","stop_sequence":null,"type":"message","usage":{"input_tokens":26722,"cache_creation_input_tokens":0,"cache_read_input_tokens":0,"output_tokens":1456,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard"}},"type":"assistant","uuid":"1e7e86fc-490e-4dee-802c-2edfa57d8d66","timestamp":"2026-03-01T09:06:11.478Z"}
