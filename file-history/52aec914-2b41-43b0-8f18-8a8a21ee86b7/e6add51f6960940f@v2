name: Build Windows Installer

on:
  push:
    tags:
      - 'v*'
  workflow_dispatch:

jobs:
  build:
    runs-on: windows-latest
    steps:
      - name: Checkout code
        uses: actions/checkout@v3

      - name: Setup Python
        uses: actions/setup-python@v4
        with:
          python-version: '3.12'

      - name: Setup Node.js
        uses: actions/setup-node@v3
        with:
          node-version: '18'

      - name: Install PyInstaller
        run: pip install pyinstaller

      - name: Build API executable
        run: |
          cd build/pyinstaller
          pyinstaller legalflow-api.spec

      - name: Build frontend
        run: |
          cd apps/web
          npm install
          npm run build

      - name: Prepare Electron app
        run: |
          cd apps/desktop
          mkdir -p api renderer
          copy ..\..\build\pyinstaller\dist\legalflow-api.exe api\
          xcopy /E /I /Y ..\web\out renderer

      - name: Install Electron dependencies
        run: |
          cd apps/desktop
          npm install

      - name: Build installer
        run: |
          cd apps/desktop
          npm run build:win

      - name: Upload artifact
        uses: actions/upload-artifact@v3
        with:
          name: windows-installer
          path: apps/desktop/dist/*.exe

      - name: Create Release
        if: startsWith(github.ref, 'refs/tags/')
        uses: softprops/action-gh-release@v1
        with:
          files: apps/desktop/dist/*.exe
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
