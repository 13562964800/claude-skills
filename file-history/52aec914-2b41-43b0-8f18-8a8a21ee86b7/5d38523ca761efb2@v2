# tests/test_web_auth_integration.py
import os

def test_auth_page_uses_useAuth():
    path = os.path.join(os.path.dirname(__file__), '../apps/web/app/auth/page.tsx')
    content = open(path, encoding='utf-8').read()
    assert 'useAuth' in content
    assert 'login' in content or 'register' in content
