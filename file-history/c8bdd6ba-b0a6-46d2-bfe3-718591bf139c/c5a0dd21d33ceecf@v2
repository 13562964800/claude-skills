<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>GitHub 小白科普画册</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Microsoft YaHei','PingFang SC',Arial,sans-serif;background:linear-gradient(135deg,#0f172a,#1e293b);min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;color:#334155;overflow:hidden}
.book{position:relative;width:min(900px,96vw);height:min(600px,86vh)}
.pg{position:absolute;width:100%;height:100%;border-radius:16px;padding:36px 44px;display:none;flex-direction:column;opacity:0;transform:scale(.95);transition:opacity .4s,transform .4s;overflow-y:auto;box-shadow:0 20px 50px rgba(0,0,0,.3)}
.pg.on{display:flex;opacity:1;transform:scale(1)}
.pg::-webkit-scrollbar{width:5px}
.pg::-webkit-scrollbar-thumb{background:rgba(0,0,0,.12);border-radius:3px}
.p0,.p11{background:linear-gradient(160deg,#1e293b,#334155);color:#e2e8f0}
.p1{background:linear-gradient(160deg,#eff6ff,#dbeafe)}.p2{background:linear-gradient(160deg,#f0fdf4,#dcfce7)}
.p3{background:linear-gradient(160deg,#fefce8,#fef9c3)}.p4{background:linear-gradient(160deg,#fdf4ff,#fae8ff)}
.p5{background:linear-gradient(160deg,#fff7ed,#ffedd5)}.p6{background:linear-gradient(160deg,#f0f9ff,#e0f2fe)}
.p7{background:linear-gradient(160deg,#fef2f2,#fee2e2)}.p8{background:linear-gradient(160deg,#ecfdf5,#d1fae5)}
.p9{background:linear-gradient(160deg,#eff6ff,#bfdbfe)}.p10{background:linear-gradient(160deg,#faf5ff,#e9d5ff)}
h1{font-size:clamp(20px,3.5vw,28px);font-weight:800;margin-bottom:12px;line-height:1.3}
.p0 h1,.p11 h1{color:#e2e8f0}.p1 h1{color:#1e40af}.p2 h1{color:#065f46}.p3 h1{color:#92400e}
.p4 h1{color:#7c3aed}.p5 h1{color:#c2410c}.p6 h1{color:#0369a1}.p7 h1{color:#b91c1c}
.p8 h1{color:#047857}.p9 h1{color:#1d4ed8}.p10 h1{color:#7c3aed}
.sub{font-size:clamp(12px,2vw,15px);color:#64748b;margin-bottom:12px;line-height:1.5}
.p0 .sub,.p11 .sub{color:#94a3b8}
.ct{flex:1;font-size:clamp(12px,1.8vw,14px);line-height:1.7}.ct p{margin-bottom:8px}
.em{font-size:clamp(36px,7vw,52px);margin-bottom:10px;display:block;text-align:center}
.cd{background:rgba(255,255,255,.7);border-radius:10px;padding:10px 14px;margin:5px 0;border:1px solid rgba(255,255,255,.5);font-size:clamp(12px,1.7vw,14px)}
.p0 .cd,.p11 .cd{background:rgba(255,255,255,.07);border-color:rgba(255,255,255,.1)}
.row{display:flex;gap:8px;margin:5px 0;flex-wrap:wrap}.row .cd{flex:1;min-width:90px}
.dg{background:rgba(255,255,255,.85);border-radius:8px;padding:10px;margin:6px 0;font-family:Consolas,monospace;font-size:clamp(9px,1.3vw,12px);line-height:1.5;white-space:pre;overflow-x:auto;border:1px solid rgba(0,0,0,.05)}
.p0 .dg,.p11 .dg{background:rgba(255,255,255,.06);color:#cbd5e1}
.qt{border-left:4px solid #60a5fa;padding:8px 14px;margin:8px 0;border-radius:0 8px 8px 0;background:rgba(96,165,250,.06);font-size:13px}
.tg{display:inline-block;padding:2px 9px;border-radius:14px;font-size:11px;font-weight:600;margin:1px 2px}
.tg-b{background:#dbeafe;color:#1e40af}.tg-g{background:#d1fae5;color:#065f46}
.tg-y{background:#fef3c7;color:#92400e}.tg-r{background:#fee2e2;color:#b91c1c}
.tg-p{background:#ede9fe;color:#5b21b6}.tg-k{background:#fce7f3;color:#9d174d}
table{width:100%;border-collapse:collapse;margin:6px 0;font-size:clamp(11px,1.5vw,13px)}
th,td{padding:5px 8px;text-align:left;border-bottom:1px solid rgba(0,0,0,.06)}
th{font-weight:700;background:rgba(0,0,0,.03)}
.fl{text-align:center;font-size:14px;margin:1px 0;opacity:.35}
.nav{display:flex;align-items:center;justify-content:center;gap:12px;margin-top:10px;padding:8px 14px;background:rgba(255,255,255,.06);border-radius:30px}
.btn{width:40px;height:40px;border-radius:50%;border:none;background:rgba(255,255,255,.12);color:#e2e8f0;font-size:18px;cursor:pointer;transition:all .2s;display:flex;align-items:center;justify-content:center}
.btn:hover{background:rgba(255,255,255,.25);transform:scale(1.1)}
.btn:disabled{opacity:.3;cursor:default;transform:none}
.dots{display:flex;gap:5px;align-items:center}
.dot{width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,.2);cursor:pointer;transition:all .3s}
.dot.on{background:#60a5fa;width:22px;border-radius:4px}
.pn{color:#94a3b8;font-size:13px;min-width:48px;text-align:center}
@media(max-width:640px){body{justify-content:flex-start;padding-top:4px}.book{width:98vw;height:calc(100vh - 66px)}.pg{padding:18px 14px;border-radius:12px}.row{flex-direction:column}.nav{margin-top:4px;gap:6px;padding:5px 10px}.btn{width:34px;height:34px;font-size:15px}}
</style>
</head>
<body>
<div class="book" id="book"></div>
<div class="nav">
<button class="btn" id="prev" onclick="go(-1)">&#9664;</button>
<div class="dots" id="dots"></div>
<span class="pn" id="pn"></span>
<button class="btn" id="next" onclick="go(1)">&#9654;</button>
</div>
<script>
const P = [];
// 封面
P.push(`<div class="em">🐙</div>
<h1 style="text-align:center">GitHub 小白科普画册</h1>
<p class="sub" style="text-align:center">像搭积木一样理解代码世界<br>写给零基础的你——哪怕你是个孩子，也能看懂！</p>
<div class="cd" style="text-align:center;margin-top:16px">
<p>📖 共 12 页 · 左右滑动或点击箭头翻页</p>
<p style="margin-top:6px;opacity:.6">点击下方圆点可跳转到任意页</p>
</div>`);

// 第1页
P.push(`<h1>一、GitHub 是什么？</h1>
<p class="sub">想象你和小伙伴们一起画一幅超级大的画 🎨</p>
<div class="ct">
<div class="row">
<div class="cd">🌳 你画了一棵树</div>
<div class="cd">🐱 小明画了一只猫</div>
<div class="cd">🌸 小红画了一朵花</div>
</div>
<p>但问题来了：<b>怎么把大家画的东西合到一张纸上，还不会互相覆盖？</b></p>
<div class="cd" style="text-align:center;font-size:16px"><b>GitHub 就是帮你解决这个问题的"魔法画板" ✨</b></div>
<p>它是一个<b>在线的代码仓库平台</b>，全世界的程序员都在上面：</p>
<div class="row">
<div class="cd"><b>📦 存代码</b><br>像把画存进保险柜</div>
<div class="cd"><b>🤝 合作</b><br>像一起画画</div>
<div class="cd"><b>📜 记录</b><br>像每一笔都有录像</div>
</div>
</div>`);

// 第2页
P.push(`<h1>二、Repository（仓库）</h1>
<p class="sub">你的"项目文件夹" 📁</p>
<div class="ct">
<div class="dg">📁 我的第一个项目/
├── 📄 README.md      ← 项目说明书
├── 📄 index.html     ← 网页文件
├── 📁 images/        ← 图片文件夹
│   └── 🖼️ logo.png
└── 📁 src/           ← 源代码文件夹
    └── 📄 app.js</div>
<p>仓库就是一个"项目文件夹"，就像你<b>书包</b>里装着语文书、数学书、铅笔盒——仓库里装着代码、图片、说明文档。</p>
<div class="row">
<div class="cd"><b>🏦 远程仓库 Remote</b><br>云端的保险柜<br><span style="color:#64748b;font-size:12px">存在 GitHub 网站上，大家都能看到</span></div>
<div class="cd"><b>💻 本地仓库 Local</b><br>你桌上的文件夹<br><span style="color:#64748b;font-size:12px">存在你自己电脑上，只有你能看到</span></div>
</div>
</div>`);
// 第3页 Git vs GitHub
P.push(`<h1>三、Git vs GitHub</h1>
<p class="sub">别搞混了！其实很简单 😄</p>
<div class="ct">
<table>
<tr><th></th><th>Git</th><th>GitHub</th></tr>
<tr><td><b>是什么</b></td><td>一个工具（软件）</td><td>一个网站（平台）</td></tr>
<tr><td><b>比喻</b></td><td>📷 照相机</td><td>📸 云相册</td></tr>
<tr><td><b>作用</b></td><td>在电脑上记录文件变化</td><td>放到网上，方便分享合作</td></tr>
<tr><td><b>离线？</b></td><td>✅ 可以</td><td>❌ 需联网</td></tr>
</table>
<div class="qt" style="margin-top:16px;text-align:center;font-size:15px">🎯 <b>Git 是拍照的相机，GitHub 是存照片的云相册</b></div>
<div class="row" style="margin-top:12px">
<div class="cd" style="text-align:center"><span style="font-size:40px">📷</span><br><b>Git</b><br>装在你电脑上<br>记录每次变化</div>
<div class="cd" style="text-align:center;font-size:28px;display:flex;align-items:center;justify-content:center">→</div>
<div class="cd" style="text-align:center"><span style="font-size:40px">☁️</span><br><b>GitHub</b><br>在互联网上<br>分享和协作</div>
</div>
</div>`);

// 第4页 Commit
P.push(`<h1>四、Commit（提交）</h1>
<p class="sub">给你的工作"拍张照" 📸 —— 就像游戏存档</p>
<div class="ct">
<div class="dg">时间线 ─────────────────────────────────►

  📸            📸            📸            📸
  第1次提交     第2次提交     第3次提交     第4次提交
  "创建首页"   "加了导航栏"  "修了个bug"   "加了登录"</div>
<div class="cd"><b>🎮 就像打游戏时的存档！</b><p>每存一次档，你就可以随时回到那个时间点。<br>代码写崩了？没关系，<b>读档回去就行！</b></p></div>
<p style="margin-top:10px"><b>每次 Commit 包含：</b></p>
<div class="row">
<div class="cd">📝 改了什么</div>
<div class="cd">💬 一句说明</div>
<div class="cd">🕐 时间戳</div>
<div class="cd">👤 谁改的</div>
</div>
</div>`);

// 第5页 Branch
P.push(`<h1>五、Branch（分支）</h1>
<p class="sub">平行宇宙 🌿 —— 最酷的概念之一！</p>
<div class="ct">
<div class="dg">                 🧪 feature-login（新功能分支）
                /         \
main  ●───●───●───●────●────●───●  主分支
                       \        /
                        🔧 fix-bug（修bug分支）</div>
<div class="cd"><b>📝 比喻：写作文试两种结尾</b><p>你不想在原稿上乱改，于是<b>复印两份</b>，分别写不同的结尾。写完后，选最好的那个<b>贴回原稿</b>。这就是分支！</p></div>
<table>
<tr><th>分支名</th><th>用途</th><th>比喻</th></tr>
<tr><td><span class="tg tg-b">main</span></td><td>主分支，正式版本</td><td>📖 课本定稿</td></tr>
<tr><td><span class="tg tg-g">develop</span></td><td>开发中的版本</td><td>📝 草稿本</td></tr>
<tr><td><span class="tg tg-y">feature-xxx</span></td><td>新功能开发</td><td>🧪 实验室</td></tr>
<tr><td><span class="tg tg-r">fix-xxx</span></td><td>修复bug</td><td>🔧 维修车间</td></tr>
</table>
</div>`);
// 第6页 Merge & PR
P.push(`<h1>六、Merge 与 Pull Request</h1>
<p class="sub">合并分支 & 举手发言请求合并 🙋</p>
<div class="ct">
<div class="cd"><b>🔀 Merge 合并</b><p>在草稿纸上画好了一只恐龙，觉得很满意，然后把它<b>剪下来贴到正式的画上</b>。</p></div>
<div class="cd"><b>🙋 Pull Request（PR）= 举手请求</b><p>你不能直接往课本上写字，得先写在草稿纸上，然后举手说：<br>"老师，我写好了，帮我检查一下，没问题就抄到课本上吧！"</p></div>
<div class="dg">PR 流程：
👩‍💻 你写代码  →  🙋 发起PR  →  🔍 队友审查  →  ✅ 合并！

💬 对话示例：
┌─────────────────────────────────────┐
│ 小红: 我做了照片墙功能，请帮我看看！  │
│ 小明: 代码不错，第15行建议改一下 💬   │
│ 小刚: 我觉得可以！LGTM 👍           │
│ 负责人: 好的，合并！✅               │
└─────────────────────────────────────┘</div>
</div>`);

// 第7页 四个搬运动作
P.push(`<h1>七、四个搬运动作</h1>
<p class="sub">Clone / Fork / Pull / Push 📦</p>
<div class="ct">
<div class="dg">☁️ GitHub（云端）           💻 你的电脑（本地）

┌──────────┐              ┌──────────┐
│ 远程仓库  │ ── Clone ──→ │ 本地仓库  │
│          │ ← Push  ───  │          │
│          │ ── Pull  ──→ │          │
└──────────┘              └──────────┘

┌──────────┐    Fork    ┌──────────┐
│ 别人的仓库 │ ────────→ │ 你的仓库  │
└──────────┘            └──────────┘</div>
<table>
<tr><th>动作</th><th>方向</th><th>比喻</th></tr>
<tr><td><span class="tg tg-g">Clone</span></td><td>云端→电脑</td><td>📋 复印一本书带回家</td></tr>
<tr><td><span class="tg tg-y">Fork</span></td><td>别人→你的</td><td>🍴 抄一份菜谱到自己笔记本</td></tr>
<tr><td><span class="tg tg-r">Push</span></td><td>电脑→云端</td><td>📤 把写好的作业交上去</td></tr>
<tr><td><span class="tg tg-p">Pull</span></td><td>云端→电脑</td><td>📥 下载老师发的新资料</td></tr>
</table>
<div class="qt">🎯 Clone 是复制到你的<b>电脑</b>上，Fork 是复制到你的 <b>GitHub 账号</b>下</div>
</div>`);

// 第8页 Issue
P.push(`<h1>八、Issue（议题）</h1>
<p class="sub">项目的留言板 / 意见箱 📮</p>
<div class="ct">
<div class="dg">┌─────────────────────────────────────┐
│ 🐛 Issue #42: 登录按钮点了没反应      │
│                                     │
│ 提交者: 小明    标签: [bug] [紧急]    │
│                                     │
│ 💬 评论 (3)                          │
│   小红: 我也遇到了这个问题！           │
│   小刚: 我来修，预计明天搞定           │
│   小明: 谢谢！                       │
└─────────────────────────────────────┘</div>
<p>发现了 bug？想要新功能？有问题想讨论？都可以发一个 Issue。就像班级的<b>意见箱</b> 📮 —— 谁都可以往里面塞纸条！</p>
<div class="cd" style="margin-top:10px"><b>⭐ 社交三件套</b>
<table>
<tr><th>动作</th><th>比喻</th><th>意思</th></tr>
<tr><td>⭐ Star</td><td>点赞/收藏</td><td>"这个项目真棒！"</td></tr>
<tr><td>👁️ Watch</td><td>关注</td><td>"有更新就通知我"</td></tr>
<tr><td>🍴 Fork</td><td>复制一份</td><td>"我要做自己的版本"</td></tr>
</table>
</div>
</div>`);
// 第9页 完整协作流程
P.push(`<h1>九、完整协作流程</h1>
<p class="sub">一个故事串起所有概念 🎬</p>
<div class="ct">
<div class="cd"><span class="tg tg-b">第1步</span> <b>小明</b>在 GitHub 上创建了一个仓库 📁 "班级网站"</div>
<div class="fl">⬇️</div>
<div class="cd"><span class="tg tg-y">第2步</span> <b>小红</b>觉得不错，<b>Fork</b> 了一份到自己账号 🍴</div>
<div class="fl">⬇️</div>
<div class="cd"><span class="tg tg-g">第3步</span> 小红把项目 <b>Clone</b> 到自己电脑上 📋</div>
<div class="fl">⬇️</div>
<div class="cd"><span class="tg tg-p">第4步</span> 小红创建新 <b>Branch</b> 🌿 feature-photo-wall</div>
<div class="fl">⬇️</div>
<div class="cd"><span class="tg tg-k">第5步</span> 写完代码后 <b>Commit</b> 存档 📸</div>
<div class="fl">⬇️</div>
<div class="cd"><span class="tg tg-r">第6步</span> 把代码 <b>Push</b> 到自己的 GitHub 仓库 📤</div>
<div class="fl">⬇️</div>
<div class="cd"><span class="tg tg-y">第7步</span> 发起 <b>Pull Request</b> 给小明 🙋</div>
<div class="fl">⬇️</div>
<div class="cd"><span class="tg tg-g">第8步</span> 小明审查代码，<b>Merge</b> 合并 ✅</div>
<div class="fl">⬇️</div>
<div class="cd"><span class="tg tg-b">第9步</span> 其他同学 <b>Pull</b> 最新代码 📥 "哇，多了个照片墙！"</div>
</div>`);

// 第10页 常用词速查
P.push(`<h1>十、常用词速查表</h1>
<p class="sub">一张表记住所有关键词 📋</p>
<div class="ct">
<table>
<tr><th>英文</th><th>中文</th><th>一句话解释</th></tr>
<tr><td><b>Repository</b></td><td>仓库</td><td>项目文件夹</td></tr>
<tr><td><b>Commit</b></td><td>提交</td><td>给代码拍照存档</td></tr>
<tr><td><b>Branch</b></td><td>分支</td><td>平行宇宙，互不干扰</td></tr>
<tr><td><b>Merge</b></td><td>合并</td><td>把分支贴回主线</td></tr>
<tr><td><b>Pull Request</b></td><td>合并请求</td><td>举手请老师检查</td></tr>
<tr><td><b>Clone</b></td><td>克隆</td><td>复印一本书带回家</td></tr>
<tr><td><b>Fork</b></td><td>分叉</td><td>抄一份菜谱到自己笔记本</td></tr>
<tr><td><b>Push</b></td><td>推送</td><td>把作业交上去</td></tr>
<tr><td><b>Pull</b></td><td>拉取</td><td>下载老师发的新资料</td></tr>
<tr><td><b>Issue</b></td><td>议题</td><td>意见箱里的纸条</td></tr>
<tr><td><b>Star</b></td><td>收藏</td><td>点赞，表示喜欢</td></tr>
<tr><td><b>README</b></td><td>说明文件</td><td>项目的自我介绍</td></tr>
<tr><td><b>Review</b></td><td>审查</td><td>帮同学检查作业</td></tr>
<tr><td><b>.gitignore</b></td><td>忽略文件</td><td>告诉Git哪些文件不用管</td></tr>
</table>
</div>`);

// 封底
P.push(`<div class="em">🚀</div>
<h1 style="text-align:center">勇敢迈出第一步！</h1>
<p class="sub" style="text-align:center">每个大神都是从 "Hello World" 开始的</p>
<div class="cd" style="text-align:center;margin-top:10px">
<b>🎯 动手试试</b>
<p style="margin-top:6px">1. 打开 <b>github.com</b>，注册一个账号</p>
<p>2. 点击 "New Repository"，创建你的第一个仓库</p>
