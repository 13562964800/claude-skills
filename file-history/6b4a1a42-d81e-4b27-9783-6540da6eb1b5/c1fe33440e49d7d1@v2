<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 600">
  <!-- 背景 -->
  <rect width="800" height="600" fill="#f8f9fa"/>

  <!-- 标题 -->
  <text x="400" y="40" font-family="Arial, sans-serif" font-size="24" font-weight="bold" fill="#4A90E2" text-anchor="middle">AI改变世界</text>

  <!-- 地球 -->
  <circle cx="400" cy="300" r="150" fill="#4A90E2" opacity="0.3" stroke="#4A90E2" stroke-width="3"/>
  <circle cx="400" cy="300" r="140" fill="#50C878" opacity="0.2"/>

  <!-- 大陆轮廓 -->
  <path d="M 350 250 Q 370 240 390 250 Q 410 260 420 250 Q 430 240 450 250" fill="#50C878" opacity="0.5"/>
  <path d="M 320 300 Q 340 290 360 300 Q 380 310 400 300" fill="#50C878" opacity="0.5"/>
  <path d="M 400 320 Q 420 310 440 320 Q 460 330 480 320" fill="#50C878" opacity="0.5"/>

  <!-- 围绕地球的AI应用图标 -->

  <!-- 医疗 -->
  <g transform="translate(250, 150)">
    <circle cx="0" cy="0" r="35" fill="#FF6B35" stroke="#333" stroke-width="2"/>
    <path d="M -10 0 L 10 0 M 0 -10 L 0 10" stroke="white" stroke-width="4"/>
    <text x="0" y="50" font-family="Arial, sans-serif" font-size="11" font-weight="bold" fill="#333" text-anchor="middle">医疗</text>
  </g>

  <!-- 教育 -->
  <g transform="translate(550, 150)">
    <circle cx="0" cy="0" r="35" fill="#FFD700" stroke="#333" stroke-width="2"/>
    <rect x="-12" y="-8" width="24" height="16" fill="white" rx="2"/>
    <line x1="-8" y1="-4" x2="8" y2="-4" stroke="#FFD700" stroke-width="2"/>
    <line x1="-8" y1="0" x2="8" y2="0" stroke="#FFD700" stroke-width="2"/>
    <line x1="-8" y1="4" x2="8" y2="4" stroke="#FFD700" stroke-width="2"/>
    <text x="0" y="50" font-family="Arial, sans-serif" font-size="11" font-weight="bold" fill="#333" text-anchor="middle">教育</text>
  </g>

  <!-- 交通 -->
  <g transform="translate(200, 300)">
    <circle cx="0" cy="0" r="35" fill="#50C878" stroke="#333" stroke-width="2"/>
    <rect x="-10" y="-6" width="20" height="12" fill="white" rx="2"/>
    <circle cx="-6" cy="6" r="4" fill="white"/>
    <circle cx="6" cy="6" r="4" fill="white"/>
    <text x="0" y="50" font-family="Arial, sans-serif" font-size="11" font-weight="bold" fill="#333" text-anchor="middle">交通</text>
  </g>

  <!-- 环境 -->
  <g transform="translate(600, 300)">
    <circle cx="0" cy="0" r="35" fill="#50C878" stroke="#333" stroke-width="2"/>
    <path d="M -8 5 L -8 -5 Q -8 -10 -3 -10 Q 2 -10 2 -5 L 2 5" fill="white"/>
    <path d="M 2 5 L 2 -3 Q 2 -8 7 -8 Q 12 -8 12 -3 L 12 5" fill="white"/>
    <text x="0" y="50" font-family="Arial, sans-serif" font-size="11" font-weight="bold" fill="#333" text-anchor="middle">环境</text>
  </g>

  <!-- 娱乐 -->
  <g transform="translate(250, 450)">
    <circle cx="0" cy="0" r="35" fill="#FF6B35" stroke="#333" stroke-width="2"/>
    <circle cx="-6" cy="-3" r="3" fill="white"/>
    <circle cx="6" cy="-3" r="3" fill="white"/>
    <path d="M -8 5 Q 0 12 8 5" stroke="white" stroke-width="3" fill="none" stroke-linecap="round"/>
    <text x="0" y="50" font-family="Arial, sans-serif" font-size="11" font-weight="bold" fill="#333" text-anchor="middle">娱乐</text>
  </g>

  <!-- 工作 -->
  <g transform="translate(550, 450)">
    <circle cx="0" cy="0" r="35" fill="#4A90E2" stroke="#333" stroke-width="2"/>
    <rect x="-10" y="-8" width="20" height="16" fill="white" rx="2"/>
    <rect x="-6" y="-4" width="4" height="8" fill="#4A90E2"/>
    <rect x="2" y="-4" width="4" height="8" fill="#4A90E2"/>
    <text x="0" y="50" font-family="Arial, sans-serif" font-size="11" font-weight="bold" fill="#333" text-anchor="middle">工作</text>
  </g>

  <!-- 中心AI标志 -->
  <circle cx="400" cy="300" r="50" fill="white" stroke="#4A90E2" stroke-width="3"/>
  <text x="400" y="310" font-family="Arial, sans-serif" font-size="24" font-weight="bold" fill="#4A90E2" text-anchor="middle">AI</text>

  <!-- 连接线 -->
  <line x1="250" y1="185" x2="365" y2="265" stroke="#4A90E2" stroke-width="2" opacity="0.5" stroke-dasharray="5,5"/>
  <line x1="550" y1="185" x2="435" y2="265" stroke="#4A90E2" stroke-width="2" opacity="0.5" stroke-dasharray="5,5"/>
  <line x1="235" y1="300" x2="350" y2="300" stroke="#4A90E2" stroke-width="2" opacity="0.5" stroke-dasharray="5,5"/>
  <line x1="565" y1="300" x2="450" y2="300" stroke="#4A90E2" stroke-width="2" opacity="0.5" stroke-dasharray="5,5"/>
  <line x1="250" y1="415" x2="365" y2="335" stroke="#4A90E2" stroke-width="2" opacity="0.5" stroke-dasharray="5,5"/>
  <line x1="550" y1="415" x2="435" y2="335" stroke="#4A90E2" stroke-width="2" opacity="0.5" stroke-dasharray="5,5"/>

  <!-- 装饰星星 -->
  <path d="M 100 100 L 105 110 L 115 110 L 107 117 L 110 127 L 100 120 L 90 127 L 93 117 L 85 110 L 95 110 Z" fill="#FFD700" opacity="0.6"/>
  <path d="M 700 100 L 705 110 L 715 110 L 707 117 L 710 127 L 700 120 L 690 127 L 693 117 L 685 110 L 695 110 Z" fill="#FFD700" opacity="0.6"/>
  <path d="M 100 500 L 105 510 L 115 510 L 107 517 L 110 527 L 100 520 L 90 527 L 93 517 L 85 510 L 95 510 Z" fill="#FFD700" opacity="0.6"/>
  <path d="M 700 500 L 705 510 L 715 510 L 707 517 L 710 527 L 700 520 L 690 527 L 693 517 L 685 510 L 695 510 Z" fill="#FFD700" opacity="0.6"/>

  <!-- 底部说明 -->
  <rect x="50" y="540" width="700" height="50" fill="white" stroke="#4A90E2" stroke-width="2" rx="10"/>
  <text x="400" y="565" font-family="Arial, sans-serif" font-size="13" font-weight="bold" fill="#333" text-anchor="middle">🌍 AI正在改变世界的每一个角落</text>
  <text x="400" y="583" font-family="Arial, sans-serif" font-size="11" fill="#666" text-anchor="middle">从医疗到教育，从交通到环境，AI让世界变得更美好！</text>
</svg>
