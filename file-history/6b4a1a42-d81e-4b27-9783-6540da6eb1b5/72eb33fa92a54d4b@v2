<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 600">
  <!-- 背景 -->
  <rect width="800" height="600" fill="#f8f9fa"/>

  <!-- 标题 -->
  <text x="400" y="40" font-family="Arial, sans-serif" font-size="24" font-weight="bold" fill="#4A90E2" text-anchor="middle">儿童与AI携手未来</text>

  <!-- 左侧：儿童 -->
  <g transform="translate(200, 250)">
    <!-- 身体 -->
    <rect x="-20" y="20" width="40" height="60" fill="#FFD700" rx="5"/>

    <!-- 头 -->
    <circle cx="0" cy="0" r="30" fill="#FFD700" stroke="#333" stroke-width="2"/>

    <!-- 脸部特征 -->
    <circle cx="-10" cy="-5" r="4" fill="#333"/>
    <circle cx="10" cy="-5" r="4" fill="#333"/>
    <path d="M -12 10 Q 0 18 12 10" stroke="#333" stroke-width="2" fill="none" stroke-linecap="round"/>

    <!-- 头发 -->
    <path d="M -25 -10 Q -30 -20 -20 -25 Q -10 -30 0 -28 Q 10 -30 20 -25 Q 30 -20 25 -10" fill="#333"/>

    <!-- 手臂（伸出） -->
    <rect x="20" y="30" width="40" height="12" fill="#FFD700" rx="6"/>
    <circle cx="60" cy="36" r="8" fill="#FFD700" stroke="#333" stroke-width="2"/>

    <!-- 腿 -->
    <rect x="-15" y="80" width="12" height="40" fill="#4A90E2" rx="6"/>
    <rect x="3" y="80" width="12" height="40" fill="#4A90E2" rx="6"/>

    <!-- 鞋子 -->
    <ellipse cx="-9" cy="120" rx="10" ry="6" fill="#333"/>
    <ellipse cx="9" cy="120" rx="10" ry="6" fill="#333"/>
  </g>

  <!-- 右侧：AI机器人 -->
  <g transform="translate(600, 250)">
    <!-- 身体 -->
    <rect x="-30" y="20" width="60" height="80" fill="#4A90E2" stroke="#333" stroke-width="2" rx="10"/>

    <!-- 头 -->
    <rect x="-25" y="-20" width="50" height="50" fill="#4A90E2" stroke="#333" stroke-width="2" rx="8"/>

    <!-- 眼睛 -->
    <circle cx="-10" cy="5" r="6" fill="#FFD700"/>
    <circle cx="10" cy="5" r="6" fill="#FFD700"/>

    <!-- 嘴巴 -->
    <rect x="-15" y="18" width="30" height="4" fill="#FFD700" rx="2"/>

    <!-- 天线 -->
    <line x1="0" y1="-20" x2="0" y2="-35" stroke="#333" stroke-width="2"/>
    <circle cx="0" cy="-35" r="5" fill="#FF6B35"/>

    <!-- 手臂（伸出） -->
    <rect x="-70" y="40" width="40" height="12" fill="#4A90E2" stroke="#333" stroke-width="2" rx="6"/>
    <circle cx="-70" cy="46" r="10" fill="#4A90E2" stroke="#333" stroke-width="2"/>

    <!-- 腿 -->
    <rect x="-18" y="100" width="14" height="30" fill="#4A90E2" stroke="#333" stroke-width="2" rx="7"/>
    <rect x="4" y="100" width="14" height="30" fill="#4A90E2" stroke="#333" stroke-width="2" rx="7"/>

    <!-- 脚 -->
    <rect x="-20" y="130" width="18" height="8" fill="#333" rx="4"/>
    <rect x="2" y="130" width="18" height="8" fill="#333" rx="4"/>
  </g>

  <!-- 握手的手 -->
  <g transform="translate(400, 286)">
    <!-- 左手（儿童） -->
    <ellipse cx="-30" cy="0" rx="15" ry="10" fill="#FFD700" stroke="#333" stroke-width="2"/>

    <!-- 右手（AI） -->
    <ellipse cx="30" cy="0" rx="15" ry="10" fill="#4A90E2" stroke="#333" stroke-width="2"/>

    <!-- 握手连接 -->
    <rect x="-15" y="-5" width="30" height="10" fill="#50C878" opacity="0.5"/>
  </g>

  <!-- 心形符号 -->
  <g transform="translate(400, 200)">
    <path d="M 0 10 L -15 -5 Q -20 -15 -10 -20 Q 0 -15 0 -10 Q 0 -15 10 -20 Q 20 -15 15 -5 Z" fill="#FF6B35" opacity="0.7"/>
  </g>

  <!-- 周围的图标 -->
  <!-- 书本 -->
  <g transform="translate(150, 150)">
    <rect x="-15" y="-10" width="30" height="20" fill="#FFD700" stroke="#333" stroke-width="1" rx="2"/>
    <line x1="-15" y1="0" x2="15" y2="0" stroke="#333" stroke-width="1"/>
  </g>

  <!-- 灯泡 -->
  <g transform="translate(650, 150)">
    <circle cx="0" cy="-5" r="12" fill="#FFD700" stroke="#333" stroke-width="1"/>
    <rect x="-5" y="7" width="10" height="8" fill="#666" rx="2"/>
    <line x1="-8" y1="-5" x2="-15" y2="-8" stroke="#FFD700" stroke-width="2"/>
    <line x1="8" y1="-5" x2="15" y2="-8" stroke="#FFD700" stroke-width="2"/>
    <line x1="0" y1="-17" x2="0" y2="-24" stroke="#FFD700" stroke-width="2"/>
  </g>

  <!-- 齿轮 -->
  <g transform="translate(100, 400)">
    <circle cx="0" cy="0" r="15" fill="#4A90E2" stroke="#333" stroke-width="1"/>
    <circle cx="0" cy="0" r="8" fill="white"/>
    <rect x="-3" y="-18" width="6" height="6" fill="#4A90E2"/>
    <rect x="-3" y="12" width="6" height="6" fill="#4A90E2"/>
    <rect x="-18" y="-3" width="6" height="6" fill="#4A90E2"/>
    <rect x="12" y="-3" width="6" height="6" fill="#4A90E2"/>
  </g>

  <!-- 火箭 -->
  <g transform="translate(700, 400)">
    <path d="M 0 -20 L -8 5 L 8 5 Z" fill="#FF6B35" stroke="#333" stroke-width="1"/>
    <circle cx="0" cy="-10" r="3" fill="white"/>
    <path d="M -8 5 L -12 15 L -8 10 Z" fill="#FFD700"/>
    <path d="M 8 5 L 12 15 L 8 10 Z" fill="#FFD700"/>
  </g>

  <!-- 星星装饰 -->
  <path d="M 300 100 L 305 110 L 315 110 L 307 117 L 310 127 L 300 120 L 290 127 L 293 117 L 285 110 L 295 110 Z" fill="#FFD700" opacity="0.6"/>
  <path d="M 500 100 L 505 110 L 515 110 L 507 117 L 510 127 L 500 120 L 490 127 L 493 117 L 485 110 L 495 110 Z" fill="#FFD700" opacity="0.6"/>
  <path d="M 250 450 L 255 460 L 265 460 L 257 467 L 260 477 L 250 470 L 240 477 L 243 467 L 235 460 L 245 460 Z" fill="#FFD700" opacity="0.6"/>
  <path d="M 550 450 L 555 460 L 565 460 L 557 467 L 560 477 L 550 470 L 540 477 L 543 467 L 535 460 L 545 460 Z" fill="#FFD700" opacity="0.6"/>

  <!-- 底部文字 -->
  <rect x="50" y="480" width="700" height="100" fill="white" stroke="#4A90E2" stroke-width="2" rx="10"/>
  <text x="400" y="510" font-family="Arial, sans-serif" font-size="16" font-weight="bold" fill="#4A90E2" text-anchor="middle">🌟 你是AI时代的主人翁</text>
  <text x="400" y="535" font-family="Arial, sans-serif" font-size="13" fill="#333" text-anchor="middle">学习AI知识，掌握AI工具，</text>
  <text x="400" y="555" font-family="Arial, sans-serif" font-size="13" fill="#333" text-anchor="middle">与AI携手创造更美好的未来！</text>
</svg>
