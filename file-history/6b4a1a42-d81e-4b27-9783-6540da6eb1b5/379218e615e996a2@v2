<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 600">
  <!-- 背景 -->
  <rect width="800" height="600" fill="#f8f9fa"/>

  <!-- 标题 -->
  <text x="400" y="40" font-family="Arial, sans-serif" font-size="24" font-weight="bold" fill="#4A90E2" text-anchor="middle">Repository - 项目的家</text>

  <!-- 房子主体 -->
  <rect x="250" y="200" width="300" height="250" fill="#FFD700" stroke="#333" stroke-width="3"/>

  <!-- 屋顶 -->
  <path d="M 200 200 L 400 100 L 600 200 Z" fill="#FF6B35" stroke="#333" stroke-width="3"/>

  <!-- 烟囱 -->
  <rect x="480" y="130" width="40" height="70" fill="#FF6B35" stroke="#333" stroke-width="2"/>
  <ellipse cx="500" cy="130" rx="20" ry="8" fill="#666"/>

  <!-- 烟 -->
  <circle cx="490" cy="110" r="8" fill="#ccc" opacity="0.7"/>
  <circle cx="505" cy="100" r="10" fill="#ccc" opacity="0.6"/>
  <circle cx="495" cy="85" r="12" fill="#ccc" opacity="0.5"/>

  <!-- 门 -->
  <rect x="350" y="320" width="100" height="130" fill="#50C878" rx="10" stroke="#333" stroke-width="3"/>
  <circle cx="420" cy="385" r="8" fill="#333"/>

  <!-- 窗户左 -->
  <rect x="280" y="250" width="80" height="80" fill="#4A90E2" stroke="#333" stroke-width="3"/>
  <line x1="320" y1="250" x2="320" y2="330" stroke="#333" stroke-width="2"/>
  <line x1="280" y1="290" x2="360" y2="290" stroke="#333" stroke-width="2"/>

  <!-- 窗户右 -->
  <rect x="440" y="250" width="80" height="80" fill="#4A90E2" stroke="#333" stroke-width="3"/>
  <line x1="480" y1="250" x2="480" y2="330" stroke="#333" stroke-width="2"/>
  <line x1="440" y1="290" x2="520" y2="290" stroke="#333" stroke-width="2"/>

  <!-- 文件图标在窗户里 -->
  <rect x="290" y="260" width="25" height="30" fill="white" rx="2"/>
  <line x1="295" y1="270" x2="310" y2="270" stroke="#333" stroke-width="1"/>
  <line x1="295" y1="275" x2="310" y2="275" stroke="#333" stroke-width="1"/>
  <line x1="295" y1="280" x2="310" y2="280" stroke="#333" stroke-width="1"/>

  <rect x="450" y="260" width="25" height="30" fill="white" rx="2"/>
  <line x1="455" y1="270" x2="470" y2="270" stroke="#333" stroke-width="1"/>
  <line x1="455" y1="275" x2="470" y2="275" stroke="#333" stroke-width="1"/>
  <line x1="455" y1="280" x2="470" y2="280" stroke="#333" stroke-width="1"/>

  <!-- 草地 -->
  <ellipse cx="400" cy="470" rx="250" ry="30" fill="#50C878" opacity="0.5"/>

  <!-- 花朵装饰 -->
  <circle cx="200" cy="460" r="8" fill="#FF6B35"/>
  <circle cx="195" cy="455" r="5" fill="#FFD700"/>
  <circle cx="205" cy="455" r="5" fill="#FFD700"/>
  <circle cx="200" cy="450" r="5" fill="#FFD700"/>
  <circle cx="200" cy="465" r="5" fill="#FFD700"/>
  <line x1="200" y1="460" x2="200" y2="480" stroke="#50C878" stroke-width="2"/>

  <circle cx="600" cy="460" r="8" fill="#FF6B35"/>
  <circle cx="595" cy="455" r="5" fill="#FFD700"/>
  <circle cx="605" cy="455" r="5" fill="#FFD700"/>
  <circle cx="600" cy="450" r="5" fill="#FFD700"/>
  <circle cx="600" cy="465" r="5" fill="#FFD700"/>
  <line x1="600" y1="460" x2="600" y2="480" stroke="#50C878" stroke-width="2"/>

  <!-- 标签 -->
  <rect x="300" y="480" width="200" height="50" fill="white" stroke="#4A90E2" stroke-width="2" rx="5"/>
  <text x="400" y="510" font-family="Arial, sans-serif" font-size="16" font-weight="bold" fill="#333" text-anchor="middle">我的项目仓库</text>

  <!-- 说明文字 -->
  <text x="400" y="560" font-family="Arial, sans-serif" font-size="14" fill="#666" text-anchor="middle">Repository就像一个房子，存放着项目的所有文件和代码</text>
</svg>
