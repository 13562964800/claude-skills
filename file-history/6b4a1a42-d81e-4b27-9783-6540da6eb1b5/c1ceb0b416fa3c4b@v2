def find_illustration(text):
    """根据文本内容查找合适的插图"""
    for keyword, img in illustration_map.items():
        if keyword in text:
            return img
    return None

# 处理内容：分段落，每2-3段一页
def process_content(text):
    # 移除目录部分
    text = re.sub(r'## 完整目录.*?---', '', text, flags=re.DOTALL)

    # 按段落分割
    paragraphs = text.split('\n\n')

    pages_html = ''
    current_page = ''
    para_count = 0

    for para in paragraphs:
        para = para.strip()
        if not para or para == '---':
            continue

        # 处理标题
        if para.startswith('# '):
            # 一级标题 - 新的部分封面
            if current_page:
                pages_html += f'<div class="page">\n{current_page}\n</div>\n\n'
                current_page = ''
                para_count = 0

            title = para.replace('# ', '')
            pages_html += f'''<div class="page cover">
    <h1 style="color: white;">{title}</h1>
</div>\n\n'''

        elif para.startswith('## '):
            # 二级标题 - 新章节
            if current_page:
                pages_html += f'<div class="page">\n{current_page}\n</div>\n\n'
                current_page = ''
                para_count = 0

            title = para.replace('## ', '')
            current_page += f'<h1>{title}</h1>\n'

            # 添加插图
            img = find_illustration(title)
            if img:
                current_page += f'''<div class="illustration">
    <img src="插图/{img}" alt="{title}">
    <div class="illustration-caption">{title}</div>
</div>\n'''

        elif para.startswith('### '):
            # 三级标题 - 新页面
            if current_page:
                pages_html += f'<div class="page">\n{current_page}\n</div>\n\n'
                current_page = ''
                para_count = 0

            title = para.replace('### ', '')
            current_page += f'<h2>{title}</h2>\n'

        elif para.startswith('**') and para.endswith('**'):
            # 粗体段落标题
            title = para.replace('**', '')
            current_page += f'<h3>{title}</h3>\n'

        elif para.startswith('【插图'):
            # 跳过插图标记
            continue

        else:
            # 普通段落
            para = para.replace('**', '<strong>').replace('**', '</strong>')
            current_page += f'<p>{para}</p>\n'
            para_count += 1

            # 每2段分页（增加页数）
            if para_count >= 2:
                pages_html += f'<div class="page">\n{current_page}\n</div>\n\n'
                current_page = ''
                para_count = 0

    # 最后一页
    if current_page:
        pages_html += f'<div class="page">\n{current_page}\n</div>\n\n'

    return pages_html

