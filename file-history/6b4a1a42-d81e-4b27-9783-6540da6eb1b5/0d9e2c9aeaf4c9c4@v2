<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 600">
  <!-- 背景 -->
  <rect width="800" height="600" fill="#f8f9fa"/>

  <!-- 标题 -->
  <text x="400" y="40" font-family="Arial, sans-serif" font-size="24" font-weight="bold" fill="#4A90E2" text-anchor="middle">Commit - 保存快照</text>

  <!-- 相机主体 -->
  <rect x="250" y="200" width="300" height="200" fill="#4A90E2" rx="20" stroke="#333" stroke-width="3"/>

  <!-- 镜头 -->
  <circle cx="400" cy="300" r="80" fill="#333" stroke="#666" stroke-width="3"/>
  <circle cx="400" cy="300" r="60" fill="#666"/>
  <circle cx="400" cy="300" r="40" fill="#333"/>
  <circle cx="380" cy="280" r="10" fill="white" opacity="0.5"/>

  <!-- 闪光灯 -->
  <rect x="320" y="220" width="60" height="30" fill="#FFD700" rx="5" stroke="#333" stroke-width="2"/>
  <circle cx="350" cy="235" r="8" fill="white"/>

  <!-- 快门按钮 -->
  <circle cx="480" cy="240" r="20" fill="#FF6B35" stroke="#333" stroke-width="2"/>
  <circle cx="480" cy="240" r="12" fill="#FFD700"/>

  <!-- 取景器 -->
  <rect x="420" y="220" width="40" height="25" fill="#333" rx="3"/>

  <!-- 相机带 -->
  <path d="M 250 250 Q 200 280 220 320" stroke="#FF6B35" stroke-width="8" fill="none" stroke-linecap="round"/>
  <path d="M 550 250 Q 600 280 580 320" stroke="#FF6B35" stroke-width="8" fill="none" stroke-linecap="round"/>

  <!-- 时间线 -->
  <line x1="100" y1="450" x2="700" y2="450" stroke="#4A90E2" stroke-width="3"/>

  <!-- 快照1 -->
  <rect x="120" y="470" width="80" height="60" fill="#FFD700" stroke="#333" stroke-width="2" rx="3"/>
  <text x="160" y="505" font-family="Arial, sans-serif" font-size="12" font-weight="bold" fill="#333" text-anchor="middle">快照1</text>
  <circle cx="160" cy="450" r="8" fill="#50C878" stroke="#333" stroke-width="2"/>
  <line x1="160" y1="450" x2="160" y2="470" stroke="#333" stroke-width="2"/>

  <!-- 快照2 -->
  <rect x="260" y="470" width="80" height="60" fill="#FFD700" stroke="#333" stroke-width="2" rx="3"/>
  <text x="300" y="505" font-family="Arial, sans-serif" font-size="12" font-weight="bold" fill="#333" text-anchor="middle">快照2</text>
  <circle cx="300" cy="450" r="8" fill="#50C878" stroke="#333" stroke-width="2"/>
  <line x1="300" y1="450" x2="300" y2="470" stroke="#333" stroke-width="2"/>

  <!-- 快照3 -->
  <rect x="400" y="470" width="80" height="60" fill="#FFD700" stroke="#333" stroke-width="2" rx="3"/>
  <text x="440" y="505" font-family="Arial, sans-serif" font-size="12" font-weight="bold" fill="#333" text-anchor="middle">快照3</text>
  <circle cx="440" cy="450" r="8" fill="#50C878" stroke="#333" stroke-width="2"/>
  <line x1="440" y1="450" x2="440" y2="470" stroke="#333" stroke-width="2"/>

  <!-- 快照4（当前） -->
  <rect x="540" y="470" width="80" height="60" fill="#FF6B35" stroke="#333" stroke-width="2" rx="3"/>
  <text x="580" y="505" font-family="Arial, sans-serif" font-size="12" font-weight="bold" fill="white" text-anchor="middle">当前</text>
  <circle cx="580" cy="450" r="8" fill="#FF6B35" stroke="#333" stroke-width="2"/>
  <line x1="580" y1="450" x2="580" y2="470" stroke="#333" stroke-width="2"/>

  <!-- 箭头指示 -->
  <path d="M 400 180 L 400 200" stroke="#FF6B35" stroke-width="3" fill="none"/>
  <path d="M 400 180 L 390 190 M 400 180 L 410 190" stroke="#FF6B35" stroke-width="3" fill="none"/>

  <!-- 说明文字 -->
  <text x="400" y="160" font-family="Arial, sans-serif" font-size="14" fill="#666" text-anchor="middle">每次Commit就像拍照</text>
  <text x="400" y="570" font-family="Arial, sans-serif" font-size="14" fill="#666" text-anchor="middle">记录项目在不同时刻的状态，可以随时回到过去的版本</text>
</svg>
