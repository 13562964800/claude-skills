<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 600">
  <!-- 背景 -->
  <rect width="800" height="600" fill="#f8f9fa"/>

  <!-- 标题 -->
  <text x="400" y="40" font-family="Arial, sans-serif" font-size="24" font-weight="bold" fill="#4A90E2" text-anchor="middle">传统编程 vs Vibecoding</text>

  <!-- 分隔线 -->
  <line x1="400" y1="80" x2="400" y2="560" stroke="#ccc" stroke-width="3" stroke-dasharray="10,5"/>

  <!-- 左侧：传统编程 -->
  <text x="200" y="100" font-family="Arial, sans-serif" font-size="20" font-weight="bold" fill="#666" text-anchor="middle">传统编程</text>

  <!-- 程序员在电脑前 -->
  <g transform="translate(100, 130)">
    <!-- 电脑 -->
    <rect x="50" y="50" width="100" height="70" fill="#333" stroke="#666" stroke-width="2" rx="5"/>
    <rect x="55" y="55" width="90" height="50" fill="#4A90E2"/>
    <rect x="85" y="120" width="40" height="5" fill="#666"/>
    <rect x="70" y="125" width="70" height="3" fill="#666"/>

    <!-- 代码符号 -->
    <text x="100" y="75" font-family="monospace" font-size="8" fill="white">&lt;code&gt;</text>
    <text x="100" y="85" font-family="monospace" font-size="8" fill="white">function</text>
    <text x="100" y="95" font-family="monospace" font-size="8" fill="white">{...}</text>

    <!-- 程序员 -->
    <circle cx="100" cy="20" r="15" fill="#FFD700" stroke="#333" stroke-width="2"/>
    <circle cx="95" cy="17" r="2" fill="#333"/>
    <circle cx="105" cy="17" r="2" fill="#333"/>
    <path d="M 95 25 Q 100 28 105 25" stroke="#333" stroke-width="1.5" fill="none"/>
  </g>

  <!-- 传统编程特点 -->
  <g transform="translate(50, 260)">
    <rect x="0" y="0" width="300" height="250" fill="white" stroke="#666" stroke-width="2" rx="10"/>

    <text x="150" y="30" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="#333" text-anchor="middle">特点</text>

    <!-- 特点1 -->
    <circle cx="30" cy="60" r="8" fill="#FF6B35"/>
    <text x="50" y="65" font-family="Arial, sans-serif" font-size="12" fill="#333" text-anchor="start">需要学习编程语言</text>

    <!-- 特点2 -->
    <circle cx="30" cy="95" r="8" fill="#FF6B35"/>
    <text x="50" y="100" font-family="Arial, sans-serif" font-size="12" fill="#333" text-anchor="start">一行一行写代码</text>

    <!-- 特点3 -->
    <circle cx="30" cy="130" r="8" fill="#FF6B35"/>
    <text x="50" y="135" font-family="Arial, sans-serif" font-size="12" fill="#333" text-anchor="start">需要记住语法规则</text>

    <!-- 特点4 -->
    <circle cx="30" cy="165" r="8" fill="#FF6B35"/>
    <text x="50" y="170" font-family="Arial, sans-serif" font-size="12" fill="#333" text-anchor="start">调试错误很费时</text>

    <!-- 特点5 -->
    <circle cx="30" cy="200" r="8" fill="#50C878"/>
    <text x="50" y="205" font-family="Arial, sans-serif" font-size="12" fill="#333" text-anchor="start">完全掌控代码</text>

    <!-- 特点6 -->
    <circle cx="30" cy="235" r="8" fill="#50C878"/>
    <text x="50" y="240" font-family="Arial, sans-serif" font-size="12" fill="#333" text-anchor="start">性能可优化</text>
  </g>

  <!-- 右侧：Vibecoding -->
  <text x="600" y="100" font-family="Arial, sans-serif" font-size="20" font-weight="bold" fill="#4A90E2" text-anchor="middle">Vibecoding</text>

  <!-- 人和AI助手 -->
  <g transform="translate(500, 130)">
    <!-- 人 -->
    <circle cx="80" cy="20" r="15" fill="#FFD700" stroke="#333" stroke-width="2"/>
    <circle cx="75" cy="17" r="2" fill="#333"/>
    <circle cx="85" cy="17" r="2" fill="#333"/>
    <path d="M 75 25 Q 80 28 85 25" stroke="#333" stroke-width="1.5" fill="none"/>

    <!-- 对话框 -->
    <rect x="30" y="50" width="100" height="40" fill="white" stroke="#4A90E2" stroke-width="2" rx="5"/>
    <text x="80" y="70" font-family="Arial, sans-serif" font-size="10" fill="#333" text-anchor="middle">做一个</text>
    <text x="80" y="82" font-family="Arial, sans-serif" font-size="10" fill="#333" text-anchor="middle">计算器</text>

    <!-- AI机器人 -->
    <rect x="140" y="50" width="40" height="50" fill="#4A90E2" stroke="#333" stroke-width="2" rx="5"/>
    <circle cx="150" cy="65" r="4" fill="#FFD700"/>
    <circle cx="170" cy="65" r="4" fill="#FFD700"/>
    <rect x="148" y="75" width="24" height="3" fill="#FFD700" rx="1"/>
    <text x="160" y="115" font-family="Arial, sans-serif" font-size="10" fill="#333" text-anchor="middle">AI助手</text>

    <!-- 魔法星星 -->
    <path d="M 120 60 L 122 65 L 127 65 L 123 68 L 125 73 L 120 70 L 115 73 L 117 68 L 113 65 L 118 65 Z" fill="#FFD700"/>
    <path d="M 130 80 L 132 85 L 137 85 L 133 88 L 135 93 L 130 90 L 125 93 L 127 88 L 123 85 L 128 85 Z" fill="#FFD700"/>
  </g>

  <!-- Vibecoding特点 -->
  <g transform="translate(450, 260)">
    <rect x="0" y="0" width="300" height="250" fill="white" stroke="#4A90E2" stroke-width="2" rx="10"/>

    <text x="150" y="30" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="#333" text-anchor="middle">特点</text>

    <!-- 特点1 -->
    <circle cx="30" cy="60" r="8" fill="#50C878"/>
    <text x="50" y="65" font-family="Arial, sans-serif" font-size="12" fill="#333" text-anchor="start">用自然语言描述</text>

    <!-- 特点2 -->
    <circle cx="30" cy="95" r="8" fill="#50C878"/>
    <text x="50" y="100" font-family="Arial, sans-serif" font-size="12" fill="#333" text-anchor="start">AI帮你写代码</text>

    <!-- 特点3 -->
    <circle cx="30" cy="130" r="8" fill="#50C878"/>
    <text x="50" y="135" font-family="Arial, sans-serif" font-size="12" fill="#333" text-anchor="start">快速实现想法</text>

    <!-- 特点4 -->
    <circle cx="30" cy="165" r="8" fill="#50C878"/>
    <text x="50" y="170" font-family="Arial, sans-serif" font-size="12" fill="#333" text-anchor="start">降低学习门槛</text>

    <!-- 特点5 -->
    <circle cx="30" cy="200" r="8" fill="#FF6B35"/>
    <text x="50" y="205" font-family="Arial, sans-serif" font-size="12" fill="#333" text-anchor="start">需要理解AI生成</text>

    <!-- 特点6 -->
    <circle cx="30" cy="235" r="8" fill="#FFD700"/>
    <text x="50" y="240" font-family="Arial, sans-serif" font-size="12" fill="#333" text-anchor="start">人机协作编程</text>
  </g>

  <!-- 底部总结 -->
  <rect x="50" y="530" width="700" height="50" fill="#e8f4f8" rx="10" stroke="#4A90E2" stroke-width="2"/>
  <text x="400" y="555" font-family="Arial, sans-serif" font-size="13" font-weight="bold" fill="#333" text-anchor="middle">💡 两种方式各有优势，未来的程序员需要两者结合！</text>
</svg>
