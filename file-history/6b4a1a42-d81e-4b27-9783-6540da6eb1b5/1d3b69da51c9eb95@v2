<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 1000">
  <!-- 背景渐变 -->
  <defs>
    <linearGradient id="bgGradient" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#4A90E2;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#2C5F8D;stop-opacity:1" />
    </linearGradient>
    <radialGradient id="glowGradient" cx="50%" cy="50%" r="50%">
      <stop offset="0%" style="stop-color:#FFD700;stop-opacity:0.8" />
      <stop offset="100%" style="stop-color:#FFD700;stop-opacity:0" />
    </radialGradient>
  </defs>

  <rect width="800" height="1000" fill="url(#bgGradient)"/>

  <!-- 装饰星星 -->
  <circle cx="100" cy="100" r="3" fill="white" opacity="0.8"/>
  <circle cx="700" cy="150" r="2" fill="white" opacity="0.6"/>
  <circle cx="150" cy="200" r="2.5" fill="white" opacity="0.7"/>
  <circle cx="650" cy="250" r="3" fill="white" opacity="0.8"/>
  <circle cx="200" cy="800" r="2" fill="white" opacity="0.6"/>
  <circle cx="600" cy="850" r="2.5" fill="white" opacity="0.7"/>
  <circle cx="100" cy="900" r="3" fill="white" opacity="0.8"/>
  <circle cx="700" cy="950" r="2" fill="white" opacity="0.6"/>

  <!-- 大星星 -->
  <path d="M 150 150 L 155 165 L 170 165 L 158 175 L 163 190 L 150 180 L 137 190 L 142 175 L 130 165 L 145 165 Z" fill="#FFD700" opacity="0.6"/>
  <path d="M 650 120 L 655 135 L 670 135 L 658 145 L 663 160 L 650 150 L 637 160 L 642 145 L 630 135 L 645 135 Z" fill="#FFD700" opacity="0.6"/>

  <!-- 主标题 -->
  <text x="400" y="180" font-family="Arial, sans-serif" font-size="48" font-weight="bold" fill="white" text-anchor="middle">AI前沿知识</text>
  <text x="400" y="240" font-family="Arial, sans-serif" font-size="48" font-weight="bold" fill="white" text-anchor="middle">儿童科普画册</text>

  <!-- 副标题 -->
  <text x="400" y="290" font-family="Arial, sans-serif" font-size="20" fill="#FFD700" text-anchor="middle">从LLM到GitHub，从Vibecoding到未来</text>

  <!-- 中央AI机器人 -->
  <g transform="translate(400, 500)">
    <!-- 光晕 -->
    <circle cx="0" cy="0" r="120" fill="url(#glowGradient)" opacity="0.3"/>

    <!-- 身体 -->
    <rect x="-60" y="0" width="120" height="150" fill="white" stroke="#333" stroke-width="3" rx="15"/>

    <!-- 头部 -->
    <rect x="-50" y="-80" width="100" height="90" fill="white" stroke="#333" stroke-width="3" rx="12"/>

    <!-- 眼睛 -->
    <circle cx="-20" cy="-40" r="12" fill="#4A90E2"/>
    <circle cx="-20" cy="-40" r="6" fill="white"/>
    <circle cx="20" cy="-40" r="12" fill="#4A90E2"/>
    <circle cx="20" cy="-40" r="6" fill="white"/>

    <!-- 嘴巴 -->
    <path d="M -25 -10 Q 0 5 25 -10" stroke="#FF6B35" stroke-width="4" fill="none" stroke-linecap="round"/>

    <!-- 天线 -->
    <line x1="0" y1="-80" x2="0" y2="-110" stroke="#333" stroke-width="3"/>
    <circle cx="0" cy="-110" r="8" fill="#FF6B35"/>
    <circle cx="0" cy="-110" r="4" fill="#FFD700"/>

    <!-- 胸部显示屏 -->
    <rect x="-35" y="30" width="70" height="50" fill="#4A90E2" rx="5"/>
    <text x="0" y="60" font-family="Arial, sans-serif" font-size="24" font-weight="bold" fill="white" text-anchor="middle">AI</text>

    <!-- 手臂 -->
    <rect x="-90" y="40" width="30" height="15" fill="white" stroke="#333" stroke-width="2" rx="7"/>
    <circle cx="-90" cy="47" r="12" fill="white" stroke="#333" stroke-width="2"/>

    <rect x="60" y="40" width="30" height="15" fill="white" stroke="#333" stroke-width="2" rx="7"/>
    <circle cx="90" cy="47" r="12" fill="white" stroke="#333" stroke-width="2"/>

    <!-- 腿 -->
    <rect x="-35" y="150" width="25" height="50" fill="white" stroke="#333" stroke-width="2" rx="12"/>
    <rect x="10" y="150" width="25" height="50" fill="white" stroke="#333" stroke-width="2" rx="12"/>

    <!-- 脚 -->
    <ellipse cx="-22" cy="200" rx="18" ry="10" fill="#333"/>
    <ellipse cx="22" cy="200" rx="18" ry="10" fill="#333"/>
  </g>

  <!-- 周围图标 -->
  <!-- 左上：书本 -->
  <g transform="translate(150, 400)">
    <rect x="-20" y="-15" width="40" height="30" fill="#FFD700" stroke="#333" stroke-width="2" rx="3"/>
    <line x1="-20" y1="0" x2="20" y2="0" stroke="#333" stroke-width="2"/>
  </g>

  <!-- 右上：齿轮 -->
  <g transform="translate(650, 400)">
    <circle cx="0" cy="0" r="20" fill="#50C878" stroke="#333" stroke-width="2"/>
    <circle cx="0" cy="0" r="10" fill="white"/>
    <rect x="-4" y="-24" width="8" height="8" fill="#50C878"/>
    <rect x="-4" y="16" width="8" height="8" fill="#50C878"/>
    <rect x="-24" y="-4" width="8" height="8" fill="#50C878"/>
    <rect x="16" y="-4" width="8" height="8" fill="#50C878"/>
  </g>

  <!-- 左下：代码符号 -->
  <g transform="translate(150, 600)">
    <text x="0" y="0" font-family="monospace" font-size="36" fill="#FFD700" text-anchor="middle">&lt;/&gt;</text>
  </g>

  <!-- 右下：火箭 -->
  <g transform="translate(650, 600)">
    <path d="M 0 -30 L -12 10 L 12 10 Z" fill="#FF6B35" stroke="#333" stroke-width="2"/>
    <circle cx="0" cy="-10" r="5" fill="white"/>
    <path d="M -12 10 L -18 25 L -12 15 Z" fill="#FFD700"/>
    <path d="M 12 10 L 18 25 L 12 15 Z" fill="#FFD700"/>
  </g>

  <!-- 底部信息 -->
  <rect x="100" y="780" width="600" height="180" fill="white" opacity="0.9" rx="15"/>

  <text x="400" y="820" font-family="Arial, sans-serif" font-size="18" font-weight="bold" fill="#333" text-anchor="middle">作者：单夫纯</text>

  <text x="400" y="860" font-family="Arial, sans-serif" font-size="14" fill="#666" text-anchor="middle">适合8-14岁儿童阅读</text>
  <text x="400" y="885" font-family="Arial, sans-serif" font-size="14" fill="#666" text-anchor="middle">500页 | 23章 | 33幅插图</text>

  <text x="400" y="920" font-family="Arial, sans-serif" font-size="13" fill="#4A90E2" text-anchor="middle">B5纸张 | 新颖版式 | 图文并茂</text>

  <text x="400" y="950" font-family="Arial, sans-serif" font-size="12" fill="#999" text-anchor="middle">© 2026 单夫纯</text>
</svg>
