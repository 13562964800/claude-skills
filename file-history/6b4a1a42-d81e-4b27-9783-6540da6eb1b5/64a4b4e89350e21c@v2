<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 400">
  <!-- 背景 -->
  <rect width="800" height="400" fill="#f8f9fa"/>

  <!-- 标题 -->
  <text x="400" y="40" font-family="Arial, sans-serif" font-size="24" font-weight="bold" fill="#4A90E2" text-anchor="middle">AI发展历史时间线</text>

  <!-- 时间线主线 -->
  <line x1="50" y1="200" x2="750" y2="200" stroke="#4A90E2" stroke-width="4"/>

  <!-- 1950年代 - 图灵测试 -->
  <circle cx="100" cy="200" r="12" fill="#FF6B35"/>
  <line x1="100" y1="200" x2="100" y2="120" stroke="#FF6B35" stroke-width="2" stroke-dasharray="5,5"/>
  <rect x="50" y="80" width="100" height="60" fill="#FFD700" rx="5"/>
  <text x="100" y="100" font-family="Arial, sans-serif" font-size="12" font-weight="bold" fill="#333" text-anchor="middle">1950年</text>
  <text x="100" y="120" font-family="Arial, sans-serif" font-size="11" fill="#333" text-anchor="middle">图灵测试</text>

  <!-- 1956年 - AI诞生 -->
  <circle cx="200" cy="200" r="12" fill="#FF6B35"/>
  <line x1="200" y1="200" x2="200" y2="280" stroke="#FF6B35" stroke-width="2" stroke-dasharray="5,5"/>
  <rect x="150" y="290" width="100" height="60" fill="#50C878" rx="5"/>
  <text x="200" y="310" font-family="Arial, sans-serif" font-size="12" font-weight="bold" fill="#333" text-anchor="middle">1956年</text>
  <text x="200" y="330" font-family="Arial, sans-serif" font-size="11" fill="#333" text-anchor="middle">AI诞生</text>

  <!-- 1997年 - 深蓝 -->
  <circle cx="350" cy="200" r="12" fill="#FF6B35"/>
  <line x1="350" y1="200" x2="350" y2="120" stroke="#FF6B35" stroke-width="2" stroke-dasharray="5,5"/>
  <rect x="300" y="80" width="100" height="60" fill="#FFD700" rx="5"/>
  <text x="350" y="100" font-family="Arial, sans-serif" font-size="12" font-weight="bold" fill="#333" text-anchor="middle">1997年</text>
  <text x="350" y="120" font-family="Arial, sans-serif" font-size="11" fill="#333" text-anchor="middle">深蓝战胜</text>
  <text x="350" y="135" font-family="Arial, sans-serif" font-size="11" fill="#333" text-anchor="middle">国际象棋</text>

  <!-- 2012年 - 深度学习 -->
  <circle cx="500" cy="200" r="12" fill="#FF6B35"/>
  <line x1="500" y1="200" x2="500" y2="280" stroke="#FF6B35" stroke-width="2" stroke-dasharray="5,5"/>
  <rect x="450" y="290" width="100" height="60" fill="#50C878" rx="5"/>
  <text x="500" y="310" font-family="Arial, sans-serif" font-size="12" font-weight="bold" fill="#333" text-anchor="middle">2012年</text>
  <text x="500" y="330" font-family="Arial, sans-serif" font-size="11" fill="#333" text-anchor="middle">深度学习</text>
  <text x="500" y="345" font-family="Arial, sans-serif" font-size="11" fill="#333" text-anchor="middle">突破</text>

  <!-- 2022年 - ChatGPT -->
  <circle cx="650" cy="200" r="12" fill="#FF6B35"/>
  <line x1="650" y1="200" x2="650" y2="120" stroke="#FF6B35" stroke-width="2" stroke-dasharray="5,5"/>
  <rect x="600" y="80" width="100" height="60" fill="#FFD700" rx="5"/>
  <text x="650" y="100" font-family="Arial, sans-serif" font-size="12" font-weight="bold" fill="#333" text-anchor="middle">2022年</text>
  <text x="650" y="120" font-family="Arial, sans-serif" font-size="11" fill="#333" text-anchor="middle">ChatGPT</text>
  <text x="650" y="135" font-family="Arial, sans-serif" font-size="11" fill="#333" text-anchor="middle">发布</text>

  <!-- 装饰性星星 -->
  <path d="M 100 60 L 105 70 L 115 70 L 107 77 L 110 87 L 100 80 L 90 87 L 93 77 L 85 70 L 95 70 Z" fill="#FFD700"/>
  <path d="M 350 60 L 355 70 L 365 70 L 357 77 L 360 87 L 350 80 L 340 87 L 343 77 L 335 70 L 345 70 Z" fill="#FFD700"/>
  <path d="M 650 60 L 655 70 L 665 70 L 657 77 L 660 87 L 650 80 L 640 87 L 643 77 L 635 70 L 645 70 Z" fill="#FFD700"/>
</svg>
