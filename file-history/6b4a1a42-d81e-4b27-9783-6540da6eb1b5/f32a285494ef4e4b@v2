<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 600">
  <!-- 背景 -->
  <rect width="800" height="600" fill="#f8f9fa"/>

  <!-- 标题 -->
  <text x="400" y="40" font-family="Arial, sans-serif" font-size="24" font-weight="bold" fill="#4A90E2" text-anchor="middle">Branch - 平行世界</text>

  <!-- 主树干 -->
  <rect x="380" y="450" width="40" height="100" fill="#8B4513" stroke="#333" stroke-width="2"/>

  <!-- 主分支（main） -->
  <path d="M 400 450 L 400 200" stroke="#4A90E2" stroke-width="8" fill="none" stroke-linecap="round"/>
  <circle cx="400" cy="200" r="15" fill="#4A90E2" stroke="#333" stroke-width="2"/>
  <text x="450" y="210" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="#4A90E2" text-anchor="start">main分支</text>

  <!-- 分支1 - 新功能 -->
  <path d="M 400 350 Q 450 320 500 280" stroke="#50C878" stroke-width="6" fill="none" stroke-linecap="round"/>
  <circle cx="500" cy="280" r="12" fill="#50C878" stroke="#333" stroke-width="2"/>
  <text x="520" y="285" font-family="Arial, sans-serif" font-size="13" fill="#50C878" text-anchor="start">feature分支</text>
  <text x="520" y="302" font-family="Arial, sans-serif" font-size="11" fill="#666" text-anchor="start">（新功能开发）</text>

  <!-- 分支2 - 修复bug -->
  <path d="M 400 300 Q 350 270 300 240" stroke="#FF6B35" stroke-width="6" fill="none" stroke-linecap="round"/>
  <circle cx="300" cy="240" r="12" fill="#FF6B35" stroke="#333" stroke-width="2"/>
  <text x="200" y="245" font-family="Arial, sans-serif" font-size="13" fill="#FF6B35" text-anchor="end">bugfix分支</text>
  <text x="200" y="262" font-family="Arial, sans-serif" font-size="11" fill="#666" text-anchor="end">（修复问题）</text>

  <!-- 分支3 - 实验 -->
  <path d="M 400 250 Q 500 230 600 210" stroke="#FFD700" stroke-width="6" fill="none" stroke-linecap="round"/>
  <circle cx="600" cy="210" r="12" fill="#FFD700" stroke="#333" stroke-width="2"/>
  <text x="620" y="215" font-family="Arial, sans-serif" font-size="13" fill="#8B8B00" text-anchor="start">experiment分支</text>
  <text x="620" y="232" font-family="Arial, sans-serif" font-size="11" fill="#666" text-anchor="start">（实验新想法）</text>

  <!-- 合并箭头 - bugfix合并回main -->
  <path d="M 300 240 Q 350 220 400 200" stroke="#FF6B35" stroke-width="3" fill="none" stroke-dasharray="5,5"/>
  <path d="M 400 200 L 390 205 M 400 200 L 395 210" stroke="#FF6B35" stroke-width="3" fill="none"/>

  <!-- 树叶装饰 -->
  <ellipse cx="400" cy="180" rx="40" ry="30" fill="#50C878" opacity="0.6"/>
  <ellipse cx="500" cy="260" rx="35" ry="25" fill="#50C878" opacity="0.6"/>
  <ellipse cx="300" cy="220" rx="35" ry="25" fill="#50C878" opacity="0.6"/>
  <ellipse cx="600" cy="190" rx="35" ry="25" fill="#50C878" opacity="0.6"/>

  <!-- 说明框 -->
  <rect x="50" y="480" width="700" height="100" fill="white" stroke="#4A90E2" stroke-width="2" rx="10"/>

  <!-- 说明内容 -->
  <text x="400" y="510" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="#333" text-anchor="middle">💡 Branch就像树的分支</text>
  <text x="400" y="535" font-family="Arial, sans-serif" font-size="12" fill="#666" text-anchor="middle">从主干（main分支）长出不同的分支，每个分支可以独立开发</text>
  <text x="400" y="555" font-family="Arial, sans-serif" font-size="12" fill="#666" text-anchor="middle">开发完成后，可以合并回主干，就像平行世界最终汇合</text>

  <!-- 图例 -->
  <g transform="translate(100, 100)">
    <rect x="0" y="0" width="180" height="100" fill="#e8f4f8" rx="8" stroke="#4A90E2" stroke-width="2"/>
    <text x="90" y="25" font-family="Arial, sans-serif" font-size="13" font-weight="bold" fill="#333" text-anchor="middle">分支类型</text>

    <circle cx="20" cy="45" r="6" fill="#4A90E2"/>
    <text x="35" y="50" font-family="Arial, sans-serif" font-size="11" fill="#333" text-anchor="start">main - 主分支</text>

    <circle cx="20" cy="65" r="6" fill="#50C878"/>
    <text x="35" y="70" font-family="Arial, sans-serif" font-size="11" fill="#333" text-anchor="start">feature - 新功能</text>

    <circle cx="20" cy="85" r="6" fill="#FF6B35"/>
    <text x="35" y="90" font-family="Arial, sans-serif" font-size="11" fill="#333" text-anchor="start">bugfix - 修复问题</text>
  </g>
</svg>
