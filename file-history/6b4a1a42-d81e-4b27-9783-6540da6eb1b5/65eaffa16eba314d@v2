<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 600">
  <!-- 背景 -->
  <rect width="800" height="600" fill="#f8f9fa"/>

  <!-- 标题 -->
  <text x="400" y="40" font-family="Arial, sans-serif" font-size="24" font-weight="bold" fill="#4A90E2" text-anchor="middle">AI学习路径</text>

  <!-- 时间轴 -->
  <line x1="100" y1="300" x2="700" y2="300" stroke="#4A90E2" stroke-width="4"/>

  <!-- 小学阶段 -->
  <g>
    <circle cx="150" cy="300" r="20" fill="#FFD700" stroke="#333" stroke-width="3"/>
    <text x="150" y="308" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="#333" text-anchor="middle">1</text>

    <rect x="80" y="150" width="140" height="120" fill="#FFD700" rx="10" stroke="#333" stroke-width="2"/>
    <text x="150" y="180" font-family="Arial, sans-serif" font-size="16" font-weight="bold" fill="#333" text-anchor="middle">小学阶段</text>
    <text x="150" y="205" font-family="Arial, sans-serif" font-size="11" fill="#333" text-anchor="middle">8-12岁</text>

    <text x="150" y="225" font-family="Arial, sans-serif" font-size="10" fill="#666" text-anchor="middle">• 了解AI概念</text>
    <text x="150" y="240" font-family="Arial, sans-serif" font-size="10" fill="#666" text-anchor="middle">• 体验AI工具</text>
    <text x="150" y="255" font-family="Arial, sans-serif" font-size="10" fill="#666" text-anchor="middle">• 学习Scratch</text>

    <line x1="150" y1="270" x2="150" y2="280" stroke="#333" stroke-width="2"/>
  </g>

  <!-- 初中阶段 -->
  <g>
    <circle cx="325" cy="300" r="20" fill="#50C878" stroke="#333" stroke-width="3"/>
    <text x="325" y="308" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="#333" text-anchor="middle">2</text>

    <rect x="255" y="350" width="140" height="120" fill="#50C878" rx="10" stroke="#333" stroke-width="2"/>
    <text x="325" y="380" font-family="Arial, sans-serif" font-size="16" font-weight="bold" fill="#333" text-anchor="middle">初中阶段</text>
    <text x="325" y="405" font-family="Arial, sans-serif" font-size="11" fill="#333" text-anchor="middle">12-15岁</text>

    <text x="325" y="425" font-family="Arial, sans-serif" font-size="10" fill="#666" text-anchor="middle">• 学习Python</text>
    <text x="325" y="440" font-family="Arial, sans-serif" font-size="10" fill="#666" text-anchor="middle">• 使用GitHub</text>
    <text x="325" y="455" font-family="Arial, sans-serif" font-size="10" fill="#666" text-anchor="middle">• 简单AI项目</text>

    <line x1="325" y1="300" x2="325" y2="350" stroke="#333" stroke-width="2"/>
  </g>

  <!-- 高中阶段 -->
  <g>
    <circle cx="500" cy="300" r="20" fill="#FF6B35" stroke="#333" stroke-width="3"/>
    <text x="500" y="308" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="#333" text-anchor="middle">3</text>

    <rect x="430" y="150" width="140" height="120" fill="#FF6B35" rx="10" stroke="#333" stroke-width="2"/>
    <text x="500" y="180" font-family="Arial, sans-serif" font-size="16" font-weight="bold" fill="#333" text-anchor="middle">高中阶段</text>
    <text x="500" y="205" font-family="Arial, sans-serif" font-size="11" fill="#333" text-anchor="middle">15-18岁</text>

    <text x="500" y="225" font-family="Arial, sans-serif" font-size="10" fill="#666" text-anchor="middle">• 机器学习基础</text>
    <text x="500" y="240" font-family="Arial, sans-serif" font-size="10" fill="#666" text-anchor="middle">• Vibecoding</text>
    <text x="500" y="255" font-family="Arial, sans-serif" font-size="10" fill="#666" text-anchor="middle">• 参与开源</text>

    <line x1="500" y1="270" x2="500" y2="280" stroke="#333" stroke-width="2"/>
  </g>

  <!-- 未来职业 -->
  <g>
    <circle cx="650" cy="300" r="20" fill="#4A90E2" stroke="#333" stroke-width="3"/>
    <text x="650" y="308" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="white" text-anchor="middle">★</text>

    <rect x="580" y="350" width="140" height="120" fill="#4A90E2" rx="10" stroke="#333" stroke-width="2"/>
    <text x="650" y="380" font-family="Arial, sans-serif" font-size="16" font-weight="bold" fill="white" text-anchor="middle">未来职业</text>
    <text x="650" y="405" font-family="Arial, sans-serif" font-size="11" fill="white" text-anchor="middle">18岁+</text>

    <text x="650" y="425" font-family="Arial, sans-serif" font-size="10" fill="white" text-anchor="middle">• AI工程师</text>
    <text x="650" y="440" font-family="Arial, sans-serif" font-size="10" fill="white" text-anchor="middle">• 数据科学家</text>
    <text x="650" y="455" font-family="Arial, sans-serif" font-size="10" fill="white" text-anchor="middle">• 创新者</text>

    <line x1="650" y1="300" x2="650" y2="350" stroke="#333" stroke-width="2"/>
  </g>

  <!-- 装饰星星 -->
  <path d="M 150 130 L 155 140 L 165 140 L 157 147 L 160 157 L 150 150 L 140 157 L 143 147 L 135 140 L 145 140 Z" fill="#FFD700"/>
  <path d="M 500 130 L 505 140 L 515 140 L 507 147 L 510 157 L 500 150 L 490 157 L 493 147 L 485 140 L 495 140 Z" fill="#FF6B35"/>
  <path d="M 650 330 L 655 340 L 665 340 L 657 347 L 660 357 L 650 350 L 640 357 L 643 347 L 635 340 L 645 340 Z" fill="#4A90E2"/>

  <!-- 底部说明 -->
  <rect x="50" y="510" width="700" height="70" fill="white" stroke="#4A90E2" stroke-width="2" rx="10"/>
  <text x="400" y="540" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="#333" text-anchor="middle">💡 学习AI是一个循序渐进的过程</text>
  <text x="400" y="560" font-family="Arial, sans-serif" font-size="12" fill="#666" text-anchor="middle">从小培养兴趣，逐步深入学习，最终成为AI时代的创造者！</text>
</svg>
