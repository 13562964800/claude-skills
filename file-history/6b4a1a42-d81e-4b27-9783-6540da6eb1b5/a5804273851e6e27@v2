<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 600">
  <!-- 背景 -->
  <rect width="800" height="600" fill="#f8f9fa"/>

  <!-- 标题 -->
  <text x="400" y="40" font-family="Arial, sans-serif" font-size="24" font-weight="bold" fill="#4A90E2" text-anchor="middle">AI的神奇应用</text>

  <!-- 聊天机器人 -->
  <g>
    <rect x="50" y="80" width="180" height="120" fill="#FFD700" rx="10" stroke="#333" stroke-width="2"/>
    <circle cx="140" cy="120" r="20" fill="#4A90E2"/>
    <circle cx="130" cy="115" r="4" fill="white"/>
    <circle cx="150" cy="115" r="4" fill="white"/>
    <path d="M 125 130 Q 140 140 155 130" stroke="white" stroke-width="3" fill="none" stroke-linecap="round"/>
    <text x="140" y="170" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="#333" text-anchor="middle">💬 聊天机器人</text>
    <text x="140" y="190" font-family="Arial, sans-serif" font-size="11" fill="#666" text-anchor="middle">像朋友一样聊天</text>
  </g>

  <!-- 图像识别 -->
  <g>
    <rect x="310" y="80" width="180" height="120" fill="#50C878" rx="10" stroke="#333" stroke-width="2"/>
    <rect x="360" y="110" width="80" height="60" fill="#4A90E2" rx="5"/>
    <circle cx="380" cy="130" r="8" fill="#FFD700"/>
    <path d="M 360 150 L 380 135 L 400 145 L 420 130 L 440 150 Z" fill="#FF6B35"/>
    <text x="400" y="170" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="#333" text-anchor="middle">📷 图像识别</text>
    <text x="400" y="190" font-family="Arial, sans-serif" font-size="11" fill="#666" text-anchor="middle">认出照片里的东西</text>
  </g>

  <!-- 语音助手 -->
  <g>
    <rect x="570" y="80" width="180" height="120" fill="#FF6B35" rx="10" stroke="#333" stroke-width="2"/>
    <circle cx="660" cy="120" r="25" fill="#4A90E2"/>
    <path d="M 650 110 Q 660 120 670 110" stroke="white" stroke-width="3" fill="none" stroke-linecap="round"/>
    <path d="M 650 130 Q 660 120 670 130" stroke="white" stroke-width="3" fill="none" stroke-linecap="round"/>
    <text x="660" y="170" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="#333" text-anchor="middle">🎤 语音助手</text>
    <text x="660" y="190" font-family="Arial, sans-serif" font-size="11" fill="#666" text-anchor="middle">听懂你说的话</text>
  </g>

  <!-- 自动驾驶 -->
  <g>
    <rect x="50" y="240" width="180" height="120" fill="#4A90E2" rx="10" stroke="#333" stroke-width="2"/>
    <rect x="100" y="270" width="80" height="50" fill="#FFD700" rx="5"/>
    <circle cx="110" cy="330" r="8" fill="#333"/>
    <circle cx="170" cy="330" r="8" fill="#333"/>
    <rect x="120" y="280" width="40" height="30" fill="#50C878" rx="3"/>
    <text x="140" y="350" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="white" text-anchor="middle">🚗 自动驾驶</text>
    <text x="140" y="370" font-family="Arial, sans-serif" font-size="11" fill="white" text-anchor="middle">汽车自己开</text>
  </g>

  <!-- 游戏AI -->
  <g>
    <rect x="310" y="240" width="180" height="120" fill="#FFD700" rx="10" stroke="#333" stroke-width="2"/>
    <rect x="360" y="270" width="80" height="60" fill="#4A90E2" rx="5"/>
    <circle cx="380" cy="290" r="6" fill="#FFD700"/>
    <circle cx="420" cy="290" r="6" fill="#FFD700"/>
    <rect x="375" y="305" width="30" height="15" fill="#FF6B35" rx="3"/>
    <text x="400" y="350" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="#333" text-anchor="middle">🎮 游戏AI</text>
    <text x="400" y="370" font-family="Arial, sans-serif" font-size="11" fill="#666" text-anchor="middle">和你一起玩游戏</text>
  </g>

  <!-- 艺术创作 -->
  <g>
    <rect x="570" y="240" width="180" height="120" fill="#50C878" rx="10" stroke="#333" stroke-width="2"/>
    <rect x="610" y="270" width="100" height="70" fill="white" stroke="#333" stroke-width="2"/>
    <path d="M 620 290 Q 640 280 660 290" stroke="#FF6B35" stroke-width="3" fill="none"/>
    <path d="M 630 310 Q 650 300 670 310" stroke="#4A90E2" stroke-width="3" fill="none"/>
    <circle cx="690" cy="295" r="8" fill="#FFD700"/>
    <text x="660" y="350" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="#333" text-anchor="middle">🎨 艺术创作</text>
    <text x="660" y="370" font-family="Arial, sans-serif" font-size="11" fill="#666" text-anchor="middle">画画和写诗</text>
  </g>

  <!-- 医疗诊断 -->
  <g>
    <rect x="180" y="400" width="180" height="120" fill="#FF6B35" rx="10" stroke="#333" stroke-width="2"/>
    <circle cx="270" cy="440" r="25" fill="white"/>
    <path d="M 270 420 L 270 460 M 250 440 L 290 440" stroke="#FF6B35" stroke-width="4"/>
    <text x="270" y="490" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="#333" text-anchor="middle">🏥 医疗诊断</text>
    <text x="270" y="510" font-family="Arial, sans-serif" font-size="11" fill="#666" text-anchor="middle">帮助医生看病</text>
  </g>

  <!-- 智能翻译 -->
  <g>
    <rect x="440" y="400" width="180" height="120" fill="#4A90E2" rx="10" stroke="#333" stroke-width="2"/>
    <text x="490" y="445" font-family="Arial, sans-serif" font-size="24" fill="white" text-anchor="middle">A</text>
    <text x="530" y="445" font-family="Arial, sans-serif" font-size="20" fill="white" text-anchor="middle">→</text>
    <text x="570" y="445" font-family="Arial, sans-serif" font-size="24" fill="white" text-anchor="middle">中</text>
    <text x="530" y="490" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="white" text-anchor="middle">🌍 智能翻译</text>
    <text x="530" y="510" font-family="Arial, sans-serif" font-size="11" fill="white" text-anchor="middle">说不同的语言</text>
  </g>

  <!-- 底部说明 -->
  <text x="400" y="570" font-family="Arial, sans-serif" font-size="14" fill="#666" text-anchor="middle">AI就像一个超级助手，在生活的各个方面帮助我们！</text>
</svg>
