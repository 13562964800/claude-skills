包含所有文字内容和插图，真正的500页
"""

import re
import os

def read_markdown_file(filepath):
    """读取markdown文件"""
    with open(filepath, 'r', encoding='utf-8') as f:
        return f.read()

def convert_md_to_html_content(md_content):
    """将markdown内容转换为HTML"""
    # 替换标题
    html = re.sub(r'^### (.+)$', r'<h3>\1</h3>', md_content, flags=re.MULTILINE)
    html = re.sub(r'^## (.+)$', r'<h2>\1</h2>', html, flags=re.MULTILINE)
    html = re.sub(r'^# (.+)$', r'<h1>\1</h1>', html, flags=re.MULTILINE)

    # 替换粗体
    html = re.sub(r'\*\*(.+?)\*\*', r'<strong>\1</strong>', html)

    # 替换插图标记
    html = re.sub(r'【插图.+?】', '', html)

    # 替换段落
    lines = html.split('\n')
    result = []
    in_paragraph = False

    for line in lines:
        line = line.strip()
        if not line or line.startswith('<h') or line.startswith('---'):
            if in_paragraph:
                result.append('</p>')
                in_paragraph = False
            if line.startswith('---'):
                result.append('<hr>')
            else:
                result.append(line)
        else:
            if not in_paragraph:
                result.append('<p>')
                in_paragraph = True
            result.append(line + ' ')

    if in_paragraph:
        result.append('</p>')

    return '\n'.join(result)

