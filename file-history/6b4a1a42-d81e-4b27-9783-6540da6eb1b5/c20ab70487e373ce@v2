<!-- {title} -->
<div class="page cover">
    <h1 style="color: white;">{title}</h1>
    <div class="illustration">
        <img src="插图/{cover_img}" alt="{title}" style="max-width: 400px;">
    </div>
</div>
'''
            else:
                # 每个章节
                section_content = '## ' + section
                html_content = convert_md_to_html_content(section_content)

                # 每个章节分成多页
                paragraphs = html_content.split('</p>')
                current_page_content = ''
                paragraph_count = 0

                for para in paragraphs:
                    if para.strip():
                        current_page_content += para + '</p>\n'
                        paragraph_count += 1

                        # 每3-4段或遇到标题就分页
                        if paragraph_count >= 3 or '<h2>' in para or '<h1>' in para:
                            output += f'''
<div class="page">
{current_page_content}
</div>
'''
                            current_page_content = ''
                            paragraph_count = 0

                # 剩余内容
                if current_page_content.strip():
                    output += f'''
<div class="page">
{current_page_content}
</div>
'''

