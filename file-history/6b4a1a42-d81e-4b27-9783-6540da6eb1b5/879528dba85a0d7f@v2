<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 600">
  <!-- 背景 -->
  <rect width="800" height="600" fill="#f8f9fa"/>

  <!-- 标题 -->
  <text x="400" y="40" font-family="Arial, sans-serif" font-size="24" font-weight="bold" fill="#4A90E2" text-anchor="middle">机器学习流程</text>

  <!-- 步骤1: 收集数据 -->
  <rect x="50" y="100" width="150" height="80" fill="#FFD700" rx="10" stroke="#333" stroke-width="2"/>
  <text x="125" y="130" font-family="Arial, sans-serif" font-size="16" font-weight="bold" fill="#333" text-anchor="middle">步骤1</text>
  <text x="125" y="155" font-family="Arial, sans-serif" font-size="14" fill="#333" text-anchor="middle">收集数据</text>
  <text x="125" y="175" font-family="Arial, sans-serif" font-size="12" fill="#666" text-anchor="middle">📊 大量样本</text>

  <!-- 箭头1 -->
  <path d="M 200 140 L 280 140 L 270 130 M 280 140 L 270 150" stroke="#4A90E2" stroke-width="3" fill="none"/>

  <!-- 步骤2: 训练模型 -->
  <rect x="280" y="100" width="150" height="80" fill="#50C878" rx="10" stroke="#333" stroke-width="2"/>
  <text x="355" y="130" font-family="Arial, sans-serif" font-size="16" font-weight="bold" fill="#333" text-anchor="middle">步骤2</text>
  <text x="355" y="155" font-family="Arial, sans-serif" font-size="14" fill="#333" text-anchor="middle">训练模型</text>
  <text x="355" y="175" font-family="Arial, sans-serif" font-size="12" fill="#666" text-anchor="middle">🧠 学习规律</text>

  <!-- 箭头2 -->
  <path d="M 430 140 L 510 140 L 500 130 M 510 140 L 500 150" stroke="#4A90E2" stroke-width="3" fill="none"/>

  <!-- 步骤3: 测试评估 -->
  <rect x="510" y="100" width="150" height="80" fill="#FF6B35" rx="10" stroke="#333" stroke-width="2"/>
  <text x="585" y="130" font-family="Arial, sans-serif" font-size="16" font-weight="bold" fill="#333" text-anchor="middle">步骤3</text>
  <text x="585" y="155" font-family="Arial, sans-serif" font-size="14" fill="#333" text-anchor="middle">测试评估</text>
  <text x="585" y="175" font-family="Arial, sans-serif" font-size="12" fill="#666" text-anchor="middle">✓ 检查准确度</text>

  <!-- 判断框 -->
  <path d="M 585 220 L 635 270 L 585 320 L 535 270 Z" fill="#FFD700" stroke="#333" stroke-width="2"/>
  <text x="585" y="265" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="#333" text-anchor="middle">准确吗？</text>
  <text x="585" y="285" font-family="Arial, sans-serif" font-size="12" fill="#333" text-anchor="middle">🤔</text>

  <!-- 箭头3: 向下 -->
  <path d="M 585 180 L 585 220" stroke="#4A90E2" stroke-width="3" fill="none"/>

  <!-- 不准确 - 返回 -->
  <path d="M 535 270 L 355 270 L 355 180" stroke="#FF6B35" stroke-width="3" fill="none" stroke-dasharray="5,5"/>
  <text x="445" y="260" font-family="Arial, sans-serif" font-size="12" fill="#FF6B35" text-anchor="middle">❌ 不准确</text>
  <text x="445" y="280" font-family="Arial, sans-serif" font-size="11" fill="#FF6B35" text-anchor="middle">继续训练</text>

  <!-- 准确 - 部署 -->
  <path d="M 585 320 L 585 380 L 510 380" stroke="#50C878" stroke-width="3" fill="none"/>
  <text x="650" y="350" font-family="Arial, sans-serif" font-size="12" fill="#50C878" text-anchor="start">✓ 准确</text>

  <!-- 步骤4: 部署使用 -->
  <rect x="280" y="350" width="230" height="80" fill="#4A90E2" rx="10" stroke="#333" stroke-width="2"/>
  <text x="395" y="380" font-family="Arial, sans-serif" font-size="16" font-weight="bold" fill="white" text-anchor="middle">步骤4</text>
  <text x="395" y="405" font-family="Arial, sans-serif" font-size="14" fill="white" text-anchor="middle">部署使用</text>
  <text x="395" y="425" font-family="Arial, sans-serif" font-size="12" fill="white" text-anchor="middle">🚀 实际应用</text>

  <!-- 持续改进 -->
  <path d="M 280 390 L 125 390 L 125 180" stroke="#4A90E2" stroke-width="2" fill="none" stroke-dasharray="5,5"/>
  <text x="200" y="380" font-family="Arial, sans-serif" font-size="11" fill="#4A90E2" text-anchor="middle">持续改进</text>
  <text x="200" y="395" font-family="Arial, sans-serif" font-size="11" fill="#4A90E2" text-anchor="middle">收集新数据</text>

  <!-- 底部说明 -->
  <rect x="50" y="480" width="700" height="80" fill="#e8f4f8" rx="10" stroke="#4A90E2" stroke-width="2"/>
  <text x="400" y="510" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="#333" text-anchor="middle">💡 机器学习就像教小朋友学习</text>
  <text x="400" y="535" font-family="Arial, sans-serif" font-size="12" fill="#666" text-anchor="middle">给它看很多例子，让它找规律，然后测试它学得怎么样，</text>
  <text x="400" y="555" font-family="Arial, sans-serif" font-size="12" fill="#666" text-anchor="middle">如果不够好就继续练习，直到它能准确地完成任务！</text>
</svg>
