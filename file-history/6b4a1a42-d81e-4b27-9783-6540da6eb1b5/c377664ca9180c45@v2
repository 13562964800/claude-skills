<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 600">
  <!-- 背景 -->
  <rect width="800" height="600" fill="#f8f9fa"/>

  <!-- 标题 -->
  <text x="400" y="40" font-family="Arial, sans-serif" font-size="24" font-weight="bold" fill="#4A90E2" text-anchor="middle">Merge - 河流汇合</text>

  <!-- 左侧河流（分支1） -->
  <path d="M 100 150 Q 150 200 200 250 Q 250 300 300 350" stroke="#50C878" stroke-width="40" fill="none" opacity="0.7" stroke-linecap="round"/>
  <text x="150" y="180" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="#333" text-anchor="middle">分支A</text>

  <!-- 右侧河流（分支2） -->
  <path d="M 700 150 Q 650 200 600 250 Q 550 300 500 350" stroke="#FFD700" stroke-width="40" fill="none" opacity="0.7" stroke-linecap="round"/>
  <text x="650" y="180" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="#333" text-anchor="middle">分支B</text>

  <!-- 汇合后的河流 -->
  <path d="M 400 350 L 400 500" stroke="#4A90E2" stroke-width="60" fill="none" opacity="0.7" stroke-linecap="round"/>
  <text x="450" y="430" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="#333" text-anchor="start">合并后</text>

  <!-- 汇合点 -->
  <circle cx="400" cy="350" r="40" fill="#FF6B35" stroke="#333" stroke-width="3"/>
  <text x="400" y="360" font-family="Arial, sans-serif" font-size="16" font-weight="bold" fill="white" text-anchor="middle">Merge</text>

  <!-- 小船在分支A -->
  <ellipse cx="180" cy="230" rx="25" ry="15" fill="#8B4513" stroke="#333" stroke-width="2"/>
  <path d="M 180 215 L 180 200 L 190 210 Z" fill="#FF6B35" stroke="#333" stroke-width="1"/>
  <text x="180" y="210" font-family="Arial, sans-serif" font-size="10" fill="white" text-anchor="middle">代码1</text>

  <!-- 小船在分支B -->
  <ellipse cx="620" cy="230" rx="25" ry="15" fill="#8B4513" stroke="#333" stroke-width="2"/>
  <path d="M 620 215 L 620 200 L 610 210 Z" fill="#FF6B35" stroke="#333" stroke-width="1"/>
  <text x="620" y="210" font-family="Arial, sans-serif" font-size="10" fill="white" text-anchor="middle">代码2</text>

  <!-- 大船在合并后 -->
  <ellipse cx="400" cy="450" rx="35" ry="20" fill="#8B4513" stroke="#333" stroke-width="2"/>
  <path d="M 400 430 L 400 410 L 415 425 Z" fill="#FF6B35" stroke="#333" stroke-width="1"/>
  <text x="400" y="455" font-family="Arial, sans-serif" font-size="11" fill="white" text-anchor="middle">完整代码</text>

  <!-- 箭头指示 -->
  <path d="M 300 350 L 360 350" stroke="#333" stroke-width="2" fill="none"/>
  <path d="M 360 350 L 350 345 M 360 350 L 350 355" stroke="#333" stroke-width="2" fill="none"/>

  <path d="M 500 350 L 440 350" stroke="#333" stroke-width="2" fill="none"/>
  <path d="M 440 350 L 450 345 M 440 350 L 450 355" stroke="#333" stroke-width="2" fill="none"/>

  <!-- 波浪装饰 -->
  <path d="M 150 240 Q 160 235 170 240 Q 180 245 190 240" stroke="white" stroke-width="2" fill="none" opacity="0.6"/>
  <path d="M 610 240 Q 620 235 630 240 Q 640 245 650 240" stroke="white" stroke-width="2" fill="none" opacity="0.6"/>
  <path d="M 380 460 Q 390 455 400 460 Q 410 465 420 460" stroke="white" stroke-width="2" fill="none" opacity="0.6"/>

  <!-- 说明框 -->
  <rect x="50" y="520" width="700" height="60" fill="white" stroke="#4A90E2" stroke-width="2" rx="10"/>
  <text x="400" y="545" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="#333" text-anchor="middle">💡 Merge就像河流汇合</text>
  <text x="400" y="565" font-family="Arial, sans-serif" font-size="12" fill="#666" text-anchor="middle">把不同分支的代码合并到一起，形成完整的项目</text>

  <!-- 装饰性元素 - 云朵 -->
  <ellipse cx="100" cy="80" rx="30" ry="20" fill="white" opacity="0.8"/>
  <ellipse cx="120" cy="75" rx="25" ry="18" fill="white" opacity="0.8"/>
  <ellipse cx="85" cy="75" rx="20" ry="15" fill="white" opacity="0.8"/>

  <ellipse cx="700" cy="80" rx="30" ry="20" fill="white" opacity="0.8"/>
  <ellipse cx="680" cy="75" rx="25" ry="18" fill="white" opacity="0.8"/>
  <ellipse cx="715" cy="75" rx="20" ry="15" fill="white" opacity="0.8"/>
</svg>
