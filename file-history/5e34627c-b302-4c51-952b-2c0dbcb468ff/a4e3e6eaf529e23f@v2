#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
直接插入SVG到Word文档（尝试不同方法）
"""

from docx import Document
from docx.shared import Inches, Pt, RGBColor
from docx.enum.text import WD_ALIGN_PARAGRAPH
from pathlib import Path
import re

def insert_illustrations_direct(doc_path, output_path):
    """直接插入SVG文件（尝试多种方法）"""
    print("📖 加载Word文档...")
    doc = Document(str(doc_path))

    print("🔍 查找插图文件...")
    illustration_dir = Path("C:/Users/Administrator/插图")
    svg_files = sorted(illustration_dir.glob("*.svg"))

    # 创建插图映射
    illustration_map = {}
    for svg_file in svg_files:
        name = svg_file.stem
        illustration_map[name] = svg_file

    print(f"  ✓ 找到 {len(illustration_map)} 个插图文件")

    print(f"\n🖼️  插入插图到文档...")
    inserted_count = 0
    skipped_count = 0
    placeholder_pattern = re.compile(r'\[插图占位符 #(\d+)\]')

    # 将插图文件转换为列表，按文件名排序
    sorted_illustrations = sorted(illustration_map.items())

    # 遍历所有段落
    for para in doc.paragraphs:
        match = placeholder_pattern.search(para.text)
        if match:
            placeholder_num = int(match.group(1))

            # 选择对应的插图
            if placeholder_num <= len(sorted_illustrations):
                illustration_name, svg_path = sorted_illustrations[(placeholder_num - 1) % len(sorted_illustrations)]

                try:
                    # 清空占位符段落
                    para.clear()

                    # 方法1: 尝试直接插入SVG（可能失败）
                    try:
                        run = para.add_run()
                        # 尝试使用EMF格式（Word更好支持）
                        run.add_picture(str(svg_path), width=Inches(5.5))
                        para.alignment = WD_ALIGN_PARAGRAPH.CENTER

                        inserted_count += 1
                        if inserted_count % 10 == 0:
                            print(f"  ✓ 已插入 {inserted_count} 个插图...")
                    except Exception as e:
                        # 方法2: 如果SVG插入失败，添加美化的文本说明
                        para.clear()

                        # 添加空行
                        para.add_run("\n")

                        # 添加插图说明框
                        run = para.add_run(f"┌{'─' * 60}┐\n")
                        run.font.size = Pt(10)
                        run.font.color.rgb = RGBColor(100, 100, 100)

                        run = para.add_run(f"│  🖼️  插图 #{placeholder_num}: {illustration_name}\n")
                        run.font.size = Pt(12)
                        run.font.color.rgb = RGBColor(41, 128, 185)
                        run.bold = True

                        run = para.add_run(f"│  📁 文件: {svg_path.name}\n")
                        run.font.size = Pt(10)
                        run.font.color.rgb = RGBColor(128, 128, 128)

                        run = para.add_run(f"└{'─' * 60}┘\n")
                        run.font.size = Pt(10)
                        run.font.color.rgb = RGBColor(100, 100, 100)

                        para.alignment = WD_ALIGN_PARAGRAPH.CENTER
                        skipped_count += 1
                        print(f"  ⚠️  使用文本占位: {illustration_name}")

                except Exception as e:
                    print(f"  ✗ 处理失败 #{placeholder_num}: {e}")
                    skipped_count += 1

    print(f"\n💾 保存文档...")
    doc.save(str(output_path))
    print(f"  ✓ 已保存: {output_path}")

    return inserted_count, skipped_count

def main():
    """主函数"""
    print("=" * 70)
    print("🎨 插入所有插图到Word文档")
    print("=" * 70)

    input_file = Path("C:/Users/Administrator/AI科普画册/AI前沿知识儿童科普画册-完整版-带插图占位符.docx")
    output_file = Path("C:/Users/Administrator/AI科普画册/AI前沿知识儿童科普画册-带插图标记版.docx")

    if not input_file.exists():
        print(f"❌ 找不到输入文件: {input_file}")
        return

    print(f"\n📂 输入文件: {input_file}")
    print(f"📂 输出文件: {output_file}\n")

    try:
        inserted_count, skipped_count = insert_illustrations_direct(input_file, output_file)

        print("\n" + "=" * 70)
        print(f"✅ 完成！")
        print(f"   成功插入: {inserted_count} 个插图")
        print(f"   文本占位: {skipped_count} 个")
        print(f"\n📁 输出文件: {output_file}")

        if skipped_count > 0:
            print("\n⚠️  注意: 由于python-docx不支持SVG格式，")
            print("   部分插图使用了美化的文本占位符。")
            print("\n📋 后续步骤：")
            print("   1. 打开Word文档")
            print("   2. 在每个文本占位符位置手动插入对应的SVG图片")
            print("   3. 或者使用其他工具将SVG转换为PNG后再插入")

        print("=" * 70)

    except Exception as e:
        print(f"\n❌ 错误: {e}")
        import traceback
        traceback.print_exc()

if __name__ == "__main__":
    main()
