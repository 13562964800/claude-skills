# 生成缺失的插图列表

import os

# 检查已存在的插图
existing = set()
illustration_dir = 'C:/Users/Administrator/插图/新插图'
for f in os.listdir(illustration_dir):
    if f.startswith('插图') and f.endswith('.svg'):
        num = f.replace('插图', '').replace('.svg', '')
        try:
            existing.add(int(num))
        except:
            pass

# 找出缺失的
missing = []
for i in range(1, 216):
    if i not in existing:
        missing.append(i)

print(f'已完成: {len(existing)}/215')
print(f'缺失: {len(missing)}个')
print(f'\n缺失的插图编号:')
print(missing)

# 保存到文件
with open('C:/Users/Administrator/AI科普画册/缺失插图列表.txt', 'w', encoding='utf-8') as f:
    f.write(f'缺失的{len(missing)}个插图编号:\n')
    for num in missing:
        f.write(f'{num}\n')

print(f'\n已保存到: C:/Users/Administrator/AI科普画册/缺失插图列表.txt')
