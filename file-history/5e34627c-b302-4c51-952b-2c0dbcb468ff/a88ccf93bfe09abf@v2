def generate_svg(config):
    """生成单个SVG插图"""
    filename = config["filename"]
    title = config["title"]
    description = config["description"]
    colors = config["colors"]

    # 根据不同类型生成不同的SVG
    # 这里是一个通用模板，实际应该根据描述生成不同的图形

    svg_content = f'''<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 450" width="800" height="450">
  <defs>
    <linearGradient id="bg_{filename.replace('.svg', '')}" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:{colors[0]};stop-opacity:0.2" />
      <stop offset="100%" style="stop-color:{colors[1] if len(colors) > 1 else colors[0]};stop-opacity:0.1" />
    </linearGradient>
    <filter id="glow">
      <feGaussianBlur stdDeviation="3" result="coloredBlur"/>
      <feMerge>
        <feMergeNode in="coloredBlur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>

  <!-- 背景 -->
  <rect width="800" height="450" fill="url(#bg_{filename.replace('.svg', '')})"/>

  <!-- 主要内容区域 -->
  <g transform="translate(400, 225)">
    <!-- 这里应该根据description生成具体的图形 -->
    <text x="0" y="0" font-size="48" font-weight="bold" fill="{colors[0]}" text-anchor="middle" font-family="Arial, sans-serif">
      {title}
    </text>
    <text x="0" y="50" font-size="18" fill="{colors[1] if len(colors) > 1 else colors[0]}" text-anchor="middle" font-family="Arial, sans-serif" opacity="0.8">
      {description[:30]}...
    </text>
  </g>

  <!-- 装饰元素 -->
  <circle cx="100" cy="100" r="20" fill="{colors[-1]}" opacity="0.3">
    <animate attributeName="r" values="20;25;20" dur="2s" repeatCount="indefinite"/>
  </circle>
  <circle cx="700" cy="350" r="15" fill="{colors[-1]}" opacity="0.3">
    <animate attributeName="r" values="15;20;15" dur="2.5s" repeatCount="indefinite"/>
  </circle>
</svg>'''

    return svg_content

def main():
    """主函数"""
    output_dir = "插图"
    os.makedirs(output_dir, exist_ok=True)

    print(f"开始生成{len(illustrations)}个插图...")

    for i, config in enumerate(illustrations, 1):
        filename = config["filename"]
        filepath = os.path.join(output_dir, filename)

        svg_content = generate_svg(config)

        with open(filepath, 'w', encoding='utf-8') as f:
            f.write(svg_content)

        print(f"[{i}/{len(illustrations)}] 已生成: {filename}")

    print(f"\n✅ 所有插图生成完成！保存在 {output_dir}/ 目录")

if __name__ == "__main__":
    main()
