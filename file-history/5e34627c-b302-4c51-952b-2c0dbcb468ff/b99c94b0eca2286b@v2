#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
使用svglib批量将SVG转换为PNG
"""

from pathlib import Path
from svglib.svglib import svg2rlg
from reportlab.graphics import renderPM

def convert_svg_to_png_batch():
    """批量转换SVG为PNG"""
    svg_dir = Path("C:/Users/Administrator/插图")
    svg_files = sorted(svg_dir.glob("*.svg"))

    print(f"🎨 找到 {len(svg_files)} 个SVG文件")
    print("=" * 70)

    converted_count = 0
    failed_count = 0

    for svg_file in svg_files:
        png_file = svg_file.with_suffix('.png')

        # 如果PNG已存在，跳过
        if png_file.exists():
            print(f"  ⏭️  跳过（已存在）: {svg_file.name}")
            converted_count += 1
            continue

        try:
            # 使用svglib转换
            drawing = svg2rlg(str(svg_file))
            if drawing:
                # 设置高分辨率
                renderPM.drawToFile(drawing, str(png_file), fmt='PNG', dpi=300)
                print(f"  ✓ 转换成功: {svg_file.name} → {png_file.name}")
                converted_count += 1
            else:
                print(f"  ✗ 转换失败: {svg_file.name} - 无法解析SVG")
                failed_count += 1

        except Exception as e:
            print(f"  ✗ 转换出错: {svg_file.name} - {str(e)[:80]}")
            failed_count += 1

    print("=" * 70)
    print(f"✅ 转换完成: {converted_count} 个成功, {failed_count} 个失败")
    return converted_count, failed_count

if __name__ == "__main__":
    print("🖼️  批量SVG转PNG工具（svglib版本）")
    print("=" * 70)
    convert_svg_to_png_batch()
