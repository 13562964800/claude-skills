# PowerShell脚本：强制添加可见页码

param(
    [string]$DocPath = "C:\Users\Administrator\AI科普画册\AI前沿知识儿童科普画册-最终成品.docx",
    [string]$OutputPath = "C:\Users\Administrator\AI科普画册\AI前沿知识儿童科普画册-完整页码版.docx"
)

Write-Host "=" * 70 -ForegroundColor Cyan
Write-Host "📄 强制添加可见页码" -ForegroundColor Cyan
Write-Host "=" * 70 -ForegroundColor Cyan

try {
    Write-Host "`n📖 启动Word应用程序..." -ForegroundColor Green
    $word = New-Object -ComObject Word.Application
    $word.Visible = $true  # 设置为可见，便于调试

    Write-Host "📖 打开Word文档..." -ForegroundColor Green
    $doc = $word.Documents.Open($DocPath)

    $totalPages = $doc.ComputeStatistics(2)
    Write-Host "文档总页数: $totalPages`n" -ForegroundColor Cyan

    # 使用Word内置的页码插入功能
    Write-Host "📄 使用Word内置功能添加页码..." -ForegroundColor Green

    # 选择文档
    $selection = $word.Selection

    # 跳转到第3页（跳过封面和扉页）
    $selection.GoTo(1, 2, 3) | Out-Null  # wdGoToPage, wdGoToAbsolute, 3

    # 插入页码 - 页面底端居中
    # wdAlignPageNumberCenter = 1
    # wdHeaderFooterPrimary = 1
    $doc.Sections.Item(1).Footers.Item(1).PageNumbers.Add(1) | Out-Null

    Write-Host "  ✓ 页码已添加" -ForegroundColor Green

    # 设置封面和扉页不显示页码
    Write-Host "`n📄 设置封面和扉页..." -ForegroundColor Green
    if ($doc.Sections.Count -ge 1) {
        $doc.Sections.Item(1).PageSetup.DifferentFirstPageHeaderFooter = $true
        Write-Host "  ✓ 封面不显示页码" -ForegroundColor Green
    }

    # 更新域
    Write-Host "`n📑 更新所有域..." -ForegroundColor Green
    $doc.Fields.Update() | Out-Null
    Write-Host "  ✓ 域已更新" -ForegroundColor Green

    # 保存
    Write-Host "`n💾 保存文档..." -ForegroundColor Green
    $doc.SaveAs([ref]$OutputPath)
    Write-Host "  ✓ 已保存" -ForegroundColor Green

    # 转换PDF
    Write-Host "📄 转换为PDF..." -ForegroundColor Green
    $pdfPath = $OutputPath -replace '\.docx$', '.pdf'
    $doc.SaveAs([ref]$pdfPath, [ref]17)
    Write-Host "  ✓ PDF已生成" -ForegroundColor Green

    Write-Host "`n✅ 完成！请检查Word窗口中的页码显示" -ForegroundColor Green
    Write-Host "按任意键关闭Word..." -ForegroundColor Yellow
    Read-Host

    $doc.Close()
    $word.Quit()

    [System.Runtime.Interopservices.Marshal]::ReleaseComObject($doc) | Out-Null
    [System.Runtime.Interopservices.Marshal]::ReleaseComObject($word) | Out-Null
    [System.GC]::Collect()
    [System.GC]::WaitForPendingFinalizers()

    Write-Host "`n📁 输出文件：" -ForegroundColor Yellow
    Write-Host "   $OutputPath" -ForegroundColor Green
    Write-Host "   $pdfPath" -ForegroundColor Green
}
catch {
    Write-Host "`n❌ 错误: $_" -ForegroundColor Red
    Write-Host $_.Exception.Message -ForegroundColor Red
}
