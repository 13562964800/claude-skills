#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
批量将SVG转换为PNG并插入到Word文档
"""

import subprocess
from pathlib import Path
import os

def convert_svg_to_png_batch():
    """批量转换SVG为PNG"""
    svg_dir = Path("C:/Users/Administrator/插图")
    svg_files = list(svg_dir.glob("*.svg"))

    print(f"🎨 找到 {len(svg_files)} 个SVG文件")
    print("=" * 70)

    converted_count = 0
    failed_count = 0

    for svg_file in svg_files:
        png_file = svg_file.with_suffix('.png')

        # 如果PNG已存在，跳过
        if png_file.exists():
            print(f"  ⏭️  跳过（已存在）: {svg_file.name}")
            converted_count += 1
            continue

        try:
            # 使用svg2png.js转换
            cmd = [
                'node',
                'C:/Users/Administrator/.claude/skills/svg-article-illustrator/scripts/svg2png.js',
                str(svg_file),
                str(png_file),
                '600'  # DPI
            ]

            result = subprocess.run(cmd, capture_output=True, text=True, timeout=30)

            if result.returncode == 0 and png_file.exists():
                print(f"  ✓ 转换成功: {svg_file.name} → {png_file.name}")
                converted_count += 1
            else:
                print(f"  ✗ 转换失败: {svg_file.name}")
                if result.stderr:
                    print(f"     错误: {result.stderr[:100]}")
                failed_count += 1

        except subprocess.TimeoutExpired:
            print(f"  ✗ 转换超时: {svg_file.name}")
            failed_count += 1
        except Exception as e:
            print(f"  ✗ 转换出错: {svg_file.name} - {e}")
            failed_count += 1

    print("=" * 70)
    print(f"✅ 转换完成: {converted_count} 个成功, {failed_count} 个失败")
    return converted_count, failed_count

if __name__ == "__main__":
    print("🖼️  批量SVG转PNG工具")
    print("=" * 70)
    convert_svg_to_png_batch()
