def insert_final_svgs():
    file_path = 'AI前沿知识儿童科普画册-带全部插图.md'
    with open(file_path, 'r', encoding='utf-8') as f:
        content = f.read()

    svgs = [
        ('【插图：8个概念的拼图，组成完整的AI生态系统】', svg_ecosystem()),
        ('【插图：GitHub知识地图】', svg_github_map()),
        ('【插图：Vibecoding知识地图】', svg_vibecoding_map()),
        ('【插图：封底设计 - AI小助手挥手告别】', svg_back_cover()),
    ]

    count = 0
    for marker, svg in svgs:
        if marker in content:
            pos = content.find(marker)
            next_300 = content[pos:pos+300]
            if '<svg' not in next_300:
                content = content.replace(marker, marker + '\n' + svg + '\n')
                count += 1
                print(f'✓ 已插入 {marker}')

    with open(file_path, 'w', encoding='utf-8') as f:
        f.write(content)

    print(f'\n最后一批完成! 共插入 {count} 个SVG')
    print(f'\n🎉 全部215个插图生成完成!')

if __name__ == '__main__':
    insert_final_svgs()
