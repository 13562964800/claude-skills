  <rect width="800" height="450" fill="#F0F4F8"/>
  <text x="400" y="60" font-size="28" text-anchor="middle" fill="#333" font-weight="bold">{title}</text>
  <rect x="80" y="120" width="300" height="250" rx="10" fill="#F3E8F8" stroke="#9B59B6" stroke-width="3"/>
  <text x="230" y="160" font-size="20" text-anchor="middle" fill="#333" font-weight="bold">{left_title}</text>
  <text x="230" y="260" font-size="100" text-anchor="middle">{left_emoji}</text>
  <rect x="420" y="120" width="300" height="250" rx="10" fill="#E8F4F8" stroke="#4A90E2" stroke-width="3"/>
  <text x="570" y="160" font-size="20" text-anchor="middle" fill="#333" font-weight="bold">{right_title}</text>
