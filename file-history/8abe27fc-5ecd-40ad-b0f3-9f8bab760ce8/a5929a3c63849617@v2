        svg_2_2 = generate_svg_turing_test()
        content = content.replace(marker_2_2, marker_2_2 + '\n' + svg_2_2)
        print('✓ 已插入插图2-2')

    # 保存文件
    with open(file_path, 'w', encoding='utf-8') as f:
        f.write(content)

    print('\n生成完成!')

if __name__ == '__main__':
    main()
