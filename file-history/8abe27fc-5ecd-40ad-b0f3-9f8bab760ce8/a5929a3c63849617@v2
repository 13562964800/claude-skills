def main():
    """主函数 - 读取文件并插入SVG"""
    file_path = 'AI前沿知识儿童科普画册-带全部插图.md'

    with open(file_path, 'r', encoding='utf-8') as f:
        content = f.read()

    # 插入第一个SVG
    marker_2_1 = '【插图2-1:图灵在工作台前研究密码机器,背景是二战时期】'
    if marker_2_1 in content and '<svg' not in content[content.find(marker_2_1):content.find(marker_2_1)+500]:
        svg_2_1 = generate_svg_turing_at_work()
        content = content.replace(marker_2_1, marker_2_1 + '\n' + svg_2_1)
        print('✓ 已插入插图2-1')

    # 插入第二个SVG
    marker_2_2 = '【插图2-2:图灵测试示意图——一个人通过屏幕与看不见的对象对话】'
