def generate_svg_from_config(config):
    """根据配置生成SVG"""
    marker, svg_type, *params = config

    if svg_type == 'concept':
        title, main_emoji = params[0], params[1]
        sub_emojis = params[2] if len(params) > 2 else []
        return marker, create_concept_svg(title, main_emoji, sub_emojis)
    elif svg_type == 'process':
        title, steps = params
        return marker, create_process_svg(title, steps)

    return marker, create_concept_svg(params[0], '❓')

