    file_path = 'AI前沿知识儿童科普画册-带全部插图.md'
    with open(file_path, 'r', encoding='utf-8') as f:
        content = f.read()

    count = 0
    for config in chapter4_configs:
        marker, svg = generate_svg_from_config(config)
        if marker in content:
            pos = content.find(marker)
            next_300 = content[pos:pos+300]
            if '<svg' not in next_300:
                content = content.replace(marker, marker + '\n' + svg + '\n')
                count += 1
                print(f'✓ 已插入 {marker[:40]}...')

    with open(file_path, 'w', encoding='utf-8') as f:
        f.write(content)

    print(f'\n第6批完成! 共插入 {count} 个SVG')
    print(f'第4章插图全部完成!')

