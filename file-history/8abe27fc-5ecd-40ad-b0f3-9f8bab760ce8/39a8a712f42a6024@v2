def create_concept_svg(title, main_emoji, sub_emojis=[], bg_color="#F0F4F8"):
    """创建概念展示型SVG"""
    svg = f'''
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 450">
  <rect width="800" height="450" fill="{bg_color}"/>
  <text x="400" y="80" font-size="28" text-anchor="middle" fill="#333" font-weight="bold">{title}</text>
  <text x="400" y="250" font-size="120" text-anchor="middle">{main_emoji}</text>'''

    if sub_emojis:
        positions = [(250, 350), (400, 350), (550, 350)]
        for i, emoji in enumerate(sub_emojis[:3]):
            x, y = positions[i]
            svg += f'\n  <text x="{x}" y="{y}" font-size="50" text-anchor="middle">{emoji}</text>'

    svg += '''
  <g>
    <circle cx="400" cy="250" r="140" fill="none" stroke="#4A90E2" stroke-width="3" opacity="0.2">
      <animate attributeName="r" values="140;160;140" dur="3s" repeatCount="indefinite"/>
    </circle>
  </g>
</svg>'''
    return svg

def create_process_svg(title, steps):
    """创建流程型SVG"""
    svg = f'''
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 450">
  <rect width="800" height="450" fill="#E8F4F8"/>
  <text x="400" y="60" font-size="28" text-anchor="middle" fill="#333" font-weight="bold">{title}</text>
  <defs>
    <marker id="arrow9" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
      <polygon points="0 0, 10 3.5, 0 7" fill="#4A90E2"/>
    </marker>
  </defs>'''

    x_positions = [150, 325, 500, 675]
    for i, (step_emoji, step_text) in enumerate(steps[:4]):
        x = x_positions[i]
        svg += f'''
  <rect x="{x-60}" y="180" width="120" height="100" rx="10" fill="#E8F4F8" stroke="#4A90E2" stroke-width="2"/>
  <text x="{x}" y="230" font-size="50" text-anchor="middle">{step_emoji}</text>
  <text x="{x}" y="270" font-size="14" text-anchor="middle" fill="#333">{step_text}</text>'''
        if i < len(steps) - 1:
            svg += f'''
  <line x1="{x+60}" y1="230" x2="{x_positions[i+1]-60}" y2="230" stroke="#4A90E2" stroke-width="3" marker-end="url(#arrow9)"/>'''

    svg += '\n</svg>'
    return svg

