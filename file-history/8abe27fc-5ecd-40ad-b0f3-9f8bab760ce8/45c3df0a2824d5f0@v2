def insert_svgs_batch_2():
    file_path = 'AI前沿知识儿童科普画册-带全部插图.md'
    with open(file_path, 'r', encoding='utf-8') as f:
        content = f.read()

    svgs = [
        ('【插图2-6:深蓝计算机与卡斯帕罗夫对弈的历史性场景】', svg_2_6()),
        ('【插图2-7:沃森在《危险边缘》节目中与人类选手竞赛】', svg_2_7()),
        ('【插图2-8:AlphaGo与李世石对弈,全球观众通过屏幕观看】', svg_2_8()),
        ('【插图2-9:GPT模型的进化——从GPT-1到GPT-4,能力越来越强】', svg_2_9()),
        ('【插图2-10:全球各地的人们使用ChatGPT的场景拼贴】', svg_2_10()),
    ]

    count = 0
    for marker, svg in svgs:
        if marker in content:
            pos = content.find(marker)
            next_300 = content[pos:pos+300]
            if '<svg' not in next_300:
                content = content.replace(marker, marker + '\n' + svg + '\n')
                count += 1
                print(f'✓ 已插入 {marker[:30]}...')

    with open(file_path, 'w', encoding='utf-8') as f:
        f.write(content)

    print(f'\n第2批完成! 共插入 {count} 个SVG')

if __name__ == '__main__':
