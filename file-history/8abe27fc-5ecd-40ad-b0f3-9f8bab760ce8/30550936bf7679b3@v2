# 主函数
def insert_svgs_batch_1():
    file_path = 'AI前沿知识儿童科普画册-带全部插图.md'

    with open(file_path, 'r', encoding='utf-8') as f:
        content = f.read()

    # 插入SVG
    svgs = [
        ('【插图2-1:图灵在工作台前研究密码机器,背景是二战时期】', svg_2_1()),
        ('【插图2-2:图灵测试示意图——一个人通过屏幕与看不见的对象对话】', svg_2_2()),
        ('【插图2-3:图灵的肖像,周围环绕着他的重要贡献——密码机、图灵测试、计算机理论】', svg_2_3()),
        ('【插图2-4:1956年达特茅斯会议,科学家们围坐讨论,黑板上写着"Artificial Intelligence"】', svg_2_4()),
        ('【插图2-5:早期计算机运行AI程序,屏幕上显示跳棋棋盘】', svg_2_5()),
    ]

    count = 0
    for marker, svg in svgs:
        if marker in content:
            pos = content.find(marker)
            next_300 = content[pos:pos+300]
            if '<svg' not in next_300:
                content = content.replace(marker, marker + '\n' + svg + '\n')
                count += 1
                print(f'✓ 已插入 {marker[:30]}...')

    # 保存
    with open(file_path, 'w', encoding='utf-8') as f:
        f.write(content)

    print(f'\n第1批完成! 共插入 {count} 个SVG')

if __name__ == '__main__':
    insert_svgs_batch_1()
