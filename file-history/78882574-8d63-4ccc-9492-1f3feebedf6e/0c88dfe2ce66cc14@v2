private fun calculateSegments(duration: Double, fileSize: Long = 0, dynamicSegmentDuration: Long? = null): List<AudioSegment> {
    val estimatedBitrate = if (fileSize > 0 && duration > 0) {
        (fileSize * 8.0 / duration / 1000.0)
    } else {
        128.0
    }

    val compressedBitrate = 12.0 // 更新为12kbps（与压缩参数一致）
    val maxSegmentDurationForSize = (TARGET_SEGMENT_SIZE * 8.0 / (compressedBitrate * 1000.0))
        .coerceAtMost((dynamicSegmentDuration ?: SEGMENT_DURATION).toDouble())

    val targetSegmentDuration = maxSegmentDurationForSize.coerceAtLeast(180.0)

    Log.d(TAG, "Segment strategy: targetDuration=${targetSegmentDuration.toInt()}s, dynamicDuration=${dynamicSegmentDuration}s, originalBitrate=${estimatedBitrate.toInt()}kbps, compressedBitrate=${compressedBitrate.toInt()}kbps, totalDuration=${duration.toInt()}s")

