```kotlin
val config = aiConfigStore.config.first()
val videoFile = File(videoPath)

// 根据转录模式选择引擎
val transcriptionMode = config.transcriptionMode
val useLocal = when (transcriptionMode) {
    "local" -> true
    "cloud" -> false
    "auto" -> {
        // 自动选择：无网络或文件过大时使用本地
        !isNetworkAvailable() || videoFile.length() > 100 * 1024 * 1024
    }
    else -> false
}

Log.d(TAG, "Transcription mode: $transcriptionMode, useLocal: $useLocal")

val result = if (useLocal) {
    // 本地转录
    if (!sherpaOnnxService.isModelDownloaded()) {
        sendErrorBroadcast("本地模型未下载，请先在 AI 设置中下载模型")
        _serviceState.value = ServiceState.Error("本地模型未下载")
        stopForeground(STOP_FOREGROUND_REMOVE)
        stopSelf()
        return@launch
    }

    sherpaOnnxService.transcribe(
        videoFile,
        onProgress = { progress, message ->
            updateProgress(videoName, progress, 100, progress, message)
            sendProgressBroadcast(progress, 100, progress, message, 0)
            _serviceState.value = ServiceState.Transcribing(
                progress, 100, progress, message
            )
        }
    )
} else {
    // 云端转录（现有逻辑）
    // 检查 API Key
    val hasGroqKey = config.groqApiKey.isNotBlank() ||
                     (config.provider == "groq" && config.apiKey.isNotBlank())

    if (!hasGroqKey) {
        sendErrorBroadcast("❌ 请先配置 Groq API Key\n\n获取 API Key：https://console.groq.com/keys")
        _serviceState.value = ServiceState.Error("请先配置 Groq API Key")
        stopForeground(STOP_FOREGROUND_REMOVE)
        stopSelf()
        return@launch
    }

    val transcribeLang = config.transcribeLanguage.takeIf { it.isNotBlank() }
    ffmpegSegmentedService.transcribeWithSegments(
        videoFile,
        config,
        transcribeLang,
        onProgress = { segment, total, progress, message, remainingSeconds ->
            updateProgress(videoName, segment, total, progress, message)
            sendProgressBroadcast(segment, total, progress, message, remainingSeconds)
            _serviceState.value = ServiceState.Transcribing(
                segment, total, progress, message
            )
        }
    )
}

// 转录完成（后续代码保持不变）
