```kotlin
package com.multilanglearner.data.network

import android.content.Context
import android.util.Log
import com.multilanglearner.domain.model.WordTimestamp
import dagger.hilt.android.qualifiers.ApplicationContext
import kotlinx.coroutines.Dispatchers
import kotlinx.coroutines.withContext
import sherpa_onnx.*
import java.io.File
import javax.inject.Inject
import javax.inject.Singleton

/**
 * Sherpa-ONNX 本地转录服务
 *
 * 使用 Whisper base int8 模型进行离线语音识别
 * 性能：1-2倍实时速度（1分钟音频需30-60秒）
 */
@Singleton
class SherpaOnnxTranscriptionService @Inject constructor(
    @ApplicationContext private val context: Context
) {
    companion object {
        private const val TAG = "SherpaOnnxTranscription"
        private const val MODEL_DIR = "models/sherpa-onnx-whisper-base"
    }

    private var recognizer: OfflineRecognizer? = null
    private val modelDir = File(context.filesDir, MODEL_DIR)

    /**
     * 初始化识别器（首次使用时调用）
     */
    suspend fun initialize(): Boolean = withContext(Dispatchers.IO) {
        try {
            if (recognizer != null) return@withContext true

            // 检查模型文件是否存在
            if (!isModelDownloaded()) {
                Log.e(TAG, "Model not downloaded")
                return@withContext false
            }

            val config = OfflineRecognizerConfig(
                featConfig = OfflineFeatureConfig(
                    sampleRate = 16000,
                    featureDim = 80
                ),
                modelConfig = OfflineModelConfig(
                    whisper = OfflineWhisperModelConfig(
                        encoder = File(modelDir, "whisper-base-encoder.int8.onnx").absolutePath,
                        decoder = File(modelDir, "whisper-base-decoder.int8.onnx").absolutePath,
                        language = "auto", // 自动检测语言
                        task = "transcribe"
                    ),
                    tokens = File(modelDir, "tokens.txt").absolutePath,
                    numThreads = 4, // 使用4线程并行
                    provider = "cpu"
                )
            )

            recognizer = OfflineRecognizer(config)
            Log.d(TAG, "Sherpa-ONNX initialized successfully")
            true
        } catch (e: Exception) {
            Log.e(TAG, "Failed to initialize Sherpa-ONNX", e)
            false
        }
    }

    /**
     * 转录音频文件
     */
    suspend fun transcribe(
        audioFile: File,
        onProgress: (Int, String) -> Unit = { _, _ -> }
    ): WhisperResult = withContext(Dispatchers.IO) {
        try {
            // 确保已初始化
            if (recognizer == null && !initialize()) {
                return@withContext WhisperResult(
                    success = false,
                    error = "模型未初始化，请先下载模型"
                )
            }

            onProgress(10, "预处理音频...")

            // 1. 使用 FFmpeg 转换音频为 16kHz 单声道 WAV
            val wavFile = convertToWav(audioFile)
            if (wavFile == null) {
                return@withContext WhisperResult(
                    success = false,
                    error = "音频预处理失败"
                )
            }

            onProgress(30, "加载音频数据...")

            // 2. 读取 WAV 文件
            val (samples, sampleRate) = readWave(wavFile)

            onProgress(50, "本地转录中...")

            // 3. 创建流并转录
            val stream = recognizer!!.createStream()
            stream.acceptWaveform(sampleRate, samples)

            recognizer!!.decode(stream)

            onProgress(90, "处理结果...")

            val result = stream.result

            // 4. 解析时间戳
            val words = parseTimestamps(result.timestamps, result.text)

            onProgress(100, "完成")

            // 清理临时文件
            wavFile.delete()

            WhisperResult(
                success = true,
                text = result.text,
                words = words,
                detectedLang = result.lang ?: "unknown"
            )

        } catch (e: Exception) {
            Log.e(TAG, "Transcription failed", e)
            WhisperResult(
                success = false,
                error = "本地转录失败: ${e.message}"
            )
        }
    }

    /**
     * 检查模型是否已下载
     */
    fun isModelDownloaded(): Boolean {
        val encoder = File(modelDir, "whisper-base-encoder.int8.onnx")
        val decoder = File(modelDir, "whisper-base-decoder.int8.onnx")
        val tokens = File(modelDir, "tokens.txt")
        return encoder.exists() && decoder.exists() && tokens.exists()
    }

    /**
     * 获取模型大小（MB）
     */
    fun getModelSize(): Double {
        if (!isModelDownloaded()) return 0.0
        val totalBytes = modelDir.walkTopDown()
            .filter { it.isFile }
            .map { it.length() }
            .sum()
        return totalBytes / 1024.0 / 1024.0
    }

    /**
     * 转换音频为 16kHz 单声道 WAV
     */
    private suspend fun convertToWav(inputFile: File): File? = withContext(Dispatchers.IO) {
        try {
            val outputFile = File(context.cacheDir, "temp_${System.currentTimeMillis()}.wav")

            val command = buildString {
                append("-hide_banner -y ")
                append("-i \"${inputFile.absolutePath}\" ")
                append("-ar 16000 ") // 16kHz
                append("-ac 1 ") // 单声道
                append("-f wav ") // WAV 格式
                append("\"${outputFile.absolutePath}\"")
            }

            val session = com.arthenica.ffmpegkit.FFmpegKit.execute(command)

            if (session.returnCode?.value == 0 && outputFile.exists()) {
                outputFile
            } else {
                Log.e(TAG, "FFmpeg conversion failed: ${session.output}")
                null
            }
        } catch (e: Exception) {
            Log.e(TAG, "Audio conversion error", e)
            null
        }
    }

    /**
     * 读取 WAV 文件
     */
    private fun readWave(file: File): Pair<FloatArray, Int> {
        // 简化实现：使用 Android AudioTrack 或第三方库读取 WAV
        // 这里返回示例数据，实际需要实现 WAV 解析
        // 可以使用 javax.sound.sampled 或 Android MediaExtractor

        // TODO: 实现 WAV 文件读取
        return Pair(FloatArray(0), 16000)
    }

    /**
     * 解析时间戳为 WordTimestamp 列表
     */
    private fun parseTimestamps(timestamps: String, text: String): List<WordTimestamp> {
        // Sherpa-ONNX 返回的 timestamps 格式需要解析
        // 格式示例: "0.00 0.50 Hello 0.50 1.00 world"

        // TODO: 实现时间戳解析
        return emptyList()
