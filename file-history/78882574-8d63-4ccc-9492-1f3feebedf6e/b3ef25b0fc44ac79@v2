#### 1.4 智能分段策略

**新增功能：** 根据网络速度动态调整分段时长

```kotlin
/**
 * 根据网络速度计算最优分段时长
 * @param networkSpeed 网络速度（bytes/s）
 * @param fileSize 文件大小
 * @param duration 视频时长
 * @return 最优分段时长（秒）
 */
private fun calculateOptimalSegmentDuration(
    networkSpeed: Long,
    fileSize: Long,
    duration: Double
): Long {
    return when {
        networkSpeed > 1_000_000 -> 600L // 快速网络（>1MB/s）：10分钟
        networkSpeed > 500_000 -> 480L // 中速网络（>500KB/s）：8分钟
        networkSpeed > 200_000 -> 360L // 慢速网络（>200KB/s）：6分钟
        else -> 300L // 极慢网络：5分钟（保持原策略）
    }
}

