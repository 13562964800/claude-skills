@Inject
lateinit var sherpaOnnxService: SherpaOnnxTranscriptionService

private fun executeTranscription(
    transcriptionId: String,
    videoPath: String,
    videoName: String
) {
    // ... 现有代码 ...

    val job = serviceScope.launch {
        try {
            val config = aiConfigStore.config.first()
            val videoFile = File(videoPath)

            // 根据转录模式选择引擎
            val transcriptionMode = config.transcriptionMode // "cloud" | "local" | "auto"

            val useLocal = when (transcriptionMode) {
                "local" -> true
                "cloud" -> false
                "auto" -> {
                    // 自动选择：无网络或文件过大时使用本地
                    !isNetworkAvailable() || videoFile.length() > 100 * 1024 * 1024
                }
                else -> false
            }

            val result = if (useLocal) {
                // 本地转录
                if (!sherpaOnnxService.isModelDownloaded()) {
                    sendErrorBroadcast("本地模型未下载，请先下载模型")
                    return@launch
                }

                sherpaOnnxService.transcribe(
                    videoFile,
                    onProgress = { progress, message ->
                        updateProgress(videoName, progress, 100, progress, message)
                        sendProgressBroadcast(progress, 100, progress, message, 0)
                    }
                )
            } else {
                // 云端转录（现有逻辑）
                ffmpegSegmentedService.transcribeWithSegments(
                    videoFile,
                    config,
                    transcribeLang,
                    onProgress = { segment, total, progress, message, remainingSeconds ->
                        updateProgress(videoName, segment, total, progress, message)
                        sendProgressBroadcast(segment, total, progress, message, remainingSeconds)
                    }
                )
            }

            // ... 处理结果的现有代码 ...
        } catch (e: Exception) {
            // ... 错误处理 ...
        }
    }
}

private fun isNetworkAvailable(): Boolean {
    val connectivityManager = getSystemService(Context.CONNECTIVITY_SERVICE) as ConnectivityManager
    val network = connectivityManager.activeNetwork ?: return false
    val capabilities = connectivityManager.getNetworkCapabilities(network) ?: return false
    return capabilities.hasCapability(NetworkCapabilities.NET_CAPABILITY_INTERNET)
}
