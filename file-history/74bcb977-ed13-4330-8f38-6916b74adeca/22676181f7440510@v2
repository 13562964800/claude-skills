'use client';
import { useState, useEffect } from 'react';
import { getMe } from '@/lib/api';

export default function ProfilePage() {
  const [user, setUser] = useState<any>(null);
  const [error, setError] = useState('');
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    const token = localStorage.getItem('token');
    if (!token) {
      setError('未登录，请先登录');
      setLoading(false);
      return;
    }

    getMe(token)
      .then((data) => {
        setUser(data);
        setLoading(false);
      })
      .catch((err) => {
        setError(`获取用户信息失败: ${err}`);
        setLoading(false);
      });
  }, []);

  const handleLogout = () => {
    localStorage.removeItem('token');
    window.location.href = '/auth';
  };

  if (loading) {
    return <div style={{ padding: '2rem' }}>加载中...</div>;
  }

  if (error) {
    return (
      <div style={{ padding: '2rem' }}>
        <h1>个人资料</h1>
        <p style={{ color: 'red' }}>{error}</p>
        <a href="/auth">前往登录</a>
      </div>
    );
  }

  return (
    <div style={{ padding: '2rem', maxWidth: '600px', margin: '0 auto' }}>
      <h1>个人资料</h1>

      <div style={{ marginTop: '2rem', padding: '1rem', background: '#f5f5f5', borderRadius: '8px' }}>
        <div style={{ marginBottom: '1rem' }}>
          <strong>ID:</strong> {user.id}
        </div>
        <div style={{ marginBottom: '1rem' }}>
          <strong>邮箱:</strong> {user.email}
        </div>
        <div style={{ marginBottom: '1rem' }}>
          <strong>姓名:</strong> {user.name}
        </div>
        <div style={{ marginBottom: '1rem' }}>
          <strong>角色:</strong> {user.role}
        </div>
      </div>

      <div style={{ marginTop: '2rem', display: 'flex', gap: '1rem' }}>
        <button onClick={handleLogout} style={{ padding: '0.5rem 1rem', background: '#dc3545', color: 'white', border: 'none', borderRadius: '4px', cursor: 'pointer' }}>
          退出登录
        </button>
        <a href="/dashboard" style={{ padding: '0.5rem 1rem', background: '#007bff', color: 'white', textDecoration: 'none', borderRadius: '4px', display: 'inline-block' }}>
          返回 Dashboard
        </a>
      </div>
    </div>
  );
}
