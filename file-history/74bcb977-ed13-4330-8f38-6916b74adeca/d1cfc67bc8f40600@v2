const BASE_URL = process.env.NEXT_PUBLIC_API_URL ?? 'http://localhost:8000';

async function apiFetch(path: string, options?: RequestInit) {
  const res = await fetch(`${BASE_URL}${path}`, options);
  if (!res.ok) throw new Error(`API error ${res.status}`);
  return res.json();
}

export async function register(email: string, name: string, password: string, role = 'lawyer') {
  return apiFetch('/api/v1/auth/register', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ email, name, password, role }),
  });
}

export async function login(email: string, password: string) {
  return apiFetch('/api/v1/auth/login', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ email, password }),
  });
}

export async function getMe(token: string) {
  return apiFetch('/api/v1/auth/me', {
    headers: { 'Authorization': `Bearer ${token}` },
  });
}

export async function listProjects() {
  return apiFetch('/api/v1/projects');
}

export async function createProject(name: string, type: string) {
  return apiFetch('/api/v1/projects', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'x-role': 'lawyer' },
    body: JSON.stringify({ name, type }),
  });
}

export async function getDocument(id: number) {
  return apiFetch(`/api/v1/documents/${id}`);
}

export async function exportMd(id: number): Promise<string> {
  const res = await fetch(`${BASE_URL}/api/v1/documents/${id}/export/md`, { method: 'POST' });
  return res.text();
}

export async function startWorkflow(projectId: number, template: string, payload: Record<string, string>) {
  return apiFetch('/api/v1/workflow-runs', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'x-role': 'lawyer' },
    body: JSON.stringify({ project_id: projectId, template, payload }),
  });
}

export async function listKnowledge(q = '') {
  return apiFetch(`/api/v1/knowledge${q ? `?q=${encodeURIComponent(q)}` : ''}`);
}

export async function createKnowledge(question: string, answer: string, tags: string[]) {
  return apiFetch('/api/v1/knowledge', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'x-role': 'lawyer' },
    body: JSON.stringify({ question, answer, tags }),
  });
}
