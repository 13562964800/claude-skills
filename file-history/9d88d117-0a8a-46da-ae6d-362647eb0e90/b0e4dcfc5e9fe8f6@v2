'use client';
import { useState } from 'react';
import { getDocument, exportMd } from '@/lib/api';

type Doc = { id: number; title: string; content: string; status: string };

export default function DocumentsPage() {
  const [docId, setDocId] = useState('1');
  const [doc, setDoc] = useState<Doc | null>(null);
  const [mdContent, setMdContent] = useState('');

  async function handleLoad() {
    const d = await getDocument(Number(docId));
    setDoc(d);
  }

  async function handleExportMd() {
    const md = await exportMd(Number(docId));
    setMdContent(md);
  }

  return (
    <main style={{ padding: '2rem', fontFamily: 'sans-serif' }}>
      <h1>文档中心</h1>
      <div style={{ display: 'flex', gap: '0.5rem', marginBottom: '1rem' }}>
        <input value={docId} onChange={e => setDocId(e.target.value)} style={{ width: '4rem' }} />
        <button onClick={handleLoad}>加载文档</button>
        <button onClick={handleExportMd}>导出 Markdown</button>
      </div>
      {doc && <pre style={{ background: '#f5f5f5', padding: '1rem' }}>{JSON.stringify(doc, null, 2)}</pre>}
      {mdContent && <pre style={{ background: '#eef', padding: '1rem' }}>{mdContent}</pre>}
    </main>
  );
}
