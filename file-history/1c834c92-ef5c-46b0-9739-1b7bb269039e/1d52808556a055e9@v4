const { app, BrowserWindow } = require('electron');
const path = require('path');
const { spawn } = require('child_process');
const http = require('http');

let mainWindow;
let apiProcess;
let webProcess;

function checkServer(url, callback) {
  const checkInterval = setInterval(() => {
    http.get(url, (res) => {
      if (res.statusCode === 200) {
        clearInterval(checkInterval);
        callback();
      }
    }).on('error', () => {
      // 继续等待
    });
  }, 1000);
}

function startAPI() {
  const pythonPath = 'python';
  const apiDir = path.join(__dirname, '..', 'api');

  console.log('Starting API from:', apiDir);

  apiProcess = spawn(pythonPath, ['-m', 'uvicorn', 'app.main:app', '--host', '127.0.0.1', '--port', '8000'], {
    cwd: apiDir,
    shell: true
  });

  apiProcess.stdout.on('data', (data) => {
    console.log(`API: ${data}`);
  });

  apiProcess.stderr.on('data', (data) => {
    console.error(`API: ${data}`);
  });

  apiProcess.on('error', (err) => {
    console.error('Failed to start API:', err);
  });
}

function startWeb() {
  const webDir = path.join(__dirname, '..', 'web');

  console.log('Starting Web from:', webDir);

  // 生产模式使用 next start
  webProcess = spawn('npx', ['next', 'start', '-p', '3000'], {
    cwd: webDir,
    shell: true,
    env: { ...process.env, NODE_ENV: 'production' }
  });

  webProcess.stdout.on('data', (data) => {
    console.log(`Web: ${data}`);
  });

  webProcess.stderr.on('data', (data) => {
    console.error(`Web: ${data}`);
  });

  webProcess.on('error', (err) => {
    console.error('Failed to start Web:', err);
  });
}

function createWindow() {
  mainWindow = new BrowserWindow({
    width: 1400,
    height: 900,
    show: false, // 先不显示
    webPreferences: {
      preload: path.join(__dirname, 'preload.js'),
      nodeIntegration: false,
      contextIsolation: true
    }
  });

  // 显示加载页面
  mainWindow.loadURL('data:text/html,<html><body style="margin:0;padding:0;display:flex;align-items:center;justify-content:center;height:100vh;font-family:sans-serif;background:#f5f5f5"><div style="text-align:center"><h1>LegalFlow Studio</h1><p>正在启动服务...</p><p style="color:#666;font-size:14px">请稍候 10-15 秒</p></div></body></html>');

  mainWindow.show();

  // 等待 Web 服务启动
  console.log('Waiting for web server...');
  checkServer('http://localhost:3000', () => {
    console.log('Web server is ready!');
    mainWindow.loadURL('http://localhost:3000');
  });

  mainWindow.on('closed', () => {
    mainWindow = null;
  });

  // 开发模式下打开 DevTools
  if (process.env.NODE_ENV === 'development') {
    mainWindow.webContents.openDevTools();
  }
}

app.on('ready', () => {
  startAPI();
  startWeb();
  createWindow();
});

app.on('window-all-closed', () => {
  if (apiProcess) {
    apiProcess.kill();
  }
  if (webProcess) {
    webProcess.kill();
  }
  if (process.platform !== 'darwin') {
    app.quit();
  }
});

app.on('activate', () => {
  if (mainWindow === null) {
    createWindow();
  }
});

app.on('before-quit', () => {
  if (apiProcess) {
    apiProcess.kill();
  }
  if (webProcess) {
    webProcess.kill();
  }
});
