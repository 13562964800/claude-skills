[project]
name = "legalflow-studio-api"
version = "0.1.0"
requires-python = ">=3.12"
dependencies = [
  "fastapi>=0.133.1",
  "uvicorn>=0.30.0",
]

[project.optional-dependencies]
dev = [
  "pytest>=9.0.0",
  "httpx>=0.28.0",
]

[tool.pytest.ini_options]
pythonpath = ["."]

[build-system]
requires = ["setuptools>=68.0"]
build-backend = "setuptools.build_meta"
