package com.ai.hotspot.data.local

import androidx.room.Database
import androidx.room.RoomDatabase
import com.ai.hotspot.data.local.dao.CustomRssDao
import com.ai.hotspot.data.local.dao.HotspotDao
import com.ai.hotspot.data.local.entity.CustomRssEntity
import com.ai.hotspot.data.local.entity.HotspotEntity

@Database(
    entities = [HotspotEntity::class, CustomRssEntity::class],
    version = 2,
    exportSchema = false
)
abstract class AppDatabase : RoomDatabase() {
    abstract fun hotspotDao(): HotspotDao
    abstract fun customRssDao(): CustomRssDao
}
