package com.ai.hotspot.domain.usecase

import com.ai.hotspot.domain.model.FilterState
import com.ai.hotspot.domain.model.Hotspot
import com.ai.hotspot.domain.repository.IHotspotRepository
import kotlinx.coroutines.flow.Flow
import javax.inject.Inject
import javax.inject.Singleton

@Singleton
class GetHotspotsUseCase @Inject constructor(
    private val repository: IHotspotRepository
) {
    operator fun invoke(filter: FilterState = FilterState()): Flow<List<Hotspot>> {
        return repository.getHotspots(filter)
    }
}
