    <text x="0" y="10" font-size="18" fill="{colors[1]}" text-anchor="middle" opacity="0.8">{description[:40]}</text>
  </g>

  <circle cx="150" cy="150" r="30" fill="{colors[2]}" opacity="0.3">
    <animate attributeName="r" values="30;35;30" dur="2s" repeatCount="indefinite"/>
  </circle>
  <circle cx="650" cy="300" r="25" fill="{colors[2]}" opacity="0.3">
    <animate attributeName="r" values="25;30;25" dur="2.5s" repeatCount="indefinite"/>
  </circle>
</svg>'''

def main():
    output_dir = "C:/Users/Administrator/插图/新插图"
    os.makedirs(output_dir, exist_ok=True)

    print(f"开始生成 {len(illustrations)} 个插图...")

    for num, (title, desc, colors) in illustrations.items():
        filename = f"插图{num:02d}.svg" if num < 100 else f"插图{num}.svg"
        filepath = os.path.join(output_dir, filename)

        svg_content = generate_svg(num, title, desc, colors)

        with open(filepath, 'w', encoding='utf-8') as f:
            f.write(svg_content)

        print(f"✓ 已生成: {filename}")

    print(f"\n✅ 完成！已生成 {len(illustrations)} 个插图")

if __name__ == "__main__":
    main()
