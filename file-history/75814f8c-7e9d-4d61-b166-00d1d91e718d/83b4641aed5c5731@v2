@echo off
chcp 65001 >nul
echo.
echo ========================================
echo   CourtAssistant - 快捷工具
echo   宋氏美学 @ 单夫纯律师 制作
echo ========================================
echo.
echo 当前已连接的设备:
"C:\Users\Administrator\AppData\Local\Android\Sdk\platform-tools\adb.exe" devices
echo.
echo ========================================
echo   请选择操作:
echo.
echo   [1] 编译并安装应用到手机
echo   [2] 仅安装（已有APK）
echo   [3] 启动应用
echo   [4] 停止应用
echo   [5] 清除应用数据
echo   [6] 查看设备信息
echo   [7] 发送测试短信
echo   [8] 截图
echo   [9] 退出
echo.
set /p choice=
if "%choice%"=="" set /p choice=请输入选项 [1-9]:
if errorlevel 1 goto :eof

if "%choice%"=="1" goto :install
if "%choice%"=="2" goto :install_only
if "%choice%"=="3" goto :start
if "%choice%"=="4" goto :stop
if "%choice%"=="5" goto :clear
if "%choice%"=="6" goto :info
if "%choice%"=="7" goto :sms
if "%choice%"=="8" goto :screenshot
if "%choice%"=="9" goto :eof

:install
echo.
echo ========================================
echo   编译并安装应用...
echo ========================================
echo.
cd /d "C:\Users\Administrator\CourtAssistant"
echo.
echo [1/2] 清理旧构建...
call gradlew clean
echo.
echo [2/2] 编译 Debug APK...
call gradlew assembleDebug
echo.
echo [3/2] 检查 APK 文件...
if not exist "app\build\outputs\apk\debug\app-debug.apk" (
    echo   错误: APK 文件不存在！
    pause
    goto :menu
)
echo.
echo [4/2] 卸载旧版本...
"C:\Users\Administrator\AppData\Local\Android\Sdk\platform-tools\adb.exe" uninstall com.courassistant.java
echo.
echo [5/2] 安装新版本...
"C:\Users\Administrator\AppData\Local\Android\Sdk\platform-tools\adb.exe" install -r app\build\outputs\apk\debug\app-debug.apk
echo.
echo ========================================
echo   安装完成！
echo ========================================
echo.
echo 应用已安装到您的手机，请检查：
echo   1. 手机上是否有 CourtAssistant 图标
echo   2. 是否自动启动（或手动启动）
echo.
goto :menu

:install_only
echo.
echo ========================================
echo   仅安装（不编译）
echo ========================================
echo.
if not exist "app\build\outputs\apk\debug\app-debug.apk" (
    echo   错误: APK 文件不存在！
    echo   请先运行选项 [1] 编译
    pause
    goto :menu
)
echo.
echo 正在安装...
"C:\Users\Administrator\AppData\Local\Android\Sdk\platform-tools\adb.exe" install -r app\build\outputs\apk\debug\app-debug.apk
echo.
echo 安装完成！
goto :menu

:start
echo.
echo ========================================
echo   启动应用...
echo ========================================
echo.
"C:\Users\Administrator\AppData\Local\Android\Sdk\platform-tools\adb.exe" shell am start -n com.courassistant.java/.ui.MainActivity
echo.
echo 应用已在手机上启动
goto :menu

:stop
echo.
echo ========================================
echo   停止应用...
echo ========================================
echo.
"C:\Users\Administrator\AppData\Local\Android\Sdk\platform-tools\adb.exe" shell am force-stop com.courassistant.java
echo.
echo 应用已停止
goto :menu

:clear
echo.
echo ========================================
echo   清除应用数据...
echo ========================================
echo.
"C:\Users\Administrator\AppData\Local\Android\Sdk\platform-tools\adb.exe" shell pm clear com.courassistant.java
echo.
echo 数据已清除
echo 下次启动将显示用户引导页
echo.
goto :menu

:info
echo.
echo ========================================
echo   设备信息
echo ========================================
echo.
"C:\Users\Administrator\AppData\Local\Android\Sdk\platform-tools\adb.exe" devices
echo.
"C:\Users\Administrator\AppData\Local\Android\Sdk\platform-tools\adb.exe" shell getprop ro.product.model
"C:\Users\Administrator\AppData\Local\Android\Sdk\platform-tools\adb.exe" shell getprop ro.build.version.release
echo.
goto :menu

:sms
echo.
echo ========================================
echo   发送测试短信
echo ========================================
echo.
echo 选择测试类型:
echo   1. 简单短信: 【测试】这是一条测试短信
echo   2. 法院短信: 【北京市第一中级人民法院】您有案件(2024)京01民初123号
echo   3. 带链接短信: 【法院】请点击链接: https://example.com/document.pdf
echo.
set /p choice=
if "%choice%"=="" set /p choice=请选择 [1-3]:
if errorlevel 1 goto :menu

if "%choice%"=="1" (
    echo 发送简单短信...
    "C:\Users\Administrator\AppData\Local\Android\Sdk\platform-tools\adb.exe" shell am broadcast -a android.provider.Telephony.SMS_RECEIVED --es pdus "[BATCH]" --ee sender "\"10690000\"" --ee extras "string:【测试】这是一条测试短信"
    echo. 发送成功！请检查手机
)
if "%choice%"=="2" (
    echo 发送法院短信...
    "C:\Users\Administrator\AppData\Local\Android\Sdk\platform-tools\adb.exe" shell am broadcast -a android.provider.Telephony.SMS_RECEIVED --es pdus "[BATCH]" --ee sender "\"10690000\"" --ee extras "string:【北京市第一中级人民法院】您有案件(2024)京01民初123号将于2024年3月15日上午9:30在第三法庭开庭，请准时出席。"
    echo. 发送成功！请检查手机
)
if "%choice%"=="3" (
    echo 发送带链接短信...
    "C:\Users\Administrator\AppData\Local\Android\Sdk\platform-tools\adb.exe" shell am broadcast -a android.provider.Telephony.SMS_RECEIVED --es pdus "[BATCH]" --ee sender "\"10690000\"" --ee extras "string:【法院】请点击链接下载传票：https://example.com/document.pdf"
    echo. 发送成功！请检查手机
)

echo.
goto :menu

:screenshot
echo.
echo ========================================
echo   截图
echo ========================================
echo.
"C:\Users\Administrator\AppData\Local\Android\Sdk\platform-tools\adb.exe" exec-out screencap -p > screenshot.png
echo.
echo 截图已保存到: screenshot.png
pause
goto :menu

:menu
echo.
echo ========================================
echo   返回主菜单
echo ========================================
echo.
goto :choice

:eof
pause
