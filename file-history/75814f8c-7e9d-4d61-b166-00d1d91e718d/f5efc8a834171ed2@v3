                for (CourtMessageEntity entity : entities) {
                    messages.add(convertToModel(entity));
                }
                if (callback != null) {
                    callback.onResult(messages);
                }
            } catch (Exception e) {
                Log.e(TAG, "获取已解析短信失败", e);
                if (callback != null) {
                    callback.onError(e.getMessage());
                }
            }
        });
    }

    /**
     * 获取包含传票的短信
     */
    public void getSummonsMessages(OnMessagesCallback callback) {
        executor.execute(() -> {
            try {
                List<CourtMessageEntity> entities = messageDao.getSummonsMessages();
                List<CourtMessage> messages = new ArrayList<>();
                for (CourtMessageEntity entity : entities) {
                    messages.add(convertToModel(entity));
                }
                if (callback != null) {
                    callback.onResult(messages);
                }
            } catch (Exception e) {
                Log.e(TAG, "获取传票短信失败", e);
                if (callback != null) {
                    callback.onError(e.getMessage());
                }
            }
        });
    }

    /**
     * 获取包含链接的短信
     */
    public void getMessagesWithUrl(OnMessagesCallback callback) {
        executor.execute(() -> {
            try {
                List<CourtMessageEntity> entities = messageDao.getMessagesWithUrl();
                List<CourtMessage> messages = new ArrayList<>();
                for (CourtMessageEntity entity : entities) {
                    messages.add(convertToModel(entity));
                }
                if (callback != null) {
                    callback.onResult(messages);
                }
            } catch (Exception e) {
                Log.e(TAG, "获取包含链接的短信失败", e);
                if (callback != null) {
                    callback.onError(e.getMessage());
                }
            }
        });
    }

    /**
     * 根据时间范围获取短信
     */
    public void getMessagesByTimeRange(long startTime, long endTime, OnMessagesCallback callback) {
        executor.execute(() -> {
            try {
                List<CourtMessageEntity> entities = messageDao.getByReceiveTimeRange(startTime, endTime);
                List<CourtMessage> messages = new ArrayList<>();
                for (CourtMessageEntity entity : entities) {
                    messages.add(convertToModel(entity));
                }
                if (callback != null) {
                    callback.onResult(messages);
                }
            } catch (Exception e) {
                Log.e(TAG, "根据时间范围获取短信失败", e);
                if (callback != null) {
                    callback.onError(e.getMessage());
                }
            }
        });
    }

    /**
     * 搜索短信
     */
    public void searchMessages(String keyword, OnMessagesCallback callback) {
        executor.execute(() -> {
            try {
                List<CourtMessageEntity> entities = messageDao.searchByContent(keyword);
                List<CourtMessage> messages = new ArrayList<>();
                for (CourtMessageEntity entity : entities) {
                    messages.add(convertToModel(entity));
                }
                if (callback != null) {
                    callback.onResult(messages);
                }
            } catch (Exception e) {
                Log.e(TAG, "搜索短信失败", e);
                if (callback != null) {
                    callback.onError(e.getMessage());
                }
            }
        });
    }

    /**
     * 批量更新解析状态
     */
    public void updateParseStatusBatch(List<Long> ids, int status, OnResultCallback callback) {
        executor.execute(() -> {
            try {
                messageDao.updateParseStatusBatch(ids, status);
                Log.d(TAG, "批量更新解析状态成功: " + ids.size() + " 条");
                if (callback != null) {
                    callback.onSuccess(ids.size());
                }
            } catch (Exception e) {
                Log.e(TAG, "批量更新解析状态失败", e);
                if (callback != null) {
                    callback.onError(e.getMessage());
                }
            }
        });
    }

    /**
     * 统计短信数量
     */
    public void getMessageCount(OnResultCallback callback) {
        executor.execute(() -> {
            try {
                int count = messageDao.getCount();
                if (callback != null) {
                    callback.onSuccess(count);
                }
            } catch (Exception e) {
                Log.e(TAG, "统计短信数量失败", e);
                if (callback != null) {
                    callback.onError(e.getMessage());
                }
            }
        });
    }

    /**
     * 清空所有短信
     */
    public void clearAllMessages(OnResultCallback callback) {
        executor.execute(() -> {
            try {
                messageDao.deleteAll();
                Log.d(TAG, "清空所有短信成功");
                if (callback != null) {
                    callback.onSuccess(true);
                }
            } catch (Exception e) {
                Log.e(TAG, "清空所有短信失败", e);
                if (callback != null) {
                    callback.onError(e.getMessage());
                }
            }
        });
    }

    /**
     * 转换为实体
     */
    private CourtMessageEntity convertToEntity(CourtMessage model) {
        if (model == null) return null;

        CourtMessageEntity entity = new CourtMessageEntity();
        entity.setId(model.getId());
        entity.setSender(model.getSender());
        entity.setContent(model.getContent());
        entity.setReceiveTime(model.getReceiveTime());
        entity.setIsParsed(model.getIsParsed() ? 1 : 0);
        entity.setParsedCaseNo(model.getParsedCaseNo());
        entity.setCourtName(model.getCourtName());
        entity.setHearingTime(model.getHearingTime());
        entity.setHasUrl(model.getHasUrl() ? 1 : 0);
        entity.setDocumentIds(model.getDocumentIds());
        entity.setCreatedAt(model.getCreatedAt());
        return entity;
    }

    /**
     * 转换为模型
     */
    private CourtMessage convertToModel(CourtMessageEntity entity) {
        if (entity == null) return null;

        CourtMessage model = new CourtMessage();
        model.setId(entity.getId());
        model.setSender(entity.getSender());
        model.setContent(entity.getContent());
        model.setReceiveTime(entity.getReceiveTime());
        model.setIsParsed(entity.getIsParsed() == 1);
        model.setParsedCaseNo(entity.getParsedCaseNo());
        model.setCourtName(entity.getCourtName());
        model.setHearingTime(entity.getHearingTime());
        model.setHasUrl(entity.getHasUrl() == 1);
        model.setDocumentIds(entity.getDocumentIds());
        model.setCreatedAt(entity.getCreatedAt());
        return model;
    }

    /**
     * 回调接口 - 单个结果
     */
    public interface OnResultCallback {
        void onSuccess(Object result);
        void onError(String error);
    }

    /**
     * 回调接口 - 短信结果
     */
    public interface OnMessageCallback {
        void onResult(CourtMessage message);
        void onError(String error);
    }

    /**
     * 回调接口 - 短信列表结果
     */
    public interface OnMessagesCallback {
        void onResult(List<CourtMessage> messages);
        void onError(String error);
    }

    /**
     * 关闭仓库
     */
    public void close() {
        if (executor != null && !executor.isShutdown()) {
            executor.shutdown();
        }
    }
}
