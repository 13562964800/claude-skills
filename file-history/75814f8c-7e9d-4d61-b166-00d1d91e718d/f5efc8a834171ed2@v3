package com.courassistant.java.repository;

import android.content.Context;
import android.util.Log;

import androidx.lifecycle.MutableLiveData;

import com.shanfuchun.courtassistant.java.database.CourtMessageDao;
import com.shanfuchun.courtassistant.java.database.CourtMessageEntity;
import com.shanfuchun.courtassistant.java.database.CourtDatabase;
import com.shanfuchun.courtassistant.java.model.CourtMessage;

import java.util.ArrayList;
import java.util.List;
import java.util.concurrent.ExecutorService;
import java.util.concurrent.Executors;

/**
 * 短信数据仓库
 * 单例模式，提供统一的短信数据访问接口
 *
 * 宋氏美学，单夫纯律师 制作
 */
public class MessageRepository {

    private static final String TAG = "MessageRepository";

    private static MessageRepository instance;
    private CourtMessageDao messageDao;
    private ExecutorService executor;
    private MutableLiveData<List<CourtMessage>> allMessagesLiveData;

    private MessageRepository(Context context) {
        CourtDatabase database = CourtDatabase.getInstance(context);
        messageDao = database.courtMessageDao();
        executor = Executors.newFixedThreadPool(4);
        allMessagesLiveData = new MutableLiveData<>();
    }

    /**
     * 获取仓库实例
     */
    public static synchronized MessageRepository getInstance(Context context) {
        if (instance == null) {
            instance = new MessageRepository(context.getApplicationContext());
        }
        return instance;
    }

    /**
     * 插入短信
     */
    public void insertMessage(CourtMessage message, OnResultCallback callback) {
        executor.execute(() -> {
            try {
                CourtMessageEntity entity = convertToEntity(message);
                long id = messageDao.insert(entity);
                message.setId(id);
                Log.d(TAG, "短信插入成功: " + message.getSender());
                if (callback != null) {
                    callback.onSuccess(id);
                }
            } catch (Exception e) {
                Log.e(TAG, "短信插入失败", e);
                if (callback != null) {
                    callback.onError(e.getMessage());
                }
            }
        });
    }

    /**
     * 批量插入短信
     */
    public void insertMessages(List<CourtMessage> messages, OnResultCallback callback) {
        executor.execute(() -> {
            try {
                List<CourtMessageEntity> entities = new ArrayList<>();
                for (CourtMessage msg : messages) {
                    entities.add(convertToEntity(msg));
                }
                List<Long> ids = messageDao.insertAll(entities);
                Log.d(TAG, "批量插入短信成功: " + ids.size() + " 条");
                if (callback != null) {
                    callback.onSuccess(ids.size());
                }
            } catch (Exception e) {
                Log.e(TAG, "批量插入短信失败", e);
                if (callback != null) {
                    callback.onError(e.getMessage());
                }
            }
        });
    }

    /**
     * 更新短信
     */
    public void updateMessage(CourtMessage message, OnResultCallback callback) {
        executor.execute(() -> {
            try {
                CourtMessageEntity entity = convertToEntity(message);
                int rows = messageDao.update(entity);
                Log.d(TAG, "短信更新成功: id=" + message.getId());
                if (callback != null) {
                    callback.onSuccess(rows);
                }
            } catch (Exception e) {
                Log.e(TAG, "短信更新失败", e);
                if (callback != null) {
                    callback.onError(e.getMessage());
                }
            }
        });
    }

    /**
     * 删除短信
     */
    public void deleteMessage(long messageId, OnResultCallback callback) {
        executor.execute(() -> {
            try {
                messageDao.deleteById(messageId);
                Log.d(TAG, "短信删除成功: id=" + messageId);
                if (callback != null) {
                    callback.onSuccess(true);
                }
            } catch (Exception e) {
                Log.e(TAG, "短信删除失败", e);
                if (callback != null) {
                    callback.onError(e.getMessage());
                }
            }
        });
    }

    /**
     * 根据ID获取短信
     */
    public void getMessageById(long id, OnMessageCallback callback) {
        executor.execute(() -> {
            try {
                CourtMessageEntity entity = messageDao.getById(id);
                CourtMessage message = convertToModel(entity);
                if (callback != null) {
                    callback.onResult(message);
                }
            } catch (Exception e) {
                Log.e(TAG, "获取短信失败", e);
                if (callback != null) {
                    callback.onError(e.getMessage());
                }
            }
        });
    }

    /**
     * 获取所有短信
     */
    public void getAllMessages(OnMessagesCallback callback) {
        executor.execute(() -> {
            try {
                List<CourtMessageEntity> entities = messageDao.getAll();
                List<CourtMessage> messages = new ArrayList<>();
                for (CourtMessageEntity entity : entities) {
                    messages.add(convertToModel(entity));
                }
                if (callback != null) {
                    callback.onResult(messages);
                }
            } catch (Exception e) {
                Log.e(TAG, "获取所有短信失败", e);
                if (callback != null) {
                    callback.onError(e.getMessage());
                }
            }
        });
    }

    /**
     * 获取所有短信（LiveData）
     */
    public MutableLiveData<List<CourtMessage>> getAllMessagesLiveData() {
        executor.execute(() -> {
            List<CourtMessageEntity> entities = messageDao.getAll();
            List<CourtMessage> messages = new ArrayList<>();
            for (CourtMessageEntity entity : entities) {
                messages.add(convertToModel(entity));
            }
            allMessagesLiveData.postValue(messages);
        });
        return allMessagesLiveData;
    }

    /**
     * 根据发送者获取短信
     */
    public void getMessagesBySender(String sender, OnMessagesCallback callback) {
        executor.execute(() -> {
            try {
                List<CourtMessageEntity> entities = messageDao.getBySender(sender);
                List<CourtMessage> messages = new ArrayList<>();
                for (CourtMessageEntity entity : entities) {
                    messages.add(convertToModel(entity));
                }
                if (callback != null) {
                    callback.onResult(messages);
                }
            } catch (Exception e) {
                Log.e(TAG, "根据发送者获取短信失败", e);
                if (callback != null) {
                    callback.onError(e.getMessage());
                }
            }
        });
    }

    /**
     * 获取已解析的短信
     */
    public void getParsedMessages(OnMessagesCallback callback) {
        executor.execute(() -> {
            try {
                List<CourtMessageEntity> entities = messageDao.getParsedMessages();
