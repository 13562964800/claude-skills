#!/bin/bash

# CourtAssistant 快速测试参考
# 宋氏美学 · 单夫纯律师 制作

echo "================================"
echo "CourtAssistant 快速测试参考"
echo "================================"
echo ""

# 颜色
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${BLUE}📱 常用 ADB 命令${NC}"
echo ""

echo "1️⃣ 安装应用"
echo "  ./gradlew installDebug"
echo "  或: adb install -r app/build/outputs/apk/debug/app-debug.apk"
echo ""

echo "2️⃣ 卸载应用"
echo "  adb uninstall com.courassistant.java"
echo ""

echo "3️⃣ 启动应用"
echo "  adb shell am start -n com.courassistant.java/.ui.MainActivity"
echo ""

echo "4️⃣ 停止应用"
echo "  adb shell am force-stop com.courassistant.java"
echo ""

echo "5️⃣ 清除数据"
echo "  adb shell pm clear com.courassistant.java"
echo ""

echo "6️⃣ 查看日志"
echo "  adb logcat -s SmsReceiver:SmsParser:PdfParser:CourtDatabase | tee log.txt"
echo ""

echo "7️⃣ 截图"
echo "  adb exec-out screencap -p > screen.png"
echo ""

echo "8️⃣ 录屏"
echo "  adb shell screenrecord /sdcard/demo.mp4"
echo "  # 按 Ctrl+C 停止"
echo ""

echo "9️⃣ 上传文件"
echo "  adb push test.txt /sdcard/"
echo ""

echo "🔥 模拟发送测试短信"
echo ""
echo "  # 简单短信"
echo "  adb shell am broadcast -a android.provider.Telephony.SMS_RECEIVED \\"
echo "    --es pdus \"[BATCH]\" \\"
echo "    --ee sender \"\\\"10690000\\\"\" \\"
echo "    --ee extras \"string:test message\""
echo ""

echo "  # 法院短信（带案件信息）"
echo "  adb shell am broadcast -a android.provider.Telephony.SMS_RECEIVED \\"
echo "    --es pdus \"[BATCH]\" \\"
echo "    --ee sender \"\\\"10690000\\\"\" \\"
echo "    --ee extras \"string:【北京市第一中级人民法院】您有案件(2024)京01民初123号将于2024年3月15日上午9:30在第三法庭开庭，请准时出席。\""
echo ""

echo "  # 带链接的短信"
echo "  adb shell am broadcast -a android.provider.Telephony.SMS_RECEIVED \\"
echo "    --es pdus \"[BATCH]\" \\"
echo "    --ee sender \"\\\"10690000\\\"\" \\"
echo "    --ee extras \"string:【法院】请点击链接下载传票：https://example.com/summons.pdf\""
echo ""

echo -e "${BLUE}🧪 测试场景${NC}"
echo ""

echo "场景 1: 首次启动（清除数据）"
echo "  adb shell pm clear com.courassistant.java"
echo "  adb shell am start -n com.courassistant.java/.ui.OnboardingActivity"
echo "  ✅ 应显示 4 页引导"
echo ""

echo "场景 2: 正常启动"
echo "  adb shell am start -n com.courassistant.java/.ui.MainActivity"
echo "  ✅ 应直接进入主界面"
echo ""

echo "场景 3: 权限测试"
echo "  adb shell pm grant com.courassistant.java android.permission.READ_SMS"
echo "  adb shell pm grant com.courassistant.java android.permission.RECEIVE_SMS"
echo "  adb shell pm grant com.courassistant.java android.permission.READ_CALENDAR"
echo "  adb shell pm grant com.courassistant.java android.permission.WRITE_CALENDAR"
echo ""

echo "场景 4: 测试短信接收"
echo "  # 先启动应用"
echo "  adb shell am start -n com.courassistant.java/.ui.MainActivity"
echo "  sleep 2"
echo "  # 发送测试短信"
echo "  adb shell am broadcast -a android.provider.Telephony.SMS_RECEIVED --es pdus \"[BATCH]\" --ee sender \"10690000\" --ee extras \"string:测试短信\""
echo "  sleep 3"
echo "  # 检查日志"
echo "  adb logcat -d -s SmsReceiver:SmsParser | head -20"
echo ""

echo -e "${BLUE}📊 查看应用信息${NC}"
echo ""

echo "包名: com.courassistant.java"
echo "主Activity: .ui.MainActivity"
echo "引导Activity: .ui.OnboardingActivity"
echo "设置Activity: .ui.SettingsActivity"
echo "WebViewActivity: .ui.WebViewActivity"
echo ""

echo -e "${BLUE}🎨 宋氏美学配色测试${NC}"
echo ""

echo "主色: dai_cyan (#4A6B5A)"
echo "背景: bg_rice (#F5F0E8)"
echo "文字: ink_gray (#3A3A3A)"
echo ""

echo -e "${YELLOW}⚠️  注意事项${NC}"
echo ""

echo "1. 首次安装后应显示引导页"
echo "2. 点击\"跳过\"后下次启动不再显示"
echo "3. 可通过清除数据重新显示引导页"
echo "4. 日志会记录所有解析的短信"
echo "5. PDF 下载需要点击链接"
echo ""

echo -e "${GREEN}✅ 快速测试命令${NC}"
echo ""

echo "一键完整测试:"
echo "  ./emulator_test.sh"
echo ""

echo "快速短信测试:"
echo "  ./gradlew installDebug && adb shell am broadcast -a android.provider.Telephony.SMS_RECEIVED --es pdus \"[BATCH]\" --ee sender \"10690000\" --ee extras \"string:测试\" && adb logcat -s SmsReceiver:SmsParser"
echo ""

echo "快速日志监控:"
echo "  adb logcat -s CourtAssistant:SmsReceiver:SmsParser:PdfParser:CourtDatabase"
echo ""

echo ""
echo "================================"
echo "详细测试指南请查看: EMULATOR_TEST_GUIDE.md"
echo "================================"
