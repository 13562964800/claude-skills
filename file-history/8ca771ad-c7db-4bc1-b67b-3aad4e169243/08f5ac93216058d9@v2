package com.videodownload.app.ui.transcription

import android.app.Application
import android.content.Intent
import androidx.lifecycle.AndroidViewModel
import androidx.lifecycle.viewModelScope
import com.videodownload.app.data.model.TranscriptionEntity
import com.videodownload.app.data.model.TranscriptionStatus
import com.videodownload.app.repository.TranscriptionRepository
import com.videodownload.app.service.TranscriptionProgress
import com.videodownload.app.service.TranscriptionService
import kotlinx.coroutines.flow.*
import kotlinx.coroutines.launch

/**
 * 转录 ViewModel
 *
 * 功能：
 * 1. 启动/取消转录
 * 2. 监听转录进度
 * 3. 管理转录结果
 */
class TranscriptionViewModel(application: Application) : AndroidViewModel(application) {

    private val repository = TranscriptionRepository(application)

    // 转录进度
    private val _progress = MutableStateFlow<TranscriptionProgress?>(null)
    val progress: StateFlow<TranscriptionProgress?> = _progress.asStateFlow()

    // 转录结果
    private val _transcription = MutableStateFlow<TranscriptionEntity?>(null)
    val transcription: StateFlow<TranscriptionEntity?> = _transcription.asStateFlow()

    // UI 状态
    private val _uiState = MutableStateFlow<TranscriptionUiState>(TranscriptionUiState.Idle)
    val uiState: StateFlow<TranscriptionUiState> = _uiState.asStateFlow()

    /**
     * 加载转录结果
     */
    fun loadTranscription(videoId: String) {
        viewModelScope.launch {
            val result = repository.getTranscription(videoId)
            _transcription.value = result

            _uiState.value = when {
                result == null -> TranscriptionUiState.NotStarted
                result.status == TranscriptionStatus.COMPLETED -> TranscriptionUiState.Completed(result)
                result.status == TranscriptionStatus.FAILED -> TranscriptionUiState.Failed(result.errorMessage)
                else -> TranscriptionUiState.Idle
            }
        }
    }

    /**
     * 开始转录
     */
    fun startTranscription(videoId: String, engine: String = "auto") {
        val context = getApplication<Application>()

        // 启动前台服务
        val intent = Intent(context, TranscriptionService::class.java).apply {
            action = TranscriptionService.ACTION_START
            putExtra(TranscriptionService.EXTRA_VIDEO_ID, videoId)
            putExtra(TranscriptionService.EXTRA_ENGINE, engine)
        }

        context.startForegroundService(intent)

        _uiState.value = TranscriptionUiState.Transcribing
    }

    /**
     * 取消转录
     */
    fun cancelTranscription() {
        val context = getApplication<Application>()

        val intent = Intent(context, TranscriptionService::class.java).apply {
            action = TranscriptionService.ACTION_CANCEL
        }

        context.startService(intent)

        _uiState.value = TranscriptionUiState.Idle
    }

    /**
     * 重新转录
     */
    fun retryTranscription(videoId: String, engine: String = "auto") {
        viewModelScope.launch {
            // 删除旧的转录结果
            repository.deleteTranscription(videoId)

            // 开始新的转录
            startTranscription(videoId, engine)
        }
    }

    /**
     * 测试引擎
     */
    fun testEngine(engineType: String, apiKey: String? = null) {
        viewModelScope.launch {
            _uiState.value = TranscriptionUiState.Testing

            val result = repository.testEngine(engineType, apiKey)

            _uiState.value = if (result.success) {
                TranscriptionUiState.TestSuccess(result.message)
            } else {
                TranscriptionUiState.TestFailed(result.message)
            }
        }
    }

    /**
     * 监听服务进度（需要从 Service 获取）
     */
    fun observeServiceProgress(serviceProgress: StateFlow<TranscriptionProgress?>) {
        viewModelScope.launch {
            serviceProgress.collect { progress ->
                _progress.value = progress

                // 根据进度更新 UI 状态
                progress?.let {
                    when (it.status) {
                        TranscriptionStatus.COMPLETED -> {
                            loadTranscription(it.videoId)
                            _uiState.value = TranscriptionUiState.Completed(_transcription.value)
                        }
                        TranscriptionStatus.FAILED -> {
                            _uiState.value = TranscriptionUiState.Failed(it.message)
                        }
                        TranscriptionStatus.CANCELLED -> {
                            _uiState.value = TranscriptionUiState.Idle
                        }
                        else -> {
                            _uiState.value = TranscriptionUiState.Transcribing
                        }
                    }
                }
            }
        }
    }
}

/**
 * 转录 UI 状态
 */
sealed class TranscriptionUiState {
    object Idle : TranscriptionUiState()
    object NotStarted : TranscriptionUiState()
    object Transcribing : TranscriptionUiState()
    data class Completed(val transcription: TranscriptionEntity?) : TranscriptionUiState()
    data class Failed(val error: String?) : TranscriptionUiState()
    object Testing : TranscriptionUiState()
    data class TestSuccess(val message: String) : TranscriptionUiState()
    data class TestFailed(val message: String) : TranscriptionUiState()
}
