package com.videodownload.app.utils

import android.content.Context
import com.arthenica.ffmpegkit.FFmpegKit
import com.arthenica.ffmpegkit.ReturnCode
import com.videodownload.app.repository.AudioSegment
import kotlinx.coroutines.Dispatchers
import kotlinx.coroutines.withContext
import java.io.File

/**
 * FFmpeg 工具类
 */
class FFmpegHelper(private val context: Context) {

    /**
     * 提取音频
     */
    suspend fun extractAudio(videoPath: String): String = withContext(Dispatchers.IO) {
        val outputPath = "${videoPath}_audio.mp3"

        val command = "-i \"$videoPath\" -vn -acodec libmp3lame -ar 16000 -ac 1 -ab 128k \"$outputPath\""

        val session = FFmpegKit.execute(command)

        if (ReturnCode.isSuccess(session.returnCode)) {
            outputPath
        } else {
            throw Exception("Failed to extract audio: ${session.failStackTrace}")
        }
    }

    /**
     * 提取音频片段
     */
    suspend fun extractSegment(
        inputPath: String,
        startTime: Float,
        endTime: Float,
        outputPath: String
    ): String = withContext(Dispatchers.IO) {
        val command = "-i \"$inputPath\" -ss $startTime -to $endTime -c copy \"$outputPath\""

        val session = FFmpegKit.execute(command)

        if (ReturnCode.isSuccess(session.returnCode)) {
            outputPath
        } else {
            throw Exception("Failed to extract segment: ${session.failStackTrace}")
        }
    }

    /**
     * 获取音频时长
     */
    suspend fun getAudioDuration(audioPath: String): Float = withContext(Dispatchers.IO) {
        val command = "-i \"$audioPath\" -show_entries format=duration -v quiet -of csv=\"p=0\""

        val session = FFmpegKit.execute(command)

        if (ReturnCode.isSuccess(session.returnCode)) {
            session.output?.trim()?.toFloatOrNull() ?: 0f
        } else {
            0f
        }
    }

    /**
     * 检测静音点
     */
    suspend fun detectSilence(audioPath: String): List<Float> = withContext(Dispatchers.IO) {
        val command = "-i \"$audioPath\" -af silencedetect=noise=-30dB:d=0.5 -f null -"

        val session = FFmpegKit.execute(command)

        val silencePoints = mutableListOf<Float>()

        session.allLogsAsString?.let { output ->
            val regex = "silence_end: ([0-9.]+)".toRegex()
            regex.findAll(output).forEach { match ->
                match.groupValues[1].toFloatOrNull()?.let { silencePoints.add(it) }
            }
        }

        silencePoints
    }

    /**
     * 转换为 PCM 格式
     */
    suspend fun convertToPCM(audioPath: String): String = withContext(Dispatchers.IO) {
        val outputPath = "$audioPath.pcm"

        val command = "-i \"$audioPath\" -ar 16000 -ac 1 -f s16le \"$outputPath\""

        val session = FFmpegKit.execute(command)

        if (ReturnCode.isSuccess(session.returnCode)) {
            outputPath
        } else {
            throw Exception("Failed to convert to PCM: ${session.failStackTrace}")
        }
    }
}
