package com.videodownload.app.data.model

import androidx.room.Entity
import androidx.room.PrimaryKey
import androidx.room.TypeConverters
import com.videodownload.app.data.Converters

/**
 * 转录结果实体
 */
@Entity(tableName = "transcriptions")
@TypeConverters(Converters::class)
data class TranscriptionEntity(
    @PrimaryKey
    val videoId: String,

    // 转录文本
    val text: String,

    // 词级时间戳
    val words: List<Word>,

    // 检测到的语言
    val language: String,

    // 转录引擎
    val engine: String, // "groq" or "whisper_cpp"

    // 转录状态
    val status: TranscriptionStatus,

    // 创建时间
    val createdAt: Long,

    // 更新时间
    val updatedAt: Long,

    // 总时长（秒）
    val duration: Float,

    // 分段信息
    val segments: List<Segment>? = null,

    // 错误信息
    val errorMessage: String? = null
)

/**
 * 词级时间戳
 */
data class Word(
    val word: String,
    val start: Float,
    val end: Float,
    val confidence: Float? = null
)

/**
 * 分段信息
 */
data class Segment(
    val index: Int,
    val startTime: Float,
    val endTime: Float,
    val text: String,
    val status: SegmentStatus
)

/**
 * 转录状态
 */
enum class TranscriptionStatus {
    PENDING,        // 等待中
    EXTRACTING,     // 提取音频中
    SEGMENTING,     // 分段中
    TRANSCRIBING,   // 转录中
    COMPLETED,      // 完成
    FAILED,         // 失败
    CANCELLED       // 已取消
}

/**
 * 分段状态
 */
enum class SegmentStatus {
    PENDING,        // 等待中
    TRANSCRIBING,   // 转录中
    COMPLETED,      // 完成
    FAILED          // 失败
}
