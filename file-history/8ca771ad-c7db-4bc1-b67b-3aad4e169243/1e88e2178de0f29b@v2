package com.videodownload.app.ui.settings

import android.app.Application
import androidx.lifecycle.AndroidViewModel
import androidx.lifecycle.viewModelScope
import com.videodownload.app.repository.TranscriptionRepository
import com.videodownload.app.utils.PreferenceManager
import kotlinx.coroutines.flow.MutableStateFlow
import kotlinx.coroutines.flow.StateFlow
import kotlinx.coroutines.flow.asStateFlow
import kotlinx.coroutines.launch

/**
 * 设置 ViewModel
 */
class SettingsViewModel(application: Application) : AndroidViewModel(application) {

    private val preferenceManager = PreferenceManager(application)
    private val repository = TranscriptionRepository(application)

    private val _settings = MutableStateFlow(loadSettings())
    val settings: StateFlow<AppSettings> = _settings.asStateFlow()

    private val _uiState = MutableStateFlow<SettingsUiState>(SettingsUiState.Idle)
    val uiState: StateFlow<SettingsUiState> = _uiState.asStateFlow()

    private fun loadSettings(): AppSettings {
        return AppSettings(
            groqApiKey = preferenceManager.getGroqApiKey(),
            defaultEngine = preferenceManager.getDefaultEngine(),
            aiAssistantEnabled = preferenceManager.isAIAssistantEnabled(),
            autoTranscribeEnabled = preferenceManager.isAutoTranscribeEnabled(),
            downloadPath = preferenceManager.getDownloadPath()
        )
    }

    fun updateApiKey(apiKey: String) {
        preferenceManager.setGroqApiKey(apiKey)
        _settings.value = _settings.value.copy(groqApiKey = apiKey)
    }

    fun updateDefaultEngine(engine: String) {
        preferenceManager.setDefaultEngine(engine)
        _settings.value = _settings.value.copy(defaultEngine = engine)
    }

    fun toggleAIAssistant(enabled: Boolean) {
        preferenceManager.setAIAssistantEnabled(enabled)
        _settings.value = _settings.value.copy(aiAssistantEnabled = enabled)
    }

    fun testConnection() {
        viewModelScope.launch {
            _uiState.value = SettingsUiState.Testing

            val result = repository.testEngine("groq", _settings.value.groqApiKey)

            _uiState.value = if (result.success) {
                SettingsUiState.TestSuccess(result.message)
            } else {
                SettingsUiState.TestFailed(result.message)
            }
        }
    }

    fun downloadModel() {
        // TODO: 实现模型下载
    }
}

/**
 * 应用设置
 */
data class AppSettings(
    val groqApiKey: String?,
    val defaultEngine: String,
    val aiAssistantEnabled: Boolean,
    val autoTranscribeEnabled: Boolean,
    val downloadPath: String
)

/**
 * 设置 UI 状态
 */
sealed class SettingsUiState {
    object Idle : SettingsUiState()
    object Testing : SettingsUiState()
    data class TestSuccess(val message: String) : SettingsUiState()
    data class TestFailed(val message: String) : SettingsUiState()
}
