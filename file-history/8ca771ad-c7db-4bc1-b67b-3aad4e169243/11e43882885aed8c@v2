@echo off
chcp 65001 >nul
echo ============================================================
echo 视频下载转录系统 - 一键安装程序
echo ============================================================
echo.

REM 检查管理员权限
net session >nul 2>&1
if %errorlevel% neq 0 (
    echo [!] 需要管理员权限
    echo     请右键点击此文件，选择"以管理员身份运行"
    pause
    exit /b 1
)

echo [1/6] 检查 Python...
python --version >nul 2>&1
if %errorlevel% neq 0 (
    echo [X] Python 未安装
    echo     正在打开 Python 下载页面...
    start https://www.python.org/downloads/
    pause
    exit /b 1
)
python --version
echo [OK] Python 已安装
echo.

echo [2/6] 检查 FFmpeg...
ffmpeg -version >nul 2>&1
if %errorlevel% neq 0 (
    echo [!] FFmpeg 未安装
    echo     正在打开 FFmpeg 下载页面...
    start https://ffmpeg.org/download.html
    echo.
    echo     下载后请：
    echo     1. 解压到 C:\ffmpeg
    echo     2. 将 C:\ffmpeg\bin 添加到系统 PATH
    echo     3. 重新运行此安装程序
    pause
    exit /b 1
)
ffmpeg -version | findstr "ffmpeg version"
echo [OK] FFmpeg 已安装
echo.

echo [3/6] 升级 pip...
python -m pip install --upgrade pip -i https://pypi.tuna.tsinghua.edu.cn/simple
echo.

echo [4/6] 安装 Python 依赖...
cd /d "%~dp0"
pip install -r requirements.txt -i https://pypi.tuna.tsinghua.edu.cn/simple
if %errorlevel% neq 0 (
    echo [X] 依赖安装失败
    pause
    exit /b 1
)
echo [OK] 依赖安装完成
echo.

echo [5/6] 创建配置文件...
if not exist config.yaml (
    copy config.yaml.example config.yaml >nul 2>&1
    echo [OK] 配置文件已创建
) else (
    echo [OK] 配置文件已存在
)
echo.

echo [6/6] 创建快捷方式...
echo Set oWS = WScript.CreateObject("WScript.Shell") > CreateShortcut.vbs
echo sLinkFile = "%USERPROFILE%\Desktop\视频下载转录服务.lnk" >> CreateShortcut.vbs
echo Set oLink = oWS.CreateShortcut(sLinkFile) >> CreateShortcut.vbs
echo oLink.TargetPath = "%~dp0start.bat" >> CreateShortcut.vbs
echo oLink.WorkingDirectory = "%~dp0" >> CreateShortcut.vbs
echo oLink.Description = "视频下载转录服务" >> CreateShortcut.vbs
echo oLink.Save >> CreateShortcut.vbs
cscript //nologo CreateShortcut.vbs
del CreateShortcut.vbs
echo [OK] 桌面快捷方式已创建
echo.

echo ============================================================
echo [OK] 安装完成！
echo ============================================================
echo.
echo 下一步:
echo 1. 编辑 config.yaml 配置 Groq API Key (可选)
echo 2. 双击桌面的"视频下载转录服务"快捷方式启动服务
echo 3. 在浏览器中加载扩展 (chrome://extensions/)
echo    - 开启"开发者模式"
echo    - 点击"加载已解压的扩展程序"
echo    - 选择 video-downloader-extension 文件夹
echo.
echo 按任意键打开配置文件...
pause >nul
notepad config.yaml
