@echo off
chcp 65001 >nul
title 视频下载转录系统 - 离线安装程序

echo.
echo ============================================================
echo 视频下载转录系统 v1.0.0 - 离线安装程序
echo ============================================================
echo.

:: 检查管理员权限
net session >nul 2>&1
if %errorlevel% neq 0 (
    echo [X] 需要管理员权限
    echo.
    echo 请右键点击安装程序，选择"以管理员身份运行"
    echo.
    pause
    exit /b 1
)

:: 检查 Python
echo [1/4] 检查 Python...
python --version >nul 2>&1
if %errorlevel% neq 0 (
    echo [X] Python 未安装
    echo.
    start https://www.python.org/downloads/
    echo 请安装 Python 3.10+ 后重新运行安装程序
    pause
    exit /b 1
)
echo [OK] Python 已安装

:: 检查 FFmpeg
echo [2/4] 检查 FFmpeg...
ffmpeg -version >nul 2>&1
if %errorlevel% neq 0 (
    echo [!] FFmpeg 未安装
    echo.
    start https://ffmpeg.org/download.html
    echo 请安装 FFmpeg 后重新运行安装程序
    pause
    exit /b 1
)
echo [OK] FFmpeg 已安装

:: 安装依赖（离线）
echo [3/4] 安装依赖（离线模式）...
cd video-download-service
pip install --no-index --find-links=packages -r requirements.txt --quiet
if %errorlevel% neq 0 (
    echo [X] 依赖安装失败
    pause
    exit /b 1
)
echo [OK] 依赖安装完成

:: 创建快捷方式
echo [4/4] 创建快捷方式...
if not exist config.yaml copy config.yaml.example config.yaml >nul
echo Set oWS = WScript.CreateObject("WScript.Shell") > CreateShortcut.vbs
echo sLinkFile = "%USERPROFILE%\Desktop\视频下载转录服务.lnk" >> CreateShortcut.vbs
echo Set oLink = oWS.CreateShortcut(sLinkFile) >> CreateShortcut.vbs
echo oLink.TargetPath = "%CD%\start.bat" >> CreateShortcut.vbs
echo oLink.WorkingDirectory = "%CD%" >> CreateShortcut.vbs
echo oLink.Save >> CreateShortcut.vbs
cscript //nologo CreateShortcut.vbs
del CreateShortcut.vbs
echo [OK] 快捷方式已创建

echo.
echo ============================================================
echo [OK] 安装完成！
echo ============================================================
echo.
echo 下一步:
echo 1. 双击桌面快捷方式启动服务
echo 2. 在浏览器中加载扩展 (chrome://extensions/)
echo.
pause
