package com.videodownload.app.service

import android.app.Notification
import android.app.NotificationChannel
import android.app.NotificationManager
import android.app.PendingIntent
import android.app.Service
import android.content.Intent
import android.os.Build
import android.os.IBinder
import androidx.core.app.NotificationCompat
import com.videodownload.app.R
import com.videodownload.app.data.model.TranscriptionStatus
import com.videodownload.app.repository.TranscriptionRepository
import kotlinx.coroutines.*
import kotlinx.coroutines.flow.MutableStateFlow
import kotlinx.coroutines.flow.StateFlow

/**
 * 转录前台服务
 *
 * 功能：
 * 1. 后台稳定运行，不被系统杀死
 * 2. 实时更新进度通知
 * 3. 支持取消操作
 * 4. 超时检测和错误处理
 */
class TranscriptionService : Service() {

    companion object {
        const val ACTION_START = "ACTION_START_TRANSCRIPTION"
        const val ACTION_CANCEL = "ACTION_CANCEL_TRANSCRIPTION"
        const val EXTRA_VIDEO_ID = "EXTRA_VIDEO_ID"
        const val EXTRA_ENGINE = "EXTRA_ENGINE"

        const val NOTIFICATION_ID = 1001
        const val CHANNEL_ID = "transcription_channel"

        // 超时时间：每段 5 分钟
        const val SEGMENT_TIMEOUT_MS = 5 * 60 * 1000L
    }

    private val serviceScope = CoroutineScope(Dispatchers.IO + SupervisorJob())
    private var currentJob: Job? = null

    private lateinit var repository: TranscriptionRepository
    private lateinit var notificationManager: NotificationManager

    // 进度状态
    private val _progress = MutableStateFlow<TranscriptionProgress?>(null)
    val progress: StateFlow<TranscriptionProgress?> = _progress

    override fun onCreate() {
        super.onCreate()
        repository = TranscriptionRepository(applicationContext)
        notificationManager = getSystemService(NotificationManager::class.java)
        createNotificationChannel()
    }

    override fun onStartCommand(intent: Intent?, flags: Int, startId: Int): Int {
        when (intent?.action) {
            ACTION_START -> {
                val videoId = intent.getStringExtra(EXTRA_VIDEO_ID) ?: return START_NOT_STICKY
                val engine = intent.getStringExtra(EXTRA_ENGINE) ?: "auto"

                startForeground(NOTIFICATION_ID, createNotification("准备转录...", 0))
                startTranscription(videoId, engine)
            }
            ACTION_CANCEL -> {
                cancelTranscription()
            }
        }

        return START_STICKY
    }

    override fun onBind(intent: Intent?): IBinder? = null

    /**
     * 开始转录
     */
    private fun startTranscription(videoId: String, engine: String) {
        currentJob = serviceScope.launch {
            try {
                // 更新状态为转录中
                updateProgress(TranscriptionProgress(
                    videoId = videoId,
                    status = TranscriptionStatus.TRANSCRIBING,
                    progress = 0f,
                    message = "正在转录..."
                ))

                // 执行转录（带超时检测）
                val result = withTimeout(SEGMENT_TIMEOUT_MS * 10) { // 总超时：50分钟
                    repository.transcribe(
                        videoId = videoId,
                        engine = engine,
                        onProgress = { progress ->
                            updateProgress(progress)
                            updateNotification(progress.message, progress.progress)
                        }
                    )
                }

                // 转录完成
                updateProgress(TranscriptionProgress(
                    videoId = videoId,
                    status = TranscriptionStatus.COMPLETED,
                    progress = 1f,
                    message = "转录完成"
                ))

                // 显示完成通知
                showCompletionNotification(videoId, true)

                // 延迟 2 秒后停止服务
                delay(2000)
                stopSelf()

            } catch (e: TimeoutCancellationException) {
                // 超时
                handleError(videoId, "转录超时，请重试")
            } catch (e: CancellationException) {
                // 用户取消
                updateProgress(TranscriptionProgress(
                    videoId = videoId,
                    status = TranscriptionStatus.CANCELLED,
                    progress = 0f,
                    message = "已取消"
                ))
                stopSelf()
            } catch (e: Exception) {
                // 其他错误
                handleError(videoId, e.message ?: "转录失败")
            }
        }
    }

    /**
     * 取消转录
     */
    private fun cancelTranscription() {
        currentJob?.cancel()
        stopSelf()
    }

    /**
     * 处理错误
     */
    private suspend fun handleError(videoId: String, message: String) {
        updateProgress(TranscriptionProgress(
            videoId = videoId,
            status = TranscriptionStatus.FAILED,
            progress = 0f,
            message = message
        ))

        // 保存错误状态到数据库
        repository.updateTranscriptionStatus(videoId, TranscriptionStatus.FAILED, message)

        // 显示失败通知
        showCompletionNotification(videoId, false, message)

        delay(2000)
        stopSelf()
    }

    /**
     * 更新进度
     */
    private fun updateProgress(progress: TranscriptionProgress) {
        _progress.value = progress
    }

    /**
     * 创建通知渠道
     */
    private fun createNotificationChannel() {
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
            val channel = NotificationChannel(
                CHANNEL_ID,
                "转录服务",
                NotificationManager.IMPORTANCE_LOW
            ).apply {
                description = "显示视频转录进度"
                setShowBadge(false)
            }
            notificationManager.createNotificationChannel(channel)
        }
    }

    /**
     * 创建通知
     */
    private fun createNotification(message: String, progress: Int): Notification {
        // 取消按钮
        val cancelIntent = Intent(this, TranscriptionService::class.java).apply {
            action = ACTION_CANCEL
        }
        val cancelPendingIntent = PendingIntent.getService(
            this, 0, cancelIntent,
            PendingIntent.FLAG_IMMUTABLE or PendingIntent.FLAG_UPDATE_CURRENT
        )

        return NotificationCompat.Builder(this, CHANNEL_ID)
            .setContentTitle("视频转录中")
            .setContentText(message)
            .setSmallIcon(R.drawable.ic_transcription)
            .setProgress(100, progress, progress == 0)
            .setOngoing(true)
            .addAction(R.drawable.ic_cancel, "取消", cancelPendingIntent)
            .build()
    }

    /**
     * 更新通知
     */
    private fun updateNotification(message: String, progress: Float) {
        val notification = createNotification(message, (progress * 100).toInt())
        notificationManager.notify(NOTIFICATION_ID, notification)
    }

    /**
     * 显示完成通知
     */
    private fun showCompletionNotification(videoId: String, success: Boolean, error: String? = null) {
        val notification = NotificationCompat.Builder(this, CHANNEL_ID)
            .setContentTitle(if (success) "转录完成" else "转录失败")
            .setContentText(if (success) "点击查看转录结果" else error)
            .setSmallIcon(if (success) R.drawable.ic_check else R.drawable.ic_error)
            .setAutoCancel(true)
            .build()

        notificationManager.notify(NOTIFICATION_ID + 1, notification)
    }

    override fun onDestroy() {
        super.onDestroy()
        currentJob?.cancel()
        serviceScope.cancel()
    }
}

/**
 * 转录进度
 */
data class TranscriptionProgress(
    val videoId: String,
    val status: TranscriptionStatus,
    val progress: Float, // 0.0 - 1.0
    val message: String,
    val currentSegment: Int = 0,
    val totalSegments: Int = 0
)
