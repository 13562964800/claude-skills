package com.videodownload.app.engine

import android.content.Context
import com.videodownload.app.data.model.Word
import com.videodownload.app.repository.TestResult
import com.videodownload.app.repository.TranscriptionResult
import com.videodownload.app.utils.PreferenceManager
import kotlinx.coroutines.Dispatchers
import kotlinx.coroutines.withContext
import okhttp3.*
import okhttp3.MediaType.Companion.toMediaType
import okhttp3.RequestBody.Companion.asRequestBody
import org.json.JSONObject
import java.io.File
import java.io.IOException

/**
 * Groq API 转录引擎（在线）
 *
 * 特点：
 * - 速度快（1-2x 实时）
 * - 准确度高
 * - 支持多语言
 * - 文件大小限制：25MB
 */
class GroqEngine(private val context: Context) : TranscriptionEngine {

    override val name = "groq"

    private val client = OkHttpClient.Builder()
        .connectTimeout(30, java.util.concurrent.TimeUnit.SECONDS)
        .readTimeout(300, java.util.concurrent.TimeUnit.SECONDS)
        .writeTimeout(300, java.util.concurrent.TimeUnit.SECONDS)
        .build()

    private val preferenceManager = PreferenceManager(context)

    companion object {
        private const val API_URL = "https://api.groq.com/openai/v1/audio/transcriptions"
        private const val MODEL = "whisper-large-v3-turbo"
        private const val MAX_FILE_SIZE = 25 * 1024 * 1024 // 25MB
    }

    override suspend fun transcribe(audioPath: String, language: String?): TranscriptionResult =
        withContext(Dispatchers.IO) {
            val apiKey = preferenceManager.getGroqApiKey()
                ?: throw IllegalStateException("Groq API Key not configured")

            val audioFile = File(audioPath)
            if (!audioFile.exists()) {
                throw IllegalArgumentException("Audio file not found: $audioPath")
            }

            if (audioFile.length() > MAX_FILE_SIZE) {
                throw IllegalArgumentException("File size exceeds 25MB limit")
            }

            // 构建请求
            val requestBody = MultipartBody.Builder()
                .setType(MultipartBody.FORM)
                .addFormDataPart(
                    "file",
                    audioFile.name,
                    audioFile.asRequestBody("audio/mpeg".toMediaType())
                )
                .addFormDataPart("model", MODEL)
                .addFormDataPart("response_format", "verbose_json")
                .addFormDataPart("timestamp_granularities[]", "word")
                .apply {
                    if (language != null) {
                        addFormDataPart("language", language)
                    }
                }
                .build()

            val request = Request.Builder()
                .url(API_URL)
                .addHeader("Authorization", "Bearer $apiKey")
                .post(requestBody)
                .build()

            // 发送请求
            val response = client.newCall(request).execute()

            if (!response.isSuccessful) {
                val errorBody = response.body?.string() ?: "Unknown error"
                throw IOException("Groq API error: ${response.code} - $errorBody")
            }

            // 解析响应
            val responseBody = response.body?.string()
                ?: throw IOException("Empty response from Groq API")

            parseResponse(responseBody)
        }

    /**
     * 解析 Groq API 响应
     */
    private fun parseResponse(json: String): TranscriptionResult {
        val jsonObject = JSONObject(json)

        val text = jsonObject.getString("text")
        val language = jsonObject.optString("language", "unknown")
        val duration = jsonObject.optDouble("duration", 0.0).toFloat()

        // 解析词级时间戳
        val words = mutableListOf<Word>()
        val wordsArray = jsonObject.optJSONArray("words")
        if (wordsArray != null) {
            for (i in 0 until wordsArray.length()) {
                val wordObj = wordsArray.getJSONObject(i)
                words.add(
                    Word(
                        word = wordObj.getString("word"),
                        start = wordObj.getDouble("start").toFloat(),
                        end = wordObj.getDouble("end").toFloat(),
                        confidence = null
                    )
                )
            }
        }

        return TranscriptionResult(
            text = text,
            words = words,
            language = language,
            duration = duration
        )
    }

    override fun isAvailable(): Boolean {
        return preferenceManager.getGroqApiKey() != null
    }

    override suspend fun test(apiKey: String?): TestResult = withContext(Dispatchers.IO) {
        try {
            val testKey = apiKey ?: preferenceManager.getGroqApiKey()
                ?: return@withContext TestResult(false, "API Key not configured")

            // 发送测试请求（获取模型列表）
            val request = Request.Builder()
                .url("https://api.groq.com/openai/v1/models")
                .addHeader("Authorization", "Bearer $testKey")
                .get()
                .build()

            val response = client.newCall(request).execute()

            if (response.isSuccessful) {
                // 保存 API Key
                if (apiKey != null) {
                    preferenceManager.setGroqApiKey(apiKey)
                }
                TestResult(true, "连接成功")
            } else {
                TestResult(false, "连接失败: ${response.code}")
            }
        } catch (e: Exception) {
            TestResult(false, "连接失败: ${e.message}")
        }
    }
}
