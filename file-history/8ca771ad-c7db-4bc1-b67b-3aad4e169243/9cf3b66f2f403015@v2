package com.videodownload.app.utils

import android.content.Context
import android.content.SharedPreferences
import androidx.security.crypto.EncryptedSharedPreferences
import androidx.security.crypto.MasterKey

/**
 * 配置管理器
 */
class PreferenceManager(context: Context) {

    private val masterKey = MasterKey.Builder(context)
        .setKeyScheme(MasterKey.KeyScheme.AES256_GCM)
        .build()

    private val sharedPreferences: SharedPreferences = EncryptedSharedPreferences.create(
        context,
        "app_settings",
        masterKey,
        EncryptedSharedPreferences.PrefKeyEncryptionScheme.AES256_SIV,
        EncryptedSharedPreferences.PrefValueEncryptionScheme.AES256_GCM
    )

    companion object {
        private const val KEY_GROQ_API_KEY = "groq_api_key"
        private const val KEY_DEFAULT_ENGINE = "default_engine"
        private const val KEY_AI_ASSISTANT_ENABLED = "ai_assistant_enabled"
        private const val KEY_AUTO_TRANSCRIBE = "auto_transcribe"
        private const val KEY_DOWNLOAD_PATH = "download_path"
    }

    fun getGroqApiKey(): String? {
        return sharedPreferences.getString(KEY_GROQ_API_KEY, null)
    }

    fun setGroqApiKey(apiKey: String) {
        sharedPreferences.edit().putString(KEY_GROQ_API_KEY, apiKey).apply()
    }

    fun getDefaultEngine(): String {
        return sharedPreferences.getString(KEY_DEFAULT_ENGINE, "auto") ?: "auto"
    }

    fun setDefaultEngine(engine: String) {
        sharedPreferences.edit().putString(KEY_DEFAULT_ENGINE, engine).apply()
    }

    fun isAIAssistantEnabled(): Boolean {
        return sharedPreferences.getBoolean(KEY_AI_ASSISTANT_ENABLED, true)
    }

    fun setAIAssistantEnabled(enabled: Boolean) {
        sharedPreferences.edit().putBoolean(KEY_AI_ASSISTANT_ENABLED, enabled).apply()
    }

    fun isAutoTranscribeEnabled(): Boolean {
        return sharedPreferences.getBoolean(KEY_AUTO_TRANSCRIBE, false)
    }

    fun setAutoTranscribeEnabled(enabled: Boolean) {
        sharedPreferences.edit().putBoolean(KEY_AUTO_TRANSCRIBE, enabled).apply()
    }

    fun getDownloadPath(): String {
        return sharedPreferences.getString(KEY_DOWNLOAD_PATH, "") ?: ""
    }

    fun setDownloadPath(path: String) {
        sharedPreferences.edit().putString(KEY_DOWNLOAD_PATH, path).apply()
    }
}
