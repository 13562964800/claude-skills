# 创建自解压安装包
# 使用 7-Zip SFX 创建专业的安装程序

$PackageName = "VideoDownloadTranscribe-Setup-v1.0.0"
$SourceDir = "video-download-transcribe-v1.0.0"

Write-Host "============================================================" -ForegroundColor Cyan
Write-Host "创建自解压安装包" -ForegroundColor Cyan
Write-Host "============================================================" -ForegroundColor Cyan
Write-Host ""

# 检查源目录
if (-not (Test-Path $SourceDir)) {
    Write-Host "[X] 源目录不存在，正在解压..." -ForegroundColor Red
    if (Test-Path "$SourceDir.zip") {
        Expand-Archive -Path "$SourceDir.zip" -DestinationPath "." -Force
    } else {
        Write-Host "[X] 找不到源文件" -ForegroundColor Red
        exit 1
    }
}

Write-Host "[1/5] 准备文件..." -ForegroundColor Yellow

# 创建安装脚本
$InstallScript = @"
@echo off
chcp 65001 >nul
echo ============================================================
echo 视频下载转录系统 - 安装向导
echo ============================================================
echo.

echo [1/3] 检查环境...
python --version >nul 2>&1
if %errorlevel% neq 0 (
    echo [!] Python 未安装
    echo     请从 https://www.python.org/downloads/ 下载安装
    start https://www.python.org/downloads/
    pause
    exit /b 1
)

ffmpeg -version >nul 2>&1
if %errorlevel% neq 0 (
    echo [!] FFmpeg 未安装
    echo     请从 https://ffmpeg.org/download.html 下载安装
    start https://ffmpeg.org/download.html
    pause
    exit /b 1
)

echo [2/3] 安装依赖...
cd video-download-service
pip install -r requirements.txt -i https://pypi.tuna.tsinghua.edu.cn/simple

echo [3/3] 创建快捷方式...
echo Set oWS = WScript.CreateObject("WScript.Shell") > CreateShortcut.vbs
echo sLinkFile = "%USERPROFILE%\Desktop\视频下载转录服务.lnk" >> CreateShortcut.vbs
echo Set oLink = oWS.CreateShortcut(sLinkFile) >> CreateShortcut.vbs
echo oLink.TargetPath = "%CD%\start.bat" >> CreateShortcut.vbs
echo oLink.WorkingDirectory = "%CD%" >> CreateShortcut.vbs
echo oLink.Save >> CreateShortcut.vbs
cscript //nologo CreateShortcut.vbs
del CreateShortcut.vbs

echo.
echo ============================================================
echo [OK] 安装完成！
echo ============================================================
echo.
echo 下一步:
echo 1. 双击桌面的"视频下载转录服务"快捷方式启动服务
echo 2. 在浏览器中加载扩展 (chrome://extensions/)
echo.
pause
"@

$InstallScript | Out-File -FilePath "$SourceDir\INSTALL.bat" -Encoding ASCII

# 创建配置文件
Write-Host "[2/5] 创建配置文件..." -ForegroundColor Yellow
$ConfigContent = @"
;!@Install@!UTF-8!
Title="视频下载转录系统 v1.0.0"
BeginPrompt="欢迎安装视频下载转录系统！\n\n系统要求:\n- Windows 11\n- Python 3.10+\n- FFmpeg\n\n是否继续安装？"
RunProgram="INSTALL.bat"
;!@InstallEnd@!
"@
$ConfigContent | Out-File -FilePath "config.txt" -Encoding UTF8

# 创建 README
Write-Host "[3/5] 创建说明文件..." -ForegroundColor Yellow
$ReadmeContent = @"
# 视频下载转录系统 v1.0.0

## 安装步骤

1. 运行此安装程序
2. 按照提示完成安装
3. 双击桌面快捷方式启动服务
4. 在浏览器中加载扩展

## 系统要求

- Windows 11
- Python 3.10+
- FFmpeg
- Chrome/Edge 浏览器

## 使用说明

详见安装目录中的文档：
- README.md - 完整文档
- QUICKSTART.md - 快速开始
- INSTALLATION_GUIDE.md - 安装指南

## 技术支持

遇到问题请查看 INSTALLATION_GUIDE.md

---
版本: v1.0.0 | 日期: 2026-03-01
"@
$ReadmeContent | Out-File -FilePath "$SourceDir\README.txt" -Encoding UTF8

# 检查 7-Zip
Write-Host "[4/5] 检查 7-Zip..." -ForegroundColor Yellow
$7zPath = "C:\Program Files\7-Zip\7z.exe"
if (-not (Test-Path $7zPath)) {
    $7zPath = "C:\Program Files (x86)\7-Zip\7z.exe"
}

if (Test-Path $7zPath) {
    Write-Host "[5/5] 创建自解压安装包..." -ForegroundColor Yellow

    # 创建 7z 压缩包
    & $7zPath a -t7z "$PackageName.7z" "$SourceDir\*" -mx9

    # 查找 7zSD.sfx
    $sfxPath = "C:\Program Files\7-Zip\7zSD.sfx"
    if (-not (Test-Path $sfxPath)) {
        $sfxPath = "C:\Program Files (x86)\7-Zip\7zSD.sfx"
    }

    if (Test-Path $sfxPath) {
        # 合并创建自解压文件
        cmd /c copy /b "$sfxPath" + "config.txt" + "$PackageName.7z" "$PackageName.exe"

        Write-Host ""
        Write-Host "============================================================" -ForegroundColor Green
        Write-Host "[OK] 自解压安装包创建完成！" -ForegroundColor Green
        Write-Host "============================================================" -ForegroundColor Green
        Write-Host ""
        Write-Host "文件: $PackageName.exe" -ForegroundColor White
        if (Test-Path "$PackageName.exe") {
            $FileSize = (Get-Item "$PackageName.exe").Length / 1MB
            Write-Host "大小: $([math]::Round($FileSize, 2)) MB" -ForegroundColor White
        }
    } else {
        Write-Host "[!] 未找到 7zSD.sfx，无法创建自解压文件" -ForegroundColor Yellow
        Write-Host "    已创建 7z 压缩包: $PackageName.7z" -ForegroundColor Yellow
    }

    # 清理临时文件
    Remove-Item "config.txt" -ErrorAction SilentlyContinue
    Remove-Item "$PackageName.7z" -ErrorAction SilentlyContinue
} else {
    Write-Host "[!] 未安装 7-Zip" -ForegroundColor Yellow
    Write-Host "    正在创建标准 ZIP 安装包..." -ForegroundColor Yellow

    # 使用标准压缩
    Compress-Archive -Path $SourceDir -DestinationPath "$PackageName-Installer.zip" -Force

    Write-Host ""
    Write-Host "============================================================" -ForegroundColor Green
    Write-Host "[OK] ZIP 安装包创建完成！" -ForegroundColor Green
    Write-Host "============================================================" -ForegroundColor Green
    Write-Host ""
    Write-Host "文件: $PackageName-Installer.zip" -ForegroundColor White
    $FileSize = (Get-Item "$PackageName-Installer.zip").Length / 1MB
    Write-Host "大小: $([math]::Round($FileSize, 2)) MB" -ForegroundColor White
    Write-Host ""
    Write-Host "提示: 安装 7-Zip 可以创建 .exe 格式的安装包" -ForegroundColor Cyan
    Write-Host "下载: https://www.7-zip.org/" -ForegroundColor Cyan
}

Write-Host ""
