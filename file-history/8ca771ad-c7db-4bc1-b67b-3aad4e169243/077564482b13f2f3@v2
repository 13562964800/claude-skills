@echo off
echo ============================================================
echo 视频下载转录系统 - 环境检查
echo ============================================================
echo.

REM 检查 Python
echo [1/4] 检查 Python...
python --version >nul 2>&1
if %errorlevel% neq 0 (
    echo [X] Python 未安装
    echo     请从 https://www.python.org/downloads/ 下载安装
    goto :error
) else (
    python --version
    echo [OK] Python 已安装
)
echo.

REM 检查 FFmpeg
echo [2/4] 检查 FFmpeg...
ffmpeg -version >nul 2>&1
if %errorlevel% neq 0 (
    echo [X] FFmpeg 未安装
    echo     请从 https://ffmpeg.org/download.html 下载安装
    echo     并将 bin 目录添加到系统 PATH
    goto :error
) else (
    ffmpeg -version | findstr "ffmpeg version"
    echo [OK] FFmpeg 已安装
)
echo.

REM 检查 pip
echo [3/4] 检查 pip...
pip --version >nul 2>&1
if %errorlevel% neq 0 (
    echo [X] pip 未安装
    goto :error
) else (
    pip --version
    echo [OK] pip 已安装
)
echo.

REM 检查 Python 依赖
echo [4/4] 检查 Python 依赖...
cd /d "%~dp0"
python -c "import fastapi" >nul 2>&1
if %errorlevel% neq 0 (
    echo [!] Python 依赖未安装
    echo     运行 install.bat 安装依赖
    goto :warning
) else (
    echo [OK] Python 依赖已安装
)
echo.

echo ============================================================
echo [OK] 环境检查通过！
echo ============================================================
echo.
echo 下一步:
echo 1. 编辑 config.yaml 配置 Groq API Key (可选)
echo 2. 运行 start.bat 启动服务
echo 3. 在浏览器中加载扩展 (chrome://extensions/)
echo.
pause
exit /b 0

:warning
echo.
echo ============================================================
echo [!] 环境检查部分通过
echo ============================================================
echo.
pause
exit /b 1

:error
echo.
echo ============================================================
echo [X] 环境检查失败
echo ============================================================
echo.
pause
exit /b 1
