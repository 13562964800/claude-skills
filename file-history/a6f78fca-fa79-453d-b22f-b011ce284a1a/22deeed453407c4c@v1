/**
 * 视频下载服务 - 使用在线 API 解析视频
 * 支持多平台：B站、抖音、YouTube、TikTok 等
 *
 * 改进点：
 * - 参考 Electron 版本的平台检测和视频提取逻辑
 * - 改进 B站、抖音的解析逻辑，支持多种备用 API
 * - 添加 YouTube 支持（使用 yt-dlp API 或备用方案）
 * - 改进错误处理和重试机制
 * - 添加详细的日志输出
 */
class VideoDownloadService {

    companion object {
        private const val TAG = "VideoDownloadService"
        private const val DEFAULT_TIMEOUT = 30_000L
        private const val MAX_RETRIES = 3
        private const val RETRY_DELAY_MS = 1000L
    }

    private val client = OkHttpClient.Builder()
        .connectTimeout(30, TimeUnit.SECONDS)
        .readTimeout(30, TimeUnit.SECONDS)
        .followRedirects(true)
        .build()

    /**
     * 平台检测 - 参考 Electron 版本的 detectPlatform 函数
     * 支持更多平台和短链接
     */
    fun detectPlatform(url: String): VideoPlatform {
        val lowerUrl = url.lowercase()
        return when {
            // YouTube - 支持主域名和短链接
            lowerUrl.contains("youtube.com") || lowerUrl.contains("youtu.be") -> VideoPlatform.YOUTUBE
            // Bilibili - 支持主域名和 b23.tv 短链接
            lowerUrl.contains("bilibili.com") || lowerUrl.contains("b23.tv") -> VideoPlatform.BILIBILI
            // 抖音 - 支持多种域名
            lowerUrl.contains("douyin.com") || lowerUrl.contains("iesdouyin.com") -> VideoPlatform.DOUYIN
            // TikTok
            lowerUrl.contains("tiktok.com") -> VideoPlatform.TIKTOK
            // 微博
            lowerUrl.contains("weibo.com") -> VideoPlatform.WEIBO
            // 小红书
            lowerUrl.contains("xiaohongshu.com") || lowerUrl.contains("xhslink.com") -> VideoPlatform.XIAOHONGSHU
            // 直接视频链接
            lowerUrl.contains(".mp4") || lowerUrl.contains(".m3u8") || lowerUrl.contains(".mpd") -> VideoPlatform.DIRECT
            // 未知平台
            else -> VideoPlatform.UNKNOWN
        }
    }

    /**
     * 获取视频下载链接 - 主入口函数
     * 参考 Electron 版本的 extract-info IPC 处理
     */
    suspend fun getVideoInfo(url: String): Result<VideoDownloadInfo> = withContext(Dispatchers.IO) {
        withTimeout(DEFAULT_TIMEOUT) {
            try {
                val cleanUrl = cleanUrl(url)
                Log.d(TAG, "Processing URL: $cleanUrl")

                val platform = detectPlatform(cleanUrl)
                Log.d(TAG, "Detected platform: $platform")

                when (platform) {
                    VideoPlatform.YOUTUBE -> fetchYoutubeInfo(cleanUrl)
                    VideoPlatform.BILIBILI -> fetchBilibiliInfo(cleanUrl)
                    VideoPlatform.DOUYIN -> fetchDouyinInfo(cleanUrl)
                    VideoPlatform.TIKTOK -> fetchTiktokInfo(cleanUrl)
                    VideoPlatform.DIRECT -> Result.success(
                        VideoDownloadInfo(
                            title = "直接视频链接",
                            downloadUrl = cleanUrl,
                            cover = null,
                            duration = 0L,
                            author = null
                        )
                    )
                    else -> Result.failure(
                        Exception(
                            "不支持的平台: $platform\n" +
                            "支持的平台: YouTube、B站、抖音、TikTok\n" +
                            "建议: 请使用导入功能添加本地视频"
                        )
                    )
                }
            } catch (e: Exception) {
                Log.e(TAG, "Error fetching video info", e)
                Result.failure(e)
            }
        }
    }

    /**
     * 清理 URL - 移除多余空格和无效字符
     * 参考 Electron 版本的 cleanUrl 函数
     */
    private fun cleanUrl(url: String): String {
        val trimmed = url.trim()
        // 提取第一个有效的 HTTP/HTTPS 链接
        val match = Regex("(https?://[^\\s\"'<>]+)").find(trimmed)
        return match?.value ?: trimmed
    }

    /**
     * 获取 YouTube 视频信息 - 使用 yt-dlp API 或备用方案
     * 参考 Electron 版本使用 yt-dlp 处理 YouTube
     */
    private suspend fun fetchYoutubeInfo(url: String): Result<VideoDownloadInfo> {
        Log.d(TAG, "Fetching YouTube info for: $url")

        // 尝试多个 API（按优先级排序）
        val apis = listOf(
            // API 1: yt-dlp API（如果可用）
            YoutubeApiConfig(
                "https://yt.lemnoslife.com/videosPart",
                "lemnoslife"
            ),
            // API 2: 其他 YouTube 解析 API
            YoutubeApiConfig(
                "https://noembed.com/embed?url=$url",
                "noembed"
            )
        )

        for (api in apis) {
            try {
                Log.d(TAG, "Trying YouTube API: ${api.name}")
                val result = fetchYoutubeInfoWithApi(url, api)
                if (result.isSuccess) {
                    return result
                }
            } catch (e: Exception) {
                Log.w(TAG, "YouTube API ${api.name} failed: ${e.message}")
            }
        }

        // 所有 API 都失败，返回详细错误信息
        return Result.failure(
            Exception(
                "YouTube 解析失败，可能的原因:\n" +
                "1. API 服务暂时不可用\n" +
                "2. 视频地区限制或私密视频\n" +
                "3. 网络连接问题\n\n" +
                "建议: 请在电脑上使用 yt-dlp 下载视频，然后使用导入功能添加"
            )
        )
    }

    /**
     * 使用指定 API 获取 YouTube 视频信息
     */
    private suspend fun fetchYoutubeInfoWithApi(
        url: String,
        api: YoutubeApiConfig
    ): Result<VideoDownloadInfo> = withContext(Dispatchers.IO) {
        try {
            when (api.name) {
                "lemnoslife" -> {
                    // 使用 Lemnoslife API
                    val videoId = extractYoutubeVideoId(url)
                        ?: return@withContext Result.failure(Exception("无法提取 YouTube 视频 ID"))

                    val request = Request.Builder()
                        .url("${api.endpoint}?id=$videoId")
                        .header("User-Agent", getUserAgent())
                        .build()

                    val response = client.newCall(request).execute()
                    val responseBody = response.body?.string()
                        ?: return@withContext Result.failure(IOException("空响应"))

                    Log.d(TAG, "Lemnoslife API response: ${responseBody.take(200)}")

                    val json = JSONObject(responseBody)
                    if (!json.has("items") || json.getJSONArray("items").length() == 0) {
                        return@withContext Result.failure(Exception("视频不存在或不可用"))
                    }

                    val items = json.getJSONArray("items")
                    val video = items.getJSONObject(0)

                    // 注意：这个 API 主要提供元数据，不提供下载链接
                    // 实际下载需要使用其他方法
                    Result.success(
                        VideoDownloadInfo(
                            title = video.optString("title", "YouTube 视频"),
                            downloadUrl = url, // 返回原 URL，需要特殊处理
                            cover = video.optJSONArray("thumbnails")
                                ?.optJSONObject(0)
                                ?.optString("url"),
                            duration = video.optLong("durationSeconds", 0L),
                            author = video.optJSONArray("channel")
                                ?.optJSONObject(0)
                                ?.optString("name")
                        )
                    )
                }
                "noembed" -> {
                    // 使用 NoEmbed API（主要用于获取元数据）
                    val request = Request.Builder()
                        .url(api.endpoint)
                        .header("User-Agent", getUserAgent())
                        .build()

                    val response = client.newCall(request).execute()
                    val responseBody = response.body?.string()
                        ?: return@withContext Result.failure(IOException("空响应"))

                    Log.d(TAG, "NoEmbed API response: ${responseBody.take(200)}")

                    val json = JSONObject(responseBody)
                    val title = json.optString("title", "YouTube 视频")
                    val author = json.optString("author_name")

                    Result.success(
                        VideoDownloadInfo(
                            title = title,
                            downloadUrl = url, // NoEmbed 不提供下载链接
                            cover = json.optString("thumbnail_url"),
                            duration = 0L,
                            author = author
                        )
                    )
                }
                else -> Result.failure(Exception("未知 API"))
            }
        } catch (e: Exception) {
            Log.e(TAG, "Error fetching YouTube info with ${api.name}", e)
            Result.failure(e)
        }
    }

    /**
     * 提取 YouTube 视频 ID
     */
    private fun extractYoutubeVideoId(url: String): String? {
        // 支持 youtube.com/watch?v= 和 youtu.be/ 格式
        val patterns = listOf(
            Regex("(?:youtube\\.com/watch\\?v=|youtu\\.be/)([a-zA-Z0-9_-]{11})"),
            Regex("youtube\\.com/embed/([a-zA-Z0-9_-]{11})")
        )

        for (pattern in patterns) {
            val match = pattern.find(url)
            if (match != null) {
                return match.groupValues[1]
            }
        }
        return null
    }

    /**
     * 获取 B站视频信息 - 使用多个备用API
     * 参考 Electron 版本的 yt-dlp 处理 B站（带 cookies）
     * 改进：增加更多备用 API，改进错误处理和重试机制
     */
    private suspend fun fetchBilibiliInfo(url: String): Result<VideoDownloadInfo> {
        Log.d(TAG, "Fetching Bilibili info for: $url")

        // 尝试多个API（按优先级排序）
        val apis = listOf(
            // API 1: xboba (稳定)
            BilibiliApiConfig("https://api.xboba.com/bilibili/video/download?url=$url", "xboba"),
            // API 2: 805t (备用)
            BilibiliApiConfig("https://api.805t.cn/bilibili/api?url=$url", "805t"),
            // API 3: yl (备用)
            BilibiliApiConfig("https://api.y1les.cn/api/bilibili?url=$url", "y1les"),
            // API 4: xingzhige (备用)
            BilibiliApiConfig("https://api.xingzhige.com/API/BiliBili/downUrl?url=$url", "xingzhige"),
            // API 5: 其它备用 API
            BilibiliApiConfig("https://api.jiuling.xyz/bili/video?url=$url", "jiuling")
        )

        for ((index, api) in apis.withIndex()) {
            try {
                Log.d(TAG, "[${index + 1}/${apis.size}] Trying Bilibili API: ${api.name}")

                val result = fetchBilibiliInfoWithApi(api)
                if (result.isSuccess) {
                    Log.d(TAG, "Successfully fetched info using: ${api.name}")
                    return result
                }

                Log.w(TAG, "API ${api.name} failed: ${result.exceptionOrNull()?.message}")
            } catch (e: Exception) {
                Log.e(TAG, "API ${api.name} threw exception", e)
            }
        }

        // 所有 API 都失败，返回详细错误信息
        return Result.failure(
            Exception(
                "B站解析失败，已尝试 ${apis.size} 个 API 均不可用。\n\n" +
                "可能的原因:\n" +
                "1. API 服务维护中或限流\n" +
                "2. 视频: 地区限制、会员专享、已删除\n" +
                "3. 网络连接问题\n\n" +
                "建议: 请在电脑上使用 yt-dlp 下载:\n" +
                "yt-dlp --cookies cookies.txt \"$url\""
            )
        )
    }

    /**
     * 使用指定 API 获取 B站视频信息
     */
    private suspend fun fetchBilibiliInfoWithApi(api: BilibiliApiConfig): Result<VideoDownloadInfo> = withContext(Dispatchers.IO) {
        try {
            val request = Request.Builder()
                .url(api.endpoint)
                .header("User-Agent", getUserAgent())
                .header("Referer", "https://www.bilibili.com/")
                .build()

            val response = client.newCall(request).execute()
            val responseBody = response.body?.string() ?: return@withContext Result.failure(IOException("空响应"))

            Log.d(TAG, "[${api.name}] Response: ${responseBody.take(300)}")

            // 检查是否是HTML响应（API可能失效）
            if (responseBody.trim().startsWith("<!DOCTYPE") || responseBody.trim().startsWith("<html")) {
                Log.w(TAG, "[${api.name}] API returned HTML, may be invalid")
                return@withContext Result.failure(Exception("API返回HTML，可能已失效"))
            }

            val json = JSONObject(responseBody)

            // 尝试多种返回格式解析

            // 格式1: {data: {url: "...", title: "..."}}
            if (json.has("data")) {
                val data = json.getJSONObject("data")
                val videoUrl = data.optJSONArray("url")?.optString(0)
                    ?: data.optString("url")
                    ?: data.optString("video_url")
                    ?: data.optString("playurl")
                    ?: data.optString("download_url")

                val title = data.optString("title")
                    ?: data.optString("name")
                    ?: "B站视频"

                if (videoUrl.isNotEmpty() && videoUrl.startsWith("http")) {
                    Log.d(TAG, "[${api.name}] Got video URL: $videoUrl")
                    return@withContext Result.success(VideoDownloadInfo(
                        title = title,
                        downloadUrl = videoUrl,
                        cover = data.optString("pic")
                            ?: data.optString("cover")
                            ?: data.optString("img"),
                        duration = data.optLong("duration", 0L) / 1000,
                        author = data.optString("author")
                            ?: data.optString("uploader")
                            ?: data.optString("owner")?.let { ownerJson ->
                                try { JSONObject(ownerJson).optString("name") } catch(e: Exception) { null }
                            }
                    ))
                }
            }

            // 格式2: {url: "...", title: "..."}
            val directUrl = json.optString("url")
                ?: json.optString("video_url")
                ?: json.optString("playurl")
                ?: json.optString("download_url")

            if (directUrl.startsWith("http")) {
                val title = json.optString("title") ?: "B站视频"
                Log.d(TAG, "[${api.name}] Got direct URL: $directUrl")
                return@withContext Result.success(VideoDownloadInfo(
                    title = title,
                    downloadUrl = directUrl,
                    cover = json.optString("pic") ?: json.optString("cover"),
                    duration = json.optLong("duration", 0L) / 1000,
                    author = json.optString("author")
                ))
            }

            // 格式3: {code: 200, data: {url: "..."}} 或 {code: 200, url: "..."}
            if (json.optInt("code") == 200 || json.optInt("code") == 1) {
                val nestedData = json.optJSONObject("data")
                val videoUrl = nestedData?.optString("url")
                    ?: nestedData?.optString("video_url")
                    ?: json.optString("url")
                    ?: json.optString("video_url")

                if (videoUrl?.startsWith("http") == true) {
                    val title = nestedData?.optString("title")
                        ?: json.optString("title")
                        ?: "B站视频"
                    return@withContext Result.success(VideoDownloadInfo(
                        title = title,
                        downloadUrl = videoUrl,
                        cover = nestedData?.optString("pic") ?: json.optString("pic"),
                        duration = nestedData?.optLong("duration", 0L)?.div(1000) ?: 0L
                    ))
                }
            }

            // 格式4: {msg: "...", code: ...} - 可能包含错误信息
            val msg = json.optString("msg") ?: json.optString("message")
            if (msg.isNotEmpty()) {
                return@withContext Result.failure(Exception("API返回: $msg"))
            }

            // 无法解析
            return@withContext Result.failure(Exception("无法解析API响应格式"))

        } catch (e: Exception) {
            Log.e(TAG, "[${api.name}] Request failed", e)
            Result.failure(e)
        }
    }

    /**
     * 获取抖音视频信息 - 改进版，支持多种 API 和重试机制
     * 参考 Electron 版本的浏览器内核解析方式
     * 改进：增加更多备用 API，改进解析逻辑
     */
    private suspend fun fetchDouyinInfo(url: String): Result<VideoDownloadInfo> {
        Log.d(TAG, "Fetching Douyin info for: $url")

        // 尝试多个API（按优先级排序）
        val apis = listOf(
            // API 1: pearktrue
            DouyinApiConfig("https://api.pearktrue.com/api/v1/parse/douyin?url=$url", "pearktrue"),
            // API 2: vdzx
            DouyinApiConfig("https://api.vdzx.com/api/douyin?url=$url", "vdzx"),
            // API 3: other APIs
            DouyinApiConfig("https://api.xboba.com/douyin/video/download?url=$url", "xboba")
        )

        for ((index, api) in apis.withIndex()) {
            try {
                Log.d(TAG, "[${index + 1}/${apis.size}] Trying Douyin API: ${api.name}")

                val result = fetchDouyinInfoWithApi(api)
                if (result.isSuccess) {
                    Log.d(TAG, "Successfully fetched info using: ${api.name}")
                    return result
                }

                Log.w(TAG, "API ${api.name} failed: ${result.exceptionOrNull()?.message}")

                // 如果不是最后一个API，延迟后重试
                if (index < apis.size - 1) {
                    delay(RETRY_DELAY_MS)
                }
            } catch (e: Exception) {
                Log.e(TAG, "API ${api.name} threw exception", e)
                if (index < apis.size - 1) {
                    delay(RETRY_DELAY_MS)
                }
            }
        }

        // 所有 API 都失败
        return Result.failure(
            Exception(
                "抖音解析失败，已尝试 ${apis.size} 个 API。\n\n" +
                "可能的原因:\n" +
                "1. 视频: 私密、已删除、地区限制\n" +
                "2. API 服务限流或维护\n" +
                "3. 链接无效或格式错误\n\n" +
                "建议: 请在抖音App内打开视频分享，或使用导入功能"
            )
        )
    }

    /**
     * 使用指定 API 获取抖音视频信息
     */
    private suspend fun fetchDouyinInfoWithApi(api: DouyinApiConfig): Result<VideoDownloadInfo> = withContext(Dispatchers.IO) {
        try {
            val request = Request.Builder()
                .url(api.endpoint)
                .header("User-Agent", getUserAgent())
                .header("Referer", "https://www.douyin.com/")
                .build()

            val response = client.newCall(request).execute()
            val responseBody = response.body?.string() ?: return@withContext Result.failure(IOException("空响应"))

            Log.d(TAG, "[${api.name}] Response: ${responseBody.take(300)}")

            // 检查是否是HTML
            if (responseBody.trim().startsWith("<!DOCTYPE") || responseBody.trim().startsWith("<html")) {
                return@withContext Result.failure(Exception("API返回HTML，可能已失效"))
            }

            val json = JSONObject(responseBody)

            // 检查响应状态码
            val code = json.optInt("code")
            if (code != 200 && code != 1 && code != 0) {
                val msg = json.optString("msg") ?: json.optString("message") ?: "未知错误"
                return@withContext Result.failure(Exception("API返回错误($code): $msg"))
            }

            // 解析视频数据 - 支持多种格式
            // 格式1: {code: 200, data: {video: [{play_addr: "..."}], desc: "..."}}
            if (json.has("data")) {
                val data = json.getJSONObject("data")

                // 尝试获取视频 URL
                val videoData = data.optJSONArray("video")?.optJSONObject(0)
                    ?: data.optJSONArray("data")?.optJSONObject(0)
                    ?: data

                val videoUrl = videoData.optString("play_addr")
                    ?: videoData.optString("play_addr_https")
                    ?: videoData.optString("url")
                    ?: videoData.optString("video_url")
                    ?: videoData.optString("download_addr")

                val title = data.optString("desc")
                    ?: data.optString("title")
                    ?: data.optString("text")
                    ?: "抖音视频"

                if (videoUrl.isNotEmpty() && (videoUrl.startsWith("http") || videoUrl.startsWith("//"))) {
                    // 处理相对协议 URL
                    val finalUrl = if (videoUrl.startsWith("//")) "https:$videoUrl" else videoUrl

                    // 提取作者信息
                    val author = data.optJSONObject("author")?.optString("nickname")
                        ?: data.optString("author")
                        ?: data.optString("nickname")

                    val cover = data.optString("cover")
                        ?: data.optString("thumb")
                        ?: data.optString("origin_cover")
                        ?: data.optString("dynamic_cover")
                        ?: videoData.optString("cover")

                    return@withContext Result.success(VideoDownloadInfo(
                        title = title,
                        downloadUrl = finalUrl,
                        cover = cover,
                        duration = videoData.optLong("duration", 0L),
                        author = author
                    ))
                }
            }

            // 格式2: {url: "...", title: "...", author: "..."}
            val directUrl = json.optString("url")
                ?: json.optString("play_addr")
                ?: json.optString("video_url")

            if (directUrl.startsWith("http") || directUrl.startsWith("//")) {
                val finalUrl = if (directUrl.startsWith("//")) "https:$directUrl" else directUrl
                val title = json.optString("title")
                    ?: json.optString("desc")
                    ?: json.optString("text")
                    ?: "抖音视频"

                return@withContext Result.success(VideoDownloadInfo(
                    title = title,
                    downloadUrl = finalUrl,
                    cover = json.optString("cover") ?: json.optString("thumb"),
                    duration = json.optLong("duration", 0L),
                    author = json.optString("author") ?: json.optString("nickname")
                ))
            }

            // 无法获取视频链接
            return@withContext Result.failure(Exception("无法从API响应中提取视频链接"))

        } catch (e: Exception) {
            Log.e(TAG, "[${api.name}] Request failed", e)
            Result.failure(e)
        }
    }

