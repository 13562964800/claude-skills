#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
多语言学习助手 - 视频下载脚本
基于 yt-dlp，支持 1000+ 网站：B站、抖音、YouTube、TikTok 等

使用方法：
1. 安装依赖: pip install yt-dlp
2. 运行: python download_video.py "<视频链接>"

下载的视频会自动保存到应用的下载目录
"""

import os
import sys
import subprocess
from pathlib import Path

# 配置
DOWNLOAD_DIR = Path.home() / "Downloads" / "MultilangLearner"
DOWNLOAD_DIR.mkdir(parents=True, exist_ok=True)

# 支持的网站平台
SUPPORTED_SITES = {
    "bilibili.com": "哔哩哔哩",
    "b23.tv": "哔哩哔哩",
    "douyin.com": "抖音",
    "iesdouyin.com": "抖音",
    "youtube.com": "YouTube",
    "youtu.be": "YouTube",
    "tiktok.com": "TikTok",
    "ixigua.com": "西瓜视频",
    "vimeo.com": "Vimeo",
    "weibo.com": "微博",
}

def detect_platform(url):
    """检测视频平台"""
    for domain, name in SUPPORTED_SITES.items():
        if domain in url:
            return name
    return "未知平台"

def download_with_ytdlp(url):
    """使用 yt-dlp 下载视频"""

    platform = detect_platform(url)
    print(f"🎬 检测到平台: {platform}")
    print(f"📥 开始下载...")
    print(f"🔗 链接: {url}")
    print("-" * 50)

    # yt-dlp 命令参数
    cmd = [
        "yt-dlp",
        "-f", "best[ext=mp4]/best",  # 下载最佳质量 MP4
        "-o", str(DOWNLOAD_DIR / "%(title)s.%(ext)s"),  # 输出路径
        "--no-playlist",  # 不下载播放列表
        "--print", "downloading: %(title)s",  # 显示下载进度
        url
    ]

    # B站特定选项
    if "bilibili" in url:
        print("📌 B站视频，使用 Cookie 可提升下载质量")
        print("   如需下载会员视频，请配置 Cookie")

    try:
        result = subprocess.run(cmd, check=True, capture_output=True, text=True)
        print(result.stdout)

        # 查找下载的文件
        files = list(DOWNLOAD_DIR.glob("*.mp4")) + list(DOWNLOAD_DIR.glob("*.mkv"))
        if files:
            latest_file = max(files, key=os.path.getmtime)
            print("-" * 50)
            print(f"✅ 下载成功!")
            print(f"📁 文件位置: {latest_file}")
            print(f"📱 请在应用中使用「导入本地视频」功能导入此文件")
            return str(latest_file)
        else:
            print("❌ 未找到下载的文件")
            return None

    except subprocess.CalledProcessError as e:
        print(f"❌ 下载失败: {e.stderr}")
        return None
    except FileNotFoundError:
        print("❌ 未找到 yt-dlp")
        print("   请运行: pip install yt-dlp")
        return None

def main():
    """主函数"""
    print("=" * 50)
    print("🎥 多语言学习助手 - 视频下载工具")
    print("=" * 50)
    print()

    if len(sys.argv) < 2:
        print("使用方法:")
        print("  python download_video.py \"<视频链接>\"")
        print()
        print("支持的平台:")
        for domain, name in SUPPORTED_SITES.items():
            print(f"  • {name} ({domain})")
        print()
        print("示例:")
        print('  python download_video.py "https://www.bilibili.com/video/BV1xx411c7m7"')
        print('  python download_video.py "https://www.youtube.com/watch?v=dQw4w9WgXcQ"')
        print()
        return

    url = sys.argv[1]

    if not url.startswith("http"):
        print("❌ 请输入有效的视频链接")
        return

    download_with_ytdlp(url)

if __name__ == "__main__":
    main()
