import React from 'react';
import {View, Text, TouchableOpacity, StyleSheet, ScrollView, Share, Platform} from 'react-native';
import RNShare from 'react-native-share';

export default function ResultScreen({route, navigation}: any) {
  const {outputPath, summary, diffCount, audioText, docText} = route.params;

  const shareToWechat = async () => {
    try {
      await RNShare.open({
        url: Platform.OS === 'android' ? `file://${outputPath}` : outputPath,
        type: 'application/vnd.openxmlformats-officedocument.wordprocessingml.document',
        title: '对比结果',
      });
    } catch (e: any) {
      if (e.message !== 'User did not share') {
        // 回退到系统分享
        Share.share({message: '录音文档对比结果', url: outputPath});
      }
    }
  };

  return (
    <ScrollView style={styles.container}>
      <View style={styles.summaryCard}>
        <Text style={styles.summaryTitle}>对比结果</Text>
        <Text style={styles.diffCount}>
          发现 <Text style={styles.diffNum}>{diffCount}</Text> 处差异
        </Text>
        <Text style={styles.summaryText}>{summary}</Text>
      </View>

      <View style={styles.section}>
        <Text style={styles.sectionTitle}>录音转写内容</Text>
        <Text style={styles.contentText}>{audioText}</Text>
      </View>

      <View style={styles.section}>
        <Text style={styles.sectionTitle}>文档原文</Text>
        <Text style={styles.contentText}>{docText}</Text>
      </View>

      <TouchableOpacity style={styles.shareBtn} onPress={shareToWechat}>
        <Text style={styles.shareBtnText}>分享对比文档</Text>
      </TouchableOpacity>

      <TouchableOpacity style={styles.backBtn} onPress={() => navigation.goBack()}>
        <Text style={styles.backBtnText}>返回重新对比</Text>
      </TouchableOpacity>
    </ScrollView>
  );
}

const styles = StyleSheet.create({
  container: {flex: 1, backgroundColor: '#f5f5f5'},
  summaryCard: {
    backgroundColor: '#fff', margin: 16, padding: 20, borderRadius: 12,
    borderLeftWidth: 4, borderLeftColor: '#1a73e8',
  },
  summaryTitle: {fontSize: 18, fontWeight: '600', color: '#333', marginBottom: 8},
  diffCount: {fontSize: 16, color: '#666', marginBottom: 8},
  diffNum: {fontSize: 24, fontWeight: '700', color: '#e53935'},
  summaryText: {fontSize: 14, color: '#888', lineHeight: 20},
  section: {backgroundColor: '#fff', margin: 16, marginTop: 0, padding: 16, borderRadius: 12},
  sectionTitle: {fontSize: 16, fontWeight: '600', color: '#333', marginBottom: 8},
  contentText: {fontSize: 14, color: '#555', lineHeight: 22},
  shareBtn: {
    backgroundColor: '#07c160', marginHorizontal: 16, padding: 16,
    borderRadius: 12, alignItems: 'center', marginTop: 8,
  },
  shareBtnText: {color: '#fff', fontSize: 16, fontWeight: '600'},
  backBtn: {
    marginHorizontal: 16, padding: 16, borderRadius: 12,
    alignItems: 'center', marginTop: 8, marginBottom: 32,
  },
  backBtnText: {color: '#1a73e8', fontSize: 16},
});
