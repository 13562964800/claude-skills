const JavaScriptObfuscator = require('javascript-obfuscator');
const fs = require('fs');
const path = require('path');

const files = ['main.js', 'renderer.js'];
const outDir = path.join(__dirname, 'obfuscated');
if (!fs.existsSync(outDir)) fs.mkdirSync(outDir);

for (const file of files) {
  const code = fs.readFileSync(path.join(__dirname, file), 'utf-8');
  const result = JavaScriptObfuscator.obfuscate(code, {
    compact: true,
    controlFlowFlattening: true,
    controlFlowFlatteningThreshold: 1,
    deadCodeInjection: true,
    deadCodeInjectionThreshold: 1,
    debugProtection: true,
    debugProtectionInterval: 2000,
    disableConsoleOutput: true,
    identifierNamesGenerator: 'hexadecimal',
    numbersToExpressions: true,
    renameGlobals: false,
    selfDefending: true,
    simplify: true,
    splitStrings: true,
    splitStringsChunkLength: 5,
    stringArray: true,
    stringArrayCallsTransform: true,
    stringArrayCallsTransformThreshold: 1,
    stringArrayEncoding: ['rc4'],
    stringArrayIndexShift: true,
    stringArrayRotate: true,
    stringArrayShuffle: true,
    stringArrayWrappersCount: 5,
    stringArrayWrappersChainedCalls: true,
    stringArrayWrappersParametersMaxCount: 5,
    stringArrayWrappersType: 'function',
    stringArrayThreshold: 1,
    transformObjectKeys: true,
    unicodeEscapeSequence: true
  });
  const copyright = `/**\n * 多语言视频学习 v2.0.0\n * Copyright © 2026 单夫纯律师. All Rights Reserved.\n * 未经授权，禁止复制、修改或分发本软件。\n */\n`;
  fs.writeFileSync(path.join(outDir, file), copyright + result.getObfuscatedCode());
  console.log(`Obfuscated: ${file}`);
}
