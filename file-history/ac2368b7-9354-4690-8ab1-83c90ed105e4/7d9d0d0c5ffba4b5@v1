// VTT subtitle cue
data class SubtitleCue(
    val index: Int,
    val startMs: Long,
    val endMs: Long,
    val text: String,
    val translation: String? = null
)

// Word-level timestamp (from .wordts.json)
@Serializable
data class WordTimestamp(
    val w: String,
    val s: Double,
    val e: Double
)

