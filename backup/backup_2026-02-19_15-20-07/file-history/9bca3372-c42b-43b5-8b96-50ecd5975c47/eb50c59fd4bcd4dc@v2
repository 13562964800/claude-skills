      risk:"此为法律赋予劳动者的预告期，期满后劳动关系解除。劳动者违法解除造成损失的，需赔偿。",
      law:"《劳动合同法》第37条" },
    { name:"用人单位单方解除通知工会", cat:"labor", warn:false, dur:"short",
      time:"事先通知", desc:"用人单位单方解除劳动合同，应当事先将理由通知工会。工会有权提出意见。",
      risk:"未履行通知工会程序即解除，可能被认定为违法解除，需支付赔偿金（2N）。司法实践允许事后补正。",
      law:"《劳动合同法》第43条" },
    { name:"工伤认定申请", cat:"labor", warn:true, dur:"long",
      time:"单位30日 / 个人1年", desc:"单位应自事故伤害发生之日或被诊断、鉴定为职业病之日起30日内提出。用人单位未提，工伤职工或其近亲属、工会可在1年内提出。",
      risk:"超过1年申请，人社部门可能不予受理，导致无法享受工伤待遇。",
      law:"《工伤保险条例》第17条" },
    // 商法
    { name:"股东知情权诉讼", cat:"commercial", warn:false, dur:"long",
      time:"无明确期限（受3年诉讼时效约束）", desc:"股东有权查阅、复制章程、决议、财报等。被拒绝后可请求法院要求提供查阅。法律未规定行使期限。",
      risk:"权利持续存在，但需在知道权利被侵害后的诉讼时效（3年）内起诉。",
