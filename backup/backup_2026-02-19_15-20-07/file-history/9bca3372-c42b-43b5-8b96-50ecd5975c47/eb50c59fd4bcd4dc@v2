      risk:"超过票据权利时效，持票人丧失票据权利，但仍享有民事利益返还请求权（适用3年诉讼时效）。",
      law:"《票据法》第17条" },
    // 经济法
    { name:"消费者七日无理由退货", cat:"economic", warn:false, dur:"short",
      time:"7日", desc:"经营者采用网络、电视、电话、邮购等方式销售商品，消费者自收到商品之日起7日内退货，且无需说明理由（定作、鲜活易腐等除外）。",
      risk:"经营者应自收到退回商品之日起7日内返还价款。此为法定的"冷静期"。",
      law:"《消费者权益保护法》第25条" },
    { name:"产品缺陷损害赔偿责任", cat:"economic", warn:false, dur:"long",
      time:"2年（最长10年）", desc:"因产品存在缺陷造成损害要求赔偿的诉讼时效为2年，自知道或应当知道权利受损及生产者/销售者时起算。损害赔偿请求权，在缺陷产品交付最初消费者满10年丧失。",
      risk:"此为特殊时效规定，短于普通3年诉讼时效。10年为最长权利保护期。",
      law:"《产品质量法》第45条" },
    { name:"经营者集中反垄断申报", cat:"economic", warn:true, dur:"short",
      time:"事前申报（初审30日）", desc:"达到申报标准的集中，应事先申报。执法机构应自收到完整申报材料之日起30日内进行初步审查，决定是否进一步审查。",
      risk:""抢跑"（应报未报即实施集中）面临高额罚款（最高上一年度销售额10%），可能被责令恢复原状。",
      law:"《反垄断法》第21、26条" },
    // 民事实体
    { name:"民事法律行为撤销权", cat:"civil", warn:true, dur:"long",
      time:"1年 / 90日（最长5年）", desc:"自知道或应当知道撤销事由之日起1年内行使。因胁迫产生撤销权的，自胁迫行为终止之日起1年内行使。重大误解当事人自知道或应当知道撤销事由之日起90日内行使。自民事法律行为发生之日起5年内没有行使的，撤销权消灭。",
      risk:"逾期不行使，撤销权绝对消灭，法律行为确定有效。此为除斥期间，需主动主张。",
      law:"《民法典》第152条" },
    { name:"债权人撤销权", cat:"civil", warn:true, dur:"long",
      time:"1年（最长5年）", desc:"自债权人知道或应当知道撤销事由之日起1年内行使。自债务人的行为发生之日起5年内没有行使的，撤销权消灭。",
      risk:"逾期不行使，撤销权消灭。需通过诉讼方式行使。",
      law:"《民法典》第538-542条" },
    { name:"保证期间", cat:"civil", warn:true, dur:"medium",
      time:"约定优先，无约定为6个月", desc:"债权人与保证人可以约定保证期间。没有约定或约定不明确的，保证期间为主债务履行期限届满之日起6个月。约定"保证人承担保证责任直至主债务本息还清时为止"等类似内容的，视为约定不明，保证期间为6个月。",
      risk:"保证期间是确定保证人是否承担责任的"生死线"。债权人在此期间内未向保证人主张权利（一般保证需起诉/仲裁），保证责任免除。",
      law:"《民法典》第692、693条" },
    { name:"建设工程价款优先受偿权", cat:"civil", warn:true, dur:"long",
      time:"18个月", desc:"自发包人应当给付建设工程价款之日起算。最长不超过18个月。",
      risk:"性质为法定担保物权，但行使有严格期限。逾期未主张（需通过诉讼或仲裁等方式明确请求），权利消灭。",
      law:"《民法典》第807条；《建设工程施工合同司法解释一》第41条" },
    // 诉讼程序
    { name:"管辖权异议期", cat:"procedure", warn:true, dur:"short",
      time:"15日", desc:"被告在提交答辩状期间提出。答辩期为收到起诉状副本后15日内。",
      risk:"逾期提出，法院不予审查。此为不变期间。",
      law:"《民事诉讼法》第130条" },
    { name:"增加、变更诉讼请求/提出反诉", cat:"procedure", warn:false, dur:"short",
      time:"举证期限届满前", desc:"原则在案件受理后，举证期限届满前提出。法庭辩论结束前，对方同意或法院认为可以合并审理的，也可准许。",
      risk:"逾期提出可能导致法院不予准许，需另案处理，增加讼累。",
      law:"《民诉法解释》第232条" },
    { name:"支付令异议期", cat:"procedure", warn:false, dur:"short",
      time:"15日", desc:"债务人应当自收到支付令之日起15日内清偿债务，或向法院提出书面异议。",
      risk:"15日内不提书面异议或异议不成立，支付令生效，可申请强制执行。提出有效书面异议，支付令失效，转入诉讼程序。",
      law:"《民事诉讼法》第221条" },
    { name:"仲裁裁决撤销申请", cat:"procedure", warn:true, dur:"medium",
      time:"6个月", desc:"当事人提出证据证明裁决有法定撤销情形的，可自收到裁决书之日起6个月内向仲裁委所在地中级法院申请撤销。",
      risk:"逾期未申请，撤销权消灭。",
      law:"《仲裁法》第59条" },
    { name:"公示催告申报权利期", cat:"procedure", warn:false, dur:"medium",
      time:"不少于60日", desc:"法院决定受理公示催告申请后，应同时通知支付人止付，并在3日内发出公告，催促利害关系人申报权利。公示催告期间由法院定，但不得少于60日。",
      risk:"利害关系人应在公示催告期间申报权利。无人申报的，法院根据申请作出除权判决，宣告票据无效。",
      law:"《民事诉讼法》第225条" },
];

const CAT_NAMES = { labor:"劳动法", commercial:"商法", economic:"经济法", civil:"民事实体", procedure:"诉讼程序" };
const DUR_NAMES = { short:"≤15日", medium:"1-6个月", long:"1-3年", vlong:"3年以上" };

let curCat = "all", curDur = "all", curSearch = "";

function render() {
    const filtered = DATA.filter(d => {
        if (curCat === "warning") { if (!d.warn) return false; }
        else if (curCat !== "all" && d.cat !== curCat) return false;
        if (curDur !== "all" && d.dur !== curDur) return false;
        if (curSearch) {
            const s = curSearch.toLowerCase();
            const t = (d.name + d.time + d.desc + d.risk + d.law).toLowerCase();
            if (!t.includes(s)) return false;
        }
        return true;
    });

    // 统计
    const total = filtered.length;
    const warnCount = filtered.filter(d => d.warn).length;
    const catCount = new Set(filtered.map(d => d.cat)).size;
    document.getElementById('stats').innerHTML = `
        <div class="stat-card"><div class="num">${total}</div><div class="label">匹配条目</div></div>
        <div class="stat-card warn"><div class="num">${warnCount}</div><div class="label">高风险项</div></div>
        <div class="stat-card"><div class="num">${catCount}</div><div class="label">涉及门类</div></div>
    `;

    // 卡片
    const list = document.getElementById('cardList');
    const noRes = document.getElementById('noResult');
    if (!filtered.length) { list.innerHTML = ''; noRes.style.display = 'block'; return; }
    noRes.style.display = 'none';

    list.innerHTML = filtered.map((d, i) => `
        <div class="card cat-${d.cat} ${d.warn ? 'warn-card' : ''}" onclick="this.classList.toggle('expanded')">
            ${d.warn ? '<div class="warn-badge">⚠ 高风险</div>' : ''}
            <div class="cat-tag">${CAT_NAMES[d.cat]}</div>
            <div class="title">${highlight(d.name)}</div>
            <div class="duration">${highlight(d.time)}</div>
            <div class="desc">${highlight(truncate(d.desc, 80))}</div>
            <div class="detail">
                <div class="desc" style="margin-bottom:10px">${highlight(d.desc)}</div>
                <div class="risk">${highlight(d.risk)}</div>
                <div class="law-ref">📖 ${highlight(d.law)}</div>
            </div>
            <div class="expand-hint">点击展开/收起详情 ▾</div>
        </div>
    `).join('');
}

function truncate(s, n) { return s.length > n ? s.slice(0, n) + '...' : s; }

function highlight(text) {
    if (!curSearch) return text;
    const re = new RegExp('(' + curSearch.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
    return text.replace(re, '<mark style="background:#fbbf24;color:#0f172a;border-radius:2px;padding:0 2px">$1</mark>');
}

// 事件绑定
document.getElementById('searchInput').addEventListener('input', e => { curSearch = e.target.value.trim(); render(); });

document.getElementById('catFilters').addEventListener('click', e => {
    if (!e.target.classList.contains('fbtn')) return;
    document.querySelectorAll('#catFilters .fbtn').forEach(b => b.classList.remove('active'));
    e.target.classList.add('active');
    curCat = e.target.dataset.cat;
    render();
});

document.getElementById('durFilters').addEventListener('click', e => {
    if (!e.target.classList.contains('dbtn')) return;
    document.querySelectorAll('#durFilters .dbtn').forEach(b => b.classList.remove('active'));
    e.target.classList.add('active');
    curDur = e.target.dataset.dur;
    render();
});

window.addEventListener('scroll', () => {
    document.getElementById('backTop').style.display = window.scrollY > 300 ? 'block' : 'none';
});

// 键盘快捷键：按 / 聚焦搜索
document.addEventListener('keydown', e => {
    if (e.key === '/' && document.activeElement !== document.getElementById('searchInput')) {
        e.preventDefault();
        document.getElementById('searchInput').focus();
    }
});

render();
</script>
</body>
</html>
