package com.courassistant.java.utils;

import android.Manifest;
import android.app.Activity;
import android.content.Context;
import android.content.pm.PackageManager;
import android.os.Build;

import androidx.core.app.ActivityCompat;
import androidx.core.content.ContextCompat;

import java.util.ArrayList;
import java.util.List;

/**
 * 权限管理工具类
 * 功能：
 * 1. 检查权限是否已授予
 * 2. 请求权限
 * 3. 检查是否需要显示权限说明
 */
public class PermissionUtils {

    /**
     * 应用需要的所有权限
     */
    public static final String[] REQUIRED_PERMISSIONS = {
            Manifest.permission.READ_SMS,
            Manifest.permission.RECEIVE_SMS,
            Manifest.permission.READ_CALENDAR,
            Manifest.permission.WRITE_CALENDAR,
            Manifest.permission.READ_EXTERNAL_STORAGE,
            Manifest.permission.WRITE_EXTERNAL_STORAGE
    };

    /**
     * Android 13+ 需要通知权限
     */
    public static final String[] PERMISSIONS_ANDROID_13 = {
            Manifest.permission.POST_NOTIFICATIONS
    };

    /**
     * Android 12+ 需要闹钟权限（用于设置提醒）
     */
    public static final String[] PERMISSIONS_ANDROID_12 = {
            Manifest.permission.SCHEDULE_EXACT_ALARM
    };

    /**
     * 检查单个权限是否已授予
     */
    public static boolean hasPermission(Context context, String permission) {
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.M) {
            return ContextCompat.checkSelfPermission(context, permission)
                    == PackageManager.PERMISSION_GRANTED;
        }
        return true;
    }

    /**
     * 检查多个权限是否都已授予
     */
    public static boolean hasAllPermissions(Context context, String[] permissions) {
        if (permissions == null || permissions.length == 0) {
            return true;
        }

        for (String permission : permissions) {
            if (!hasPermission(context, permission)) {
                return false;
            }
        }
        return true;
    }

    /**
     * 检查所有必需权限是否都已授予
     */
    public static boolean hasAllRequiredPermissions(Context context) {
        List<String> permissions = new ArrayList<>();

        // 添加基础权限
        for (String permission : REQUIRED_PERMISSIONS) {
            // Android 11+ 不再需要 WRITE_EXTERNAL_STORAGE
            if (permission.equals(Manifest.permission.WRITE_EXTERNAL_STORAGE) &&
                    Build.VERSION.SDK_INT >= Build.VERSION_CODES.R) {
                continue;
            }
            // Android 12+ 不再需要 READ_EXTERNAL_STORAGE（对于应用专属目录）
            if (permission.equals(Manifest.permission.READ_EXTERNAL_STORAGE) &&
                    Build.VERSION.SDK_INT >= Build.VERSION_CODES.R) {
                continue;
            }
            permissions.add(permission);
        }

        // Android 13+ 添加通知权限
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.TIRAMISU) {
            for (String permission : PERMISSIONS_ANDROID_13) {
                permissions.add(permission);
            }
        }

        return hasAllPermissions(context, permissions.toArray(new String[0]));
    }

    /**
     * 获取未授予的权限列表
     */
    public static String[] getDeniedPermissions(Context context, String[] permissions) {
        List<String> denied = new ArrayList<>();

        for (String permission : permissions) {
            if (!hasPermission(context, permission)) {
                denied.add(permission);
            }
        }

        return denied.toArray(new String[0]);
    }

    /**
     * 获取未授予的必需权限
     */
    public static String[] getDeniedRequiredPermissions(Context context) {
        List<String> permissions = new ArrayList<>();

        for (String permission : REQUIRED_PERMISSIONS) {
            // Android 11+ 跳过存储权限
            if (permission.equals(Manifest.permission.WRITE_EXTERNAL_STORAGE) &&
                    Build.VERSION.SDK_INT >= Build.VERSION_CODES.R) {
                continue;
            }
            if (permission.equals(Manifest.permission.READ_EXTERNAL_STORAGE) &&
                    Build.VERSION.SDK_INT >= Build.VERSION_CODES.R) {
                continue;
            }
            permissions.add(permission);
        }

        // Android 13+
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.TIRAMISU) {
            for (String permission : PERMISSIONS_ANDROID_13) {
                permissions.add(permission);
            }
        }

        return getDeniedPermissions(context, permissions.toArray(new String[0]));
    }

    /**
     * 请求权限
     * 需要在 Activity 的 onRequestPermissionsResult 中处理结果
     */
    public static void requestPermissions(Activity activity, String[] permissions, int requestCode) {
        ActivityCompat.requestPermissions(activity, permissions, requestCode);
    }

    /**
     * 请求所有必需权限
     */
    public static void requestAllRequiredPermissions(Activity activity, int requestCode) {
        String[] denied = getDeniedRequiredPermissions(activity);
        if (denied.length > 0) {
            requestPermissions(activity, denied, requestCode);
        }
    }

    /**
     * 检查是否应该显示权限说明对话框
     * 用户之前拒绝过该权限时返回 true
     */
    public static boolean shouldShowRequestPermissionRationale(Activity activity, String permission) {
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.M) {
            return ActivityCompat.shouldShowRequestPermissionRationale(activity, permission);
        }
        return false;
    }

    /**
     * 检查权限结果是否全部授予
     */
    public static boolean verifyPermissions(int[] grantResults) {
        if (grantResults == null || grantResults.length == 0) {
            return false;
        }

        for (int result : grantResults) {
            if (result != PackageManager.PERMISSION_GRANTED) {
                return false;
            }
        }
        return true;
    }

    /**
     * 获取权限的友好名称
     */
    public static String getPermissionFriendlyName(String permission) {
        switch (permission) {
            case Manifest.permission.READ_SMS:
            case Manifest.permission.RECEIVE_SMS:
                return "短信";
            case Manifest.permission.READ_CALENDAR:
            case Manifest.permission.WRITE_CALENDAR:
                return "日历";
            case Manifest.permission.READ_EXTERNAL_STORAGE:
            case Manifest.permission.WRITE_EXTERNAL_STORAGE:
                return "存储";
            case Manifest.permission.POST_NOTIFICATIONS:
                return "通知";
            default:
                return "权限";
        }
    }

    /**
     * 获取权限说明文本
     */
    public static String getPermissionDescription(String permission) {
        switch (permission) {
            case Manifest.permission.READ_SMS:
            case Manifest.permission.RECEIVE_SMS:
                return "需要短信权限以读取法院相关短信";
            case Manifest.permission.READ_CALENDAR:
            case Manifest.permission.WRITE_CALENDAR:
                return "需要日历权限以同步开庭信息";
            case Manifest.permission.READ_EXTERNAL_STORAGE:
            case Manifest.permission.WRITE_EXTERNAL_STORAGE:
                return "需要存储权限以保存PDF文档";
            case Manifest.permission.POST_NOTIFICATIONS:
                return "需要通知权限以提醒重要信息";
            default:
                return "需要此权限以正常使用应用功能";
        }
    }
}
