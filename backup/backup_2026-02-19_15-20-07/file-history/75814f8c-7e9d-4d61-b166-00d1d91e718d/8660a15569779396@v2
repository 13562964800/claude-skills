<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="200dp"
    android:height="200dp"
    android:viewportWidth="200"
    android:viewportHeight="200">

    <!-- 手机图标 -->
    <group
        android:translateX="50"
        android:translateY="30">

        <!-- 手机外框 -->
        <rect
            android:fillColor="@color/bg_paper"
            android:strokeColor="@color/dai_cyan"
            android:strokeWidth="8"
            android:strokeLineJoin="round"
            android:rx="10"
            android:ry="10"
            android:x="0"
            android:y="0"
            android:width="100"
            android:height="140" />

        <!-- 屏幕区域 -->
        <rect
            android:fillColor="@color/bg_rice"
            android:x="10"
            android:y="10"
            android:width="80"
            android:height="100" />

        <!-- 短信线条 -->
        <path
            android:strokeColor="@color/dai_cyan"
            android:strokeWidth="6"
            android:strokeLineCap="round"
            android:pathData="M20,40 L80,40 M20,65 L80,65 M20,90 L80,90 M20,115 L60,115" />

        <!-- 案号标签 -->
        <rect
            android:fillColor="@color/dai_cyan"
            android:rx="3"
            android:ry="3"
            android:x="65"
            android:y="105"
            android:width="20"
            android:height="12" />

        <!-- 关键词图标 -->
        <circle
            android:fillColor="@color/dai_cyan"
            android:cx="25"
            android:cy="50"
            android:r="6" />
        <circle
            android:fillColor="@color/dai_cyan"
            android:cx="25"
            android:cy="75"
            android:r="6" />
        <circle
            android:fillColor="@color/dai_cyan"
            android:cx="25"
            android:cy="100"
            android:r="6" />
    </group>

</vector>
