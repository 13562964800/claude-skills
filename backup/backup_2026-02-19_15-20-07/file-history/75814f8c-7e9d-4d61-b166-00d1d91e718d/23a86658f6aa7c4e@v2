#!/bin/bash

# CourtAssistant ADB 便捷工具脚本
# 宋氏美学 · 单夫纯律师 制作

set -e

# ADB 完整路径
ADB="C:\Users\Administrator\AppData\Local\Android\Sdk\platform-tools\adb.exe"
PACKAGE="com.courassistant.java"

# 颜色
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color

echo "================================"
echo "CourtAssistant ADB 工具"
echo "宋氏美学 · 单夫纯律师"
echo "================================"
echo ""

# 显示菜单
show_menu() {
    echo "请选择操作:"
    echo ""
    echo "  1. 检查设备连接"
    echo "  2. 安装应用"
    echo "  3. 卸载应用"
    echo "  4. 启动应用"
    echo "  5. 停止应用"
    echo "  6. 清除应用数据"
    echo "  7. 发送测试短信"
    echo "  8. 查看应用日志"
    echo "  9. 查看设备信息"
    echo "  10. 截图"
    echo "  0. 退出"
    echo ""
    echo -n "请输入选项 [0-10]: "
    read choice

    case $choice in
        0) echo "退出"; exit 0 ;;
        1) check_device ;;
        2) install_app ;;
        3) uninstall_app ;;
        4) start_app ;;
        5) stop_app ;;
        6) clear_data ;;
        7) send_test_sms ;;
        8) view_logs ;;
        9) device_info ;;
        10) capture_screen ;;
        *) echo "无效选项"; sleep 2 ;;
    esac
}

# 1. 检查设备连接
check_device() {
    echo -e "${BLUE}📱 检查设备连接...${NC}"

    DEVICES=$("$ADB" devices)
    DEVICE_COUNT=$(echo "$DEVICES" | grep -c "device")

    if [ $DEVICE_COUNT -eq 0 ]; then
        echo -e "${RED}❌ 未检测到设备${NC}"
        echo ""
        echo "请确保："
        echo "  1. USB 线已连接"
        echo "  2. 手机已解锁"
        echo "  3. 已启用 USB 调试"
        echo "  4. 已授权 USB 调试"
        echo ""
        return 1
    elif [ $DEVICE_COUNT -eq 1 ]; then
        echo -e "${GREEN}✅ 检测到 1 个设备${NC}"

        # 显示设备信息
        DEVICE_INFO=$(echo "$DEVICES" | grep "device" | awk '{print $1 "\t" $2 "\t" $3 "\t" $4 "\t" $5 "\t" $6}')
        MODEL=$(echo "$DEVICE_INFO" | cut -f2)
        ANDROID_VERSION=$(echo "$DEVICE_INFO" | cut -f3)
        DEVICE_ID=$(echo "$DEVICE_INFO" | cut -f1)

        echo "设备信息："
        echo "  序列号: $DEVICE_ID"
        echo "  型号: $MODEL"
        echo "  Android: $ANDROID_VERSION"
        echo ""
        return 0
    else
        echo -e "${YELLOW}⚠️  检测到 $DEVICE_COUNT 个设备${NC}"
        echo "$DEVICES"
        return 0
    fi
}

# 2. 安装应用
install_app() {
    echo -e "${BLUE}📦 安装应用...${NC}"

    # 编译 APK（如果不存在）
    if [ ! -f "app/build/outputs/apk/debug/app-debug.apk" ]; then
        echo "APK 文件不存在，开始编译..."
        echo ""
        cd C:\Users\Administrator\CourtAssistant
        ./gradlew assembleDebug
    fi

    # 检查 APK 是否存在
    if [ ! -f "app/build/outputs/apk/debug/app-debug.apk" ]; then
        echo -e "${RED}❌ APK 文件不存在: app-debug.apk${NC}"
        return 1
    fi

    APK_PATH="app/build/outputs/apk/debug/app-debug.apk"

    # 显示 APK 信息
    APK_SIZE=$(du -h "$APK_PATH" | cut -f1)
    echo "APK 大小: $APK_SIZE"
    echo ""

    # 卸载旧版本
    echo "卸载旧版本..."
    "$ADB" uninstall "$PACKAGE" >/dev/null 2>&1
    echo ""

    # 安装新版本
    echo "安装到设备..."
    if "$ADB" install -r "$APK_PATH"; then
        echo -e "${GREEN}✅ 安装成功！${NC}"
        echo ""
        start_app
    else
        echo -e "${RED}❌ 安装失败${NC}"
        return 1
    fi
}

# 3. 卸载应用
uninstall_app() {
    echo -e "${BLUE}🗑️ 卸载应用...${NC}"

    "$ADB" uninstall "$PACKAGE"
    echo -e "${GREEN}✅ 卸载完成${NC}"
}

# 4. 启动应用
start_app() {
    echo -e "${BLUE}▶️ 启动应用...${NC}"

    "$ADB" shell am start -n "$PACKAGE/.ui.MainActivity"

    echo -e "${GREEN}✅ 应用已启动${NC}"
    echo "请在手机上查看应用"
    echo ""
}

# 5. 停止应用
stop_app() {
    echo -e "${BLUE}⏹ 停止应用...${NC}"

    "$ADB" shell am force-stop "$PACKAGE"

    echo -e "${GREEN}✅ 应用已停止${NC}"
}

# 6. 清除应用数据
clear_data() {
    echo -e "${YELLOW}🧹 清除应用数据...${NC}"

    "$ADB" shell pm clear "$PACKAGE"

    echo -e "${GREEN}✅ 数据已清除${NC}"
    echo "下次启动将显示用户引导页"
}

# 7. 发送测试短信
send_test_sms() {
    echo -e "${BLUE}📧 发送测试短信${NC}"
    echo ""
    echo "选择测试短信类型："
    echo "  1. 简单测试短信"
    echo "  2. 法院短信（带案号）"
    echo "  3. 带链接的短信"
    echo ""
    echo -n "请选择 [1-3]: "
    read choice

    case $choice in
        1)
            "$ADB" shell am broadcast -a android.provider.Telephony.SMS_RECEIVED \
                --es pdus "[BATCH]" \
                --ee sender "\"10690000\"" \
                --ee extras "string:【测试】这是一条测试短信"
            echo -e "${GREEN}✅ 测试短信已发送${NC}"
            ;;
        2)
            "$ADB" shell am broadcast -a android.provider.Telephony.SMS_RECEIVED \
                --es pdus "[BATCH]" \
                --ee sender "\"10690000\"" \
                --ee extras "string:【北京市第一中级人民法院】您有案件(2024)京01民初123号将于2024年3月15日上午9:30在第三法庭开庭，请准时出席。"
            echo -e "${GREEN}✅ 法院短信已发送${NC}"
            ;;
        3)
            "$ADB" shell am broadcast -a android.provider.Telephony.SMS_RECEIVED \
                --es pdus "[BATCH]" \
                --ee sender "\"10690000\"" \
                --ee extras "string:【法院】请点击链接下载传票：https://example.com/document.pdf"
            echo -e "${GREEN}✅ 带链接短信已发送${NC}"
            ;;
        *)
            echo -e "${RED}❌ 无效选择${NC}"
            return
            ;;
    esac

    echo ""
    echo "请检查手机是否收到短信"
    echo "然后在 CourtAssistant 中查看"
}

# 8. 查看应用日志
view_logs() {
    echo -e "${BLUE}📋 查看应用日志...${NC}"
    echo ""
    echo "正在显示日志（按 Ctrl+C 停止）..."
    echo ""

    "$ADB" logcat -s CourtAssistant:SmsReceiver:SmsParser:PdfParser:CourtDatabase | tee app_log.txt

    echo ""
    echo -e "${GREEN}✅ 日志已保存到 app_log.txt${NC}"
}

# 9. 设备信息
device_info() {
    echo -e "${BLUE}📱 设备详细信息${NC}"
    echo ""

    DEVICES=$("$ADB" devices)
    DEVICE_INFO=$(echo "$DEVICES" | grep "device")

    if [ -z "$DEVICE_INFO" ]; then
        echo -e "${RED}❌ 未检测到设备${NC}"
        return 1
    fi

    # 解析设备信息
    MODEL=$(echo "$DEVICE_INFO" | awk '{print $2}')
    ANDROID_VERSION=$(echo "$DEVICE_INFO" | awk '{print $3}')
    DEVICE_ID=$(echo "$DEVICE_INFO" | awk '{print $1}')

    echo "设备 ID: $DEVICE_ID"
    echo "型号: $MODEL"
    echo "Android 版本: $ANDROID_VERSION"
    echo ""

    # 获取更多设备信息
    echo "详细设备信息:"
    "$ADB" shell getprop | grep -E "ro.product.model|ro.build.version|ro.build.version.sdk|ro.build.date" | head -10
}

# 10. 截图
capture_screen() {
    echo -e "${BLUE}📸 截图...${NC}"
    echo ""

    SCREENSHOT="screenshot_$(date +%Y%m%d_%H%M%S).png"

    "$ADB" exec-out screencap -p > "$SCREENSHOT"

    if [ -f "$SCREENSHOT" ]; then
        echo -e "${GREEN}✅ 截图已保存: $SCREENSHOT${NC}"
        echo "文件位置: $(pwd)/$SCREENSHOT"
    else
        echo -e "${RED}❌ 截图失败${NC}"
    fi
}

# 主程序
echo "================================"
echo "CourtAssistant ADB 工具已就绪"
echo "================================"
echo ""
echo "已检测到设备: 22N0223B0"
echo ""
show_menu
