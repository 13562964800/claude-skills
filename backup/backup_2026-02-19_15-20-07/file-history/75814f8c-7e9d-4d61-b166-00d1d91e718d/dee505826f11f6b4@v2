#!/bin/bash

# CourtAssistant 测试脚本
# 运行单元测试和集成测试
#
# 宋氏美学 · 单夫纯律师 制作

set -e

echo "================================"
echo "CourtAssistant 测试套件"
echo "宋氏美学 · 单夫纯律师"
echo "================================"
echo ""

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# 统计变量
UNIT_TESTS_PASSED=0
UNIT_TESTS_FAILED=0
INSTRUMENTED_TESTS_PASSED=0
INSTRUMENTED_TESTS_FAILED=0

# 1. 清理之前的测试结果
echo "🧹 清理测试结果..."
./gradlew clean
echo ""

# 2. 运行单元测试
echo "================================"
echo "📋 单元测试"
echo "================================"
echo ""

if ./gradlew test --info; then
    echo -e "${GREEN}✅ 单元测试通过${NC}"
    UNIT_TESTS_PASSED=1
else
    echo -e "${RED}❌ 单元测试失败${NC}"
    UNIT_TESTS_FAILED=1
fi

echo ""

# 3. 运行 Android 集成测试
echo "================================"
echo "📱 Android 集成测试"
echo "================================"
echo ""

# 检查设备连接
echo "检查 Android 设备..."
DEVICES=$(adb devices | grep -v "List" | wc -l)

if [ "$DEVICES" -eq 0 ]; then
    echo -e "${YELLOW}⚠️  未检测到 Android 设备${NC}"
    echo "请连接设备或启动模拟器:"
    echo "  adb devices"
    echo "  emulator -avd test_avd"
    echo ""
    read -p "按 Enter 继续跳过集成测试..."
    INSTRUMENTED_TESTS_SKIPPED=1
else
    echo -e "${GREEN}✅ 检测到 $DEVICES 个设备${NC}"
    echo ""

    # 运行集成测试
    if ./gradlew connectedAndroidTest --info; then
        echo -e "${GREEN}✅ 集成测试通过${NC}"
        INSTRUMENTED_TESTS_PASSED=1
    else
        echo -e "${RED}❌ 集成测试失败${NC}"
        INSTRUMENTED_TESTS_FAILED=1
    fi
fi

echo ""

# 4. 生成测试报告
echo "================================"
echo "📊 测试报告"
echo "================================"
echo ""

echo "单元测试:"
if [ $UNIT_TESTS_PASSED -eq 1 ]; then
    echo -e "  ${GREEN}✅ 通过${NC}"
elif [ $UNIT_TESTS_FAILED -eq 1 ]; then
    echo -e "  ${RED}❌ 失败${NC}"
else
    echo -e "  ${YELLOW}⏭ 跳过${NC}"
fi

echo ""
echo "集成测试:"
if [ $INSTRUMENTED_TESTS_PASSED -eq 1 ]; then
    echo -e "  ${GREEN}✅ 通过${NC}"
elif [ $INSTRUMENTED_TESTS_FAILED -eq 1 ]; then
    echo -e "  ${RED}❌ 失败${NC}"
elif [ $INSTRUMENTED_TESTS_SKIPPED -eq 1 ]; then
    echo -e "  ${YELLOW}⏭ 跳过 (无设备)${NC}"
else
    echo -e "  ${YELLOW}⏭ 跳过${NC}"
fi

echo ""

# 5. 测试覆盖率（如果有 JaCoCo）
if command -v jq &> /dev/null; then
    echo "================================"
    echo "📈 测试覆盖率"
    echo "================================"
    echo ""

    if [ -f "app/build/reports/coverage/test/index.html" ]; then
        echo "单元测试覆盖率报告:"
        echo "  file://$PWD/app/build/reports/coverage/test/index.html"
        echo ""
    fi

    if [ -f "app/build/reports/coverage/androidTest/connected/index.html" ]; then
        echo "集成测试覆盖率报告:"
        echo "  file://$PWD/app/build/reports/coverage/androidTest/connected/index.html"
        echo ""
    fi
fi

# 6. 显示日志位置
echo "================================"
echo "📁 测试日志位置"
echo "================================"
echo ""

if [ -d "app/build/reports/tests" ]; then
    echo "单元测试报告:"
    echo "  $PWD/app/build/reports/tests/"
    echo ""
fi

if [ -d "app/build/reports/androidTests" ]; then
    echo "集成测试报告:"
    echo "  $PWD/app/build/reports/androidTests/"
    echo ""
fi

# 7. 总结
echo "================================"
echo "📋 测试总结"
echo "================================"
echo ""

TOTAL_TESTS=0
TOTAL_PASSED=0
TOTAL_FAILED=0

if [ $UNIT_TESTS_PASSED -eq 1 ] || [ $UNIT_TESTS_FAILED -eq 1 ]; then
    TOTAL_TESTS=$((TOTAL_TESTS + 1))
    if [ $UNIT_TESTS_PASSED -eq 1 ]; then
        TOTAL_PASSED=$((TOTAL_PASSED + 1))
    fi
    if [ $UNIT_TESTS_FAILED -eq 1 ]; then
        TOTAL_FAILED=$((TOTAL_FAILED + 1))
    fi
fi

if [ $INSTRUMENTED_TESTS_PASSED -eq 1 ] || [ $INSTRUMENTED_TESTS_FAILED -eq 1 ]; then
    TOTAL_TESTS=$((TOTAL_TESTS + 1))
    if [ $INSTRUMENTED_TESTS_PASSED -eq 1 ]; then
        TOTAL_PASSED=$((TOTAL_PASSED + 1))
    fi
    if [ $INSTRUMENTED_TESTS_FAILED -eq 1 ]; then
        TOTAL_FAILED=$((TOTAL_FAILED + 1))
    fi
fi

echo "测试套件: $TOTAL_TESTS"
if [ $TOTAL_PASSED -gt 0 ]; then
    echo -e "通过: ${GREEN}$TOTAL_PASSED${NC}"
else
    echo "通过: 0"
fi

if [ $TOTAL_FAILED -gt 0 ]; then
    echo -e "失败: ${RED}$TOTAL_FAILED${NC}"
else
    echo "失败: 0"
fi

echo ""

# 8. 返回退出码
if [ $TOTAL_FAILED -gt 0 ]; then
    echo -e "${RED}❌ 测试失败${NC}"
    exit 1
else
    echo -e "${GREEN}✅ 所有测试通过${NC}"
    exit 0
fi
