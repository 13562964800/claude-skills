    /**
     * 测试完整传票解析流程
     */
    @Test
    public void testParseCompleteSummons() {
        String completePdfText =
            "================================\n" +
            "  北京市第一中级人民法院\n" +
            "        开庭传票\n" +
            "================================\n" +
            "\n" +
            "案号：(2024)京01民初123号\n" +
            "案件类型：民事纠纷\n" +
            "\n" +
            "当事人信息：\n" +
            "  原告：张三\n" +
            "  被告：李四\n" +
            "\n" +
            "开庭信息：\n" +
            "  时间：2024年3月15日上午9:30\n" +
            "  地点：第三法庭\n" +
            "  审判长：王法官\n" +
            "  书记员：陈书记员\n" +
            "\n" +
            "注意事项：\n" +
            "  请携带身份证件\n" +
            "  请准时出席\n" +
            "================================";

        File testFile = createTempFile("complete_summons.txt", completePdfText);

        PdfParser parser = new PdfParser();
        CourtCase courtCase = parser.parseSummonsPdf(testFile.getAbsolutePath());

        assertNotNull("完整传票应能解析", courtCase);
        assertEquals("案号正确", "(2024)京01民初123号", courtCase.getCaseNo());
        assertEquals("法院名称", "北京市第一中级人民法院", courtCase.getCourtFullName());
        assertEquals("原告", "张三", courtCase.getPlaintiff());
        assertEquals("被告", "李四", courtCase.getDefendant());
        assertEquals("案件类型", "民事", courtCase.getCaseType());
        assertTrue("开庭时间正确", courtCase.getHearingDate() > 0);
        assertEquals("地点", "第三法庭", courtCase.getLocation());
        assertEquals("审判长", "王法官", courtCase.getJudgeName());

        testFile.delete();
    }

