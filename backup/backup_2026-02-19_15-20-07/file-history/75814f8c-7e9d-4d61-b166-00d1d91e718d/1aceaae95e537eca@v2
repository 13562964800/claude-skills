    /**
     * 测试不同案号格式
     */
    @Test
    public void testExtractCaseNo_DifferentFormats() {
        PdfParser parser = new PdfParser();

        // 民事案件
        String caseNo1 = parser.extractCaseNoFromText("案号：(2024)京01民初123号");
        assertEquals("民事案号", "(2024)京01民初123号", caseNo1);

        // 刑事案件
        String caseNo2 = parser.extractCaseNoFromText("案号：(2024)京01刑初456号");
        assertEquals("刑事案号", "(2024)京01刑初456号", caseNo2);

        // 行政案件
        String caseNo3 = parser.extractCaseNoFromText("案号：(2024)京01行终789号");
        assertEquals("行政案号", "(2024)京01行终789号", caseNo3);

        // 无括号格式
        String caseNo4 = parser.extractCaseNoFromText("案号：2024年京01民初123号");
        assertNotNull("无括号格式应能解析", caseNo4);
    }

