    /**
     * 测试边界情况
     */
    @Test
    public void testEdgeCases() {
        PdfParser parser = new PdfParser();

        // 空字符串
        CourtCase emptyCase = parser.parseSummonsPdf("");
        assertNotNull("空路径应能处理", emptyCase);

        // null 输入
        CourtCase nullCase = parser.parseSummonsPdf(null);
        assertNotNull("null路径应能处理", nullCase);

        // 不存在的文件
        CourtCase notExistCase = parser.parseSummonsPdf("/path/to/not/exist.pdf");
        assertNotNull("不存在文件应能处理", notExistCase);

        // 非常长的内容
        StringBuilder longContent = new StringBuilder();
        for (int i = 0; i < 10000; i++) {
            longContent.append("测试内容 ");
        }
        File longFile = createTempFile("long.txt", longContent.toString());
        CourtCase longCase = parser.parseSummonsPdf(longFile.getAbsolutePath());
        assertNotNull("超长文件应能处理", longCase);
        longFile.delete();
    }

    /**
     * 测试部分信息缺失
     */
    @Test
    public void testPartialInformation() {
        PdfParser parser = new PdfParser();

        // 只有案号
        String partial1 = "案号：(2024)京01民初123号";
        CourtCase case1 = new CourtCase();
        case1.setCaseNo(parser.extractCaseNoFromText(partial1));
        assertEquals("仅案号应能解析", "(2024)京01民初123号", case1.getCaseNo());

        // 只有时间
        String partial2 = "开庭时间：2024年3月15日";
        long time = parser.extractHearingDateFromText(partial2);
        assertTrue("仅时间应能解析", time > 0);

        // 缺少案号
        CourtCase missingCase = parser.parseSummonsPdf("无案号文档");
        // 应该返回 null 或案号为空的 CourtCase
        assertNotNull("缺少案号应能处理", missingCase);
    }

    /**
     * 测试时间格式容错
     */
    @Test
    public void testTimeFormatTolerance() {
        PdfParser parser = new PdfParser();

        // 使用"时"而非":"
        long time1 = parser.extractHearingDateFromText("2024年3月15日9时30分");
        assertTrue("使用时应能解析", time1 > 0);

        // 24小时制
        long time2 = parser.extractHearingDateFromText("2024年3月15日14时30分");
        assertTrue("24小时制应能解析", time2 > 0);

        // 仅日期
        long time3 = parser.extractHearingDateFromText("2024年3月15日开庭");
        assertTrue("仅日期应能解析", time3 > 0);
    }

    /**
     * 测试法律文书类型识别
     */
    @Test
    public void testIdentifyDocumentType() {
        PdfParser parser = new PdfParser();

        // 传票
        boolean isSummons1 = parser.isSummonsDocument("开庭传票");
        assertTrue("传票关键词", isSummons1);

        // 应诉通知书
        boolean isSummons2 = parser.isSummonsDocument("应诉通知书");
        assertTrue("应诉通知书关键词", isSummons2);

        // 判决书
        boolean isSummons3 = parser.isSummonsDocument("民事判决书");
        assertFalse("判决书不是传票", isSummons3);

        // 裁定书
        boolean isSummons4 = parser.isSummonsDocument("裁定书");
        assertFalse("裁定书不是传票", isSummons4);
    }

    /**
     * 辅助方法：创建临时测试文件
     */
    private File createTempFile(String name, String content) {
        try {
            File tempDir = new File(System.getProperty("java.io.tmpdir"));
            File tempFile = new File(tempDir, name);
            FileWriter writer = new FileWriter(tempFile);
            writer.write(content);
            writer.close();
            return tempFile;
        } catch (IOException e) {
            fail("创建测试文件失败: " + e.getMessage());
            return null;
        }
    }
