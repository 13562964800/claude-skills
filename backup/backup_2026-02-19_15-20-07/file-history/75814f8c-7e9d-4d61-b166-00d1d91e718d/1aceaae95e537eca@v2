    /**
     * 测试标准传票解析
     */
    @Test
    public void testParseSummonsPdf_StandardFormat() {
        // 创建测试 PDF 内容（模拟文本提取）
        String pdfText = "北京市第一中级人民法院\n" +
                       "开庭传票\n" +
                       "案号：(2024)京01民初123号\n" +
                       "原告：张三\n" +
                       "被告：李四\n" +
                       "开庭时间：2024年3月15日上午9:30\n" +
                       "地点：第三法庭\n" +
                       "审判长：王法官";

        // 创建临时测试文件
        File testFile = createTempFile("test_summons.txt", pdfText);

        PdfParser parser = new PdfParser();
        CourtCase courtCase = parser.parseSummonsPdf(testFile.getAbsolutePath());

        assertNotNull("解析结果不应为null", courtCase);
        assertEquals("案号应正确", "(2024)京01民初123号", courtCase.getCaseNo());
        assertEquals("原告应正确", "张三", courtCase.getPlaintiff());
        assertEquals("被告应正确", "李四", courtCase.getDefendant());
        assertTrue("开庭时间应正确", courtCase.getHearingDate() > 0);

        // 清理测试文件
        testFile.delete();
    }

    /**
