    /**
     * 测试特殊字符处理
     */
    @Test
    public void testSpecialCharacters() {
        PdfParser parser = new PdfParser();

        // 全角标点
        String caseNo1 = parser.extractCaseNoFromText("案号：（2024）京01民初123号");
        assertNotNull("全角标点应能处理", caseNo1);

        // 空格
        String caseNo2 = parser.extractCaseNoFromText("案号： ( 2024 ) 京 01 民初 123 号");
        assertNotNull("多余空格应能处理", caseNo2);

        // 制表符
        String caseNo3 = parser.extractCaseNoFromText("案号：\t(2024)\t京01民初123号");
