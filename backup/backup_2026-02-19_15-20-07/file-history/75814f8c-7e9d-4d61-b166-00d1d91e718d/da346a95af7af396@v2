#!/bin/bash

# CourtAssistant 自动化测试脚本
# 在模拟器上执行测试
#
# 宋氏美学 · 单夫纯律师 制作

set -e

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

echo "================================"
echo "CourtAssistant 自动化测试"
echo "宋氏美学 · 单夫纯律师"
echo "================================"
echo ""

# 配置
APK_PATH="app/build/outputs/apk/debug/app-debug.apk"
PACKAGE_NAME="com.courassistant.java"
TEST_TIMEOUT=300  # 5分钟超时
LOG_FILE="test_results_$(date +%Y%m%d_%H%M%S).log"

# 统计变量
TOTAL_TESTS=0
PASSED_TESTS=0
FAILED_TESTS=0

# 日志函数
log_message() {
    local level=$1
    shift
    local message="$@"
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] [$level] $message" | tee -a "$LOG_FILE"
}

log_info() {
    log_message "INFO" "$@"
}

log_success() {
    log_message "SUCCESS" "$@"
}

log_error() {
    log_message "ERROR" "$@"
}

log_warning() {
    log_message "WARNING" "$@"
}

# 检查设备连接
check_device() {
    echo -e "${BLUE}📱 检查Android设备...${NC}"

    local attempts=0
    local max_attempts=30

    while [ $attempts -lt $max_attempts ]; do
        if adb devices | grep -q "device$"; then
            echo -e "${GREEN}✅ 设备已连接${NC}"
            return 0
        fi

        echo -n "."
        sleep 2
        attempts=$((attempts + 1))
    done

    echo ""
    log_error "未检测到设备，请确保模拟器正在运行"
    return 1
}

# 等待应用安装
wait_for_app() {
    local app_name=$1
    local timeout=${2:-30}

    log_info "等待应用启动: $app_name"

    local elapsed=0
    while [ $elapsed -lt $timeout ]; do
        if adb shell pm list packages | grep -q "$app_name"; then
            log_success "应用已安装: $app_name"
            return 0
        fi
        sleep 1
        elapsed=$((elapsed + 1))
    done

    log_error "应用安装超时"
    return 1
}

# 清除旧数据
clear_app_data() {
    log_info "清除应用旧数据"

    adb shell pm clear "$PACKAGE_NAME" 2>/dev/null || true
    sleep 2

    log_success "数据已清除"
}

# 安装应用
install_app() {
    echo -e "${BLUE}📦 安装应用...${NC}"

    if [ ! -f "$APK_PATH" ]; then
        log_error "APK文件不存在: $APK_PATH"
        echo "请先运行: ./gradlew assembleDebug"
        return 1
    fi

    # 卸载旧版本
    adb uninstall "$PACKAGE_NAME" 2>/dev/null || true

    # 安装新版本
    if adb install -r "$APK_PATH"; then
        log_success "应用安装成功"
        return 0
    else
        log_error "应用安装失败"
        return 1
    fi
}

# 启动应用
launch_app() {
    log_info "启动应用"

    adb shell am start -n "$PACKAGE_NAME/.ui.MainActivity"

    sleep 3

    # 检查应用是否在前台
    if adb shell dumpsys activity top | grep -q "$PACKAGE_NAME"; then
        log_success "应用已启动并在前台"
    else
        log_warning "应用可能未启动"
    fi
}

# 测试用户引导页
test_onboarding() {
    echo -e "${BLUE}🧪 测试：用户引导页${NC}"
    TOTAL_TESTS=$((TOTAL_TESTS + 1))

    # 重置引导状态
    adb shell pm clear "$PACKAGE_NAME"
    sleep 2

    # 启动应用
    launch_app

    # 检查引导页是否显示
    sleep 3
    local output=$(adb shell dumpsys activity top | grep "$PACKAGE_NAME")

    if echo "$output" | grep -q "OnboardingActivity"; then
        echo -e "${GREEN}  ✅ 引导页显示正常${NC}"
        PASSED_TESTS=$((PASSED_TESTS + 1))
    else
        echo -e "${RED}  ❌ 引导页未显示${NC}"
        FAILED_TESTS=$((FAILED_TESTS + 1))
    fi

    sleep 2
}

# 测试主界面
test_main_activity() {
    echo -e "${BLUE}🧪 测试：主界面${NC}"
    TOTAL_TESTS=$((TOTAL_TESTS + 1))

    # 启动应用
    adb shell am start -n "$PACKAGE_NAME/.ui.MainActivity"
    sleep 4

    # 截图
    adb shell screencap -p /sdcard/main_screenshot.png
    adb pull /sdcard/main_screenshot.png ./

    echo -e "${GREEN}  ✅ 主界面已截图保存${NC}"
    PASSED_TESTS=$((PASSED_TESTS + 1))

    sleep 2
}

# 测试短信功能
test_sms_feature() {
    echo -e "${BLUE}🧪 测试：短信功能${NC}"
    TOTAL_TESTS=$((TOTAL_TESTS + 1))

    # 发送测试短信广播
    log_info "发送测试短信"

    adb shell am broadcast -a android.provider.Telephony.SMS_RECEIVED \
        --es pdus "BATCH" \
        --ei slot 0 \
        --eu extras "string:test_court_message" \
        2>/dev/null || true

    sleep 3

    # 检查日志
    local log_output=$(adb logcat -d | tail -100 | grep "CourtAssistant" || echo "")

    if echo "$log_output" | grep -q "SmsReceiver\|SmsParser"; then
        echo -e "${GREEN}  ✅ 短信接收功能正常${NC}"
        PASSED_TESTS=$((PASSED_TESTS + 1))
    else
        echo -e "${YELLOW}  ⚠️  短信功能日志未找到${NC}"
        FAILED_TESTS=$((FAILED_TESTS + 1))
    fi

    sleep 2
}

# 测试日历功能
test_calendar_feature() {
    echo -e "${BLUE}🧪 测试：日历同步${NC}"
    TOTAL_TESTS=$((TOTAL_TESTS + 1))

    # 检查日历事件
    log_info "检查日历事件"

    local events=$(adb shell content query --uri content://com.android.calendar/events || echo "")

    if echo "$events" | grep -q "title"; then
        echo -e "${GREEN}  ✅ 日历事件创建成功${NC}"
        PASSED_TESTS=$((PASSED_TESTS + 1))
    else
        echo -e "${YELLOW}  ⚠️  未找到日历事件${NC}"
        FAILED_TESTS=$((FAILED_TESTS + 1))
    fi

    sleep 2
}

# 收集应用日志
collect_logs() {
    echo -e "${BLUE}📊 收集应用日志...${NC}"

    local log_file="app_log_$(date +%Y%m%d_%H%M%S).txt"

    # 清除logcat缓冲区
    adb logcat -c

    sleep 2

    # 收集日志
    timeout 10 adb logcat > "$log_file" || true

    if [ -f "$log_file" ]; then
        local log_size=$(du -h "$log_file" | cut -f1)
        echo -e "${GREEN}  ✅ 日志已保存: $log_file ($log_size)${NC}"

        # 分析日志中的错误
        local error_count=$(grep -i "error\|exception\|crash" "$log_file" | wc -l)
        if [ $error_count -gt 0 ]; then
            echo -e "${YELLOW}  ⚠️  发现 $error_count 个错误${NC}"
        fi
    else
        echo -e "${RED}  ❌ 日志收集失败${NC}"
    fi
}

# 性能测试
performance_test() {
    echo -e "${BLUE}⚡ 性能测试${NC}"
    TOTAL_TESTS=$((TOTAL_TESTS + 1))

    log_info "检查应用内存使用"

    local memory_info=$(adb shell dumpsys meminfo "$PACKAGE_NAME" 2>/dev/null || echo "")

    if echo "$memory_info" | grep -q "TOTAL"; then
        local total_mem=$(echo "$memory_info" | grep "TOTAL:" | awk '{print $2}')
        echo -e "  总内存: $total_mem MB"
    fi

    log_info "检查CPU使用"
    local cpu_info=$(adb shell top -n 1 | grep "$PACKAGE_NAME" | head -1)

    if [ -n "$cpu_info" ]; then
        echo "  CPU使用: $cpu_info"
    fi

    echo -e "${GREEN}  ✅ 性能数据收集完成${NC}"
    PASSED_TESTS=$((PASSED_TESTS + 1))

    sleep 2
}

# UI测试 - 截图
ui_test() {
    echo -e "${BLUE}🖼️  UI测试截图${NC}"

    local screens=("main" "sms" "docs" "settings")
    local activities=(".ui.MainActivity" ".ui.MainActivity" ".ui.MainActivity" ".ui.MainActivity")

    for i in "${!screens[@]}"; do
        echo "  测试: ${screens[$i]}"

        # 启动对应界面
        adb shell am start -n "$PACKAGE_NAME${activities[$i]}"
        sleep 3

        # 截图
        local screenshot="ui_${screens[$i]}_$(date +%Y%m%d_%H%M%S).png"
        adb shell screencap -p "/sdcard/$screenshot"
        adb pull "/sdcard/$screenshot" ./

        echo -e "${GREEN}    ✅ 截图已保存: $screenshot${NC}"
    done

    TOTAL_TESTS=$((TOTAL_TESTS + 1))
    PASSED_TESTS=$((PASSED_TESTS + 1))
    sleep 2
}

# 主测试流程
main() {
    echo "开始自动化测试..."
    echo "日志文件: $LOG_FILE"
    echo ""

    # 检查环境
    if ! command -v adb &> /dev/null; then
        log_error "adb 命令未找到，请配置 Android SDK"
        exit 1
    fi

    # 检查设备
    if ! check_device; then
        log_error "请先启动 Android 模拟器"
        exit 1
    fi

    echo ""
    echo -e "${GREEN}================================${NC}"
    echo -e "${GREEN}开始执行测试用例${NC}"
    echo -e "${GREEN}================================${NC}"
    echo ""

    # 1. 清除数据
    clear_app_data

    # 2. 安装应用
    if ! install_app; then
        log_error "应用安装失败，终止测试"
        exit 1
    fi

    # 3. 启动应用
    launch_app

    # 4. 执行测试
    test_onboarding
    test_main_activity
    test_sms_feature
    test_calendar_feature
    performance_test
    ui_test

    # 5. 收集日志
    collect_logs

    # 测试总结
    echo ""
    echo -e "${GREEN}================================${NC}"
    echo -e "${GREEN}测试总结${NC}"
    echo -e "${GREEN}================================${NC}"
    echo ""
    echo "总测试数: $TOTAL_TESTS"
    echo -e "通过: ${GREEN}$PASSED_TESTS${NC}"
    echo -e "失败: ${RED}$FAILED_TESTS${NC}"
    echo ""

    if [ $FAILED_TESTS -eq 0 ]; then
        echo -e "${GREEN}🎉 所有测试通过！${NC}"
        exit 0
    else
        echo -e "${YELLOW}⚠️  部分测试失败，请查看日志${NC}"
        echo "日志文件: $LOG_FILE"
        exit 1
    fi
}

# 运行主流程
main "$@"
