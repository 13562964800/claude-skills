    public static class PerformanceConfig {

        /**
         * 查询优化建议
         */
        public static void optimizeQueries() {
            Log.d(TAG, "数据库查询优化建议:");

            // 1. 使用索引列
            Log.d(TAG, "  1. 确保查询使用索引列");

            // 2. 避免 SELECT *
            Log.d(TAG, "  2. 避免使用 SELECT *，只查询需要的列");

            // 3. 使用事务批量操作
            Log.d(TAG, "  3. 批量插入使用事务");

            // 4. 分页查询
            Log.d(TAG, "  4. 大数据集使用分页 (LIMIT + OFFSET)");

            // 5. 避免 N+1 查询
            Log.d(TAG, "  5. 使用 @Relation 或 JOIN 避免 N+1");

            // 6. 使用查询缓存
            Log.d(TAG, "  6. LiveData 自动缓存查询结果");
        }

        /**
         * 数据库维护
         */
        public static void performMaintenance(Context context) {
            Log.d(TAG, "执行数据库维护");

            // 1. 分析表统计信息
            Log.d(TAG, "  ANALYZE 表统计信息");

            // 2. 重建索引
            Log.d(TAG, "  REINDEX 重建索引");

            // 3. 清理数据库
            Log.d(TAG, "  VACUUM 清理数据库");

            // 4. 检查数据库完整性
            Log.d(TAG, "  PRAGMA integrity_check");

            // 示例 SQL
            String[] maintenanceSqls = {
                "ANALYZE court_cases;",
                "ANALYZE court_messages;",
                "ANALYZE court_documents;",
                "REINDEX;",
                "VACUUM;"
            };

            // 注意: 这些 SQL 应在数据库连接中执行
            // 这里只是记录建议
            for (String sql : maintenanceSqls) {
                Log.d(TAG, "    " + sql);
            }
        }

        /**
         * 数据库大小检查
         */
        public static void checkDatabaseSize(Context context) {
            long dbSize = FileUtils.getDatabaseSize(context);

            if (dbSize > 0) {
                String sizeStr = FileUtils.formatFileSize(dbSize);
                Log.d(TAG, "数据库大小: " + sizeStr);

                // 警告阈值
                long warningThreshold = 50 * 1024 * 1024; // 50MB
                if (dbSize > warningThreshold) {
                    Log.w(TAG, "⚠️  数据库大小超过阈值，建议清理旧数据");
                }
            }
        }
    }

