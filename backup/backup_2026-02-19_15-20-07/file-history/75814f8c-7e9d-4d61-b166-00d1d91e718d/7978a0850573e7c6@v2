    /**
     * 分页查询辅助
     */
    public static class PaginationHelper {

        /**
         * 计算偏移量
         * @param page 页码 (从1开始)
         * @param pageSize 每页大小
         * @return OFFSET 值
         */
        public static int calculateOffset(int page, int pageSize) {
            if (page < 1) page = 1;
            return (page - 1) * pageSize;
        }

        /**
         * 计算总页数
         * @param totalCount 总记录数
         * @param pageSize 每页大小
         * @return 总页数
         */
        public static int calculateTotalPages(int totalCount, int pageSize) {
            if (pageSize <= 0) return 0;
            return (int) Math.ceil((double) totalCount / pageSize);
        }

        /**
         * 生成分页查询 SQL
         * @param tableName 表名
         * @param pageSize 每页大小
         * @param offset 偏移量
         * @return 分页 SQL
         */
        public static String buildPagedQuery(String tableName, int pageSize, int offset) {
            return String.format(
                "SELECT * FROM %s ORDER BY created_at DESC LIMIT %d OFFSET %d",
                tableName, pageSize, offset
            );
        }

        /**
         * 生成分页查询 SQL (带条件)
         * @param tableName 表名
         * @param where WHERE 条件
         * @param pageSize 每页大小
         * @param offset 偏移量
         * @return 分页 SQL
         */
        public static String buildPagedQueryWithCondition(
                String tableName,
                String where,
                int pageSize,
                int offset) {
            return String.format(
                "SELECT * FROM %s WHERE %s ORDER BY created_at DESC LIMIT %d OFFSET %d",
                tableName, where, pageSize, offset
            );
        }
    }

    /**
     * 批量操作优化
     */
    public static class BatchOperationHelper {

        /**
         * 批量插入大小建议
         * 建议每批 100-500 条记录
         */
        public static final int RECOMMENDED_BATCH_SIZE = 200;

        /**
         * 估算批量操作时间
         * @param recordCount 记录数
         * @param batchSize 批量大小
         * @return 批次数
         */
        public static int estimateBatches(int recordCount, int batchSize) {
            if (batchSize <= 0) return 0;
            return (int) Math.ceil((double) recordCount / batchSize);
        }

        /**
         * 批量操作性能建议
