    }

    /**
     * 数据库迁移优化
     */
    public static class MigrationOptimization {

        /**
         * 迁移性能建议
         */
        public static void provideMigrationTips() {
            Log.d(TAG, "数据库迁移性能建议:");
            Log.d(TAG, "  1. 预写数据库并复制");
            Log.d(TAG, "  2. 使用批量操作而非逐条迁移");
            Log.d(TAG, "  3. 在迁移期间禁用索引");
            Log.d(TAG, "  4. 迁移完成后重建索引");
            Log.d(TAG, "  5. 使用 Room 的自动迁移");
        }

        /**
         * 迁移监控
         */
        public static void monitorMigration(int fromVersion, int toVersion) {
            Log.d(TAG, String.format("数据库迁移: %d -> %d", fromVersion, toVersion));
            long startTime = System.currentTimeMillis();

            // 迁移完成后
            long duration = System.currentTimeMillis() - startTime;
            if (duration > 5000) { // 超过5秒
                Log.w(TAG, String.format("⚠️  迁移耗时较长: %dms", duration));
            }
        }
    }
