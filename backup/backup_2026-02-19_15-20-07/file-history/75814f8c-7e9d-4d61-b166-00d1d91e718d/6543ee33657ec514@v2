## 🎯 快速测试命令

```bash
# 一键安装测试
./gradlew assembleDebug && adb install -r app/build/outputs/apk/debug/app-debug.apk

# 一键清除重装
adb uninstall com.courassistant.java && adb install app-debug.apk

# 查看实时日志
adb logcat -s CourtAssistant:SmsReceiver:SmsParser:PdfParser | grep -i "error\|exception"

# 启动应用
adb shell am start -n com.courassistant.java/.ui.MainActivity

# 清除数据重新开始
adb shell pm clear com.courassistant.java

# 查看应用信息
adb shell dumpsys package com.courassistant.java | head -50

# 检查权限
adb shell dumpsys package com.courassistant.java | grep -A 20 "granted=true"
```

