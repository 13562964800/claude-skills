@OptIn(ExperimentalMaterial3Api::class)
@Composable
fun MainScreen(
    viewModel: MainViewModel,
    onOpenWebView: (smsId: Long, url: String) -> Unit,
    onOpenPdf: (pdfId: Long) -> Unit,
    onOpenSettings: () -> Unit = {},
    onShareAllPdfs: (smsId: Long) -> Unit = {}
) {
    val state by viewModel.uiState.collectAsState()
    val snackbarHostState = remember { SnackbarHostState() }
    var showDeleteDialog by remember { mutableStateOf(false) }

    LaunchedEffect(state.message) {
        state.message?.let {
            snackbarHostState.showSnackbar(it)
            viewModel.clearMessage()
        }
    }

    if (showDeleteDialog) {
        AlertDialog(
            onDismissRequest = { showDeleteDialog = false },
            title = { Text("确认删除") },
            text = { Text("确定要删除选中的 ${state.selectedPdfIds.size} 个文件吗？此操作不可恢复。") },
            confirmButton = {
                TextButton(
                    onClick = {
                        viewModel.deleteSelectedPdfs()
                        showDeleteDialog = false
                    }
                ) {
                    Text("删除", color = CinnabarRed)
                }
            },
            dismissButton = {
                TextButton(onClick = { showDeleteDialog = false }) {
                    Text("取消")
                }
            }
        )
    }

    Scaffold(
        snackbarHost = { SnackbarHost(snackbarHostState) },
        topBar = {
            TopAppBar(
                title = {
                    if (state.isSearchExpanded) {
                        TextField(
                            value = state.searchQuery,
                            onValueChange = { viewModel.onSearchQueryChange(it) },
                            placeholder = { Text("搜索案号、法院、当事人") },
                            modifier = Modifier.fillMaxWidth(),
                            colors = TextFieldDefaults.colors(
                                focusedContainerColor = Color.Transparent,
                                unfocusedContainerColor = Color.Transparent,
                                focusedIndicatorColor = Color.Transparent,
                                unfocusedIndicatorColor = Color.Transparent
                            ),
                            singleLine = true,
                            textStyle = MaterialTheme.typography.bodyLarge
                        )
                    } else {
                        Text("法院助手", style = MaterialTheme.typography.headlineMedium)
                    }
                },
                navigationIcon = {
                    if (state.isSearchExpanded) {
                        IconButton(onClick = { viewModel.toggleSearchExpanded() }) {
                            Icon(Icons.Default.Close, contentDescription = "关闭搜索")
                        }
                    }
                },
                actions = {
                    IconButton(onClick = { viewModel.toggleFilterMenu() }) {
                        Icon(Icons.Default.Menu, contentDescription = "筛选")
                    }
                    IconButton(onClick = { viewModel.toggleSearchExpanded() }) {
                        Icon(Icons.Default.Search, contentDescription = "搜索")
                    }
                    IconButton(onClick = { viewModel.loadSms() }) {
                        Icon(Icons.Default.Refresh, contentDescription = "刷新短信")
                    }
                    IconButton(onClick = onOpenSettings) {
                        Icon(Icons.Default.Settings, contentDescription = "设置")
                    }
                },
                colors = TopAppBarDefaults.topAppBarColors(
                    containerColor = Ivory,
                    titleContentColor = InkBlack
                )
            )
        },
        bottomBar = {
            Surface(
                color = ParchmentBg,
                tonalElevation = 0.dp
            ) {
                Text(
                    text = "宋氏美学，单夫纯律师制作保留权利",
                    style = MaterialTheme.typography.labelSmall,
                    color = CharcoalGray.copy(alpha = 0.6f),
                    modifier = Modifier
                        .fillMaxWidth()
                        .padding(vertical = 8.dp, horizontal = 16.dp)
                )
            }
        }
    ) { padding ->
        Box(modifier = Modifier.fillMaxSize().padding(padding)) {
            // Filter Menu
            if (state.showFilterMenu) {
                FilterMenu(
                    state = state,
                    onFilterTypeChange = { viewModel.setFilterType(it) },
                    onSortTypeChange = { viewModel.setSortType(it) },
                    onDismiss = { viewModel.toggleFilterMenu() },
                    modifier = Modifier.align(Alignment.TopEnd)
                )
            }

            if (state.loading) {
                CircularProgressIndicator(
                    modifier = Modifier.align(Alignment.Center),
                    color = CinnabarRed
                )
            } else if (state.filteredSmsWithPdfs.isEmpty()) {
                Text(
                    if (state.searchQuery.isNotBlank()) "未找到匹配的短信" else "暂无法院短信\n点击右上角刷新读取",
                    style = MaterialTheme.typography.bodyLarge,
                    color = CharcoalGray,
                    modifier = Modifier.align(Alignment.Center)
                )
            } else {
                LazyColumn(
                    modifier = Modifier.fillMaxSize(),
                    contentPadding = PaddingValues(12.dp),
                    verticalArrangement = Arrangement.spacedBy(8.dp)
                ) {
                    items(state.filteredSmsWithPdfs, key = { it.sms.id }) { item ->
                        SmsMenuCard(
                            item = item,
                            onOpenWebView = onOpenWebView,
                            onOpenPdf = onOpenPdf,
                            onShareAll = onShareAllPdfs
                        )
                    }
                }
            }
        }
    }
}

@Composable
fun SmsMenuCard(
    item: SmsWithPdfs,
    onOpenWebView: (smsId: Long, url: String) -> Unit,
    onOpenPdf: (pdfId: Long) -> Unit,
    onShareAll: (smsId: Long) -> Unit = {}
) {
    var expanded by remember { mutableStateOf(false) }
    val dateFormat = remember { SimpleDateFormat("yyyy-MM-dd HH:mm", Locale.CHINA) }

    Card(
        modifier = Modifier.fillMaxWidth(),
        shape = RoundedCornerShape(8.dp),
        colors = CardDefaults.cardColors(containerColor = WarmWhite),
        elevation = CardDefaults.cardElevation(defaultElevation = 1.dp)
    ) {
        Column {
            Row(
                modifier = Modifier
                    .fillMaxWidth()
                    .clickable { expanded = !expanded }
                    .padding(12.dp),
                verticalAlignment = Alignment.CenterVertically
            ) {
                Column(modifier = Modifier.weight(1f)) {
                    Row(
                        modifier = Modifier.fillMaxWidth(),
                        horizontalArrangement = Arrangement.SpaceBetween
                    ) {
                        Text(
                            dateFormat.format(Date(item.sms.receivedAt)),
                            style = MaterialTheme.typography.labelSmall,
                            color = CharcoalGray
                        )
                        item.sms.partyNames?.let {
                            Text(
                                it,
                                style = MaterialTheme.typography.labelLarge,
                                color = CinnabarRed
                            )
                        }
                    }
                    Spacer(modifier = Modifier.height(4.dp))
                    Row(
                        modifier = Modifier.fillMaxWidth(),
                        horizontalArrangement = Arrangement.SpaceBetween
                    ) {
                        item.sms.courtName?.let {
                            Text(
                                it,
                                style = MaterialTheme.typography.titleMedium,
                                color = InkBlack
                            )
                        }
                        item.sms.caseNumber?.let {
                            Text(
                                it,
                                style = MaterialTheme.typography.bodyMedium,
                                color = CharcoalGray,
                                maxLines = 1,
                                overflow = TextOverflow.Ellipsis
                            )
                        }
                    }
                    if (item.sms.webUrl != null && item.pdfs.isEmpty()) {
                        Spacer(modifier = Modifier.height(4.dp))
                        Text(
                            "📄 点击展开查看文书",
                            style = MaterialTheme.typography.labelSmall,
                            color = AmberGold
                        )
                    }
                    if (item.pdfs.isNotEmpty()) {
                        Spacer(modifier = Modifier.height(2.dp))
                        Text(
                            "${item.pdfs.size} 个文书",
                            style = MaterialTheme.typography.labelSmall,
                            color = JadeGreen
                        )
                    }
                }
                Icon(
                    if (expanded) Icons.Default.KeyboardArrowUp else Icons.Default.KeyboardArrowDown,
                    contentDescription = null,
                    tint = CharcoalGray
                )
            }

            AnimatedVisibility(visible = expanded) {
                Column(
                    modifier = Modifier.padding(start = 12.dp, end = 12.dp, bottom = 12.dp),
                    verticalArrangement = Arrangement.spacedBy(6.dp)
                ) {
                    if (item.sms.webUrl != null) {
                        OutlinedButton(
                            onClick = { onOpenWebView(item.sms.id, item.sms.webUrl!!) },
                            modifier = Modifier.fillMaxWidth(),
                            colors = ButtonDefaults.outlinedButtonColors(contentColor = CinnabarRed),
                            shape = RoundedCornerShape(6.dp)
                        ) {
                            Text("打开送达链接下载文书")
                        }
                    }
                    // 批量分享按钮
                    if (item.pdfs.isNotEmpty()) {
                        Button(
                            onClick = { onShareAll(item.sms.id) },
                            modifier = Modifier.fillMaxWidth(),
                            colors = ButtonDefaults.buttonColors(containerColor = JadeGreen),
                            shape = RoundedCornerShape(6.dp)
                        ) {
                            Icon(
                                Icons.Default.Share,
                                contentDescription = null,
                                modifier = Modifier.size(18.dp),
                                tint = WarmWhite
                            )
                            Spacer(modifier = Modifier.width(8.dp))
                            Text("打包分享 ${item.pdfs.size} 个文书", color = WarmWhite)
                        }
                    }
                    item.pdfs.forEach { pdf ->
                        PdfCard(pdf = pdf, onClick = { onOpenPdf(pdf.id) })
                    }
                }
            }
        }
    }
}

@Composable
fun PdfCard(pdf: PdfDocumentEntity, onClick: () -> Unit) {
    val dateFormat = remember { SimpleDateFormat("MM-dd HH:mm", Locale.CHINA) }
    Surface(
        modifier = Modifier
            .fillMaxWidth()
            .clip(RoundedCornerShape(6.dp))
            .clickable(onClick = onClick),
        color = ParchmentBg,
        shape = RoundedCornerShape(6.dp)
    ) {
        Row(
            modifier = Modifier.padding(10.dp),
            verticalAlignment = Alignment.CenterVertically
        ) {
            Text(
                if (pdf.isSubpoena) "📋" else "📄",
                style = MaterialTheme.typography.titleLarge
            )
            Spacer(modifier = Modifier.width(8.dp))
            Column(modifier = Modifier.weight(1f)) {
                Text(
                    pdf.fileName,
                    style = MaterialTheme.typography.bodyMedium,
                    color = InkBlack,
                    maxLines = 1,
                    overflow = TextOverflow.Ellipsis
                )
                Text(
                    "${dateFormat.format(Date(pdf.downloadedAt))} · ${formatSize(pdf.fileSize)}",
                    style = MaterialTheme.typography.labelSmall,
                    color = CharcoalGray
                )
            }
            if (pdf.isSubpoena && pdf.hearingInfo != null) {
                Text("已同步日历", style = MaterialTheme.typography.labelSmall, color = JadeGreen)
            }
        }
    }
}

private fun formatSize(bytes: Long): String {
    return when {
        bytes < 1024 -> "${bytes}B"
        bytes < 1024 * 1024 -> "${bytes / 1024}KB"
        else -> String.format("%.1fMB", bytes / (1024.0 * 1024.0))
    }
}

@Composable
fun FilterMenu(
    state: com.court.assistant.viewmodel.UiState,
    onFilterTypeChange: (com.court.assistant.viewmodel.FilterType) -> Unit,
    onSortTypeChange: (com.court.assistant.viewmodel.SortType) -> Unit,
    onDismiss: () -> Unit,
    modifier: Modifier = Modifier
) {
    Card(
        modifier = modifier.padding(end = 8.dp, top = 8.dp),
        shape = RoundedCornerShape(8.dp),
        elevation = CardDefaults.cardElevation(defaultElevation = 8.dp)
    ) {
        Column(modifier = Modifier.padding(8.dp), verticalArrangement = Arrangement.spacedBy(4.dp)) {
            Text(
                "筛选",
                style = MaterialTheme.typography.titleSmall,
                color = CharcoalGray,
                modifier = Modifier.padding(horizontal = 8.dp, vertical = 4.dp)
            )
            Divider(color = MistGray)

            // Filter Type
            Text(
                "类型",
                style = MaterialTheme.typography.labelSmall,
                color = CharcoalGray.copy(alpha = 0.7f),
                modifier = Modifier.padding(horizontal = 8.dp, vertical = 4.dp)
            )
            com.court.assistant.viewmodel.FilterType.values().forEach { type ->
                FilterOptionItem(
                    text = when (type) {
                        com.court.assistant.viewmodel.FilterType.ALL -> "全部"
                        com.court.assistant.viewmodel.FilterType.SUBPOENA_ONLY -> "仅传票"
                        com.court.assistant.viewmodel.FilterType.WITH_PDFS -> "有文书"
                    },
                    selected = state.filterType == type,
                    onClick = { onFilterTypeChange(type) }
                )
            }

            Divider(color = MistGray)

            // Sort Type
            Text(
                "排序",
                style = MaterialTheme.typography.labelSmall,
                color = CharcoalGray.copy(alpha = 0.7f),
                modifier = Modifier.padding(horizontal = 8.dp, vertical = 4.dp)
            )
            com.court.assistant.viewmodel.SortType.values().forEach { type ->
                FilterOptionItem(
                    text = when (type) {
                        com.court.assistant.viewmodel.SortType.DATE_DESC -> "日期 (最新)"
                        com.court.assistant.viewmodel.SortType.DATE_ASC -> "日期 (最早)"
                        com.court.assistant.viewmodel.SortType.COURT_NAME -> "法院名称"
                    },
                    selected = state.sortType == type,
                    onClick = { onSortTypeChange(type) }
                )
            }

            Divider(color = MistGray)

            TextButton(
                onClick = onDismiss,
                modifier = Modifier.fillMaxWidth()
            ) {
                Text("关闭", color = CharcoalGray)
            }
        }
    }
}

@Composable
fun FilterOptionItem(
    text: String,
    selected: Boolean,
    onClick: () -> Unit
) {
    Surface(
        onClick = onClick,
        modifier = Modifier.fillMaxWidth(),
        color = if (selected) CinnabarRed.copy(alpha = 0.1f) else Color.Transparent
    ) {
        Row(
            modifier = Modifier.padding(horizontal = 12.dp, vertical = 10.dp),
            verticalAlignment = Alignment.CenterVertically
        ) {
            Text(
                text,
                style = MaterialTheme.typography.bodyMedium,
                color = if (selected) CinnabarRed else InkBlack,
                modifier = Modifier.weight(1f)
            )
            if (selected) {
                Text(
                    "✓",
                    style = MaterialTheme.typography.bodyMedium,
                    color = CinnabarRed
                )
            }
        }
    }
}
