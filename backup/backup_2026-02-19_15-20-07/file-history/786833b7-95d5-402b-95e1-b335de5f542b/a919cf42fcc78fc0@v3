package com.court.assistant.ui

import android.content.Intent
import android.net.Uri
import androidx.compose.runtime.Composable
import androidx.compose.ui.platform.LocalContext
import androidx.core.content.FileProvider
import androidx.navigation.NavType
import androidx.navigation.compose.NavHost
import androidx.navigation.compose.composable
import androidx.navigation.compose.rememberNavController
import androidx.navigation.navArgument
import com.court.assistant.viewmodel.MainViewModel
import java.io.File

@Composable
fun Navigation(viewModel: MainViewModel) {
    val context = LocalContext.current
    val navController = rememberNavController()

    NavHost(navController = navController, startDestination = "main") {
        composable("main") {
            MainScreen(
                viewModel = viewModel,
                onOpenWebView = { smsId, url ->
                    navController.navigate("webview/$smsId/${java.net.URLEncoder.encode(url, "UTF-8")}")
                },
                onOpenPdf = { pdfId ->
                    navController.navigate("pdf/$pdfId")
                },
                onOpenSettings = {
                    navController.navigate("settings")
                },
                onShareAllPdfs = { smsId ->
                    sharePdfAsZip(context, viewModel, smsId)
                }
            )
        }
        composable("settings") {
            SettingsScreen(
                viewModel = viewModel,
                onBack = { navController.popBackStack() }
            )
        }
        composable(
            "webview/{smsId}/{url}",
            arguments = listOf(
                navArgument("smsId") { type = NavType.LongType },
                navArgument("url") { type = NavType.StringType }
            )
        ) { entry ->
            val smsId = entry.arguments?.getLong("smsId") ?: return@composable
            val url = java.net.URLDecoder.decode(entry.arguments?.getString("url") ?: "", "UTF-8")
            WebViewScreen(
                viewModel = viewModel,
                smsId = smsId,
                url = url,
                onBack = { navController.popBackStack() }
            )
        }
        composable(
            "pdf/{pdfId}",
            arguments = listOf(navArgument("pdfId") { type = NavType.LongType })
        ) { entry ->
            val pdfId = entry.arguments?.getLong("pdfId") ?: return@composable
            PdfPreviewScreen(
                viewModel = viewModel,
                pdfId = pdfId,
                onBack = { navController.popBackStack() }
            )
        }
    }
}

/**
 * 分享某个案件的所有PDF为ZIP压缩包
 */
private fun sharePdfAsZip(context: android.content.Context, viewModel: MainViewModel, smsId: Long) {
    val zipPath = viewModel.createZipForSms(smsId)
    if (zipPath != null) {
        val zipFile = File(zipPath)
        val uri = FileProvider.getUriForFile(
            context,
            "${context.packageName}.fileprovider",
            zipFile
        )

        val intent = Intent(Intent.ACTION_SEND).apply {
            type = "application/zip"
            putExtra(Intent.EXTRA_STREAM, uri)
            addFlags(Intent.FLAG_GRANT_READ_URI_PERMISSION)
        }

        context.startActivity(Intent.createChooser(intent, "分享文书压缩包"))
    } else {
        android.widget.Toast.makeText(context, "创建压缩包失败", android.widget.Toast.LENGTH_SHORT).show()
    }
}
