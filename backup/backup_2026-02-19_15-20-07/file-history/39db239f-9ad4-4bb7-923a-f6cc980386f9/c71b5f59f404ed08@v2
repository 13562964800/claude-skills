package com.shanfuchun.courtassistant.ai.model

/**
 * AI 传票抽取结果
 */
data class SummonsExtraction(
    val caseNo: String? = null,          // 案号，如：(2024)鲁1312民初4967号
    val courtName: String? = null,       // 法院名称，如：北京市朝阳区人民法院
    val hearingTime: Long? = null,       // 开庭时间戳（毫秒）
    val location: String? = null,        // 开庭地点
    val partyName: String? = null,        // 当事人名称
    val confidence: Float = 0f,          // AI 自信度 0-1
    val rawResponse: String = ""          // 原始响应
) {
    /**
     * 是否为有效结果（至少包含开庭时间）
     */
    fun isValid(): Boolean = hearingTime != null && hearingTime > 0

    /**
     * 获取完整度评分（0-1）
     */
    fun getCompleteness(): Float {
        var score = 0f
        if (caseNo != null) score += 0.25f
        if (courtName != null) score += 0.25f
        if (hearingTime != null) score += 0.35f
        if (location != null || partyName != null) score += 0.15f
        return score
    }
}
