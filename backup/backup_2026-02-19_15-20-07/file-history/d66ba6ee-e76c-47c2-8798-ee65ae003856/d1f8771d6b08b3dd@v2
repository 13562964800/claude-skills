<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/song_paper">

    <!-- 顶部标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/song_wood"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="智能填表助手"
            android:textColor="@color/song_paper"
            android:textSize="20sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnEnableAutofill"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="自动填充"
            android:textSize="12sp"
            android:layout_marginEnd="6dp"
            android:backgroundTint="@color/song_gold"
            android:textColor="@color/white" />

        <Button
            android:id="@+id/btnEnableIME"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="输入法"
            android:textSize="12sp"
            android:backgroundTint="@color/song_celadon"
            android:textColor="@color/white" />
    </LinearLayout>

    <!-- 档案选择 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <Spinner
            android:id="@+id/spProfile"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/btnAddProfile"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_input_add"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="新建档案" />

        <ImageButton
            android:id="@+id/btnDeleteProfile"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="删除档案" />
    </LinearLayout>

    <!-- 文本输入区 -->
    <EditText
        android:id="@+id/etInput"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_marginHorizontal="12dp"
        android:padding="10dp"
        android:gravity="top"
        android:hint="粘贴法律文书文本，或点击下方按钮导入..."
        android:background="@drawable/input_bg"
        android:textSize="14sp"
        android:inputType="textMultiLine" />

    <Button
        android:id="@+id/btnExtract"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_margin="12dp"
        android:text="提取字段"
        android:backgroundTint="@color/song_celadon"
        android:textColor="@color/white"
        android:textSize="16sp" />

    <!-- 字段列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvFields"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false" />

    <!-- 底部手动添加 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/etLabel"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:hint="标签"
            android:textSize="13sp"
            android:paddingHorizontal="8dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/input_bg" />

        <EditText
            android:id="@+id/etValue"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="2"
            android:hint="值"
            android:textSize="13sp"
            android:paddingHorizontal="8dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/input_bg" />

        <Button
            android:id="@+id/btnAdd"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="添加"
            android:textSize="13sp"
            android:backgroundTint="@color/song_wood"
            android:textColor="@color/white" />
    </LinearLayout>

</LinearLayout>
