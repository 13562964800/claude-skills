{"parentUuid":"dc7d65f5-c6a8-4d41-8ba5-aed61f98ef76","isSidechain":false,"userType":"external","cwd":"C:\\Users\\Administrator","sessionId":"a4e11369-bc15-4ff1-9b18-115fc4dd0659","version":"2.1.41","gitBranch":"HEAD","slug":"buzzing-wobbling-rossum","type":"user","message":{"role":"user","content":[{"tool_use_id":"tooluse_QKDEf7SFBsYRFtJV9TInoK","type":"tool_result","content":"The file C:\\Users\\Administrator\\Desktop\\CourtAssistant\\app\\src\\main\\java\\com\\court\\assistant\\sms\\SmsParser.kt has been updated successfully."}]},"uuid":"570da31d-cf83-431b-b9f1-006fdcbb1194","timestamp":"2026-02-13T15:49:05.043Z","toolUseResult":{"filePath":"C:\\Users\\Administrator\\Desktop\\CourtAssistant\\app\\src\\main\\java\\com\\court\\assistant\\sms\\SmsParser.kt","oldString":"    // 开庭时间 - 多种格式\n    private val datePatterns = listOf(\n        // 2024年12月5日 上午9时30分 / 下午2时30分\n        Regex(\"(\\\\d{4})年(\\\\d{1,2})月(\\\\d{1,2})日[\\\\s]*[（(]?(?:上午|下午|AM|PM)?[）)]?[\\\\s]*(\\\\d{1,2})[时点:：](\\\\d{0,2})[分]?\"),\n        Regex(\"(\\\\d{4})-(\\\\d{1,2})-(\\\\d{1,2})[\\\\s]+(\\\\d{1,2}):(\\\\d{2})\"),\n        Regex(\"(\\\\d{4})/(\\\\d{1,2})/(\\\\d{1,2})[\\\\s]+(\\\\d{1,2}):(\\\\d{2})\")\n    )\n    // 用于检测下午时间\n    private val pmPattern = Regex(\"下午|PM\")\n\n    fun parse(body: String): ParsedSms {","newString":"    // 开庭时间 - 多种格式\n    private val datePatterns = listOf(\n        Regex(\"(\\\\d{4})年(\\\\d{1,2})月(\\\\d{1,2})日[\\\\s]*(\\\\d{1,2})[时点:：](\\\\d{0,2})[分]?\"),\n        Regex(\"(\\\\d{4})-(\\\\d{1,2})-(\\\\d{1,2})[\\\\s]+(\\\\d{1,2}):(\\\\d{2})\"),\n        Regex(\"(\\\\d{4})/(\\\\d{1,2})/(\\\\d{1,2})[\\\\s]+(\\\\d{1,2}):(\\\\d{2})\")\n    )\n\n    fun parse(body: String): ParsedSms {","originalFile":"package com.court.assistant.sms\n\nimport java.text.SimpleDateFormat\nimport java.util.*\n\ndata class ParsedSms(\n    val caseNumber: String?,\n    val courtName: String?,\n    val hearingTime: Long?,\n    val partyNames: String?,\n    val webUrl: String?\n)\n\nclass SmsParser {\n    // 案号: （2024）鲁1312民初1324号\n    private val caseNumberPattern = Regex(\"[（(]\\\\d{4}[）)][^\\\\s，。,\\\\.]+号\")\n    // 法院名称: 【xxx法院】\n    private val courtPattern = Regex(\"【(.+?法院[）】]?)\")\n    // 当事人: 】xxx你好 or 】xxx，你好\n    private val partyPattern = Regex(\"】(\\\\S+?)(?:你好|，你好|,你好)\")\n    // URL\n    private val urlPattern = Regex(\"https?://[^\\\\s<>\\\"]+\")\n    // 开庭时间 - 多种格式\n    private val datePatterns = listOf(\n        // 2024年12月5日 上午9时30分 / 下午2时30分\n        Regex(\"(\\\\d{4})年(\\\\d{1,2})月(\\\\d{1,2})日[\\\\s]*[（(]?(?:上午|下午|AM|PM)?[）)]?[\\\\s]*(\\\\d{1,2})[时点:：](\\\\d{0,2})[分]?\"),\n        Regex(\"(\\\\d{4})-(\\\\d{1,2})-(\\\\d{1,2})[\\\\s]+(\\\\d{1,2}):(\\\\d{2})\"),\n        Regex(\"(\\\\d{4})/(\\\\d{1,2})/(\\\\d{1,2})[\\\\s]+(\\\\d{1,2}):(\\\\d{2})\")\n    )\n    // 用于检测下午时间\n    private val pmPattern = Regex(\"下午|PM\")\n\n    fun parse(body: String): ParsedSms {\n        val caseNumber = caseNumberPattern.find(body)?.value\n        val courtFull = courtPattern.find(body)?.groupValues?.getOrNull(1)\n        val courtName = courtFull?.let { simplifyCourtName(it) }\n        val partyNames = partyPattern.find(body)?.groupValues?.getOrNull(1)\n        val webUrl = urlPattern.find(body)?.value\n        val hearingTime = parseHearingTime(body)\n\n        return ParsedSms(\n            caseNumber = caseNumber,\n            courtName = courtName,\n            hearingTime = hearingTime,\n            partyNames = partyNames,\n            webUrl = webUrl\n        )\n    }\n\n    private fun simplifyCourtName(name: String): String {\n        // 去掉省市前缀，保留区+法院\n        // \"临沂市河东区人民法院\" -> \"河东区法院\"\n        val cleaned = name.replace(\"】\", \"\").replace(\"【\", \"\")\n        val match = Regex(\"(\\\\S+?[区县市旗])人民法院\").find(cleaned)\n        if (match != null) {\n            val district = match.groupValues[1]\n            // 取最后一个行政区划\n            val parts = Regex(\"[省市州盟]\").split(district)\n            return \"${parts.last()}法院\"\n        }\n        return cleaned.replace(\"人民\", \"\")\n    }\n\n    private fun parseHearingTime(text: String): Long? {\n        for (pattern in datePatterns) {\n            val match = pattern.find(text) ?: continue\n            try {\n                val year = match.groupValues[1].toInt()\n                val month = match.groupValues[2].toInt()\n                val day = match.groupValues[3].toInt()\n                var hour = match.groupValues[4].toInt()\n                val minute = match.groupValues.getOrNull(5)?.takeIf { it.isNotEmpty() }?.toInt() ?: 0\n                // 检查匹配位置前面是否有\"下午/PM\"，需要+12小时\n                val prefix = text.substring(0, match.range.first + match.value.length)\n                if (hour < 12 && pmPattern.containsMatchIn(prefix)) {\n                    hour += 12\n                }\n                val cal = Calendar.getInstance(TimeZone.getTimeZone(\"Asia/Shanghai\")).apply {\n                    clear()\n                    set(year, month - 1, day, hour, minute, 0)\n                }\n                return cal.timeInMillis\n            } catch (_: Exception) { continue }\n        }\n        return null\n    }\n}\n","structuredPatch":[{"oldStart":22,"oldLines":13,"newStart":22,"newLines":10,"lines":["     private val urlPattern = Regex(\"https?://[^\\\\s<>\\\"]+\")","     // 开庭时间 - 多种格式","     private val datePatterns = listOf(","-        // 2024年12月5日 上午9时30分 / 下午2时30分","-        Regex(\"(\\\\d{4})年(\\\\d{1,2})月(\\\\d{1,2})日[\\\\s]*[（(]?(?:上午|下午|AM|PM)?[）)]?[\\\\s]*(\\\\d{1,2})[时点:：](\\\\d{0,2})[分]?\"),","+        Regex(\"(\\\\d{4})年(\\\\d{1,2})月(\\\\d{1,2})日[\\\\s]*(\\\\d{1,2})[时点:：](\\\\d{0,2})[分]?\"),","         Regex(\"(\\\\d{4})-(\\\\d{1,2})-(\\\\d{1,2})[\\\\s]+(\\\\d{1,2}):(\\\\d{2})\"),","         Regex(\"(\\\\d{4})/(\\\\d{1,2})/(\\\\d{1,2})[\\\\s]+(\\\\d{1,2}):(\\\\d{2})\")","     )","-    // 用于检测下午时间","-    private val pmPattern = Regex(\"下午|PM\")"," ","     fun parse(body: String): ParsedSms {","         val caseNumber = caseNumberPattern.find(body)?.value"]}],"userModified":false,"replaceAll":false},"sourceToolAssistantUUID":"dc7d65f5-c6a8-4d41-8ba5-aed61f98ef76"}
