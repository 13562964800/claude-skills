{"parentUuid":"6edeebe4-0df4-4e00-9be7-f66b328e6789","isSidechain":false,"userType":"external","cwd":"C:\\Users\\Administrator","sessionId":"a4e11369-bc15-4ff1-9b18-115fc4dd0659","version":"2.1.41","gitBranch":"HEAD","slug":"buzzing-wobbling-rossum","type":"progress","data":{"message":{"type":"assistant","timestamp":"2026-02-13T15:31:33.772Z","message":{"content":[{"id":"tooluse_2yhKx5i2QfmXNAfNKAh3rC","input":{"command":"cat \"C:/Users/Administrator/Desktop/CourtAssistant/app/src/main/java/com/court/assistant/calendar/CalendarSync.kt\"","description":"Read CalendarSync.kt"},"name":"Bash","type":"tool_use"}],"id":"msg_20260213153127","model":"claude-opus-4-6","role":"assistant","stop_reason":null,"stop_sequence":null,"type":"message","usage":{"cache_creation_input_tokens":0,"cache_read_input_tokens":7687,"input_tokens":2456,"output_tokens":1},"context_management":null},"uuid":"7024dccf-becc-436f-98a0-eab5bb9273bb"},"normalizedMessages":[],"type":"agent_progress","prompt":"Explore the directory C:\\Users\\Administrator\\Desktop\\CourtAssistant thoroughly. List the directory structure, identify the project type, key files, and provide a summary of what this project is about. Look at package.json, README, main entry points, and any configuration files.","agentId":"acabb7d"},"toolUseID":"agent_msg_20260213153029","parentToolUseID":"tooluse_U26VaulPbCKIH6CBIZfr1O","uuid":"9445dd60-3360-432e-8d2d-9b7bd5d073c0","timestamp":"2026-02-13T15:31:33.772Z"}
{"parentUuid":"9445dd60-3360-432e-8d2d-9b7bd5d073c0","isSidechain":false,"userType":"external","cwd":"C:\\Users\\Administrator","sessionId":"a4e11369-bc15-4ff1-9b18-115fc4dd0659","version":"2.1.41","gitBranch":"HEAD","slug":"buzzing-wobbling-rossum","type":"progress","data":{"message":{"type":"user","message":{"role":"user","content":[{"tool_use_id":"tooluse_tvp2sdAsYTp4zTcCeHiC5b","type":"tool_result","content":"package com.court.assistant.ui\r\n\r\nimport androidx.compose.runtime.Composable\r\nimport androidx.navigation.NavType\r\nimport androidx.navigation.compose.NavHost\r\nimport androidx.navigation.compose.composable\r\nimport androidx.navigation.compose.rememberNavController\r\nimport androidx.navigation.navArgument\r\nimport com.court.assistant.viewmodel.MainViewModel\r\n\r\n@Composable\r\nfun Navigation(viewModel: MainViewModel) {\r\n    val navController = rememberNavController()\r\n\r\n    NavHost(navController = navController, startDestination = \"main\") {\r\n        composable(\"main\") {\r\n            MainScreen(\r\n                viewModel = viewModel,\r\n                onOpenWebView = { smsId, url ->\r\n                    navController.navigate(\"webview/$smsId/${java.net.URLEncoder.encode(url, \"UTF-8\")}\")\r\n                },\r\n                onOpenPdf = { pdfId ->\r\n                    navController.navigate(\"pdf/$pdfId\")\r\n                }\r\n            )\r\n        }\r\n        composable(\r\n            \"webview/{smsId}/{url}\",\r\n            arguments = listOf(\r\n                navArgument(\"smsId\") { type = NavType.LongType },\r\n                navArgument(\"url\") { type = NavType.StringType }\r\n            )\r\n        ) { entry ->\r\n            val smsId = entry.arguments?.getLong(\"smsId\") ?: return@composable\r\n            val url = java.net.URLDecoder.decode(entry.arguments?.getString(\"url\") ?: \"\", \"UTF-8\")\r\n            WebViewScreen(\r\n                viewModel = viewModel,\r\n                smsId = smsId,\r\n                url = url,\r\n                onBack = { navController.popBackStack() }\r\n            )\r\n        }\r\n        composable(\r\n            \"pdf/{pdfId}\",\r\n            arguments = listOf(navArgument(\"pdfId\") { type = NavType.LongType })\r\n        ) { entry ->\r\n            val pdfId = entry.arguments?.getLong(\"pdfId\") ?: return@composable\r\n            PdfPreviewScreen(\r\n                viewModel = viewModel,\r\n                pdfId = pdfId,\r\n                onBack = { navController.popBackStack() }\r\n            )\r\n        }\r\n    }\r\n}","is_error":false}]},"uuid":"359f98d2-1016-46ff-ad2a-18c5f071ad8f","timestamp":"2026-02-13T15:31:35.786Z"},"normalizedMessages":[],"type":"agent_progress","prompt":"Explore the directory C:\\Users\\Administrator\\Desktop\\CourtAssistant thoroughly. List the directory structure, identify the project type, key files, and provide a summary of what this project is about. Look at package.json, README, main entry points, and any configuration files.","agentId":"acabb7d"},"toolUseID":"agent_msg_20260213153029","parentToolUseID":"tooluse_U26VaulPbCKIH6CBIZfr1O","uuid":"757ec8bb-5098-4011-8759-04bca3f20396","timestamp":"2026-02-13T15:31:35.793Z"}
{"parentUuid":"757ec8bb-5098-4011-8759-04bca3f20396","isSidechain":false,"userType":"external","cwd":"C:\\Users\\Administrator","sessionId":"a4e11369-bc15-4ff1-9b18-115fc4dd0659","version":"2.1.41","gitBranch":"HEAD","slug":"buzzing-wobbling-rossum","type":"progress","data":{"message":{"type":"user","message":{"role":"user","content":[{"tool_use_id":"tooluse_2yhKx5i2QfmXNAfNKAh3rC","type":"tool_result","content":"package com.court.assistant.calendar\r\n\r\nimport android.content.ContentUris\r\nimport android.content.ContentValues\r\nimport android.content.Context\r\nimport android.provider.CalendarContract\r\nimport java.util.*\r\n\r\nclass CalendarSync(private val context: Context) {\r\n\r\n    fun syncHearing(\r\n        caseNumber: String,\r\n        courtName: String?,\r\n        hearingTime: Long,\r\n        defendant: String?,        // 被传唤人\r\n        handler: String?,          // 承办人\r\n        location: String?,         // 应到处所\r\n        phone: String?,            // 电话\r\n        partyNames: String? = null,\r\n        description: String? = null\r\n    ): Long? {\r\n        // 去重：检查是否已存在\r\n        if (eventExists(caseNumber, hearingTime)) return null\r\n\r\n        val calendarId = getOrCreateCalendarId() ?: return null\r\n        val title = buildString {\r\n            append(\"开庭 \")\r\n            if (courtName != null) append(\"$courtName \")\r\n            append(caseNumber)\r\n        }\r\n        val desc = buildString {\r\n            // 格式化显示精确的开庭时间\r\n            val timeFormat = java.text.SimpleDateFormat(\"yyyy年MM月dd日 HH:mm\", java.util.Locale.CHINA)\r\n            append(\"⏰ 开庭时间: ${timeFormat.format(java.util.Date(hearingTime))}\\n\")\r\n\r\n            // 7个关键信息字段\r\n            append(\"案号: $caseNumber\")\r\n            if (courtName != null) append(\"\\n法院: $courtName\")\r\n            if (defendant != null) append(\"\\n被传唤人: $defendant\")\r\n            if (handler != null) append(\"\\n承办人: $handler\")\r\n            if (location != null) append(\"\\n应到处所: $location\")\r\n            if (phone != null) append(\"\\n电话: $phone\")\r\n            if (partyNames != null) append(\"\\n当事人: $partyNames\")\r\n            if (description != null) append(\"\\n$description\")\r\n        }\r\n\r\n        val values = ContentValues().apply {\r\n            put(CalendarContract.Events.CALENDAR_ID, calendarId)\r\n            put(CalendarContract.Events.TITLE, title)\r\n            put(CalendarContract.Events.DESCRIPTION, desc)\r\n            put(CalendarContract.Events.DTSTART, hearingTime)\r\n            put(CalendarContract.Events.DTEND, hearingTime + 2 * 3600 * 1000) // 2小时\r\n            put(CalendarContract.Events.EVENT_TIMEZONE, TimeZone.getDefault().id)\r\n            put(CalendarContract.Events.HAS_ALARM, 1)\r\n        }\r\n\r\n        val uri = context.contentResolver.insert(CalendarContract.Events.CONTENT_URI, values)\r\n        val eventId = uri?.let { ContentUris.parseId(it) }\r\n\r\n        // 添加提醒：提前1天和1小时\r\n        if (eventId != null) {\r\n            addReminder(eventId, 24 * 60) // 1天\r\n            addReminder(eventId, 60)       // 1小时\r\n        }\r\n        return eventId\r\n    }\r\n\r\n    private fun eventExists(caseNumber: String, hearingTime: Long): Boolean {\r\n        val projection = arrayOf(CalendarContract.Events._ID)\r\n        val selection = \"${CalendarContract.Events.TITLE} LIKE ? AND ${CalendarContract.Events.DTSTART} = ?\"\r\n        val args = arrayOf(\"%$caseNumber%\", hearingTime.toString())\r\n        val cursor = context.contentResolver.query(\r\n            CalendarContract.Events.CONTENT_URI, projection, selection, args, null\r\n        )\r\n        val exists = cursor?.use { it.count > 0 } ?: false\r\n        return exists\r\n    }\r\n\r\n    private fun getOrCreateCalendarId(): Long? {\r\n        // 先查找已有日历\r\n        val projection = arrayOf(CalendarContract.Calendars._ID)\r\n        val cursor = context.contentResolver.query(\r\n            CalendarContract.Calendars.CONTENT_URI, projection, null, null, null\r\n        )\r\n        cursor?.use {\r\n            if (it.moveToFirst()) return it.getLong(0)\r\n        }\r\n        return null // 使用系统默认日历\r\n    }\r\n\r\n    private fun addReminder(eventId: Long, minutes: Int) {\r\n        val values = ContentValues().apply {\r\n            put(CalendarContract.Reminders.EVENT_ID, eventId)\r\n            put(CalendarContract.Reminders.MINUTES, minutes)\r\n            put(CalendarContract.Reminders.METHOD, CalendarContract.Reminders.METHOD_ALERT)\r\n        }\r\n        context.contentResolver.insert(CalendarContract.Reminders.CONTENT_URI, values)\r\n    }\r\n}","is_error":false}]},"uuid":"37c2b0a1-c09c-47e0-a371-79af77cda08d","timestamp":"2026-02-13T15:31:35.804Z"},"normalizedMessages":[],"type":"agent_progress","prompt":"Explore the directory C:\\Users\\Administrator\\Desktop\\CourtAssistant thoroughly. List the directory structure, identify the project type, key files, and provide a summary of what this project is about. Look at package.json, README, main entry points, and any configuration files.","agentId":"acabb7d"},"toolUseID":"agent_msg_20260213153029","parentToolUseID":"tooluse_U26VaulPbCKIH6CBIZfr1O","uuid":"dfbebe40-112d-4289-ab32-68308acadafb","timestamp":"2026-02-13T15:31:35.810Z"}
{"parentUuid":"dfbebe40-112d-4289-ab32-68308acadafb","isSidechain":false,"userType":"external","cwd":"C:\\Users\\Administrator","sessionId":"a4e11369-bc15-4ff1-9b18-115fc4dd0659","version":"2.1.41","gitBranch":"HEAD","slug":"buzzing-wobbling-rossum","type":"progress","data":{"message":{"type":"user","message":{"role":"user","content":[{"tool_use_id":"tooluse_ZBK7Nspqg6DLkHTYAVwag0","type":"tool_result","content":"package com.court.assistant.ui\r\n\r\nimport androidx.compose.animation.*\r\nimport androidx.compose.foundation.background\r\nimport androidx.compose.foundation.clickable\r\nimport androidx.compose.foundation.layout.*\r\nimport androidx.compose.foundation.lazy.LazyColumn\r\nimport androidx.compose.foundation.lazy.items\r\nimport androidx.compose.foundation.shape.RoundedCornerShape\r\nimport androidx.compose.material.icons.Icons\r\nimport androidx.compose.material.icons.filled.KeyboardArrowDown\r\nimport androidx.compose.material.icons.filled.KeyboardArrowUp\r\nimport androidx.compose.material.icons.filled.Refresh\r\nimport androidx.compose.material3.*\r\nimport androidx.compose.runtime.*\r\nimport androidx.compose.ui.Alignment\r\nimport androidx.compose.ui.Modifier\r\nimport androidx.compose.ui.draw.clip\r\nimport androidx.compose.ui.text.style.TextOverflow\r\nimport androidx.compose.ui.unit.dp\r\nimport com.court.assistant.data.db.PdfDocumentEntity\r\nimport com.court.assistant.ui.theme.*\r\nimport com.court.assistant.viewmodel.MainViewModel\r\nimport com.court.assistant.viewmodel.SmsWithPdfs\r\nimport java.text.SimpleDateFormat\r\nimport java.util.*\r\n\r\n@OptIn(ExperimentalMaterial3Api::class)\r\n@Composable\r\nfun MainScreen(\r\n    viewModel: MainViewModel,\r\n    onOpenWebView: (smsId: Long, url: String) -> Unit,\r\n    onOpenPdf: (pdfId: Long) -> Unit\r\n) {\r\n    val state by viewModel.uiState.collectAsState()\r\n    val snackbarHostState = remember { SnackbarHostState() }\r\n\r\n    LaunchedEffect(state.message) {\r\n        state.message?.let {\r\n            snackbarHostState.showSnackbar(it)\r\n            viewModel.clearMessage()\r\n        }\r\n    }\r\n\r\n    Scaffold(\r\n        snackbarHost = { SnackbarHost(snackbarHostState) },\r\n        topBar = {\r\n            TopAppBar(\r\n                title = {\r\n                    Text(\"法院助手\", style = MaterialTheme.typography.headlineMedium)\r\n                },\r\n                actions = {\r\n                    IconButton(onClick = { viewModel.loadSms() }) {\r\n                        Icon(Icons.Default.Refresh, contentDescription = \"刷新短信\")\r\n                    }\r\n                },\r\n                colors = TopAppBarDefaults.topAppBarColors(\r\n                    containerColor = Ivory,\r\n                    titleContentColor = InkBlack\r\n                )\r\n            )\r\n        },\r\n        bottomBar = {\r\n            Surface(\r\n                color = ParchmentBg,\r\n                tonalElevation = 0.dp\r\n            ) {\r\n                Text(\r\n                    text = \"宋氏美学，单夫纯律师制作保留权利\",\r\n                    style = MaterialTheme.typography.labelSmall,\r\n                    color = CharcoalGray.copy(alpha = 0.6f),\r\n                    modifier = Modifier\r\n                        .fillMaxWidth()\r\n                        .padding(vertical = 8.dp, horizontal = 16.dp)\r\n                )\r\n            }\r\n        }\r\n    ) { padding ->\r\n        Box(modifier = Modifier.fillMaxSize().padding(padding)) {\r\n            if (state.loading) {\r\n                CircularProgressIndicator(\r\n                    modifier = Modifier.align(Alignment.Center),\r\n                    color = CinnabarRed\r\n                )\r\n            } else if (state.smsWithPdfs.isEmpty()) {\r\n                Text(\r\n                    \"暂无法院短信\\n点击右上角刷新读取\",\r\n                    style = MaterialTheme.typography.bodyLarge,\r\n                    color = CharcoalGray,\r\n                    modifier = Modifier.align(Alignment.Center)\r\n                )\r\n            } else {\r\n                LazyColumn(\r\n                    modifier = Modifier.fillMaxSize(),\r\n                    contentPadding = PaddingValues(12.dp),\r\n                    verticalArrangement = Arrangement.spacedBy(8.dp)\r\n                ) {\r\n                    items(state.smsWithPdfs, key = { it.sms.id }) { item ->\r\n                        SmsMenuCard(\r\n                            item = item,\r\n                            onOpenWebView = onOpenWebView,\r\n                            onOpenPdf = onOpenPdf\r\n                        )\r\n                    }\r\n                }\r\n            }\r\n        }\r\n    }\r\n}\r\n\r\n@Composable\r\nfun SmsMenuCard(\r\n    item: SmsWithPdfs,\r\n    onOpenWebView: (smsId: Long, url: String) -> Unit,\r\n    onOpenPdf: (pdfId: Long) -> Unit\r\n) {\r\n    var expanded by remember { mutableStateOf(false) }\r\n    val dateFormat = remember { SimpleDateFormat(\"yyyy-MM-dd HH:mm\", Locale.CHINA) }\r\n\r\n    Card(\r\n        modifier = Modifier.fillMaxWidth(),\r\n        shape = RoundedCornerShape(8.dp),\r\n        colors = CardDefaults.cardColors(containerColor = WarmWhite),\r\n        elevation = CardDefaults.cardElevation(defaultElevation = 1.dp)\r\n    ) {\r\n        Column {\r\n            Row(\r\n                modifier = Modifier\r\n                    .fillMaxWidth()\r\n                    .clickable { expanded = !expanded }\r\n                    .padding(12.dp),\r\n                verticalAlignment = Alignment.CenterVertically\r\n            ) {\r\n                Column(modifier = Modifier.weight(1f)) {\r\n                    Row(\r\n                        modifier = Modifier.fillMaxWidth(),\r\n                        horizontalArrangement = Arrangement.SpaceBetween\r\n                    ) {\r\n                        Text(\r\n                            dateFormat.format(Date(item.sms.receivedAt)),\r\n                            style = MaterialTheme.typography.labelSmall,\r\n                            color = CharcoalGray\r\n                        )\r\n                        item.sms.partyNames?.let {\r\n                            Text(\r\n                                it,\r\n                                style = MaterialTheme.typography.labelLarge,\r\n                                color = CinnabarRed\r\n                            )\r\n                        }\r\n                    }\r\n                    Spacer(modifier = Modifier.height(4.dp))\r\n                    Row(\r\n                        modifier = Modifier.fillMaxWidth(),\r\n                        horizontalArrangement = Arrangement.SpaceBetween\r\n                    ) {\r\n                        item.sms.courtName?.let {\r\n                            Text(\r\n                                it,\r\n                                style = MaterialTheme.typography.titleMedium,\r\n                                color = InkBlack\r\n                            )\r\n                        }\r\n                        item.sms.caseNumber?.let {\r\n                            Text(\r\n                                it,\r\n                                style = MaterialTheme.typography.bodyMedium,\r\n                                color = CharcoalGray,\r\n                                maxLines = 1,\r\n                                overflow = TextOverflow.Ellipsis\r\n                            )\r\n                        }\r\n                    }\r\n                    if (item.sms.webUrl != null && item.pdfs.isEmpty()) {\r\n                        Spacer(modifier = Modifier.height(4.dp))\r\n                        Text(\r\n                            \"📄 点击展开查看文书\",\r\n                            style = MaterialTheme.typography.labelSmall,\r\n                            color = AmberGold\r\n                        )\r\n                    }\r\n                    if (item.pdfs.isNotEmpty()) {\r\n                        Spacer(modifier = Modifier.height(2.dp))\r\n                        Text(\r\n                            \"${item.pdfs.size} 个文书\",\r\n                            style = MaterialTheme.typography.labelSmall,\r\n                            color = JadeGreen\r\n                        )\r\n                    }\r\n                }\r\n                Icon(\r\n                    if (expanded) Icons.Default.KeyboardArrowUp else Icons.Default.KeyboardArrowDown,\r\n                    contentDescription = null,\r\n                    tint = CharcoalGray\r\n                )\r\n            }\r\n\r\n            AnimatedVisibility(visible = expanded) {\r\n                Column(\r\n                    modifier = Modifier.padding(start = 12.dp, end = 12.dp, bottom = 12.dp),\r\n                    verticalArrangement = Arrangement.spacedBy(6.dp)\r\n                ) {\r\n                    if (item.sms.webUrl != null) {\r\n                        OutlinedButton(\r\n                            onClick = { onOpenWebView(item.sms.id, item.sms.webUrl!!) },\r\n                            modifier = Modifier.fillMaxWidth(),\r\n                            colors = ButtonDefaults.outlinedButtonColors(contentColor = CinnabarRed),\r\n                            shape = RoundedCornerShape(6.dp)\r\n                        ) {\r\n                            Text(\"打开送达链接下载文书\")\r\n                        }\r\n                    }\r\n                    item.pdfs.forEach { pdf ->\r\n                        PdfCard(pdf = pdf, onClick = { onOpenPdf(pdf.id) })\r\n                    }\r\n                }\r\n            }\r\n        }\r\n    }\r\n}\r\n\r\n@Composable\r\nfun PdfCard(pdf: PdfDocumentEntity, onClick: () -> Unit) {\r\n    val dateFormat = remember { SimpleDateFormat(\"MM-dd HH:mm\", Locale.CHINA) }\r\n    Surface(\r\n        modifier = Modifier\r\n            .fillMaxWidth()\r\n            .clip(RoundedCornerShape(6.dp))\r\n            .clickable(onClick = onClick),\r\n        color = ParchmentBg,\r\n        shape = RoundedCornerShape(6.dp)\r\n    ) {\r\n        Row(\r\n            modifier = Modifier.padding(10.dp),\r\n            verticalAlignment = Alignment.CenterVertically\r\n        ) {\r\n            Text(\r\n                if (pdf.isSubpoena) \"📋\" else \"📄\",\r\n                style = MaterialTheme.typography.titleLarge\r\n            )\r\n            Spacer(modifier = Modifier.width(8.dp))\r\n            Column(modifier = Modifier.weight(1f)) {\r\n                Text(\r\n                    pdf.fileName,\r\n                    style = MaterialTheme.typography.bodyMedium,\r\n                    color = InkBlack,\r\n                    maxLines = 1,\r\n                    overflow = TextOverflow.Ellipsis\r\n                )\r\n                Text(\r\n                    \"${dateFormat.format(Date(pdf.downloadedAt))} · ${formatSize(pdf.fileSize)}\",\r\n                    style = MaterialTheme.typography.labelSmall,\r\n                    color = CharcoalGray\r\n                )\r\n            }\r\n            if (pdf.isSubpoena && pdf.hearingInfo != null) {\r\n                Text(\"已同步日历\", style = MaterialTheme.typography.labelSmall, color = JadeGreen)\r\n            }\r\n        }\r\n    }\r\n}\r\n\r\nprivate fun formatSize(bytes: Long): String {\r\n    return when {\r\n        bytes < 1024 -> \"${bytes}B\"\r\n        bytes < 1024 * 1024 -> \"${bytes / 1024}KB\"\r\n        else -> String.format(\"%.1fMB\", bytes / (1024.0 * 1024.0))\r\n    }\r\n}","is_error":false}]},"uuid":"8e945098-0dc9-4879-a313-d7bbb5ea74aa","timestamp":"2026-02-13T15:31:35.811Z"},"normalizedMessages":[],"type":"agent_progress","prompt":"Explore the directory C:\\Users\\Administrator\\Desktop\\CourtAssistant thoroughly. List the directory structure, identify the project type, key files, and provide a summary of what this project is about. Look at package.json, README, main entry points, and any configuration files.","agentId":"acabb7d"},"toolUseID":"agent_msg_20260213153029","parentToolUseID":"tooluse_U26VaulPbCKIH6CBIZfr1O","uuid":"677d8cb8-7f83-472c-8c84-20b8b3116bda","timestamp":"2026-02-13T15:31:35.817Z"}
{"parentUuid":"677d8cb8-7f83-472c-8c84-20b8b3116bda","isSidechain":false,"userType":"external","cwd":"C:\\Users\\Administrator","sessionId":"a4e11369-bc15-4ff1-9b18-115fc4dd0659","version":"2.1.41","gitBranch":"HEAD","slug":"buzzing-wobbling-rossum","type":"progress","data":{"message":{"type":"user","message":{"role":"user","content":[{"tool_use_id":"tooluse_XMZdkuSKv8cVViToYlBPbM","type":"tool_result","content":"package com.court.assistant.pdf\r\n\r\nimport android.content.Context\r\nimport android.graphics.Bitmap\r\nimport android.graphics.pdf.PdfRenderer\r\nimport android.os.ParcelFileDescriptor\r\nimport com.google.mlkit.vision.common.InputImage\r\nimport com.google.mlkit.vision.text.TextRecognition\r\nimport com.google.mlkit.vision.text.chinese.ChineseTextRecognizerOptions\r\nimport kotlinx.coroutines.Dispatchers\r\nimport kotlinx.coroutines.suspendCancellableCoroutine\r\nimport kotlinx.coroutines.withContext\r\nimport java.io.File\r\nimport java.util.*\r\nimport kotlin.coroutines.resume\r\n\r\ndata class SubpoenaInfo(\r\n    val caseNumber: String?,       // 案号\r\n    val courtName: String?,       // 法院简称\r\n    val hearingTime: Long?,       // 应到时间\r\n    val defendant: String?,        // 被传唤人\r\n    val handler: String?,         // 承办人\r\n    val location: String?,        // 应到处所\r\n    val phone: String?,           // 电话\r\n    val caseType: String?         // 案由\r\n)\r\n\r\nclass PdfParser(private val context: Context) {\r\n\r\n    suspend fun parseSubpoena(filePath: String): SubpoenaInfo? = withContext(Dispatchers.IO) {\r\n        val text = extractText(filePath)\r\n        if (text.isNullOrBlank()) return@withContext null\r\n        parseSubpoenaText(text)\r\n    }\r\n\r\n    private suspend fun extractText(filePath: String): String? {\r\n        // 先尝试 iText 提取\r\n        val iTextResult = extractWithIText(filePath)\r\n        if (!iTextResult.isNullOrBlank() && iTextResult.any { it.code > 0x4E00 }) {\r\n            return iTextResult\r\n        }\r\n        // 回退到 OCR\r\n        return extractWithOcr(filePath)\r\n    }\r\n\r\n    private fun extractWithIText(filePath: String): String? {\r\n        return try {\r\n            val reader = com.itextpdf.kernel.pdf.PdfReader(filePath)\r\n            val doc = com.itextpdf.kernel.pdf.PdfDocument(reader)\r\n            val sb = StringBuilder()\r\n            for (i in 1..doc.numberOfPages) {\r\n                val text = com.itextpdf.kernel.pdf.canvas.parser.PdfTextExtractor.getTextFromPage(doc.getPage(i))\r\n                sb.appendLine(text)\r\n            }\r\n            doc.close()\r\n            sb.toString()\r\n        } catch (_: Exception) { null }\r\n    }\r\n\r\n    private suspend fun extractWithOcr(filePath: String): String? {\r\n        val file = File(filePath)\r\n        if (!file.exists()) return null\r\n        val fd = ParcelFileDescriptor.open(file, ParcelFileDescriptor.MODE_READ_ONLY)\r\n        val renderer = PdfRenderer(fd)\r\n        val sb = StringBuilder()\r\n        val recognizer = TextRecognition.getClient(ChineseTextRecognizerOptions.Builder().build())\r\n\r\n        for (i in 0 until renderer.pageCount) {\r\n            val page = renderer.openPage(i)\r\n            val bitmap = Bitmap.createBitmap(page.width * 2, page.height * 2, Bitmap.Config.ARGB_8888)\r\n            page.render(bitmap, null, null, PdfRenderer.Page.RENDER_MODE_FOR_DISPLAY)\r\n            page.close()\r\n\r\n            val text = suspendCancellableCoroutine<String?> { cont ->\r\n                val image = InputImage.fromBitmap(bitmap, 0)\r\n                recognizer.process(image)\r\n                    .addOnSuccessListener { result -> cont.resume(result.text) }\r\n                    .addOnFailureListener { cont.resume(null) }\r\n            }\r\n            if (text != null) sb.appendLine(text)\r\n            bitmap.recycle()\r\n        }\r\n        renderer.close()\r\n        fd.close()\r\n        return sb.toString().takeIf { it.isNotBlank() }\r\n    }\r\n\r\n    private fun parseSubpoenaText(text: String): SubpoenaInfo {\r\n        val caseNumber = Regex(\"[（(]\\\\d{4}[）)][^\\\\s，。]+号\").find(text)?.value\r\n        val courtName = Regex(\"(.+?法院)\").find(text)?.groupValues?.get(1)\r\n\r\n        // 提取被传唤人（优先提取\"被传唤人\"或\"被告\"）\r\n        val defendant = try {\r\n            // 优先匹配\"被传唤人\"\r\n            Regex(\"被传唤人[：:]?\\\\s*([^\\\\n，。]+)\").find(text)?.groupValues?.get(1)?.trim()\r\n                // 其次匹配\"被告\"\r\n                ?: Regex(\"被告[：:]?\\\\s*([^\\\\n，。]+)\").find(text)?.groupValues?.get(1)?.trim()\r\n        } catch (e: Exception) { null }\r\n\r\n        // 提取承办人（法官/审判员）\r\n        val handler = try {\r\n            listOf(\r\n                Regex(\"承办人[：:]?\\\\s*([^\\\\n，。]+)\"),\r\n                Regex(\"审判[长员][：:]?\\\\s*([^\\\\n，。]+)\"),\r\n                Regex(\"法官[：:]?\\\\s*([^\\\\n，。]+)\"),\r\n                Regex(\"经办人[：:]?\\\\s*([^\\\\n，。]+)\")\r\n            ).firstNotNullOfOrNull { it.find(text)?.groupValues?.get(1)?.trim() }\r\n        } catch (e: Exception) { null }\r\n\r\n        // 提取联系电话\r\n        val phone = try {\r\n            listOf(\r\n                Regex(\"电话[：:]?\\\\s*([1][3-9]\\\\d{9})\"),\r\n                Regex(\"联系电话[：:]?\\\\s*([1][3-9]\\\\d{9})\"),\r\n                Regex(\"手机[：:]?\\\\s*([1][3-9]\\\\d{9})\"),\r\n                Regex(\"联系方式[：:]?\\\\s*([1][3-9]\\\\d{9})\"),\r\n                Regex(\"(?:tel|Tel|TEL)[：:]?\\\\s*([1][3-9]\\\\d{9})\")\r\n            ).firstNotNullOfOrNull { it.find(text)?.groupValues?.get(1)?.trim() }\r\n        } catch (e: Exception) { null }\r\n\r\n        val location = Regex(\"(?:应到地点|地[点址])[：:]?\\\\s*(\\\\S+)\").find(text)?.groupValues?.get(1)\r\n\r\n        var hearingTime: Long? = null\r\n        val timeMatch = Regex(\"(?:应到时间|开庭时间|定于)[：:]?\\\\s*(\\\\d{4})[年-](\\\\d{1,2})[月-](\\\\d{1,2})[日]?\\\\s*(\\\\d{1,2})[时点:：](\\\\d{0,2})\").find(text)\r\n        if (timeMatch != null) {\r\n            val cal = Calendar.getInstance().apply {\r\n                set(timeMatch.groupValues[1].toInt(),\r\n                    timeMatch.groupValues[2].toInt() - 1,\r\n                    timeMatch.groupValues[3].toInt(),\r\n                    timeMatch.groupValues[4].toInt(),\r\n                    timeMatch.groupValues[5].takeIf { it.isNotEmpty() }?.toInt() ?: 0, 0)\r\n                set(Calendar.MILLISECOND, 0)\r\n            }\r\n            hearingTime = cal.timeInMillis\r\n        }\r\n\r\n        return SubpoenaInfo(caseNumber, courtName, hearingTime, defendant, handler, location, phone)\r\n    }\r\n}","is_error":false}]},"uuid":"ed30b35b-95bf-4c69-94fd-4e124f339315","timestamp":"2026-02-13T15:31:35.819Z"},"normalizedMessages":[],"type":"agent_progress","prompt":"Explore the directory C:\\Users\\Administrator\\Desktop\\CourtAssistant thoroughly. List the directory structure, identify the project type, key files, and provide a summary of what this project is about. Look at package.json, README, main entry points, and any configuration files.","agentId":"acabb7d"},"toolUseID":"agent_msg_20260213153029","parentToolUseID":"tooluse_U26VaulPbCKIH6CBIZfr1O","uuid":"3b2917c1-6428-4a57-8f81-f223e678b403","timestamp":"2026-02-13T15:31:35.824Z"}
{"parentUuid":"3b2917c1-6428-4a57-8f81-f223e678b403","isSidechain":false,"userType":"external","cwd":"C:\\Users\\Administrator","sessionId":"a4e11369-bc15-4ff1-9b18-115fc4dd0659","version":"2.1.41","gitBranch":"HEAD","slug":"buzzing-wobbling-rossum","type":"progress","data":{"message":{"type":"user","message":{"role":"user","content":[{"tool_use_id":"tooluse_bHNSLVzSjjzurFGe4rQKzw","type":"tool_result","content":"package com.court.assistant.pdf\r\n\r\nimport android.content.Context\r\nimport android.webkit.CookieManager\r\nimport com.court.assistant.utils.Md5Util\r\nimport kotlinx.coroutines.Dispatchers\r\nimport kotlinx.coroutines.withContext\r\nimport okhttp3.OkHttpClient\r\nimport okhttp3.Request\r\nimport java.io.File\r\n\r\nclass PdfDownloadManager(private val context: Context) {\r\n    private val client = OkHttpClient.Builder()\r\n        .followRedirects(true)\r\n        .followSslRedirects(true)\r\n        .build()\r\n\r\n    fun getStorageDir(): File {\r\n        val dir = File(context.getExternalFilesDir(null), \"Documents\")\r\n        if (!dir.exists()) dir.mkdirs()\r\n        return dir\r\n    }\r\n\r\n    suspend fun download(url: String, fileName: String? = null, cookies: String? = null): DownloadResult = withContext(Dispatchers.IO) {\r\n        try {\r\n            val requestBuilder = Request.Builder().url(url)\r\n            val cookie = cookies ?: CookieManager.getInstance()?.getCookie(url)\r\n            if (cookie != null) {\r\n                requestBuilder.addHeader(\"Cookie\", cookie)\r\n            }\r\n            val response = client.newCall(requestBuilder.build()).execute()\r\n            if (!response.isSuccessful) return@withContext DownloadResult.Error(\"HTTP ${response.code}\")\r\n\r\n            val contentDisposition = response.header(\"Content-Disposition\")\r\n            val resolvedName = fileName\r\n                ?: parseFileNameFromDisposition(contentDisposition)\r\n                ?: \"document_${System.currentTimeMillis()}.pdf\"\r\n\r\n            // 只替换文件系统中真正不允许的字符，保留中文括号等\r\n            val safeName = resolvedName.replace(Regex(\"[/\\\\\\\\:*?\\\"<>|]\"), \"_\")\r\n            val file = File(getStorageDir(), safeName)\r\n            response.body?.byteStream()?.use { input ->\r\n                file.outputStream().use { output -> input.copyTo(output) }\r\n            }\r\n\r\n            // 计算MD5用于去重\r\n            val md5 = Md5Util.calculateMd5(file)\r\n\r\n            DownloadResult.Success(file.absolutePath, safeName, file.length(), md5)\r\n        } catch (e: Exception) {\r\n            DownloadResult.Error(e.message ?: \"Download failed\")\r\n        }\r\n    }\r\n\r\n    private fun parseFileNameFromDisposition(header: String?): String? {\r\n        if (header == null) return null\r\n        // filename*=UTF-8''xxx.pdf\r\n        Regex(\"filename\\\\*=(?:UTF-8''|utf-8'')(.+)\").find(header)?.let {\r\n            return java.net.URLDecoder.decode(it.groupValues[1], \"UTF-8\")\r\n        }\r\n        // filename=\"xxx.pdf\"\r\n        Regex(\"filename=\\\"?([^\\\"]+)\\\"?\").find(header)?.let {\r\n            return it.groupValues[1].trim()\r\n        }\r\n        return null\r\n    }\r\n}\r\n\r\nsealed class DownloadResult {\r\n    data class Success(\r\n        val filePath: String,\r\n        val fileName: String,\r\n        val fileSize: Long,\r\n        val fileMd5: String\r\n    ) : DownloadResult()\r\n    data class Error(val message: String) : DownloadResult()\r\n}","is_error":false}]},"uuid":"3190363c-4810-442b-94b6-7f992bd2cbd5","timestamp":"2026-02-13T15:31:35.830Z"},"normalizedMessages":[],"type":"agent_progress","prompt":"Explore the directory C:\\Users\\Administrator\\Desktop\\CourtAssistant thoroughly. List the directory structure, identify the project type, key files, and provide a summary of what this project is about. Look at package.json, README, main entry points, and any configuration files.","agentId":"acabb7d"},"toolUseID":"agent_msg_20260213153029","parentToolUseID":"tooluse_U26VaulPbCKIH6CBIZfr1O","uuid":"44014907-77f6-4ac4-a7a6-d863823a408d","timestamp":"2026-02-13T15:31:35.835Z"}
{"parentUuid":"44014907-77f6-4ac4-a7a6-d863823a408d","isSidechain":false,"userType":"external","cwd":"C:\\Users\\Administrator","sessionId":"a4e11369-bc15-4ff1-9b18-115fc4dd0659","version":"2.1.41","gitBranch":"HEAD","slug":"buzzing-wobbling-rossum","type":"progress","data":{"message":{"type":"user","message":{"role":"user","content":[{"tool_use_id":"tooluse_B3u31kxDkqXezAlEEgzYKb","type":"tool_result","content":"package com.court.assistant.viewmodel\r\n\r\nimport android.app.Application\r\nimport androidx.lifecycle.AndroidViewModel\r\nimport androidx.lifecycle.viewModelScope\r\nimport com.court.assistant.CourtApp\r\nimport com.court.assistant.calendar.CalendarSync\r\nimport com.court.assistant.data.db.CourtSmsEntity\r\nimport com.court.assistant.data.db.PdfDocumentEntity\r\nimport com.court.assistant.pdf.PdfDownloadManager\r\nimport com.court.assistant.pdf.PdfParser\r\nimport com.court.assistant.pdf.DownloadResult\r\nimport com.court.assistant.sms.SmsParser\r\nimport com.court.assistant.sms.SmsReader\r\nimport kotlinx.coroutines.flow.*\r\nimport kotlinx.coroutines.launch\r\n\r\ndata class SmsWithPdfs(\r\n    val sms: CourtSmsEntity,\r\n    val pdfs: List<PdfDocumentEntity>\r\n)\r\n\r\ndata class UiState(\r\n    val smsWithPdfs: List<SmsWithPdfs> = emptyList(),\r\n    val loading: Boolean = false,\r\n    val message: String? = null,\r\n    val downloadCount: Int = 0\r\n)\r\n\r\nclass MainViewModel(application: Application) : AndroidViewModel(application) {\r\n    private val app = application as CourtApp\r\n    private val repo = app.repository\r\n    private val smsReader = SmsReader(application)\r\n    private val smsParser = SmsParser()\r\n    private val calendarSync = CalendarSync(application)\r\n    val pdfDownloader = PdfDownloadManager(application)\r\n    private val pdfParser = PdfParser(application)\r\n\r\n    private val _uiState = MutableStateFlow(UiState())\r\n    val uiState: StateFlow<UiState> = _uiState.asStateFlow()\r\n\r\n    private val _downloadEvent = MutableSharedFlow<String>()\r\n    val downloadEvent: SharedFlow<String> = _downloadEvent.asSharedFlow()\r\n\r\n    init {\r\n        viewModelScope.launch {\r\n            repo.getAllSms().collect { smsList ->\r\n                val withPdfs = smsList.map { sms ->\r\n                    val pdfs = repo.getPdfsBySmsId(sms.id).first()\r\n                    SmsWithPdfs(sms, pdfs)\r\n                }\r\n                _uiState.update { it.copy(smsWithPdfs = withPdfs, loading = false) }\r\n            }\r\n        }\r\n    }\r\n\r\n    fun loadSms() {\r\n        viewModelScope.launch {\r\n            _uiState.update { it.copy(loading = true) }\r\n            val rawList = smsReader.readCourtSms()\r\n            for (raw in rawList) {\r\n                val hash = raw.body.hashCode()\r\n                if (repo.smsExists(hash)) continue\r\n                val parsed = smsParser.parse(raw.body)\r\n                val entity = CourtSmsEntity(\r\n                    sender = raw.sender,\r\n                    body = raw.body,\r\n                    bodyHash = hash,\r\n                    receivedAt = raw.date,\r\n                    caseNumber = parsed.caseNumber,\r\n                    courtName = parsed.courtName,\r\n                    hearingTime = parsed.hearingTime,\r\n                    partyNames = parsed.partyNames,\r\n                    webUrl = parsed.webUrl\r\n                )\r\n                val id = repo.insertSms(entity)\r\n                if (id > 0 && parsed.hearingTime != null && parsed.caseNumber != null) {\r\n                    val eventId = calendarSync.syncHearing(\r\n                        caseNumber = parsed.caseNumber,\r\n                        courtName = parsed.courtName,\r\n                        hearingTime = parsed.hearingTime,\r\n                        defendant = parsed.partyNames, // SMS解析暂无单独的被传唤人字段\r\n                        handler = null,\r\n                        location = null,\r\n                        phone = null,\r\n                        partyNames = parsed.partyNames\r\n                    )\r\n                    if (eventId != null) {\r\n                        repo.updateSms(entity.copy(id = id, calendarEventId = eventId))\r\n                    }\r\n                }\r\n            }\r\n            _uiState.update { it.copy(loading = false, message = \"已读取 ${rawList.size} 条法院短信\") }\r\n        }\r\n    }\r\n\r\n    fun downloadPdf(url: String, smsId: Long, fileName: String? = null, cookies: String? = null) {\r\n        viewModelScope.launch {\r\n            val result = pdfDownloader.download(url, fileName, cookies)\r\n            when (result) {\r\n                is DownloadResult.Success -> {\r\n                    val pdf = PdfDocumentEntity(\r\n                        smsId = smsId,\r\n                        fileName = result.fileName,\r\n                        filePath = result.filePath,\r\n                        fileSize = result.fileSize,\r\n                        fileMd5 = result.fileMd5,\r\n                        downloadedAt = System.currentTimeMillis(),\r\n                        isSubpoena = false\r\n                    )\r\n                    val pdfId = repo.insertPdf(pdf)\r\n                    if (pdfId > 0) {\r\n                        _uiState.update { it.copy(downloadCount = it.downloadCount + 1) }\r\n                        _downloadEvent.emit(\"已保存: ${result.fileName}\")\r\n                        // 所有PDF都尝试解析同步\r\n                        tryParseAndSync(pdfId, result.filePath, smsId)\r\n                    } else {\r\n                        _downloadEvent.emit(\"文件已存在: ${result.fileName}\")\r\n                    }\r\n                }\r\n                is DownloadResult.Error -> {\r\n                    _downloadEvent.emit(\"下载失败: ${result.message}\")\r\n                }\r\n            }\r\n        }\r\n    }\r\n\r\n    private suspend fun tryParseAndSync(pdfId: Long, filePath: String, smsId: Long) {\r\n        val info = pdfParser.parseSubpoena(filePath) ?: return\r\n        val pdf = repo.getPdfById(pdfId) ?: return\r\n\r\n        // 判断是否为传票：有开庭时间或文件名/内容含传票关键词\r\n        val isSubpoena = info.hearingTime != null ||\r\n            pdf.fileName.contains(\"传票\") ||\r\n            info.defendant != null\r\n\r\n        val hearingDesc = buildString {\r\n            if (info.courtName != null) append(\"法院: ${info.courtName}\\n\")\r\n            if (info.defendant != null) append(\"被传唤人: ${info.defendant}\\n\")\r\n            if (info.handler != null) append(\"承办人: ${info.handler}\\n\")\r\n            if (info.location != null) append(\"地点: ${info.location}\")\r\n            if (info.phone != null) append(\"\\n电话: ${info.phone}\")\r\n        }.takeIf { it.isNotBlank() }\r\n\r\n        if (info.hearingTime != null && info.caseNumber != null) {\r\n            val eventId = calendarSync.syncHearing(\r\n                caseNumber = info.caseNumber,\r\n                courtName = info.courtName,\r\n                hearingTime = info.hearingTime,\r\n                defendant = info.defendant,\r\n                handler = info.handler,\r\n                location = info.location,\r\n                phone = info.phone\r\n            )\r\n            repo.updatePdf(pdf.copy(isSubpoena = isSubpoena, hearingInfo = hearingDesc, calendarEventId = eventId))\r\n            if (eventId != null) {\r\n                _downloadEvent.emit(\"📅 已同步到日历\")\r\n            }\r\n        } else if (hearingDesc != null || isSubpoena) {\r\n            repo.updatePdf(pdf.copy(isSubpoena = isSubpoena, hearingInfo = hearingDesc))\r\n        }\r\n    }\r\n\r\n    fun resetDownloadCount() {\r\n        _uiState.update { it.copy(downloadCount = 0) }\r\n    }\r\n\r\n    fun clearMessage() {\r\n        _uiState.update { it.copy(message = null) }\r\n    }\r\n\r\n    /**\r\n     * 手动同步PDF到日程\r\n     */\r\n    fun syncPdfToCalendar(pdfId: Long) {\r\n        viewModelScope.launch {\r\n            val pdf = repo.getPdfById(pdfId) ?: return@launch\r\n            val info = pdfParser.parseSubpoena(pdf.filePath)\r\n\r\n            if (info == null) {\r\n                _uiState.update { it.copy(message = \"无法解析文件内容\") }\r\n                return@launch\r\n            }\r\n\r\n            if (info.hearingTime == null || info.caseNumber == null) {\r\n                _uiState.update { it.copy(message = \"未找到开庭时间或案号\") }\r\n                return@launch\r\n            }\r\n\r\n            val eventId = calendarSync.syncHearing(\r\n                caseNumber = info.caseNumber,\r\n                courtName = info.courtName,\r\n                hearingTime = info.hearingTime,\r\n                defendant = info.defendant,\r\n                handler = info.handler,\r\n                location = info.location,\r\n                phone = info.phone\r\n            )\r\n\r\n            if (eventId != null) {\r\n                val hearingDesc = buildString {\r\n                    if (info.courtName != null) append(\"法院: ${info.courtName}\\n\")\r\n                    if (info.defendant != null) append(\"被传唤人: ${info.defendant}\\n\")\r\n                    if (info.handler != null) append(\"承办人: ${info.handler}\\n\")\r\n                    if (info.location != null) append(\"地点: ${info.location}\")\r\n                    if (info.phone != null) append(\"\\n电话: ${info.phone}\")\r\n                }.takeIf { it.isNotBlank() }\r\n                repo.updatePdf(pdf.copy(isSubpoena = true, hearingInfo = hearingDesc, calendarEventId = eventId))\r\n                _uiState.update { it.copy(message = \"已添加到日历\") }\r\n            } else {\r\n                _uiState.update { it.copy(message = \"日历事件已存在\") }\r\n            }\r\n        }\r\n    }\r\n}","is_error":false}]},"uuid":"5ea849cd-73d8-4d74-a177-26fe46a2eafa","timestamp":"2026-02-13T15:31:35.837Z"},"normalizedMessages":[],"type":"agent_progress","prompt":"Explore the directory C:\\Users\\Administrator\\Desktop\\CourtAssistant thoroughly. List the directory structure, identify the project type, key files, and provide a summary of what this project is about. Look at package.json, README, main entry points, and any configuration files.","agentId":"acabb7d"},"toolUseID":"agent_msg_20260213153029","parentToolUseID":"tooluse_U26VaulPbCKIH6CBIZfr1O","uuid":"a0b77749-6b57-4e99-9a65-02a61667c653","timestamp":"2026-02-13T15:31:35.841Z"}
