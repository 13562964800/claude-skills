{"parentUuid":"6a19a25d-32ad-400a-97b0-4f4753da492d","isSidechain":false,"userType":"external","cwd":"C:\\Users\\Administrator","sessionId":"a4e11369-bc15-4ff1-9b18-115fc4dd0659","version":"2.1.41","gitBranch":"HEAD","slug":"buzzing-wobbling-rossum","type":"user","message":{"role":"user","content":[{"tool_use_id":"tooluse_U9br0WwiiCNIlmRCGaLcXt","type":"tool_result","content":"     1→package com.court.assistant.pdf\n     2→\n     3→import android.content.Context\n     4→import android.graphics.Bitmap\n     5→import android.graphics.pdf.PdfRenderer\n     6→import android.os.ParcelFileDescriptor\n     7→import com.google.mlkit.vision.common.InputImage\n     8→import com.google.mlkit.vision.text.TextRecognition\n     9→import com.google.mlkit.vision.text.chinese.ChineseTextRecognizerOptions\n    10→import kotlinx.coroutines.Dispatchers\n    11→import kotlinx.coroutines.suspendCancellableCoroutine\n    12→import kotlinx.coroutines.withContext\n    13→import java.io.File\n    14→import java.util.*\n    15→import kotlin.coroutines.resume\n    16→\n    17→data class SubpoenaInfo(\n    18→    val caseNumber: String?,       // 案号\n    19→    val courtName: String?,       // 法院简称\n    20→    val hearingTime: Long?,       // 应到时间\n    21→    val defendant: String?,        // 被传唤人\n    22→    val handler: String?,         // 承办人\n    23→    val location: String?,        // 应到处所\n    24→    val phone: String?,           // 电话\n    25→    val caseType: String?         // 案由\n    26→)\n    27→\n    28→class PdfParser(private val context: Context) {\n    29→\n    30→    suspend fun parseSubpoena(filePath: String): SubpoenaInfo? = withContext(Dispatchers.IO) {\n    31→        val text = extractText(filePath)\n    32→        if (text.isNullOrBlank()) return@withContext null\n    33→        parseSubpoenaText(text)\n    34→    }\n    35→\n    36→    private suspend fun extractText(filePath: String): String? {\n    37→        // 先尝试 iText 提取\n    38→        val iTextResult = extractWithIText(filePath)\n    39→        if (!iTextResult.isNullOrBlank() && iTextResult.any { it.code > 0x4E00 }) {\n    40→            return iTextResult\n    41→        }\n    42→        // 回退到 OCR\n    43→        return extractWithOcr(filePath)\n    44→    }\n    45→\n    46→    private fun extractWithIText(filePath: String): String? {\n    47→        return try {\n    48→            val reader = com.itextpdf.kernel.pdf.PdfReader(filePath)\n    49→            val doc = com.itextpdf.kernel.pdf.PdfDocument(reader)\n    50→            val sb = StringBuilder()\n    51→            for (i in 1..doc.numberOfPages) {\n    52→                val text = com.itextpdf.kernel.pdf.canvas.parser.PdfTextExtractor.getTextFromPage(doc.getPage(i))\n    53→                sb.appendLine(text)\n    54→            }\n    55→            doc.close()\n    56→            sb.toString()\n    57→        } catch (_: Exception) { null }\n    58→    }\n    59→\n    60→    private suspend fun extractWithOcr(filePath: String): String? {\n    61→        val file = File(filePath)\n    62→        if (!file.exists()) return null\n    63→        val fd = ParcelFileDescriptor.open(file, ParcelFileDescriptor.MODE_READ_ONLY)\n    64→        val renderer = PdfRenderer(fd)\n    65→        val sb = StringBuilder()\n    66→        val recognizer = TextRecognition.getClient(ChineseTextRecognizerOptions.Builder().build())\n    67→\n    68→        for (i in 0 until renderer.pageCount) {\n    69→            val page = renderer.openPage(i)\n    70→            val bitmap = Bitmap.createBitmap(page.width * 2, page.height * 2, Bitmap.Config.ARGB_8888)\n    71→            page.render(bitmap, null, null, PdfRenderer.Page.RENDER_MODE_FOR_DISPLAY)\n    72→            page.close()\n    73→\n    74→            val text = suspendCancellableCoroutine<String?> { cont ->\n    75→                val image = InputImage.fromBitmap(bitmap, 0)\n    76→                recognizer.process(image)\n    77→                    .addOnSuccessListener { result -> cont.resume(result.text) }\n    78→                    .addOnFailureListener { cont.resume(null) }\n    79→            }\n    80→            if (text != null) sb.appendLine(text)\n    81→            bitmap.recycle()\n    82→        }\n    83→        renderer.close()\n    84→        fd.close()\n    85→        return sb.toString().takeIf { it.isNotBlank() }\n    86→    }\n    87→\n    88→    private fun parseSubpoenaText(text: String): SubpoenaInfo {\n    89→        val caseNumber = Regex(\"[（(]\\\\d{4}[）)][^\\\\s，。]+号\").find(text)?.value\n    90→        val courtName = Regex(\"(.+?法院)\").find(text)?.groupValues?.get(1)\n    91→\n    92→        // 提取被传唤人（优先提取\"被传唤人\"或\"被告\"）\n    93→        val defendant = try {\n    94→            // 优先匹配\"被传唤人\"\n    95→            Regex(\"被传唤人[：:]?\\\\s*([^\\\\n，。]+)\").find(text)?.groupValues?.get(1)?.trim()\n    96→                // 其次匹配\"被告\"\n    97→                ?: Regex(\"被告[：:]?\\\\s*([^\\\\n，。]+)\").find(text)?.groupValues?.get(1)?.trim()\n    98→        } catch (e: Exception) { null }\n    99→\n   100→        // 提取承办人（法官/审判员）\n   101→        val handler = try {\n   102→            listOf(\n   103→                Regex(\"承办人[：:]?\\\\s*([^\\\\n，。]+)\"),\n   104→                Regex(\"审判[长员][：:]?\\\\s*([^\\\\n，。]+)\"),\n   105→                Regex(\"法官[：:]?\\\\s*([^\\\\n，。]+)\"),\n   106→                Regex(\"经办人[：:]?\\\\s*([^\\\\n，。]+)\")\n   107→            ).firstNotNullOfOrNull { it.find(text)?.groupValues?.get(1)?.trim() }\n   108→        } catch (e: Exception) { null }\n   109→\n   110→        // 提取联系电话\n   111→        val phone = try {\n   112→            listOf(\n   113→                Regex(\"电话[：:]?\\\\s*([1][3-9]\\\\d{9})\"),\n   114→                Regex(\"联系电话[：:]?\\\\s*([1][3-9]\\\\d{9})\"),\n   115→                Regex(\"手机[：:]?\\\\s*([1][3-9]\\\\d{9})\"),\n   116→                Regex(\"联系方式[：:]?\\\\s*([1][3-9]\\\\d{9})\"),\n   117→                Regex(\"(?:tel|Tel|TEL)[：:]?\\\\s*([1][3-9]\\\\d{9})\")\n   118→            ).firstNotNullOfOrNull { it.find(text)?.groupValues?.get(1)?.trim() }\n   119→        } catch (e: Exception) { null }\n   120→\n   121→        val location = Regex(\"(?:应到处所|应到地点|地[点址])[：:]?\\\\s*([^\\\\n，。]+)\").find(text)?.groupValues?.get(1)?.trim()\n   122→\n   123→        var hearingTime: Long? = null\n   124→        val timeMatch = Regex(\"(?:应到时间|开庭时间|定于)[：:]?\\\\s*(\\\\d{4})[年-](\\\\d{1,2})[月-](\\\\d{1,2})[日号]?[\\\\s]*[（(]?(?:上午|下午|AM|PM)?[）)]?[\\\\s]*(\\\\d{1,2})[时点:：](\\\\d{0,2})[分]?\").find(text)\n   125→        if (timeMatch != null) {\n   126→            var hour = timeMatch.groupValues[4].toInt()\n   127→            val minute = timeMatch.groupValues[5].takeIf { it.isNotEmpty() }?.toInt() ?: 0\n   128→            // 检查是否有\"下午/PM\"\n   129→            val matchedText = text.substring(0, timeMatch.range.first + timeMatch.value.length)\n   130→            if (hour < 12 && Regex(\"下午|PM\").containsMatchIn(matchedText)) {\n   131→                hour += 12\n   132→            }\n   133→            val cal = Calendar.getInstance().apply {\n   134→                set(timeMatch.groupValues[1].toInt(),\n   135→                    timeMatch.groupValues[2].toInt() - 1,\n   136→                    timeMatch.groupValues[3].toInt(),\n   137→                    hour, minute, 0)\n   138→                set(Calendar.MILLISECOND, 0)\n   139→            }\n   140→            hearingTime = cal.timeInMillis\n   141→        }\n   142→\n   143→        // 提取案由\n   144→        val caseType = Regex(\"(?:案由|纠纷类型)[：:]?\\\\s*([^\\\\n，。]+)\").find(text)?.groupValues?.get(1)?.trim()\n   145→\n   146→        return SubpoenaInfo(caseNumber, courtName, hearingTime, defendant, handler, location, phone, caseType)\n   147→    }\n   148→}\n   149→"}]},"uuid":"0b77c78a-9b47-44f0-872c-e982c3d34bde","timestamp":"2026-02-13T15:34:13.203Z","toolUseResult":{"type":"text","file":{"filePath":"C:\\Users\\Administrator\\Desktop\\CourtAssistant\\app\\src\\main\\java\\com\\court\\assistant\\pdf\\PdfParser.kt","content":"package com.court.assistant.pdf\n\nimport android.content.Context\nimport android.graphics.Bitmap\nimport android.graphics.pdf.PdfRenderer\nimport android.os.ParcelFileDescriptor\nimport com.google.mlkit.vision.common.InputImage\nimport com.google.mlkit.vision.text.TextRecognition\nimport com.google.mlkit.vision.text.chinese.ChineseTextRecognizerOptions\nimport kotlinx.coroutines.Dispatchers\nimport kotlinx.coroutines.suspendCancellableCoroutine\nimport kotlinx.coroutines.withContext\nimport java.io.File\nimport java.util.*\nimport kotlin.coroutines.resume\n\ndata class SubpoenaInfo(\n    val caseNumber: String?,       // 案号\n    val courtName: String?,       // 法院简称\n    val hearingTime: Long?,       // 应到时间\n    val defendant: String?,        // 被传唤人\n    val handler: String?,         // 承办人\n    val location: String?,        // 应到处所\n    val phone: String?,           // 电话\n    val caseType: String?         // 案由\n)\n\nclass PdfParser(private val context: Context) {\n\n    suspend fun parseSubpoena(filePath: String): SubpoenaInfo? = withContext(Dispatchers.IO) {\n        val text = extractText(filePath)\n        if (text.isNullOrBlank()) return@withContext null\n        parseSubpoenaText(text)\n    }\n\n    private suspend fun extractText(filePath: String): String? {\n        // 先尝试 iText 提取\n        val iTextResult = extractWithIText(filePath)\n        if (!iTextResult.isNullOrBlank() && iTextResult.any { it.code > 0x4E00 }) {\n            return iTextResult\n        }\n        // 回退到 OCR\n        return extractWithOcr(filePath)\n    }\n\n    private fun extractWithIText(filePath: String): String? {\n        return try {\n            val reader = com.itextpdf.kernel.pdf.PdfReader(filePath)\n            val doc = com.itextpdf.kernel.pdf.PdfDocument(reader)\n            val sb = StringBuilder()\n            for (i in 1..doc.numberOfPages) {\n                val text = com.itextpdf.kernel.pdf.canvas.parser.PdfTextExtractor.getTextFromPage(doc.getPage(i))\n                sb.appendLine(text)\n            }\n            doc.close()\n            sb.toString()\n        } catch (_: Exception) { null }\n    }\n\n    private suspend fun extractWithOcr(filePath: String): String? {\n        val file = File(filePath)\n        if (!file.exists()) return null\n        val fd = ParcelFileDescriptor.open(file, ParcelFileDescriptor.MODE_READ_ONLY)\n        val renderer = PdfRenderer(fd)\n        val sb = StringBuilder()\n        val recognizer = TextRecognition.getClient(ChineseTextRecognizerOptions.Builder().build())\n\n        for (i in 0 until renderer.pageCount) {\n            val page = renderer.openPage(i)\n            val bitmap = Bitmap.createBitmap(page.width * 2, page.height * 2, Bitmap.Config.ARGB_8888)\n            page.render(bitmap, null, null, PdfRenderer.Page.RENDER_MODE_FOR_DISPLAY)\n            page.close()\n\n            val text = suspendCancellableCoroutine<String?> { cont ->\n                val image = InputImage.fromBitmap(bitmap, 0)\n                recognizer.process(image)\n                    .addOnSuccessListener { result -> cont.resume(result.text) }\n                    .addOnFailureListener { cont.resume(null) }\n            }\n            if (text != null) sb.appendLine(text)\n            bitmap.recycle()\n        }\n        renderer.close()\n        fd.close()\n        return sb.toString().takeIf { it.isNotBlank() }\n    }\n\n    private fun parseSubpoenaText(text: String): SubpoenaInfo {\n        val caseNumber = Regex(\"[（(]\\\\d{4}[）)][^\\\\s，。]+号\").find(text)?.value\n        val courtName = Regex(\"(.+?法院)\").find(text)?.groupValues?.get(1)\n\n        // 提取被传唤人（优先提取\"被传唤人\"或\"被告\"）\n        val defendant = try {\n            // 优先匹配\"被传唤人\"\n            Regex(\"被传唤人[：:]?\\\\s*([^\\\\n，。]+)\").find(text)?.groupValues?.get(1)?.trim()\n                // 其次匹配\"被告\"\n                ?: Regex(\"被告[：:]?\\\\s*([^\\\\n，。]+)\").find(text)?.groupValues?.get(1)?.trim()\n        } catch (e: Exception) { null }\n\n        // 提取承办人（法官/审判员）\n        val handler = try {\n            listOf(\n                Regex(\"承办人[：:]?\\\\s*([^\\\\n，。]+)\"),\n                Regex(\"审判[长员][：:]?\\\\s*([^\\\\n，。]+)\"),\n                Regex(\"法官[：:]?\\\\s*([^\\\\n，。]+)\"),\n                Regex(\"经办人[：:]?\\\\s*([^\\\\n，。]+)\")\n            ).firstNotNullOfOrNull { it.find(text)?.groupValues?.get(1)?.trim() }\n        } catch (e: Exception) { null }\n\n        // 提取联系电话\n        val phone = try {\n            listOf(\n                Regex(\"电话[：:]?\\\\s*([1][3-9]\\\\d{9})\"),\n                Regex(\"联系电话[：:]?\\\\s*([1][3-9]\\\\d{9})\"),\n                Regex(\"手机[：:]?\\\\s*([1][3-9]\\\\d{9})\"),\n                Regex(\"联系方式[：:]?\\\\s*([1][3-9]\\\\d{9})\"),\n                Regex(\"(?:tel|Tel|TEL)[：:]?\\\\s*([1][3-9]\\\\d{9})\")\n            ).firstNotNullOfOrNull { it.find(text)?.groupValues?.get(1)?.trim() }\n        } catch (e: Exception) { null }\n\n        val location = Regex(\"(?:应到处所|应到地点|地[点址])[：:]?\\\\s*([^\\\\n，。]+)\").find(text)?.groupValues?.get(1)?.trim()\n\n        var hearingTime: Long? = null\n        val timeMatch = Regex(\"(?:应到时间|开庭时间|定于)[：:]?\\\\s*(\\\\d{4})[年-](\\\\d{1,2})[月-](\\\\d{1,2})[日号]?[\\\\s]*[（(]?(?:上午|下午|AM|PM)?[）)]?[\\\\s]*(\\\\d{1,2})[时点:：](\\\\d{0,2})[分]?\").find(text)\n        if (timeMatch != null) {\n            var hour = timeMatch.groupValues[4].toInt()\n            val minute = timeMatch.groupValues[5].takeIf { it.isNotEmpty() }?.toInt() ?: 0\n            // 检查是否有\"下午/PM\"\n            val matchedText = text.substring(0, timeMatch.range.first + timeMatch.value.length)\n            if (hour < 12 && Regex(\"下午|PM\").containsMatchIn(matchedText)) {\n                hour += 12\n            }\n            val cal = Calendar.getInstance().apply {\n                set(timeMatch.groupValues[1].toInt(),\n                    timeMatch.groupValues[2].toInt() - 1,\n                    timeMatch.groupValues[3].toInt(),\n                    hour, minute, 0)\n                set(Calendar.MILLISECOND, 0)\n            }\n            hearingTime = cal.timeInMillis\n        }\n\n        // 提取案由\n        val caseType = Regex(\"(?:案由|纠纷类型)[：:]?\\\\s*([^\\\\n，。]+)\").find(text)?.groupValues?.get(1)?.trim()\n\n        return SubpoenaInfo(caseNumber, courtName, hearingTime, defendant, handler, location, phone, caseType)\n    }\n}\n","numLines":149,"startLine":1,"totalLines":149}},"sourceToolAssistantUUID":"6a19a25d-32ad-400a-97b0-4f4753da492d"}
