urtName(it) }\n    37→        val partyNames = partyPattern.find(body)?.groupValues?.getOrNull(1)\n    38→        val webUrl = urlPattern.find(body)?.value\n    39→        val hearingTime = parseHearingTime(body)\n    40→\n    41→        return ParsedSms(\n    42→            caseNumber = caseNumber,\n    43→            courtName = courtName,\n    44→            hearingTime = hearingTime,\n    45→            partyNames = partyNames,\n    46→            webUrl = webUrl\n    47→        )\n    48→    }\n    49→\n    50→    private fun simplifyCourtName(name: String): String {\n    51→        // 去掉省市前缀，保留区+法院\n    52→        // \"临沂市河东区人民法院\" -> \"河东区法院\"\n    53→        val cleaned = name.replace(\"】\", \"\").replace(\"【\", \"\")\n    54→        val match = Regex(\"(\\\\S+?[区县市旗])人民法院\").find(cleaned)\n    55→        if (match != null) {\n    56→            val district = match.groupValues[1]\n    57→            // 取最后一个行政区划\n    58→            val parts = Regex(\"[省市州盟]\").split(district)\n    59→            return \"${parts.last()}法院\"\n    60→        }\n    61→        return cleaned.replace(\"人民\", \"\")\n    62→    }\n    63→\n    64→    private fun parseHearingTime(text: String): Long? {\n    65→        for (pattern in datePatterns) {\n    66→            val match = pattern.find(text) ?: continue\n    67→            try {\n    68→                val year = match.groupValues[1].toInt()\n    69→                val month = match.groupValues[2].toInt()\n    70→                val day = match.groupValues[3].toInt()\n    71→                var hour = match.groupValues[4].toInt()\n    72→                val minute = match.groupValues.getOrNull(5)?.takeIf { it.isNotEmpty() }?.toInt() ?: 0\n    73→                // 检查匹配位置前面是否有\"下午/PM\"，需要+12小时\n    74→                val prefix = text.substring(0, match.range.first + match.value.length)\n    75→                if (hour < 12 && pmPattern.containsMatchIn(prefix)) {\n    76→                    hour += 12\n    77→                }\n    78→                val cal = Calendar.getInstance().apply {\n    79→                    set(year, month - 1, day, hour, minute, 0)\n    80→                    set(Calendar.MILLISECOND, 0)\n    81→                }\n    82→                return cal.timeInMillis\n    83→            } catch (_: Exception) { continue }\n    84→        }\n    85→        return null\n    86→    }\n    87→}\n    88→"}]},"uuid":"c5330a87-f010-4a3d-b106-c1c95ef072a5","timestamp":"2026-02-13T15:34:13.206Z","toolUseResult":{"type":"text","file":{"filePath":"C:\\Users\\Administrator\\Desktop\\CourtAssistant\\app\\src\\main\\java\\com\\court\\assistant\\sms\\SmsParser.kt","content":"package com.court.assistant.sms\n\nimport java.text.SimpleDateFormat\nimport java.util.*\n\ndata class ParsedSms(\n    val caseNumber: String?,\n    val courtName: String?,\n    val hearingTime: Long?,\n    val partyNames: String?,\n    val webUrl: String?\n)\n\nclass SmsParser {\n    // 案号: （2024）鲁1312民初1324号\n    private val caseNumberPattern = Regex(\"[（(]\\\\d{4}[）)][^\\\\s，。,\\\\.]+号\")\n    // 法院名称: 【xxx法院】\n    private val courtPattern = Regex(\"【(.+?法院[）】]?)\")\n    // 当事人: 】xxx你好 or 】xxx，你好\n    private val partyPattern = Regex(\"】(\\\\S+?)(?:你好|，你好|,你好)\")\n    // URL\n    private val urlPattern = Regex(\"https?://[^\\\\s<>\\\"]+\")\n    // 开庭时间 - 多种格式\n    private val datePatterns = listOf(\n        // 2024年12月5日 上午9时30分 / 下午2时30分\n        Regex(\"(\\\\d{4})年(\\\\d{1,2})月(\\\\d{1,2})日[\\\\s]*[（(]?(?:上午|下午|AM|PM)?[）)]?[\\\\s]*(\\\\d{1,2})[时点:：](\\\\d{0,2})[分]?\"),\n        Regex(\"(\\\\d{4})-(\\\\d{1,2})-(\\\\d{1,2})[\\\\s]+(\\\\d{1,2}):(\\\\d{2})\"),\n        Regex(\"(\\\\d{4})/(\\\\d{1,2})/(\\\\d{1,2})[\\\\s]+(\\\\d{1,2}):(\\\\d{2})\")\n    )\n    // 用于检测下午时间\n    private val pmPattern = Regex(\"下午|PM\")\n\n    fun parse(body: String): ParsedSms {\n        val caseNumber = caseNumberPattern.find(body)?.value\n        val courtFull = courtPattern.find(body)?.groupValues?.getOrNull(1)\n        val courtName = courtFull?.let { simplifyCourtName(it) }\n        val partyNames = partyPattern.find(body)?.groupValues?.getOrNull(1)\n        val webUrl = urlPattern.find(body)?.value\n        val hearingTime = parseHearingTime(body)\n\n        return ParsedSms(\n            caseNumber = caseNumber,\n            courtName = courtName,\n            hearingTime = hearingTime,\n            partyNames = partyNames,\n            webUrl = webUrl\n        )\n    }\n\n    private fun simplifyCourtName(name: String): String {\n        // 去掉省市前缀，保留区+法院\n        // \"临沂市河东区人民法院\" -> \"河东区法院\"\n        val cleaned = name.replace(\"】\", \"\").replace(\"【\", \"\")\n        val match = Regex(\"(\\\\S+?[区县市旗])人民法院\").find(cleaned)\n        if (match != null) {\n            val district = match.groupValues[1]\n            // 取最后一个行政区划\n            val parts = Regex(\"[省市州盟]\").split(district)\n            return \"${parts.last()}法院\"\n        }\n        return cleaned.replace(\"人民\", \"\")\n    }\n\n    private fun parseHearingTime(text: String): Long? {\n        for (pattern in datePatterns) {\n            val match = pattern.find(text) ?: continue\n            try {\n                val year = match.groupValues[1].toInt()\n                val month = match.groupValues[2].toInt()\n                val day = match.groupValues[3].toInt()\n                var hour = match.groupValues[4].toInt()\n                val minute = match.groupValues.getOrNull(5)?.takeIf { it.isNotEmpty() }?.toInt() ?: 0\n                // 检查匹配位置前面是否有\"下午/PM\"，需要+12小时\n                val prefix = text.substring(0, match.range.first + match.value.length)\n                if (hour < 12 && pmPattern.containsMatchIn(prefix)) {\n                    hour += 12\n                }\n                val cal = Calendar.getInstance().apply {\n                    set(year, month - 1, day, hour, minute, 0)\n                    set(Calendar.MILLISECOND, 0)\n                }\n                return cal.timeInMillis\n        