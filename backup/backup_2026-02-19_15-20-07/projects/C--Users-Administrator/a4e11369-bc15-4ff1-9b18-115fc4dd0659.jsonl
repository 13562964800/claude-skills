{"parentUuid":"1f6427f0-5598-4dee-891e-50953d604bc3","isSidechain":false,"userType":"external","cwd":"C:\\Users\\Administrator","sessionId":"a4e11369-bc15-4ff1-9b18-115fc4dd0659","version":"2.1.41","gitBranch":"HEAD","slug":"buzzing-wobbling-rossum","type":"user","message":{"role":"user","content":[{"tool_use_id":"tooluse_psN2MIMEEGx2KUKK0X1FNX","type":"tool_result","content":"     1→package com.court.assistant.webview\n     2→\n     3→import android.webkit.WebResourceRequest\n     4→import android.webkit.WebView\n     5→import android.webkit.WebViewClient\n     6→\n     7→class CourtWebViewClient(\n     8→    private val onPdfDetected: (url: String) -> Unit,\n     9→    private val onPageLoaded: () -> Unit\n    10→) : WebViewClient() {\n    11→\n    12→    override fun shouldOverrideUrlLoading(view: WebView?, request: WebResourceRequest?): Boolean {\n    13→        val url = request?.url?.toString() ?: return false\n    14→        if (isPdfUrl(url)) {\n    15→            onPdfDetected(url)\n    16→            return true\n    17→        }\n    18→        return false\n    19→    }\n    20→\n    21→    override fun onPageFinished(view: WebView?, url: String?) {\n    22→        super.onPageFinished(view, url)\n    23→        onPageLoaded()\n    24→    }\n    25→\n    26→    private fun isPdfUrl(url: String): Boolean {\n    27→        val lower = url.lowercase()\n    28→        return lower.endsWith(\".pdf\") || lower.contains(\".pdf?\") || lower.contains(\"getpdf\")\n    29→    }\n    30→}\n    31→"}]},"uuid":"b22c707d-985c-4f7c-9100-06db9b5e4c26","timestamp":"2026-02-13T15:33:45.159Z","toolUseResult":{"type":"text","file":{"filePath":"C:\\Users\\Administrator\\Desktop\\CourtAssistant\\app\\src\\main\\java\\com\\court\\assistant\\webview\\CourtWebViewClient.kt","content":"package com.court.assistant.webview\n\nimport android.webkit.WebResourceRequest\nimport android.webkit.WebView\nimport android.webkit.WebViewClient\n\nclass CourtWebViewClient(\n    private val onPdfDetected: (url: String) -> Unit,\n    private val onPageLoaded: () -> Unit\n) : WebViewClient() {\n\n    override fun shouldOverrideUrlLoading(view: WebView?, request: WebResourceRequest?): Boolean {\n        val url = request?.url?.toString() ?: return false\n        if (isPdfUrl(url)) {\n            onPdfDetected(url)\n            return true\n        }\n        return false\n    }\n\n    override fun onPageFinished(view: WebView?, url: String?) {\n        super.onPageFinished(view, url)\n        onPageLoaded()\n    }\n\n    private fun isPdfUrl(url: String): Boolean {\n        val lower = url.lowercase()\n        return lower.endsWith(\".pdf\") || lower.contains(\".pdf?\") || lower.contains(\"getpdf\")\n    }\n}\n","numLines":31,"startLine":1,"totalLines":31}},"sourceToolAssistantUUID":"1f6427f0-5598-4dee-891e-50953d604bc3"}
