       if (defendant != null) append(\"\\n被传唤人: $defendant\")\n    40→            if (handler != null) append(\"\\n承办人: $handler\")\n    41→            if (location != null) append(\"\\n应到处所: $location\")\n    42→            if (phone != null) append(\"\\n电话: $phone\")\n    43→            if (partyNames != null) append(\"\\n当事人: $partyNames\")\n    44→            if (description != null) append(\"\\n$description\")\n    45→        }\n    46→\n    47→        val values = ContentValues().apply {\n    48→            put(CalendarContract.Events.CALENDAR_ID, calendarId)\n    49→            put(CalendarContract.Events.TITLE, title)\n    50→            put(CalendarContract.Events.DESCRIPTION, desc)\n    51→            put(CalendarContract.Events.DTSTART, hearingTime)\n    52→            put(CalendarContract.Events.DTEND, hearingTime + 2 * 3600 * 1000) // 2小时\n    53→            put(CalendarContract.Events.EVENT_TIMEZONE, TimeZone.getDefault().id)\n    54→            put(CalendarContract.Events.HAS_ALARM, 1)\n    55→        }\n    56→\n    57→        val uri = context.contentResolver.insert(CalendarContract.Events.CONTENT_URI, values)\n    58→        val eventId = uri?.let { ContentUris.parseId(it) }\n    59→\n    60→        // 添加提醒：提前1天和1小时\n    61→        if (eventId != null) {\n    62→            addReminder(eventId, 24 * 60) // 1天\n    63→            addReminder(eventId, 60)       // 1小时\n    64→        }\n    65→        return eventId\n    66→    }\n    67→\n    68→    private fun eventExists(caseNumber: String, hearingTime: Long): Boolean {\n    69→        val projection = arrayOf(CalendarContract.Events._ID)\n    70→        val selection = \"${CalendarContract.Events.TITLE} LIKE ? AND ${CalendarContract.Events.DTSTART} = ?\"\n    71→        val args = arrayOf(\"%$caseNumber%\", hearingTime.toString())\n    72→        val cursor = context.contentResolver.query(\n    73→            CalendarContract.Events.CONTENT_URI, projection, selection, args, null\n    74→        )\n    75→        val exists = cursor?.use { it.count > 0 } ?: false\n    76→        return exists\n    77→    }\n    78→\n    79→    private fun getOrCreateCalendarId(): Long? {\n    80→        // 先查找已有日历\n    81→        val projection = arrayOf(CalendarContract.Calendars._ID)\n    82→        val cursor = context.contentResolver.query(\n    83→            CalendarContract.Calendars.CONTENT_URI, projection, null, null, null\n    84→        )\n    85→        cursor?.use {\n    86→            if (it.moveToFirst()) return it.getLong(0)\n    87→        }\n    88→        return null // 使用系统默认日历\n    89→    }\n    90→\n    91→    private fun addReminder(eventId: Long, minutes: Int) {\n    92→        val values = ContentValues().apply {\n    93→            put(CalendarContract.Reminders.EVENT_ID, eventId)\n    94→            put(CalendarContract.Reminders.MINUTES, minutes)\n    95→            put(CalendarContract.Reminders.METHOD, CalendarContract.Reminders.METHOD_ALERT)\n    96→        }\n    97→        context.contentResolver.insert(CalendarContract.Reminders.CONTENT_URI, values)\n    98→    }\n    99→}\n   100→"}]},"uuid":"590f767d-5f4a-4097-a95e-59eb3cc64a56","timestamp":"2026-02-13T15:43:31.128Z","toolUseResult":{"type":"text","file":{"filePath":"C:\\Users\\Administrator\\Desktop\\CourtAssistant\\app\\src\\main\\java\\com\\court\\assistant\\calendar\\CalendarSync.kt","content":"package com.court.assistant.calendar\n\nimport android.content.ContentUris\nimport android.content.ContentValues\nimport android.content.Context\nimport android.provider.CalendarContract\nimport java.util.*\n\nclass CalendarSync(private val context: Context) {\n\n    fun syncHearing(\n        caseNumber: String,\n        courtName: String?,\n        hearingTime: Long,\n        defendant: String?,        // 被传唤人\n        handler: String?,          // 承办人\n        location: String?,         // 应到处所\n        phone: String?,            // 电话\n        partyNames: String? = null,\n        description: String? = null\n    ): Long? {\n        // 去重：检查是否已存在\n        if (eventExists(caseNumber, hearingTime)) return null\n\n        val calendarId = getOrCreateCalendarId() ?: return null\n        val title = buildString {\n            append(\"开庭 \")\n            if (courtName != null) append(\"$courtName \")\n            append(caseNumber)\n        }\n        val desc = buildString {\n            // 格式化显示精确的开庭时间\n            val timeFormat = java.text.SimpleDateFormat(\"yyyy年MM月dd日 HH:mm\", java.util.Locale.CHINA)\n            append(\"⏰ 开庭时间: ${timeFormat.format(java.util.Date(hearingTime))}\\n\")\n\n            // 7个关键信息字段\n            append(\"案号: $caseNumber\")\n            if (courtName != null) append(\"\\n法院: $courtName\")\n            if (defendant != null) append(\"\\n被传唤人: $defendant\")\n            if (handler != null) append(\"\\n承办人: $handler\")\n            if (location != null) append(\"\\n应到处所: $location\")\n            if (phone != null) append(\"\\n电话: $phone\")\n            if (partyNames != null) append(\"\\n当事人: $partyNames\")\n            if (description != null) append(\"\\n$description\")\n        }\n\n        val values = ContentValues().apply {\n            put(CalendarContract.Events.CALENDAR_ID, calendarId)\n            put(CalendarContract.Events.TITLE, title)\n            put(CalendarContract.Events.DESCRIPTION, desc)\n            put(CalendarContract.Events.DTSTART, hearingTime)\n            put(CalendarContract.Events.DTEND, hearingTime + 2 * 3600 * 1000) // 2小时\n            put(CalendarContract.Events.EVENT_TIMEZONE, TimeZone.getDefault().id)\n            put(CalendarContract.Events.HAS_ALARM, 1)\n        }\n\n        val uri = context.contentResolver.insert(CalendarContract.Events.CONTENT_URI, values)\n        val eventId = uri?.let { ContentUris.parseId(it) }\n\n        // 添加提醒：提前1天和1小时\n        if (eventId != null) {\n            addReminder(eventId, 24 * 60) // 1天\n            addReminder(eventId, 60)       // 1小时\n        }\n        return eventId\n    }\n\n    private fun eventExists(caseNumber: String, hearingTime: Long): Boolean {\n        val projection = arrayOf(CalendarContract.Events._ID)\n        val selection = \"${CalendarContract.Events.TITLE} LIKE ? AND ${CalendarContract.Events.DTSTART} = ?\"\n        val args = arrayOf(\"%$caseNumber%\", hearingTime.toString())\n        val cursor = context.contentResolver.query(\n            CalendarContract.Events.CONTENT_URI, projection, selection, args, null\n        )\n        val exists = cursor?.use { it.count > 0 } ?: false\n        return exists\n    }\n\n    private fun getOrCreateCalendarId(): Long? {\n        // 先查找已有日历\n        val projection = arrayOf(CalendarContract.Calendars._ID)\n        val cursor = context.contentResolver.query(\n            CalendarContract.Calendars.CONTENT_URI, projection, null, null, null\n        )\n        cursor?.use {\n            if (it.moveToFirst()) return it.getLong(0)\n        }\n        return null // 使用系统默认日历\n    }\n\n    private fun addReminder(eventId: Long, minutes: Int) {\n        val values = ContentValues().apply {\n            put(CalendarContract.Reminders.EVENT_ID, eventId)\n            put(CalendarContract.Reminders.MINUTES, minutes)\n            put(CalendarContract.Reminders.METHOD, CalendarContract.Reminders.METHOD_ALERT)\n        }\n        context.contentResolver.insert(CalendarContract.Reminders.CONTENT_URI, values)\n    }\n}\n","numLines":100,"startLine":1,"totalLines":100}},"sourceToolAssistantUUID":"6abb767f-9619-44cb-92ac-dd457fc9952f"}
