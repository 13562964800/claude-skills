{"parentUuid":"f9f3a18d-3dc9-4bc8-bf7e-f170c6b56dec","isSidechain":false,"userType":"external","cwd":"C:\\Users\\Administrator","sessionId":"a4e11369-bc15-4ff1-9b18-115fc4dd0659","version":"2.1.41","gitBranch":"HEAD","slug":"buzzing-wobbling-rossum","type":"user","message":{"role":"user","content":[{"tool_use_id":"tooluse_VQHuUOrXpk7NyQ5uQJXfYg","type":"tool_result","content":"     1→package com.court.assistant.sms\n     2→\n     3→import java.text.SimpleDateFormat\n     4→import java.util.*\n     5→\n     6→data class ParsedSms(\n     7→    val caseNumber: String?,\n     8→    val courtName: String?,\n     9→    val hearingTime: Long?,\n    10→    val partyNames: String?,\n    11→    val webUrl: String?\n    12→)\n    13→\n    14→class SmsParser {\n    15→    // 案号: （2024）鲁1312民初1324号\n    16→    private val caseNumberPattern = Regex(\"[（(]\\\\d{4}[）)][^\\\\s，。,\\\\.]+号\")\n    17→    // 法院名称: 【xxx法院】\n    18→    private val courtPattern = Regex(\"【(.+?法院[）】]?)\")\n    19→    // 当事人: 】xxx你好 or 】xxx，你好\n    20→    private val partyPattern = Regex(\"】(\\\\S+?)(?:你好|，你好|,你好)\")\n    21→    // URL\n    22→    private val urlPattern = Regex(\"https?://[^\\\\s<>\\\"]+\")\n    23→    // 开庭时间 - 多种格式\n    24→    private val datePatterns = listOf(\n    25→        Regex(\"(\\\\d{4})年(\\\\d{1,2})月(\\\\d{1,2})日[\\\\s]*(\\\\d{1,2})[时点:：](\\\\d{0,2})\"),\n    26→        Regex(\"(\\\\d{4})-(\\\\d{1,2})-(\\\\d{1,2})\\\\s+(\\\\d{1,2}):(\\\\d{2})\"),\n    27→        Regex(\"(\\\\d{4})/(\\\\d{1,2})/(\\\\d{1,2})\\\\s+(\\\\d{1,2}):(\\\\d{2})\")\n    28→    )\n    29→\n    30→    fun parse(body: String): ParsedSms {\n    31→        val caseNumber = caseNumberPattern.find(body)?.value\n    32→        val courtFull = courtPattern.find(body)?.groupValues?.getOrNull(1)\n    33→        val courtName = courtFull?.let { simplifyCourtName(it) }\n    34→        val partyNames = partyPattern.find(body)?.groupValues?.getOrNull(1)\n    35→        val webUrl = urlPattern.find(body)?.value\n    36→        val hearingTime = parseHearingTime(body)\n    37→\n    38→        return ParsedSms(\n    39→            caseNumber = caseNumber,\n    40→            courtName = courtName,\n    41→            hearingTime = hearingTime,\n    42→            partyNames = partyNames,\n    43→            webUrl = webUrl\n    44→        )\n    45→    }\n    46→\n    47→    private fun simplifyCourtName(name: String): String {\n    48→        // 去掉省市前缀，保留区+法院\n    49→        // \"临沂市河东区人民法院\" -> \"河东区法院\"\n    50→        val cleaned = name.replace(\"】\", \"\").replace(\"【\", \"\")\n    51→        val match = Regex(\"(\\\\S+?[区县市旗])人民法院\").find(cleaned)\n    52→        if (match != null) {\n    53→            val district = match.groupValues[1]\n    54→            // 取最后一个行政区划\n    55→            val parts = Regex(\"[省市州盟]\").split(district)\n    56→            return \"${parts.last()}法院\"\n    57→        }\n    58→        return cleaned.replace(\"人民\", \"\")\n    59→    }\n    60→\n    61→    private fun parseHearingTime(text: String): Long? {\n    62→        for (pattern in datePatterns) {\n    63→            val match = pattern.find(text) ?: continue\n    64→            try {\n    65→                val year = match.groupValues[1].toInt()\n    66→                val month = match.groupValues[2].toInt()\n    67→                val day = match.groupValues[3].toInt()\n    68→                val hour = match.groupValues[4].toInt()\n    69→                val minute = match.groupValues.getOrNull(5)?.takeIf { it.isNotEmpty() }?.toInt() ?: 0\n    70→                val cal = Calendar.getInstance().apply {\n    71→                    set(year, month - 1, day, hour, minute, 0)\n    72→                    set(Calendar.MILLISECOND, 0)\n    73→                }\n    74→                return cal.timeInMillis\n    75→            } catch (_: Exception) { continue }\n    76→        }\n    77→        return null\n    78→    }\n    79→}\n    80→"}]},"uuid":"b8022e9e-4f5c-420b-a439-7785f8f741fe","timestamp":"2026-02-13T15:32:36.509Z","toolUseResult":{"type":"text","file":{"filePath":"C:\\Users\\Administrator\\Desktop\\CourtAssistant\\app\\src\\main\\java\\com\\court\\assistant\\sms\\SmsParser.kt","content":"package com.court.assistant.sms\n\nimport java.text.SimpleDateFormat\nimport java.util.*\n\ndata class ParsedSms(\n    val caseNumber: String?,\n    val courtName: String?,\n    val hearingTime: Long?,\n    val partyNames: String?,\n    val webUrl: String?\n)\n\nclass SmsParser {\n    // 案号: （2024）鲁1312民初1324号\n    private val caseNumberPattern = Regex(\"[（(]\\\\d{4}[）)][^\\\\s，。,\\\\.]+号\")\n    // 法院名称: 【xxx法院】\n    private val courtPattern = Regex(\"【(.+?法院[）】]?)\")\n    // 当事人: 】xxx你好 or 】xxx，你好\n    private val partyPattern = Regex(\"】(\\\\S+?)(?:你好|，你好|,你好)\")\n    // URL\n    private val urlPattern = Regex(\"https?://[^\\\\s<>\\\"]+\")\n    // 开庭时间 - 多种格式\n    private val datePatterns = listOf(\n        Regex(\"(\\\\d{4})年(\\\\d{1,2})月(\\\\d{1,2})日[\\\\s]*(\\\\d{1,2})[时点:：](\\\\d{0,2})\"),\n        Regex(\"(\\\\d{4})-(\\\\d{1,2})-(\\\\d{1,2})\\\\s+(\\\\d{1,2}):(\\\\d{2})\"),\n        Regex(\"(\\\\d{4})/(\\\\d{1,2})/(\\\\d{1,2})\\\\s+(\\\\d{1,2}):(\\\\d{2})\")\n    )\n\n    fun parse(body: String): ParsedSms {\n        val caseNumber = caseNumberPattern.find(body)?.value\n        val courtFull = courtPattern.find(body)?.groupValues?.getOrNull(1)\n        val courtName = courtFull?.let { simplifyCourtName(it) }\n        val partyNames = partyPattern.find(body)?.groupValues?.getOrNull(1)\n        val webUrl = urlPattern.find(body)?.value\n        val hearingTime = parseHearingTime(body)\n\n        return ParsedSms(\n            caseNumber = caseNumber,\n            courtName = courtName,\n            hearingTime = hearingTime,\n            partyNames = partyNames,\n            webUrl = webUrl\n        )\n    }\n\n    private fun simplifyCourtName(name: String): String {\n        // 去掉省市前缀，保留区+法院\n        // \"临沂市河东区人民法院\" -> \"河东区法院\"\n        val cleaned = name.replace(\"】\", \"\").replace(\"【\", \"\")\n        val match = Regex(\"(\\\\S+?[区县市旗])人民法院\").find(cleaned)\n        if (match != null) {\n            val district = match.groupValues[1]\n            // 取最后一个行政区划\n            val parts = Regex(\"[省市州盟]\").split(district)\n            return \"${parts.last()}法院\"\n        }\n        return cleaned.replace(\"人民\", \"\")\n    }\n\n    private fun parseHearingTime(text: String): Long? {\n        for (pattern in datePatterns) {\n            val match = pattern.find(text) ?: continue\n            try {\n                val year = match.groupValues[1].toInt()\n                val month = match.groupValues[2].toInt()\n                val day = match.groupValues[3].toInt()\n                val hour = match.groupValues[4].toInt()\n                val minute = match.groupValues.getOrNull(5)?.takeIf { it.isNotEmpty() }?.toInt() ?: 0\n                val cal = Calendar.getInstance().apply {\n                    set(year, month - 1, day, hour, minute, 0)\n                    set(Calendar.MILLISECOND, 0)\n                }\n                return cal.timeInMillis\n            } catch (_: Exception) { continue }\n        }\n        return null\n    }\n}\n","numLines":80,"startLine":1,"totalLines":80}},"sourceToolAssistantUUID":"f9f3a18d-3dc9-4bc8-bf7e-f170c6b56dec"}
