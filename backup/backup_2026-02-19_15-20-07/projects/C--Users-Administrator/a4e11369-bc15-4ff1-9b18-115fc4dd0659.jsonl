ontext ->\n   126→                    WebView(context).apply {\n   127→                        layoutParams = ViewGroup.LayoutParams(\n   128→                            ViewGroup.LayoutParams.MATCH_PARENT,\n   129→                            ViewGroup.LayoutParams.MATCH_PARENT\n   130→                        )\n   131→                        settings.apply {\n   132→                            javaScriptEnabled = true\n   133→                            domStorageEnabled = true\n   134→                            useWideViewPort = true\n   135→                            loadWithOverviewMode = true\n   136→                            allowFileAccess = true\n   137→                            mixedContentMode = WebSettings.MIXED_CONTENT_ALWAYS_ALLOW\n   138→                            userAgentString = settings.userAgentString.replace(\"wv\", \"\")\n   139→                        }\n   140→\n   141→                        webViewClient = CourtWebViewClient(\n   142→                            onPdfDetected = { pdfUrl ->\n   143→                                val cookies = CookieManager.getInstance().getCookie(pdfUrl)\n   144→                                viewModel.downloadPdf(pdfUrl, smsId, cookies = cookies)\n   145→                            },\n   146→                            onPageLoaded = { loading = false }\n   147→                        )\n   148→\n   149→                        webChromeClient = object : WebChromeClient() {\n   150→                            override fun onProgressChanged(view: WebView?, newProgress: Int) {\n   151→                                if (newProgress >= 100) loading = false\n   152→                            }\n   153→                        }\n   154→\n   155→                        setDownloadListener { downloadUrl, userAgent, contentDisposition, mimetype, contentLength ->\n   156→                            val cookies = CookieManager.getInstance().getCookie(downloadUrl)\n   157→                            // 从 Content-Disposition 提取文件名\n   158→                            val fileName = parseContentDispositionFileName(contentDisposition)\n   159→                            viewModel.downloadPdf(downloadUrl, smsId, fileName, cookies)\n   160→                        }\n   161→\n   162→                        loadUrl(url)\n   163→                    }\n   164→                }\n   165→            )\n   166→        }\n   167→    }\n   168→}\n   169→\n   170→private fun parseContentDispositionFileName(contentDisposition: String?): String? {\n   171→    if (contentDisposition == null) return null\n   172→    Regex(\"\"\"filename\\*=(?:UTF-8''|utf-8'')(.+)\"\"\").find(contentDisposition)?.let {\n   173→        return try { java.net.URLDecoder.decode(it.groupValues[1], \"UTF-8\") } catch (_: Exception) { null }\n   174→    }\n   175→    Regex(\"filename=\\\"?([^\\\"]+)\\\"?\").find(contentDisposition)?.let {\n   176→        return it.groupValues[1].trim()\n   177→    }\n   178→    return null\n   179→}\n   180→"}]},"uuid":"fbbeb2b2-9074-48fa-ac3b-fafb90c6d056","timestamp":"2026-02-13T15:33:45.164Z","toolUseResult":{"type":"text","file":{"filePath":"C:\\Users\\Administrator\\Desktop\\CourtAssistant\\app\\src\\main\\java\\com\\court\\assistant\\ui\\WebViewScreen.kt","content":"package com.court.assistant.ui\n\nimport android.annotation.SuppressLint\nimport android.view.ViewGroup\nimport android.webkit.*\nimport androidx.compose.foundation.background\nimport androidx.compose.foundation.layout.*\nimport androidx.compose.foundation.shape.RoundedCornerShape\nimport androidx.compose.material.icons.Icons\nimport androidx.compose.material.icons.filled.ArrowBack\nimport androidx.compose.material3.*\nimport androidx.compose.runtime.*\nimport androidx.compose.ui.Alignment\nimport androidx.compose.ui.Modifier\nimport androidx.compose.ui.platform.LocalContext\nimport androidx.compose.ui.unit.dp\nimport androidx.compose.ui.viewinterop.AndroidView\nimport com.court.assistant.ui.theme.*\nimport com.court.assistant.viewmodel.MainViewModel\nimport com.court.assistant.webview.CourtWebViewClient\nimport kotlinx.coroutines.launch\n\n@OptIn(ExperimentalMaterial3Api::class)\n@SuppressLint(\"SetJavaScriptEnabled\")\n@Composable\nfun WebViewScreen(\n    viewModel: MainViewModel,\n    smsId: Long,\n    url: String,\n    onBack: () -> Unit\n) {\n    val state by viewModel.uiState.collectAsState()\n    val snackbarHostState = remember { SnackbarHostState() }\n    val scope = rememberCoroutineScope()\n    var loading by remember { mutableStateOf(true) }\n    var showBackDialog by remember { mutableStateOf(false) }\n\n    LaunchedEffect(Unit) {\n        viewModel.resetDownloadCount()\n        viewModel.downloadEvent.collect { msg ->\n            snackbarHostState.showSnackbar(msg, duration = SnackbarDuration.Short)\n        }\n    }\n\n    if (showBackDialog && state.downloadCount > 0) {\n        AlertDialog(\n            onDismissRequest = { showBackDialog = false },\n            title = { Text(\"下载完成\") },\n            text = { Text(\"已下载 ${state.downloadCount} 个文书，确认返回？\") },\n            confirmButton = {\n                TextButton(onClick = {\n                    showBackDialog = false\n                    viewModel.resetDownloadCount()\n                    onBack()\n                }) { Text(\"返回\", color = CinnabarRed) }\n            },\n            dismissButton = {\n                TextButton(onClick = { showBackDialog = false }) { Text(\"继续下载\") }\n            }\n        )\n    }\n\n    Scaffold(\n        snackbarHost = { SnackbarHost(snackbarHostState) },\n        topBar = {\n            TopAppBar(\n                title = { Text(\"文书送达\", style = MaterialTheme.typography.titleLarge) },\n                navigationIcon = {\n                    IconButton(onClick = {\n                        if (state.downloadCount > 0) showBackDialog = true else onBack()\n                    }) {\n                        Icon(Icons.Default.ArrowBack, contentDescription = \"返回\")\n                    }\n                },\n                colors = TopAppBarDefaults.topAppBarColors(\n                    containerColor = Ivory,\n                    titleContentColor = InkBlack\n                )\n            )\n        }\n    ) { padding ->\n        Column(modifier = Modifier.fillMaxSize().padding(padding)) {\n            // 提示条\n            Surface(\n                color = AmberGold.copy(alpha = 0.15f),\n                modifier = Modifier.fillMaxWidth()\n            ) {\n                Row(\n                    modifier = Modifier.padding(horizontal = 16.dp, vertical = 8.dp),\n                    verticalAlignment = Alignment.CenterVertically,\n                    horizontalArrangement = Arrangement.SpaceBetween\n                ) {\n                    Text(\n                        \"请点击文书下载，完成后自动保存\",\n                        style = MaterialTheme.typography.labelLarge,\n                        color = CharcoalGray\n                    )\n                    if (state.downloadCount > 0) {\n                        Surface(\n                            color = JadeGreen,\n                            shape = RoundedCornerShape(12.dp)\n                        ) {\n                            Text(\n                                \" ${state.downloadCount} 已下载 \",\n                                style = MaterialTheme.typography.labelSmall,\n                                color = WarmWhite,\n                                modifier = Modifier.padding(horizontal = 8.dp, vertical = 2.dp)\n                            )\n                        }\n                    }\n                }\n            }\n\n            // Loading indicator\n            if (loading) {\n                LinearProgressIndicator(\n                    modifier = Modifier.fillMaxWidth(),\n                    color = CinnabarRed\n                )\n            }\n\n            // WebView\n            AndroidView(\n                modifier = Modifier.fillMaxSize(),\n                factory = { context ->\n                    WebView(context).apply {\n                        layoutParams = ViewGroup.LayoutParams(\n                            ViewGroup.LayoutParams.MATCH_PARENT,\n                            ViewGroup.LayoutParams.MATCH_PARENT\n                        )\n                        settings.apply {\n                            javaScriptEnabled = true\n                            domStorageEnabled = true\n                            useWideViewPort = true\n                            loadWithOverviewMode = true\n                            allowFileAccess = true\n                            mixedContentMode = WebSettings.MIXED_CONTENT_ALWAYS_ALLOW\n                            userAgentString = settings.userAgentString.replace(\"wv\", \"\")\n                        }\n\n                        webViewClient = CourtWebViewClient(\n                            onPdfDetected = { pdfUrl ->\n                                val cookies = CookieManager.getInstance().getCookie(pdfUrl)\n                                viewModel.downloadPdf(pdfUrl, smsId, cookies = cookies)\n                            },\n                            onPageLoaded = { loading = false }\n                        )\n\n                        webChromeClient = object : WebChromeClient() {\n                            override fun onProgressChanged(view: WebView?, newProgress: Int) {\n                                if (newProgress >= 100) loading = false\n                            }\n                        }\n\n                        setDownloadListener { downloadUrl, userAgent, contentDisposition, mimetype, contentLength ->\n                            val cookies = CookieManager.getInstance().getCookie(downloadUrl)\n                            // 从 Content-Disposition 提取文件名\n                            val fileName = parseContentDispositionFileName(contentDisposition)\n                            viewModel.downloadPdf(downloadUrl, smsId, fileName, cookies)\n                        }\n\n                        loadUrl(url)\n                    }\n                }\n            )\n        }\n    }\n}\n\nprivate fun parseContentDispositionFileName(contentDisposition: String?): String? {\n    if (contentDisposition == null) return null\n    Regex(\"\"\"filename\\*=(?:UTF-8''|utf-8'')(.+)\"\"\").find(contentDisposition)?.let {\n        return try { java.net.URLDecoder.decode(it.groupValues[1], \"UTF-8\") } catch (_: Exception) { null }\n    }\n    Regex(\"filename=\\\"?([^\\\"]+)\\\"?\").find(contentDisposition)?.let {\n        return it.groupValues[1].trim()\n    }\n    return null\n}\n","numLines":180,"startLine":1,"totalLines":180}},"sourceToolAssistantUUID":"67e8135d-270c-44e6-9d8f-800a8b942acc"}
