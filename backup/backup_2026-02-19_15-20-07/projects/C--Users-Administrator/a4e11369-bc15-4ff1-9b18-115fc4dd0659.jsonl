{"parentUuid":"f764386e-38a1-4f24-a479-30287bebb078","isSidechain":false,"userType":"external","cwd":"C:\\Users\\Administrator","sessionId":"a4e11369-bc15-4ff1-9b18-115fc4dd0659","version":"2.1.41","gitBranch":"HEAD","slug":"buzzing-wobbling-rossum","type":"user","message":{"role":"user","content":[{"tool_use_id":"tooluse_qhUTTaQYisAbbN2hPW7RU5","type":"tool_result","content":"     1→package com.court.assistant.viewmodel\n     2→\n     3→import android.app.Application\n     4→import androidx.lifecycle.AndroidViewModel\n     5→import androidx.lifecycle.viewModelScope\n     6→import com.court.assistant.CourtApp\n     7→import com.court.assistant.calendar.CalendarSync\n     8→import com.court.assistant.data.db.CourtSmsEntity\n     9→import com.court.assistant.data.db.PdfDocumentEntity\n    10→import com.court.assistant.pdf.PdfDownloadManager\n    11→import com.court.assistant.pdf.PdfParser\n    12→import com.court.assistant.pdf.DownloadResult\n    13→import com.court.assistant.sms.SmsParser\n    14→import com.court.assistant.sms.SmsReader\n    15→import kotlinx.coroutines.flow.*\n    16→import kotlinx.coroutines.launch\n    17→\n    18→data class SmsWithPdfs(\n    19→    val sms: CourtSmsEntity,\n    20→    val pdfs: List<PdfDocumentEntity>\n    21→)\n    22→\n    23→data class UiState(\n    24→    val smsWithPdfs: List<SmsWithPdfs> = emptyList(),\n    25→    val loading: Boolean = false,\n    26→    val message: String? = null,\n    27→    val downloadCount: Int = 0\n    28→)\n    29→\n    30→class MainViewModel(application: Application) : AndroidViewModel(application) {\n    31→    private val app = application as CourtApp\n    32→    private val repo = app.repository\n    33→    private val smsReader = SmsReader(application)\n    34→    private val smsParser = SmsParser()\n    35→    private val calendarSync = CalendarSync(application)\n    36→    val pdfDownloader = PdfDownloadManager(application)\n    37→    private val pdfParser = PdfParser(application)\n    38→\n    39→    private val _uiState = MutableStateFlow(UiState())\n    40→    val uiState: StateFlow<UiState> = _uiState.asStateFlow()\n    41→\n    42→    private val _downloadEvent = MutableSharedFlow<String>()\n    43→    val downloadEvent: SharedFlow<String> = _downloadEvent.asSharedFlow()\n    44→\n    45→    init {\n    46→        viewModelScope.launch {\n    47→            repo.getAllSms().collect { smsList ->\n    48→                val withPdfs = smsList.map { sms ->\n    49→                    val pdfs = repo.getPdfsBySmsId(sms.id).first()\n    50→                    SmsWithPdfs(sms, pdfs)\n    51→                }\n    52→                _uiState.update { it.copy(smsWithPdfs = withPdfs, loading = false) }\n    53→            }\n    54→        }\n    55→    }\n    56→\n    57→    fun loadSms() {\n    58→        viewModelScope.launch {\n    59→            _uiState.update { it.copy(loading = true) }\n    60→            val rawList = smsReader.readCourtSms()\n    61→            for (raw in rawList) {\n    62→                val hash = raw.body.hashCode()\n    63→                if (repo.smsExists(hash)) continue\n    64→                val parsed = smsParser.parse(raw.body)\n    65→                val entity = CourtSmsEntity(\n    66→                    sender = raw.sender,\n    67→                    body = raw.body,\n    68→                    bodyHash = hash,\n    69→                    receivedAt = raw.date,\n    70→                    caseNumber = parsed.caseNumber,\n    71→                    courtName = parsed.courtName,\n    72→                    hearingTime = parsed.hearingTime,\n    73→                    partyNames = parsed.partyNames,\n    74→                    webUrl = parsed.webUrl\n    75→                )\n    76→                val id = repo.insertSms(entity)\n    77→                if (id > 0 && parsed.hearingTime != null && parsed.caseNumber != null) {\n    78→                    val eventId = calendarSync.syncHearing(\n    79→                        caseNumber = parsed.caseNumber,\n    80→                        courtName = parsed.courtName,\n    81→                        hearingTime = parsed.hearingTime,\n    82→                        defendant = parsed.partyNames, // SMS解析暂无单独的被传唤人字段\n    83→                        handler = null,\n    84→                        location = null,\n    85→                        phone = null,\n    86→                        partyNames = parsed.partyNames\n    87→                    )\n    88→                    if (eventId != null) {\n    89→                        repo.updateSms(entity.copy(id = id, calendarEventId = eventId))\n    90→                    }\n    91→                }\n    92→            }\n    93→            _uiState.update { it.copy(loading = false, message = \"已读取 ${rawList.size} 条法院短信\") }\n    94→        }\n    95→    }\n    96→\n    97→    fun downloadPdf(url: String, smsId: Long, fileName: String? = null, cookies: String? = null) {\n    98→        viewModelScope.launch {\n    99→            val result = pdfDownloader.download(url, fileName, cookies)\n   100→            when (result) {\n   101→                is DownloadResult.Success -> {\n   102→                    val pdf = PdfDocumentEntity(\n   103→                        smsId = smsId,\n   104→                        fileName = result.fileName,\n   105→                        filePath = result.filePath,\n   106→                        fileSize = result.fileSize,\n   107→                        fileMd5 = result.fileMd5,\n   108→                        downloadedAt = System.currentTimeMillis(),\n   109→                        isSubpoena = false\n   110→                    )\n   111→                    val pdfId = repo.insertPdf(pdf)\n   112→                    if (pdfId > 0) {\n   113→                        _uiState.update { it.copy(downloadCount = it.downloadCount + 1) }\n   114→                        _downloadEvent.emit(\"已保存: ${result.fileName}\")\n   115→                        // 所有PDF都尝试解析同步\n   116→                        tryParseAndSync(pdfId, result.filePath, smsId)\n   117→                    } else {\n   118→                        _downloadEvent.emit(\"文件已存在: ${result.fileName}\")\n   119→                    }\n   120→                }\n   121→                is DownloadResult.Error -> {\n   122→                    _downloadEvent.emit(\"下载失败: ${result.message}\")\n   123→                }\n   124→            }\n   125→        }\n   126→    }\n   127→\n   128→    private suspend fun tryParseAndSync(pdfId: Long, filePath: String, smsId: Long) {\n   129→        val info = pdfParser.parseSubpoena(filePath) ?: return\n   130→        val pdf = repo.getPdfById(pdfId) ?: return\n   131→\n   132→        // 判断是否为传票：有开庭时间或文件名/内容含传票关键词\n   133→        val isSubpoena = info.hearingTime != null ||\n   134→            pdf.fileName.contains(\"传票\") ||\n   135→            info.defendant != null\n   136→\n   137→        val hearingDesc = buildString {\n   138→            if (info.courtName != null) append(\"法院: ${info.courtName}\\n\")\n   139→            if (info.defendant != null) append(\"被传唤人: ${info.defendant}\\n\")\n   140→            if (info.handler != null) append(\"承办人: ${info.handler}\\n\")\n   141→            if (info.location != null) append(\"地点: ${info.location}\")\n   142→            if (info.phone != null) append(\"\\n电话: ${info.phone}\")\n   143→        }.takeIf { it.isNotBlank() }\n   144→\n   145→        if (info.hearingTime != null && info.caseNumber != null) {\n   146→            val eventId = calendarSync.syncHearing(\n   147→                caseNumber = info.caseNumber,\n   148→                courtName = info.courtName,\n   149→                hearingTime = info.hearingTime,\n   150→                defendant = info.defendant,\n   151→                handler = info.handler,\n   152→                location = info.location,\n   153→                phone = info.phone\n   154→            )\n   155→            repo.updatePdf(pdf.copy(isSubpoena = isSubpoena, hearingInfo = hearingDesc, calendarEventId = eventId))\n   156→            if (eventId != null) {\n   157→                _downloadEvent.emit(\"📅 已同步到日历\")\n   158→            }\n   159→        } else if (hearingDesc != null || isSubpoena) {\n   160→            repo.updatePdf(pdf.copy(isSubpoena = isSubpoena, hearingInfo = hearingDesc))\n   161→        }\n   162→    }\n   163→\n   164→    fun resetDownloadCount() {\n   165→        _uiState.update { it.copy(downloadCount = 0) }\n   166→    }\n   167→\n   168→    fun clearMessage() {\n   169→        _uiState.update { it.copy(message = null) }\n   170→    }\n   171→\n   172→    /**\n   173→     * 手动同步PDF到日程\n   174→     */\n   175→    fun syncPdfToCalendar(pdfId: Long) {\n   176→        viewModelScope.launch {\n   177→            val pdf = repo.getPdfById(pdfId) ?: return@launch\n   178→            val info = pdfParser.parseSubpoena(pdf.filePath)\n   179→\n   180→            if (info == null) {\n   181→                _uiState.update { it.copy(message = \"无法解析文件内容\") }\n   182→                return@launch\n   183→            }\n   184→\n   185→            if (info.hearingTime == null || info.caseNumber == null) {\n   186→                _uiState.update { it.copy(message = \"未找到开庭时间或案号\") }\n   187→                return@launch\n   188→            }\n   189→\n   190→            val eventId = calendarSync.syncHearing(\n   191→                caseNumber = info.caseNumber,\n   192→                courtName = info.courtName,\n   193→                hearingTime = info.hearingTime,\n   194→                defendant = info.defendant,\n   195→                handler = info.handler,\n   196→                location = info.location,\n   197→                phone = info.phone\n   198→            )\n   199→\n   200→            if (eventId != null) {\n   201→                val hearingDesc = buildString {\n   202→                    if (info.courtName != null) append(\"法院: ${info.courtName}\\n\")\n   203→                    if (info.defendant != null) append(\"被传唤人: ${info.defendant}\\n\")\n   204→                    if (info.handler != null) append(\"承办人: ${info.handler}\\n\")\n   205→                    if (info.location != null) append(\"地点: ${info.location}\")\n   206→                    if (info.phone != null) append(\"\\n电话: ${info.phone}\")\n   207→                }.takeIf { it.isNotBlank() }\n   208→                repo.updatePdf(pdf.copy(isSubpoena = true, hearingInfo = hearingDesc, calendarEventId = eventId))\n   209→                _uiState.update { it.copy(message = \"已添加到日历\") }\n   210→            } else {\n   211→                _uiState.update { it.copy(message = \"日历事件已存在\") }\n   212→            }\n   213→        }\n   214→    }\n   215→}\n   216→"}]},"uuid":"c6fa2418-a6d2-4508-8e5d-1eef4919ccef","timestamp":"2026-02-13T15:32:36.532Z","toolUseResult":{"type":"text","file":{"filePath":"C:\\Users\\Administrator\\Desktop\\CourtAssistant\\app\\src\\main\\java\\com\\court\\assistant\\viewmodel\\MainViewModel.kt","content":"package com.court.assistant.viewmodel\n\nimport android.app.Application\nimport androidx.lifecycle.AndroidViewModel\nimport androidx.lifecycle.viewModelScope\nimport com.court.assistant.CourtApp\nimport com.court.assistant.calendar.CalendarSync\nimport com.court.assistant.data.db.CourtSmsEntity\nimport com.court.assistant.data.db.PdfDocumentEntity\nimport com.court.assistant.pdf.PdfDownloadManager\nimport com.court.assistant.pdf.PdfParser\nimport com.court.assistant.pdf.DownloadResult\nimport com.court.assistant.sms.SmsParser\nimport com.court.assistant.sms.SmsReader\nimport kotlinx.coroutines.flow.*\nimport kotlinx.coroutines.launch\n\ndata class SmsWithPdfs(\n    val sms: CourtSmsEntity,\n    val pdfs: List<PdfDocumentEntity>\n)\n\ndata class UiState(\n    val smsWithPdfs: List<SmsWithPdfs> = emptyList(),\n    val loading: Boolean = false,\n    val message: String? = null,\n    val downloadCount: Int = 0\n)\n\nclass MainViewModel(application: Application) : AndroidViewModel(application) {\n    private val app = application as CourtApp\n    private val repo = app.repository\n    private val smsReader = SmsReader(application)\n    private val smsParser = SmsParser()\n    private val calendarSync = CalendarSync(application)\n    val pdfDownloader = PdfDownloadManager(application)\n    private val pdfParser = PdfParser(application)\n\n    private val _uiState = MutableStateFlow(UiState())\n    val uiState: StateFlow<UiState> = _uiState.asStateFlow()\n\n    private val _downloadEvent = MutableSharedFlow<String>()\n    val downloadEvent: SharedFlow<String> = _downloadEvent.asSharedFlow()\n\n    init {\n        viewModelScope.launch {\n            repo.getAllSms().collect { smsList ->\n                val withPdfs = smsList.map { sms ->\n                    val pdfs = repo.getPdfsBySmsId(sms.id).first()\n                    SmsWithPdfs(sms, pdfs)\n                }\n                _uiState.update { it.copy(smsWithPdfs = withPdfs, loading = false) }\n            }\n        }\n    }\n\n    fun loadSms() {\n        viewModelScope.launch {\n            _uiState.update { it.copy(loading = true) }\n            val rawList = smsReader.readCourtSms()\n            for (raw in rawList) {\n                val hash = raw.body.hashCode()\n                if (repo.smsExists(hash)) continue\n                val parsed = smsParser.parse(raw.body)\n                val entity = CourtSmsEntity(\n                    sender = raw.sender,\n                    body = raw.body,\n                    bodyHash = hash,\n                    receivedAt = raw.date,\n                    caseNumber = parsed.caseNumber,\n                    courtName = parsed.courtName,\n                    hearingTime = parsed.hearingTime,\n                    partyNames = parsed.partyNames,\n                    webUrl = parsed.webUrl\n                )\n                val id = repo.insertSms(entity)\n                if (id > 0 && parsed.hearingTime != null && parsed.caseNumber != null) {\n                    val eventId = calendarSync.syncHearing(\n                        caseNumber = parsed.caseNumber,\n                        courtName = parsed.courtName,\n                        hearingTime = parsed.hearingTime,\n                        defendant = parsed.partyNames, // SMS解析暂无单独的被传唤人字段\n                        handler = null,\n                        location = null,\n                        phone = null,\n                        partyNames = parsed.partyNames\n                    )\n                    if (eventId != null) {\n                        repo.updateSms(entity.copy(id = id, calendarEventId = eventId))\n                    }\n                }\n            }\n            _uiState.update { it.copy(loading = false, message = \"已读取 ${rawList.size} 条法院短信\") }\n        }\n    }\n\n    fun downloadPdf(url: String, smsId: Long, fileName: String? = null, cookies: String? = null) {\n        viewModelScope.launch {\n            val result = pdfDownloader.download(url, fileName, cookies)\n            when (result) {\n                is DownloadResult.Success -> {\n                    val pdf = PdfDocumentEntity(\n                        smsId = smsId,\n                        fileName = result.fileName,\n                        filePath = result.filePath,\n                        fileSize = result.fileSize,\n                        fileMd5 = result.fileMd5,\n                        downloadedAt = System.currentTimeMillis(),\n                        isSubpoena = false\n                    )\n                    val pdfId = repo.insertPdf(pdf)\n                    if (pdfId > 0) {\n                        _uiState.update { it.copy(downloadCount = it.downloadCount + 1) }\n                        _downloadEvent.emit(\"已保存: ${result.fileName}\")\n                        // 所有PDF都尝试解析同步\n                        tryParseAndSync(pdfId, result.filePath, smsId)\n                    } else {\n                        _downloadEvent.emit(\"文件已存在: ${result.fileName}\")\n                    }\n                }\n                is DownloadResult.Error -> {\n                    _downloadEvent.emit(\"下载失败: ${result.message}\")\n                }\n            }\n        }\n    }\n\n    private suspend fun tryParseAndSync(pdfId: Long, filePath: String, smsId: Long) {\n        val info = pdfParser.parseSubpoena(filePath) ?: return\n        val pdf = repo.getPdfById(pdfId) ?: return\n\n        // 判断是否为传票：有开庭时间或文件名/内容含传票关键词\n        val isSubpoena = info.hearingTime != null ||\n            pdf.fileName.contains(\"传票\") ||\n            info.defendant != null\n\n        val hearingDesc = buildString {\n            if (info.courtName != null) append(\"法院: ${info.courtName}\\n\")\n            if (info.defendant != null) append(\"被传唤人: ${info.defendant}\\n\")\n            if (info.handler != null) append(\"承办人: ${info.handler}\\n\")\n            if (info.location != null) append(\"地点: ${info.location}\")\n            if (info.phone != null) append(\"\\n电话: ${info.phone}\")\n        }.takeIf { it.isNotBlank() }\n\n        if (info.hearingTime != null && info.caseNumber != null) {\n            val eventId = calendarSync.syncHearing(\n                caseNumber = info.caseNumber,\n                courtName = info.courtName,\n                hearingTime = info.hearingTime,\n                defendant = info.defendant,\n                handler = info.handler,\n                location = info.location,\n                phone = info.phone\n            )\n            repo.updatePdf(pdf.copy(isSubpoena = isSubpoena, hearingInfo = hearingDesc, calendarEventId = eventId))\n            if (eventId != null) {\n                _downloadEvent.emit(\"📅 已同步到日历\")\n            }\n        } else if (hearingDesc != null || isSubpoena) {\n            repo.updatePdf(pdf.copy(isSubpoena = isSubpoena, hearingInfo = hearingDesc))\n        }\n    }\n\n    fun resetDownloadCount() {\n        _uiState.update { it.copy(downloadCount = 0) }\n    }\n\n    fun clearMessage() {\n        _uiState.update { it.copy(message = null) }\n    }\n\n    /**\n     * 手动同步PDF到日程\n     */\n    fun syncPdfToCalendar(pdfId: Long) {\n        viewModelScope.launch {\n            val pdf = repo.getPdfById(pdfId) ?: return@launch\n            val info = pdfParser.parseSubpoena(pdf.filePath)\n\n            if (info == null) {\n                _uiState.update { it.copy(message = \"无法解析文件内容\") }\n                return@launch\n            }\n\n            if (info.hearingTime == null || info.caseNumber == null) {\n                _uiState.update { it.copy(message = \"未找到开庭时间或案号\") }\n                return@launch\n            }\n\n            val eventId = calendarSync.syncHearing(\n                caseNumber = info.caseNumber,\n                courtName = info.courtName,\n                hearingTime = info.hearingTime,\n                defendant = info.defendant,\n                handler = info.handler,\n                location = info.location,\n                phone = info.phone\n            )\n\n            if (eventId != null) {\n                val hearingDesc = buildString {\n                    if (info.courtName != null) append(\"法院: ${info.courtName}\\n\")\n                    if (info.defendant != null) append(\"被传唤人: ${info.defendant}\\n\")\n                    if (info.handler != null) append(\"承办人: ${info.handler}\\n\")\n                    if (info.location != null) append(\"地点: ${info.location}\")\n                    if (info.phone != null) append(\"\\n电话: ${info.phone}\")\n                }.takeIf { it.isNotBlank() }\n                repo.updatePdf(pdf.copy(isSubpoena = true, hearingInfo = hearingDesc, calendarEventId = eventId))\n                _uiState.update { it.copy(message = \"已添加到日历\") }\n            } else {\n                _uiState.update { it.copy(message = \"日历事件已存在\") }\n            }\n        }\n    }\n}\n","numLines":216,"startLine":1,"totalLines":216}},"sourceToolAssistantUUID":"f764386e-38a1-4f24-a479-30287bebb078"}
