{"parentUuid":"9fd596a0-33ff-4994-9789-6cde7f1f6a1c","isSidechain":true,"userType":"external","cwd":"C:\\Users\\Administrator","sessionId":"adaecc18-afba-49ab-8b68-922e84059f57","version":"2.1.44","gitBranch":"HEAD","agentId":"acfce99","slug":"cosmic-floating-bird","type":"user","message":{"role":"user","content":[{"tool_use_id":"tooluse_CBauVtwv2XSmY2NE8ZEWiQ","type":"tool_result","content":"     1→import os, time, html\n     2→\n     3→def _fmt(seconds):\n     4→    if seconds is None: return ''\n     5→    m, s = divmod(int(seconds), 60)\n     6→    return f'{m}:{s:02d}'\n     7→\n     8→def generate_html_report(diffs, summary, audio_text, doc_text, audio_path=None, output_dir=None):\n     9→    if output_dir is None:\n    10→        output_dir = os.path.join(os.path.expanduser('~'), 'Desktop')\n    11→\n    12→    doc_paragraphs = [p.strip() for p in doc_text.split('\\n') if p.strip()]\n    13→\n    14→    # Build annotated paragraphs\n    15→    diff_by_pos = {}\n    16→    for d in diffs:\n    17→        diff_by_pos.setdefault(d.get('position', 0), []).append(d)\n    18→\n    19→    annotated = []\n    20→    for idx, para in enumerate(doc_paragraphs):\n    21→        if idx not in diff_by_pos:\n    22→            annotated.append(html.escape(para))\n    23→            continue\n    24→\n    25→        para_diffs = diff_by_pos[idx]\n    26→        located = []\n    27→        used = set()\n    28→        for d in para_diffs:\n    29→            dt = d.get('docText', '')\n    30→            if d.get('type') == 'extra_in_audio' or not dt:\n    31→                located.append((len(para), len(para), d))\n    32→                continue\n    33→            start = 0\n    34→            while True:\n    35→                pos = para.find(dt, start)\n    36→                if pos == -1:\n    37→                    located.append((len(para), len(para), d))\n    38→                    break\n    39→                if pos not in used:\n    40→                    used.add(pos)\n    41→                    located.append((pos, pos + len(dt), d))\n    42→                    break\n    43→                start = pos + 1\n    44→        located.sort(key=lambda x: x[0])\n    45→\n    46→        parts = []\n    47→        cursor = 0\n    48→        for start, end, d in located:\n    49→            dtype = d.get('type', 'mismatch')\n    50→            at = html.escape(d.get('audioText', ''))\n    51→            ts = _fmt(d.get('time_start'))\n    52→            uncertain = ' uncertain' if d.get('uncertain') else ''\n    53→            ts_attr = f' data-time=\"{d[\"time_start\"]}\"' if d.get('time_start') is not None else ''\n    54→            ts_label = f' <span class=\"ts\">@{ts}</span>' if ts else ''\n    55→\n    56→            if start > cursor:\n    57→                parts.append(html.escape(para[cursor:start]))\n    58→\n    59→            if dtype == 'mismatch':\n    60→                parts.append(f'<span class=\"diff mismatch{uncertain}\"{ts_attr}>{html.escape(para[start:end])}'\n    61→                             f'<span class=\"note\">[误读为:\"{at}\"{ts_label}]</span></span>')\n    62→            elif dtype == 'missing_in_audio':\n    63→                parts.append(f'<span class=\"diff missing{uncertain}\"{ts_attr}>{html.escape(para[start:end])}'\n    64→                             f'<span class=\"note\">[漏读{ts_label}]</span></span>')\n    65→            elif dtype == 'extra_in_audio':\n    66→                parts.append(f'<span class=\"diff extra{uncertain}\"{ts_attr}>'\n    67→                             f'<span class=\"note\">[多读:\"{at}\"{ts_label}]</span></span>')\n    68→            cursor = end\n    69→\n    70→        if cursor < len(para):\n    71→            parts.append(html.escape(para[cursor:]))\n    72→        annotated.append(''.join(parts))\n    73→\n    74→    audio_tag = ''\n    75→    if audio_path and os.path.exists(audio_path):\n    76→        audio_tag = f'<audio id=\"player\" controls src=\"file:///{audio_path.replace(os.sep, \"/\")}\"></audio>'\n    77→\n    78→    body = '\\n'.join(f'<p>{a}</p>' for a in annotated)\n    79→    summary_html = html.escape(summary).replace('\\n', '<br>')\n    80→\n    81→    content = f'''<!DOCTYPE html>\n    82→<html lang=\"zh\"><head><meta charset=\"utf-8\"><title>配音对比报告</title>\n    83→<style>\n    84→body {{ font-family: \"Microsoft YaHei\", sans-serif; max-width: 900px; margin: 40px auto; padding: 0 20px; line-height: 1.8; }}\n    85→.summary {{ background: #f5f5f5; padding: 16px; border-radius: 8px; margin-bottom: 24px; font-size: 15px; }}\n    86→.diff {{ position: relative; cursor: pointer; }}\n    87→.mismatch {{ color: #d32f2f; font-weight: bold; text-decoration: underline; }}\n    88→.missing {{ color: #d32f2f; font-weight: bold; text-decoration: line-through; }}\n    89→.extra {{ color: #e65100; }}\n    90→.uncertain {{ opacity: 0.6; font-style: italic; }}\n    91→.note {{ font-size: 12px; font-weight: bold; color: #d32f2f; }}\n    92→.ts {{ color: #1565c0; font-size: 11px; }}\n    93→p {{ margin: 8px 0; font-size: 16px; }}\n    94→audio {{ width: 100%; margin-bottom: 16px; }}\n    95→.legend {{ display: flex; gap: 20px; margin-bottom: 16px; font-size: 13px; }}\n    96→.legend span {{ padding: 2px 8px; border-radius: 4px; }}\n    97→</style></head><body>\n    98→<h2>配音质量核查报告</h2>\n    99→<div class=\"summary\">{summary_html}</div>\n   100→<div class=\"legend\">\n   101→<span class=\"mismatch\">误读</span>\n   102→<span class=\"missing\">漏读</span>\n   103→<span style=\"color:#e65100\">多读</span>\n   104→</div>\n   105→{audio_tag}\n   106→<div id=\"content\">{body}</div>\n   107→<script>\n   108→document.querySelectorAll('.diff[data-time]').forEach(el => {{\n   109→  el.addEventListener('click', () => {{\n   110→    const player = document.getElementById('player');\n   111→    if (player) {{ player.currentTime = parseFloat(el.dataset.time); player.play(); }}\n   112→  }});\n   113→}});\n   114→</script>\n   115→</body></html>'''\n   116→\n   117→    ts = time.strftime('%Y%m%d_%H%M%S')\n   118→    path = os.path.join(output_dir, f'对比报告_{ts}.html')\n   119→    with open(path, 'w', encoding='utf-8') as f:\n   120→        f.write(content)\n   121→    return path\n   122→"}]},"uuid":"5f538557-49a1-4f11-9dcb-e5423109b064","timestamp":"2026-02-17T09:41:12.562Z","sourceToolAssistantUUID":"9fd596a0-33ff-4994-9789-6cde7f1f6a1c"}
