            LLMProvider.KIMI to listOf("moonshot-v1-8k", "moonshot-v1-32k", "moonshot-v1-128k"),
            LLMProvider.QWEN to listOf("qwen-turbo", "qwen-plus", "qwen-max"),
            LLMProvider.DEEPSEEK to listOf("deepseek-chat", "deepseek-coder"),
