# -*- coding: utf-8 -*-
"""快速启动打包脚本 - onedir模式（启动快，无需解压）"""
import os
import subprocess
import shutil

APP_NAME = "配音文字核对宝完整版"
VERSION = "1.0.1"

# 清理旧文件
for d in ["dist", "build", "setup_output_onedir"]:
    if os.path.exists(d):
        try:
            shutil.rmtree(d)
        except:
            pass

# 安装依赖
print("正在检查依赖...")
subprocess.run(["python", "-m", "pip", "install", "-q",
    "jieba", "python-docx", "requests", "jiwer", "pypinyin",
    "opencc-python-reimplemented", "pyinstaller",
    "torch", "torchaudio", "stable-ts", "pydub"], check=True)

# onedir 打包 - 启动快！
print(f"正在打包 {APP_NAME}（onedir 模式，启动快）...")
subprocess.run([
    "python", "-m", "PyInstaller",
    "--onedir",
    "--windowed",
    "--name", APP_NAME,
    "--hidden-import", "jieba",
    "--hidden-import", "jieba.posseg",
    "--hidden-import", "docx",
    "--hidden-import", "requests",
    "--hidden-import", "jiwer",
    "--hidden-import", "pypinyin",
    "--hidden-import", "pypinyin.style",
    "--hidden-import", "opencc",
    "--hidden-import", "torch",
    "--hidden-import", "torchaudio",
    "--hidden-import", "stable_whisper",
    "--hidden-import", "whisper",
    "--hidden-import", "pydub",
    "--hidden-import", "pydub.silence",
    "--hidden-import", "numpy",
    "--upx-exclude", "avif*",
    "main.py",
    "config.py",
    "compare.py",
    "transcribe.py",
    "docx_util.py",
    "html_report.py"
], check=True)

print("\n打包完成!")
print(f"程序文件夹: dist/{APP_NAME}/")
