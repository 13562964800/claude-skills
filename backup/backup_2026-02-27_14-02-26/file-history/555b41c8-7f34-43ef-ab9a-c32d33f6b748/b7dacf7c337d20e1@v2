    }

    /**
     * 构建去重键
     *
     * 优先级策略：
     * 1. 案号+时间（最高优先级）
     * 2. 时间+法院+当事人
     * 3. sourceId+时间（最低优先级）
     *
     * @param info 开庭信息
     * @param sourceId 源记录ID
     * @return 去重键字符串
     */
    private fun buildDedupKey(info: HearingInfo, sourceId: Long): String {
        // 优先用案号+时间去重（短信和PDF来源共享同一key）
        if (info.caseNo.isNotEmpty()) {
            return "${info.caseNo}_${info.hearingTime}"
        }

        // 无案号时用时间+法院+当事人去重
        if (info.hearingTime > 0 && (info.courtName.isNotEmpty() || info.partyName.isNotEmpty())) {
            return "${info.hearingTime}_${info.courtName}_${info.partyName}"
        }

        // 最后用sourceId+时间去重
        return "${sourceId}_${info.hearingTime}"
    }

    /**
     * 构建日历事件标题
     *
     * 格式：[法院简称] 开庭 [当事人简称]
     * 或：[法院简称] 开庭 [案号]
     *
     * @param info 开庭信息
     * @return 事件标题
     */
    private fun buildTitle(info: HearingInfo): String {
        val parts = mutableListOf<String>()

        // 添加法院简称
        if (info.courtName.isNotEmpty()) {
            parts.add(shortenCourtName(info.courtName))
        }

        parts.add("开庭")

        // 添加当事人或案号
        if (info.partyName.isNotEmpty()) {
            parts.add(shortenPartyName(info.partyName))
        } else if (info.caseNo.isNotEmpty()) {
            parts.add(info.caseNo)
        }

        return parts.joinToString(" ")
    }

    /**
     * 构建日历事件描述
     *
     * 包含：案号、法院、当事人、地点、承办人、传票文件、短信原文
     *
     * @param info 开庭信息
     * @param smsBody 短信原文
     * @param pdfFilePath PDF文件路径
     * @return 事件描述
     */
    private fun buildDescription(
        info: HearingInfo,
        smsBody: String,
        pdfFilePath: String
    ): String {
        val sb = StringBuilder()

        if (info.caseNo.isNotEmpty()) sb.appendLine("案号：${info.caseNo}")
        if (info.courtName.isNotEmpty()) sb.appendLine("法院：${info.courtName}")
        if (info.partyName.isNotEmpty()) sb.appendLine("当事人：${info.partyName}")
        if (info.location.isNotEmpty()) sb.appendLine("地点：${info.location}")
        if (info.judge.isNotEmpty()) sb.appendLine("承办人：${info.judge}")
        if (pdfFilePath.isNotEmpty()) sb.appendLine("\n传票文件：$pdfFilePath")
        if (smsBody.isNotEmpty()) sb.appendLine("\n短信原文：$smsBody")

        return sb.toString().trim()
    }

    /**
     * 简化法院名称
     *
     * 规则：
     * - 最高人民法院 → 最高法院
     * - XX省高级人民法院 → XX高院
     * - XX市中级人民法院 → XX中院
     * - XX区/县人民法院 → XX法院
     * - XX人民法庭 → XX法庭
     * - XX仲裁委员会 → XX仲裁委
     *
     * @param name 完整法院名称
     * @return 简化后的名称
     */
    fun shortenCourtName(name: String): String {
        // 最高人民法院
        if (name.contains("最高人民法院")) return "最高法院"

        // XX省高级人民法院 → XX高院
        val highMatch = Regex("(\\S{2,3}?)省?高级人民法院").find(name)
        if (highMatch != null) return "${highMatch.groupValues[1]}高院"

        // XX市中级人民法院 → XX中院
        val midMatch = Regex("(\\S{2,4}?)(?:市|自治州)?中级人民法院").find(name)
        if (midMatch != null) return "${midMatch.groupValues[1]}中院"

        // XX区/县人民法院 → XX法院
        val baseMatch = Regex("(\\S{2,4}?)(?:区|县|市)?人民法院").find(name)
        if (baseMatch != null) return "${baseMatch.groupValues[1]}法院"

        // XX人民法庭 → XX法庭
        val courtMatch = Regex("(\\S{2,4}?)人民法庭").find(name)
        if (courtMatch != null) return "${courtMatch.groupValues[1]}法庭"

        // XX仲裁委员会 → XX仲裁委
        val arbMatch = Regex("(\\S{2,6}?)仲裁委员会").find(name)
        if (arbMatch != null) return "${arbMatch.groupValues[1]}仲裁委"

        return name
    }

    /**
     * 简化当事人名称
     *
     * 规则：
     * - 6字以内不缩
     * - 个人名字（无公司/有限/集团）8字以内不缩
     * - 其他情况取前4字+...
     *
     * @param name 完整当事人名称
     * @return 简化后的名称
     */
    fun shortenPartyName(name: String): String {
        if (name.length <= 6) return name

        // 个人名字一般2-4字，不缩
        if (!name.contains("公司") && !name.contains("有限") &&
            !name.contains("集团") && name.length <= 8) {
            return name
        }

        return name.take(4) + "..."
    }

    /**
     * 检查同步记录是否有效（未过期）
     *
     * @param syncedAt 同步时间戳
     * @return true表示未过期，false表示已过期
     */
    fun isValidRecord(syncedAt: Long): Boolean {
        val currentTime = System.currentTimeMillis()
        val recordAge = currentTime - syncedAt
        return recordAge <= EXPIRY_MILLIS
    }

    /**
     * 获取过期时间阈值（当前时间 - 7天）
     *
     * @return 过期阈值时间戳
     */
    fun getExpiryThreshold(): Long {
        return System.currentTimeMillis() - EXPIRY_MILLIS
    }

    /**
     * 获取过期天数配置
     *
     * @return 过期天数
     */
    fun getExpiryDays(): Int = EXPIRY_DAYS
}

/**
 * 开庭信息数据类
 */
data class HearingInfo(
    val caseNo: String = "",      // 案号
    val courtName: String = "",     // 法院名称
    val partyName: String = "",     // 当事人名称
    val hearingTime: Long = 0,     // 开庭时间
    val location: String = "",       // 开庭地点
    val judge: String = ""          // 承办人/法官
)
