package com.shanfuchun.courtassistant.service

import android.content.ContentValues
import android.content.Context
import android.provider.CalendarContract
import com.shanfuchun.courtassistant.data.CalendarSyncRecord
import com.shanfuchun.courtassistant.data.AppDatabase

/**
 * Calendar Helper - 系统日历操作工具类
 *
 * 提供以下功能：
 * - 创建日历事件
 * - 同步开庭信息到日历
 * - 去重检查
 * - 过期记录清理（7天有效期）
 */
object CalendarHelper {

    // 过期时间：7天（毫秒）
    private const val EXPIRY_DAYS = 7
    private const val EXPIRY_MILLIS = EXPIRY_DAYS * 24 * 60 * 60 * 1000L

    /**
     * 创建日历事件
     *
     * @param context 应用上下文
     * @param title 事件标题
     * @param startTime 事件开始时间（时间戳）
     * @param description 事件描述
     * @param location 事件地点
     * @param reminderMinutes 提醒时间列表（分钟），默认提前60分钟和1440分钟（1天）
     * @return 创建成功返回事件ID，失败返回-1
     */
    fun createEvent(
        context: Context,
        title: String,
        startTime: Long,
        description: String = "",
        location: String = "",
        reminderMinutes: List<Int> = listOf(60, 1440)
    ): Long {
        // 获取默认日历ID
        val calId = getDefaultCalendarId(context) ?: return -1

        // 构建事件内容
        val values = ContentValues().apply {
            put(CalendarContract.Events.CALENDAR_ID, calId)
            put(CalendarContract.Events.TITLE, title)
            put(CalendarContract.Events.DTSTART, startTime)
            put(CalendarContract.Events.DTEND, startTime + 3600_000) // 默认1小时
            put(CalendarContract.Events.DESCRIPTION, description)
            put(CalendarContract.Events.EVENT_LOCATION, location)
            put(CalendarContract.Events.EVENT_TIMEZONE, java.util.TimeZone.getDefault().id)
        }

        // 插入事件
        val uri = context.contentResolver.insert(CalendarContract.Events.CONTENT_URI, values)
            ?: return -1
        val eventId = uri.lastPathSegment?.toLongOrNull() ?: return -1

        // 添加提醒
        for (min in reminderMinutes) {
            val rv = ContentValues().apply {
                put(CalendarContract.Reminders.EVENT_ID, eventId)
                put(CalendarContract.Reminders.MINUTES, min)
                put(CalendarContract.Reminders.METHOD, CalendarContract.Reminders.METHOD_ALERT)
            }
            context.contentResolver.insert(CalendarContract.Reminders.CONTENT_URI, rv)
        }

        return eventId
    }

    /**
     * 获取默认日历ID
     *
     * @param context 应用上下文
     * @return 返回第一个可见日历的ID，没有返回null
     */
    private fun getDefaultCalendarId(context: Context): Long? {
        val cursor = context.contentResolver.query(
            CalendarContract.Calendars.CONTENT_URI,
            arrayOf(CalendarContract.Calendars._ID),
            "${CalendarContract.Calendars.VISIBLE} = 1",
            null,
            "${CalendarContract.Calendars._ID} ASC"
        )
        cursor?.use { if (it.moveToFirst()) return it.getLong(0) }
        return null
    }

    /**
     * 同步开庭信息到日历
     *
     * @param context 应用上下文
     * @param db 数据库实例
     * @param info 开庭信息
     * @param sourceId 源记录ID（短信ID或文档ID）
     * @param sourceType 源类型（"sms" 或 "document"）
     * @param smsBody 短信原文（可选，用于描述）
     * @param pdfFilePath PDF文件路径（可选，用于描述）
     * @return 同步成功返回true，失败或已存在返回false
     */
    suspend fun syncHearing(
        context: Context,
        db: AppDatabase,
        info: HearingInfo,
        sourceId: Long,
        sourceType: String,
        smsBody: String = "",
        pdfFilePath: String = ""
    ): Boolean {
        // 验证开庭时间
        if (info.hearingTime <= 0) return false

        // 生成去重键
        val dedupKey = buildDedupKey(info, sourceId)

        // 检查是否已同步（含过期检查）
        val existing = findValidSyncRecord(db, dedupKey)
        if (existing != null) {
            // 记录存在且未过期，跳过同步
            return false
        }

        // 清理该去重键的过期记录（如果有）
        cleanExpiredRecordsByKey(db, dedupKey)

        // 构建事件信息
        val title = buildTitle(info)
        val desc = buildDescription(info, smsBody, pdfFilePath)

        // 创建日历事件
        val eventId = createEvent(
            context = context,
            title = title,
            startTime = info.hearingTime,
            description = desc,
            location = info.location
        )

        if (eventId < 0) return false

        // 保存同步记录
        db.calendarSyncDao().insert(
            CalendarSyncRecord(
                sourceId = sourceId,
                sourceType = sourceType,
                eventId = eventId,
                syncStatus = 1, // 1=已同步
                dedupKey = dedupKey,
                syncedAt = System.currentTimeMillis()
            )
        )

        return true
    }

    /**
     * 查找有效的同步记录（未过期）
     *
     * @param db 数据库实例
     * @param dedupKey 去重键
     * @return 有效记录存在返回记录，否则返回null
     */
    private suspend fun findValidSyncRecord(
        db: AppDatabase,
        dedupKey: String
    ): CalendarSyncRecord? {
        val record = db.calendarSyncDao().findByDedupKey(dedupKey) ?: return null

        // 检查是否过期
        val currentTime = System.currentTimeMillis()
        val recordAge = currentTime - record.syncedAt

        return if (recordAge <= EXPIRY_MILLIS) {
            // 记录未过期，返回有效记录
            record
        } else {
            // 记录已过期
            null
        }
    }

    /**
     * 清理指定去重键的过期记录
     *
     * @param db 数据库实例
     * @param dedupKey 去重键
     */
    private suspend fun cleanExpiredRecordsByKey(
        db: AppDatabase,
        dedupKey: String
    ) {
        val record = db.calendarSyncDao().findByDedupKey(dedupKey) ?: return

        val currentTime = System.currentTimeMillis()
        val recordAge = currentTime - record.syncedAt

        if (recordAge > EXPIRY_MILLIS) {
            // 记录已过期，删除同步记录和日历事件
            deleteCalendarEventById(record.eventId)
            db.calendarSyncDao().delete(record)
        }
    }

    /**
     * 清理所有过期的同步记录
     *
     * @param context 应用上下文
     * @param db 数据库实例
     * @return 清理的记录数量
     */
    suspend fun cleanAllExpiredRecords(
        context: Context,
        db: AppDatabase
    ): Int {
        val currentTime = System.currentTimeMillis()
        val expiryThreshold = currentTime - EXPIRY_MILLIS

        // 获取所有同步记录
        val allRecords = db.calendarSyncDao().getAllSync()
        var cleanedCount = 0

        for (record in allRecords) {
            if (record.syncedAt < expiryThreshold) {
                // 记录已过期
                deleteCalendarEventById(record.eventId)
                db.calendarSyncDao().delete(record)
                cleanedCount++
            }
        }

        return cleanedCount
    }

    /**
     * 删除指定的日历事件
     *
     * @param eventId 事件ID
     */
    private fun deleteCalendarEventById(eventId: Long) {
