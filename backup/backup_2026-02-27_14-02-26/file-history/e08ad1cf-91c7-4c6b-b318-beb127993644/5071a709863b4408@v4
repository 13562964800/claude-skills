import re

# 常见法律停用短语
_STOP_PHRASES = {
    "根据", "依照", "本院认为", "经审理查明", "判决如下", "裁定如下",
    "事实和理由", "诉讼请求", "如不服本判决", "上诉于", "审判长", "审判员",
    "书记员", "人民法院", "民事判决书", "民事裁定书", "行政判决书",
    "请求", "赔偿", "损失", "支付", "返还", "确认", "撤销", "驳回",
    "民事起诉状", "民事答辩状", "起诉状", "答辩状",
}

# 百家姓前100
_SURNAMES = (
    "赵钱孙李周吴郑王冯陈褚卫蒋沈韩杨朱秦尤许何吕施张孔曹严华金魏陶姜"
    "戚谢邹喻柏水窦章云苏潘葛奚范彭郎鲁韦昌马苗凤花方俞任袁柳酆鲍史唐"
    "费廉岑薛雷贺倪汤滕殷罗毕郝邬安常乐于时傅皮卞齐康伍余元卜顾孟平黄"
    "和穆萧尹姚邵湛汪祁毛禹狄米贝明臧计伏成戴谈宋茅庞熊纪舒屈项祝董梁"
    "杜阮蓝闵席季麻强贾路娄危江童颜郭梅盛林刁钟徐邱骆高夏蔡田樊胡凌霍"
    "虞万支柯昝管卢莫经房裘缪干解应宗丁宣贲邓郁单杭洪包诸左石崔吉钮龚"
)
_SURNAME_SET = set(_SURNAMES) | {"欧阳", "司马", "上官", "诸葛", "司徒", "令狐", "皇甫"}

# 全部诉讼参与人角色关键词
_ROLES = (
    "原告", "被告", "第三人",
    "上诉人", "被上诉人",
    "申请人", "被申请人",
    "申请执行人", "被执行人",
    "再审申请人", "再审被申请人",
    "抗诉申请人",
    "答辩人", "被答辩人",
    "异议人", "被异议人",
    "反诉原告", "反诉被告",
    "原审原告", "原审被告", "原审第三人",
    "委托诉讼代理人", "委托代理人", "诉讼代理人",
    "法定代理人", "指定代理人",
    "法定代表人", "负责人",
)

# 正则模式
_ID_CARD = re.compile(r'[1-9]\d{5}(?:19|20)\d{2}(?:0[1-9]|1[0-2])(?:0[1-9]|[12]\d|3[01])\d{3}[\dXx]')
_PHONE = re.compile(r'(?<!\d)1[3-9]\d{9}(?!\d)')
_LANDLINE = re.compile(r'(?<!\d)0\d{2,3}-?\d{7,8}(?!\d)')

# 角色+名称提取：支持角色后跟括号说明、冒号、空格等
_ROLE_PAT = re.compile(
    r'(' + '|'.join(re.escape(r) for r in sorted(_ROLES, key=len, reverse=True)) + r')'
    r'(?:[（(]([^）)]{1,30})[）)])?'  # 可选括号内容（如"原审被告"）
    r'[：:\s]*'
    r'([^\s，。；：！？、,.:;!?\n]{2,30})?'  # 名称
)

_COMPANY = re.compile(r'[\u4e00-\u9fff]{2,20}(?:有限公司|股份有限公司|集团|公司|事务所|合伙企业)')
_ADDRESS = re.compile(r'(?:住所地|地址|住址|住)[：:\s]*([^\s，。；！？\n]{4,50})')
_POSTAL = re.compile(r'[1-9]\d{5}(?!\d)')

# 当事人信息块：角色开头，后续跟多行属性直到下一个角色或空行
_PARTY_BLOCK = re.compile(
    r'(' + '|'.join(re.escape(r) for r in sorted(_ROLES, key=len, reverse=True)) + r')'
    r'(?:[（(][^）)]*[）)])?'
    r'[：:\s]*'
    r'([\s\S]*?)(?='
    r'(?:' + '|'.join(re.escape(r) for r in sorted(_ROLES, key=len, reverse=True)) + r')'
    r'|事实和理由|诉讼请求|审理查明|本院认为|\Z)'
)

# 内置键值对字段名
_KV_KEYS = (
    "姓名", "性别", "民族", "出生日期", "出生年月", "年龄", "职业", "工作单位",
    "联系电话", "电话", "手机", "电话号码", "手机号码", "手机号",
    "身份证号", "身份证号码", "公民身份号码", "身份证",
    "律师事务所", "统一社会信用代码", "企业信用代码", "社会信用代码", "信用代码",
    "法定代表人", "负责人", "执行董事",
    "住所地", "地址", "住址", "联系地址", "住所", "住",
    "邮政编码", "邮编", "案号", "合同编号", "职务", "电子邮箱", "名称",
    "公司名称", "企业名称", "单位名称", "组织机构代码",
)

# 用于过滤的集合：冒号前面的键名不应作为字段提取
_KV_KEY_SET = set(_KV_KEYS) | set(_ROLES)


class LegalFieldExtractor:
    def extract_fields(self, text, custom_keys=None):
        if not text:
            return []
        fields = []

        # 截取当事人区域（诉讼请求/事实和理由之前）
        party_end = re.search(r'诉讼请求|事实和理由|审理查明|本院认为', text)
        party_text = text[:party_end.start()] if party_end else text

        # 1. 当事人信息块提取（优先，覆盖文档首部的角色段落）
        for m in _PARTY_BLOCK.finditer(party_text):
            block = m.group(2).strip()
            if block:
                self._extract_from_block(block, fields)

        # 2. 键值对提取（内置 + 自定义字段名），在当事人区域内
        all_keys = list(_KV_KEYS) + (custom_keys or [])
        if all_keys:
            kv_pat = re.compile(
                r'(' + '|'.join(re.escape(k) for k in all_keys) + r')'
                r'[：:=\s]\s*'
                r'([^\s，。；！？\n：:]{1,50})'
            )
            for m in kv_pat.finditer(party_text):
                fields.append(m.group(2).strip())

        # 3. 结构化提取（全文）
        for m in _ID_CARD.finditer(party_text):
            fields.append(m.group())
        for m in _PHONE.finditer(party_text):
            fields.append(m.group())
        for m in _LANDLINE.finditer(party_text):
            fields.append(m.group())
        for m in _ROLE_PAT.finditer(party_text):
            if m.group(2):
                fields.append(m.group(2).strip())
            if m.group(3):
                name = m.group(3).strip()
                if name and name not in _STOP_PHRASES:
                    fields.append(name)
        for m in _COMPANY.finditer(party_text):
            fields.append(m.group())
        for m in _ADDRESS.finditer(party_text):
            fields.append(m.group(1).strip())

        # 4. 标点分界提取（当事人区域内，跳过键名）
        segments = re.split(r'[，。；：！？、,.:;!?\n\r\t]+', party_text)
        for seg in segments:
            seg = seg.strip()
            if 2 <= len(seg) <= 30 and self._is_likely_field(seg) and seg not in _KV_KEY_SET:
                fields.append(seg)

        return self._deduplicate(fields)

    def _extract_from_block(self, block, fields):
        """从当事人信息块中提取所有字段值"""
        lines = [l.strip() for l in re.split(r'[，。\n\r]+', block) if l.strip()]
        for line in lines:
            # 键值对格式
            kv = re.match(r'(.+?)[：:=]\s*(.+)', line)
            if kv:
                fields.append(kv.group(2).strip())
            elif 1 <= len(line) <= 40 and line not in _KV_KEY_SET:
                fields.append(line)
        # 从整个块中提取身份证、电话等
        for m in _ID_CARD.finditer(block):
            fields.append(m.group())
        for m in _PHONE.finditer(block):
            fields.append(m.group())
        for m in _COMPANY.finditer(block):
            fields.append(m.group())

    def _is_likely_field(self, seg):
        if seg in _STOP_PHRASES:
            return False
        if not re.search(r'[\u4e00-\u9fff]', seg):
            return False
        # 排除含动词/叙述性短语
        if re.search(r'请求|赔偿|支付|返还|确认|撤销|驳回|判决|裁定|依据|根据|认为|查明|约定|违反|承担|损失', seg):
            return False
        if re.search(r'\d{3,}', seg):
            return True
        if seg[0] in _SURNAME_SET and 2 <= len(seg) <= 4:
            return True
        if seg[:2] in _SURNAME_SET and 3 <= len(seg) <= 5:
            return True
        if re.search(r'[省市区县镇村路街道号楼室]', seg):
            return True
        if re.search(r'原告|被告|代理人|律师|法院|法官|上诉|申请|执行|答辩|异议|第三人|抗诉|再审', seg):
            return True
        return False

    def _deduplicate(self, fields):
        seen = set()
        result = []
        for f in fields:
            f = f.strip()
            if f and len(f) <= 40 and f not in seen:
                seen.add(f)
                result.append(f)
        return result
