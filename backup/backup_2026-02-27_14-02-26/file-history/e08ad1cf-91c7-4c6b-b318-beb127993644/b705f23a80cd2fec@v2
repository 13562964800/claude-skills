/* 宋代美学配色
   宣纸: #F5F0E8   木色: #8B4513   青瓷: #5B7F5B
   暖金: #C4956A   墨色: #3C2415   纸边: #D4C5A9
*/

QMainWindow, QDialog {
    background-color: #F5F0E8;
}

QLabel {
    color: #3C2415;
    font-family: "SimSun", "宋体", serif;
    font-size: 13px;
}

QPushButton {
    background-color: #C4956A;
    color: #3C2415;
    border: 1px solid #8B4513;
    border-radius: 5px;
    padding: 8px 16px;
    font-family: "SimSun", "宋体", serif;
    font-size: 13px;
    min-height: 28px;
}

QPushButton:hover {
    background-color: #D4A574;
    border-color: #6B3410;
}

QPushButton:pressed {
    background-color: #A07850;
}

QPushButton#fillButton {
    background-color: #5B7F5B;
    color: #FFF8EE;
    font-size: 20px;
    font-weight: bold;
    font-family: "KaiTi", "楷体", serif;
    min-width: 80px;
    min-height: 55px;
    border-radius: 8px;
    border: 2px solid #3D5C3D;
}

QPushButton#fillButton:hover {
    background-color: #6B9F6B;
}

QPushButton#importBtn {
    background-color: #8B6F5B;
    color: #FFF8EE;
    font-size: 12px;
    padding: 6px 12px;
    min-height: 24px;
}

QPushButton#importBtn:hover {
    background-color: #A0836D;
}

QPushButton#clearBtn {
    background-color: #B85C5C;
    color: #FFF8EE;
}

QPushButton#clearBtn:hover {
    background-color: #D06B6B;
}

QPushButton#favBtn {
    background-color: #6B7F9F;
    color: #FFF8EE;
}

QPushButton#favBtn:hover {
    background-color: #7B8FAF;
}

QPushButton#smallBtn {
    font-size: 11px;
    padding: 3px 8px;
    min-height: 20px;
    background-color: #D4C5A9;
    color: #3C2415;
}

QPushButton#smallBtn:hover {
    background-color: #E0D4B8;
}

QLabel#fieldDisplay {
    font-family: "KaiTi", "楷体", "SimSun", serif;
    font-size: 28px;
    color: #3C2415;
    background-color: #FFF8EE;
    border: 2px solid #D4C5A9;
    border-radius: 8px;
    padding: 15px;
    qproperty-alignment: AlignCenter;
}

QLabel#copyright {
    font-size: 11px;
    color: #8B7355;
    font-family: "SimSun", serif;
    padding: 5px;
}

QLabel#sectionTitle {
    font-size: 14px;
    font-weight: bold;
    color: #5B7F5B;
    font-family: "KaiTi", "楷体", serif;
    padding: 4px 0;
}

QScrollArea {
    border: 1px solid #D4C5A9;
    background-color: #FFFDF5;
    border-radius: 4px;
}

QWidget#fieldItem {
    background-color: #FFFDF5;
    border-bottom: 1px solid #E8DCC8;
    padding: 4px;
}

QWidget#fieldItem:hover {
    background-color: #F0E8D8;
}

QLineEdit {
    border: 1px solid #D4C5A9;
    border-radius: 4px;
    padding: 5px;
    background-color: #FFF8EE;
    font-family: "SimSun", serif;
    font-size: 13px;
    color: #3C2415;
}

QLineEdit:focus {
    border-color: #5B7F5B;
}

QComboBox {
    border: 1px solid #D4C5A9;
    border-radius: 4px;
    padding: 5px;
    background-color: #FFF8EE;
    font-family: "SimSun", serif;
    color: #3C2415;
}

QMessageBox {
    background-color: #F5F0E8;
}

QWidget#dropZone {
    border: 2px dashed #C4956A;
    border-radius: 8px;
    background-color: #FFF8EE;
    min-height: 40px;
}

QTabWidget::pane {
    border: 1px solid #D4C5A9;
    background-color: #F5F0E8;
}

QTabBar::tab {
    background-color: #D4C5A9;
    color: #3C2415;
    padding: 8px 16px;
    font-family: "SimSun", serif;
    border: 1px solid #8B4513;
    border-bottom: none;
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
}

QTabBar::tab:selected {
    background-color: #F5F0E8;
}

QPushButton#testBtn {
    background-color: #5B7F5B;
    color: #FFF8EE;
    font-size: 12px;
    padding: 6px 12px;
}

QPushButton#testBtn:hover {
    background-color: #6B9F6B;
}

QPushButton#settingsBtn {
    background-color: #8B7355;
    color: #FFF8EE;
}

QPushButton#settingsBtn:hover {
    background-color: #9B8365;
}

QListWidget {
    border: 1px solid #D4C5A9;
    background-color: #FFFDF5;
    border-radius: 4px;
    font-family: "SimSun", serif;
    font-size: 13px;
    color: #3C2415;
}

QListWidget::item:selected {
    background-color: #D4C5A9;
    color: #3C2415;
}

QCheckBox {
    font-family: "SimSun", serif;
    color: #3C2415;
    font-size: 13px;
}
