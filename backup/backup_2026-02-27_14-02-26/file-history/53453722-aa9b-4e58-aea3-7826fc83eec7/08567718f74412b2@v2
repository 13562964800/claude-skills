@echo off
chcp 65001 >nul
echo ========================================
echo    高性能图片处理器 - 一键启动
echo ========================================
echo.
echo [1/3] 正在启动后端服务...
start "图片处理器-后端" /MIN cmd /c "cd /d "%~dp0backend" && python app.py"
timeout /t 3 /nobreak >nul

echo [2/3] 等待服务就绪...
timeout /t 2 /nobreak >nul

echo [3/3] 正在打开前端界面...
start "" "%~dp0frontend\image-editor.html"

echo.
echo ========================================
echo    ✓ 启动完成！
echo ========================================
echo.
echo 后端服务: http://localhost:5000
echo 前端界面: 已在浏览器中打开
echo.
echo 如需停止服务，请关闭"图片处理器-后端"窗口
echo ========================================
echo.
timeout /t 5
