<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="200dp"
    android:height="200dp"
    android:viewportWidth="200"
    android:viewportHeight="200">

    <!-- 文档图标 -->
    <group
        android:translateX="50"
        android:translateY="30">

        <!-- 纸张叠层效果 -->
        <rect
            android:fillColor="@color/bg_paper"
            android:strokeColor="@color/dai_cyan"
            android:strokeWidth="6"
            android:x="70"
            android:y="20"
            android:width="85"
            android:height="110" />

        <rect
            android:fillColor="@color/bg_paper"
            android:strokeColor="@color/dai_cyan"
            android:strokeWidth="6"
            android:x="50"
            android:y="40"
            android:width="85"
            android:height="110" />

        <rect
            android:fillColor="@color/bg_paper"
            android:strokeColor="@color/dai_cyan"
            android:strokeWidth="6"
            android:x="30"
            android:y="60"
            android:width="85"
            android:height="110" />

        <!-- PDF 标签 -->
        <rect
            android:fillColor="@color/dai_cyan"
            android:x="60"
            android:y="80"
            android:width="30"
            android:height="20" />

        <!-- 文字线条 -->
        <path
            android:strokeColor="@color/ink_light"
            android:strokeWidth="4"
            android:strokeLineCap="round"
            android:pathData="M40,100 L100,100 M40,115 L90,115 M50,130 L95,130" />

        <!-- 下载箭头 -->
        <path
            android:fillColor="@color/dai_cyan"
            android:pathData="M120,50 L140,70 L135,70 L135,75 L145,60 L140,60 L140,80 L120,60 Z" />
    </group>

</vector>
