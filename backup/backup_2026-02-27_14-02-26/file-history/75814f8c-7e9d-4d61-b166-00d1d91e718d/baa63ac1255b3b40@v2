    /**
     * 测试短信去重 - 完全相同
     */
    @Test
    public void testIsDuplicateSms_Identical() {
        CourtMessage existingMsg = new CourtMessage();
        existingMsg.setContent("测试短信内容");
        existingMsg.setReceiveTime(1710465000000L);

        CourtMessage newMsg = new CourtMessage();
        newMsg.setContent("测试短信内容");
        newMsg.setReceiveTime(1710465001000L); // 相差1秒

        List<CourtMessage> existingList = new ArrayList<>();
        existingList.add(existingMsg);

        boolean isDuplicate = DeduplicationHelper.isDuplicateSms(newMsg, existingList);
        assertTrue("内容和时间相同应判定为重复", isDuplicate);
    }

