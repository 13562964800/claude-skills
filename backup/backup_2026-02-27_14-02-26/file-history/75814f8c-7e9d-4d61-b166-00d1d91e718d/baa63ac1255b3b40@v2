    /**
     * 测试批量去重
     */
    @Test
    public void testDeduplicateList() {
        List<CourtMessage> messages = new ArrayList<>();

        CourtMessage msg1 = new CourtMessage();
        msg1.setContent("消息1");
        msg1.setReceiveTime(1710465000000L);
        messages.add(msg1);

        CourtMessage msg2 = new CourtMessage();
        msg2.setContent("消息1"); // 重复
        msg2.setReceiveTime(1710465001000L);
        messages.add(msg2);

        CourtMessage msg3 = new CourtMessage();
        msg3.setContent("消息3");
        msg3.setReceiveTime(1710465100000L);
        messages.add(msg3);

        CourtMessage msg4 = new CourtMessage();
        msg4.setContent("消息1"); // 重复
        msg4.setReceiveTime(1710465002000L);
        messages.add(msg4);

        List<CourtMessage> unique = DeduplicationHelper.deduplicateList(messages, new DeduplicationHelper.DeduplicateComparator<CourtMessage>() {
            @Override
            public boolean isDuplicate(CourtMessage item1, CourtMessage item2) {
                return DeduplicationHelper.isDuplicateSms(item1, java.util.Arrays.asList(item2));
            }
        });

        assertEquals("应去重后剩余2条", 2, unique.size());
        assertEquals("第一条应保留", "消息1", unique.get(0).getContent());
        assertEquals("第三条应保留", "消息3", unique.get(1).getContent());
    }

    /**
     * 测试边界情况
     */
    @Test
    public void testEdgeCases() {
        // null 输入
        CourtMessage nullMsg = DeduplicationHelper.parseAndValidateSms(null, "10690000");
        assertNotNull("null短信应返回消息对象", nullMsg);

        // 空字符串
        CourtMessage emptyMsg = DeduplicationHelper.parseAndValidateSms("", "10690000");
        assertNotNull("空短信应返回消息对象", emptyMsg);

        // 空格内容
        CourtMessage spacesMsg = DeduplicationHelper.parseAndValidateSms("   ", "10690000");
        assertNotNull("纯空格短信应返回消息对象", spacesMsg);

        // 超长内容
        StringBuilder longContent = new StringBuilder();
        for (int i = 0; i < 10000; i++) {
            longContent.append("测");
        }
        CourtMessage longMsg = DeduplicationHelper.parseAndValidateSms(longContent.toString(), "10690000");
        assertNotNull("超长短信应能处理", longMsg);
    }
