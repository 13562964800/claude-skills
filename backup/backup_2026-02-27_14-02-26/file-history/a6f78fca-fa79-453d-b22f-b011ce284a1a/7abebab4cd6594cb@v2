package com.multilanglearner.data.network

import android.content.Context
import android.util.Log
import com.arthenica.ffmpegkit.FFmpegKit
import com.arthenica.ffmpegkit.FFmpegKitConfig
import com.arthenica.ffmpegkit.FFprobeKit
import com.arthenica.ffmpegkit.MediaInformationSession
import com.multilanglearner.domain.model.AIConfig
import com.multilanglearner.domain.model.WordTimestamp
import dagger.hilt.android.qualifiers.ApplicationContext
import kotlinx.coroutines.Dispatchers
import kotlinx.coroutines.delay
import kotlinx.coroutines.withContext
import java.io.File
import javax.inject.Inject
import javax.inject.Singleton

/**
 * FFmpeg 分段转录服务 - 使用 FFmpeg Kit 处理大视频文件
 * 参考 GitHub 项目：
 * - WritingMinds/ffmpeg-kit: Android FFmpeg 支持
 * - gvk7/Whisper-Ffmpeg-Multi-Segment: 多段 Whisper 转录
 * - wendy7756/AI-Video-Transcriber: 20分钟分段策略
 */
@Singleton
class FFmpegSegmentedTranscriptionService @Inject constructor(
    @ApplicationContext private val context: Context,
    private val whisperService: WhisperService
) {
    companion object {
        private const val TAG = "FFmpegSegmentTrans"
        // Groq API 文件大小限制
        private const val MAX_API_FILE_SIZE = 100 * 1024 * 1024L // 100MB
        // 分段时长（秒）- 参考 AI-Video-Transcriber 项目的 20 分钟策略
        private const val SEGMENT_DURATION = 600L // 10分钟，保守估计
        // 段间重叠时间（秒）
        private const val OVERLAP_DURATION = 5L
        // 临时文件目录
        private const val TEMP_DIR = "transcription_temp"
    }

    /**
     * 分段转录视频
     * @param videoFile 视频文件
     * @param config AI配置
     * @param onProgress 进度回调
     */
    suspend fun transcribeWithSegments(
        videoFile: File,
        config: AIConfig,
        onProgress: (Int, Int, Int, String) -> Unit = { _, _, _, _ -> }
    ): WhisperResult? = withContext(Dispatchers.IO) {
        try {
            val fileSize = videoFile.length()
            val fileSizeMB = String.format("%.2f", fileSize / 1024.0 / 1024.0)

            Log.d(TAG, "Starting segmented transcription: ${videoFile.name}, $fileSizeMB MB")
            onProgress(0, 1, 5, "获取视频信息...")

            // 获取视频时长和详细信息
            val mediaInfo = getMediaInformation(videoFile)
            val duration = mediaInfo?.getDuration()?.toLong()?.let { it / 1000.0 } // 转换为秒

            if (duration == null) {
                Log.e(TAG, "Failed to get video duration")
                return@withContext WhisperResult(
                    success = false,
                    error = "Cannot read video duration. Please ensure the video file is valid."
                )
            }

            val durationMinutes = String.format("%.1f", duration / 60.0)
            Log.d(TAG, "Video duration: $durationMinutes minutes ($duration seconds)")

            // 判断处理策略
            return@withContext when {
                fileSize <= MAX_API_FILE_SIZE -> {
                    // 文件在限制内，直接转录
                    Log.d(TAG, "File within API limit, direct transcription")
                    onProgress(1, 1, 10, "Direct transcription...")
                    whisperService.transcribeGroq(videoFile, config)
                }
                else -> {
                    // 需要分段处理
                    transcribeSegmentedInternal(videoFile, config, duration, onProgress)
                }
            }

        } catch (e: Exception) {
            Log.e(TAG, "Transcription error", e)
            WhisperResult(
                success = false,
                error = "Transcription failed: ${e.message}"
            )
        }
    }

    /**
     * 内部分段转录实现
     */
    private suspend fun transcribeSegmentedInternal(
        videoFile: File,
        config: AIConfig,
        duration: Double,
        onProgress: (Int, Int, Int, String) -> Unit
    ): WhisperResult? {
        // 计算分段数量
        val segments = calculateSegments(duration)
        val totalSegments = segments.size

        Log.d(TAG, "Will process in $totalSegments segments")
        onProgress(0, totalSegments, 10, "Preparing $totalSegments segments...")

        // 创建临时目录
        val tempDir = File(context.cacheDir, "$TEMP_DIR${System.currentTimeMillis()}")
        tempDir.mkdirs()

        return try {
            val allWords = mutableListOf<WordTimestamp>()

            segments.forEachIndexed { index, segment ->
                val segmentFile = File(tempDir, "segment_${index}.m4a")

                onProgress(index + 1, totalSegments, ((index + 1) * 80 / totalSegments) + 10,
                    "Extracting segment ${index + 1}/$totalSegments...")

                // 提取音频段
                val extractSuccess = extractAudioSegment(videoFile, segmentFile, segment.startTime, segment.duration)

                if (!extractSuccess || !segmentFile.exists()) {
                    Log.e(TAG, "Failed to extract segment $index")
                    onProgress(index + 1, totalSegments, ((index + 1) * 80 / totalSegments) + 10,
                        "Segment $index extraction failed")
                    return@forEachIndexed
                }

                onProgress(index + 1, totalSegments, ((index + 1) * 80 / totalSegments) + 10,
                    "Transcribing segment ${index + 1}/$totalSegments...")

                // 转录该段
                val result = whisperService.transcribeGroq(segmentFile, config)

                if (result?.success == true) {
                    // 调整时间戳
                    val adjustedWords = result.words.map { wt ->
                        wt.copy(s = wt.s + segment.startTime, e = wt.e + segment.startTime)
                    }

                    // 去除重叠部分
                    if (index > 0) {
                        val overlapThreshold = segment.startTime - OVERLAP_DURATION.toDouble()
                        val filteredWords = adjustedWords.filter { it.s >= overlapThreshold }
                        allWords.addAll(filteredWords)
                    } else {
                        allWords.addAll(adjustedWords)
                    }

                    Log.d(TAG, "Segment $index transcribed: ${result.words.size} words")

                    // 删除临时段文件
                    segmentFile.delete()
                } else {
                    Log.e(TAG, "Segment $index transcription failed: ${result?.error}")
                }
            }

            // 清理临时目录
            tempDir.deleteRecursively()

            if (allWords.isEmpty()) {
                WhisperResult(
                    success = false,
                    error = "All segments failed to transcribe. Please check your network connection and API key."
                )
            } else {
                // 构建完整文本
                val sentences = buildSentences(allWords)
                val fullText = sentences.joinToString(" ")

                onProgress(totalSegments, totalSegments, 100, "Transcription complete!")

                Log.d(TAG, "Segmented transcription complete: ${allWords.size} words, ${sentences.size} sentences")

                WhisperResult(
                    success = true,
                    text = fullText,
                    words = allWords,
                    detectedLang = ""
                )
            }
        } catch (e: Exception) {
            tempDir.deleteRecursively()
            Log.e(TAG, "Segmented transcription error", e)
            WhisperResult(
                success = false,
                error = "Segmented transcription failed: ${e.message}"
            )
        }
    }

    /**
     * 计算分段策略
     */
    private fun calculateSegments(duration: Double): List<AudioSegment> {
        val segments = mutableListOf<AudioSegment>()
        var currentTime = 0.0
        var index = 0
        val segmentDurationSec = SEGMENT_DURATION.toDouble() // 转换为 Double
        val overlapDurationSec = OVERLAP_DURATION.toDouble() // 转换为 Double

        while (currentTime < duration) {
            val segmentDuration = minOf(segmentDurationSec, duration - currentTime)
            segments.add(AudioSegment(index, currentTime, segmentDuration))
            currentTime += segmentDuration - overlapDurationSec // 重叠
            index++
        }

        return segments
    }

    /**
     * 提取音频段
     */
    private suspend fun extractAudioSegment(
        inputFile: File,
        outputFile: File,
        startTime: Double,
        duration: Double
    ): Boolean = withContext(Dispatchers.IO) {
        try {
            val command = arrayOf(
                "-hide_banner",
                "-y",
                "-ss", startTime.toString(),
                "-i", inputFile.absolutePath,
                "-t", duration.toString(),
                "-vn", // 不包含视频
                "-acodec", "aac",
                "-b:a", "64k", // 低比特率以减小文件大小
                "-ac", "1", // 单声道
                outputFile.absolutePath
            )

            Log.d(TAG, "FFmpeg command: ffmpeg ${command.joinToString(" ")}")

            val session = FFmpegKit.executeAsync(command.joinToString(" ")) { session ->
                val state = session.state
                val returnCode = session.returnCode

                Log.d(TAG, "FFmpeg state: $state, return code: $returnCode")
            }

            // 等待完成
            while (session.state.name == "RUNNING") {
                delay(100)
            }

            val returnCode = session.returnCode
            val success = returnCode?.value == 0 && outputFile.exists() && outputFile.length() > 1024

            Log.d(TAG, "Segment extraction result: $success, file size: ${outputFile.length()}")
            success

        } catch (e: Exception) {
            Log.e(TAG, "Error extracting segment", e)
            false
        }
    }

    /**
     * 获取视频信息
     */
    private fun getMediaInformation(file: File): com.arthenica.ffmpegkit.MediaInformation? {
        return try {
            val session: MediaInformationSession = FFprobeKit.getMediaInformation(file.absolutePath)
            if (session.returnCode?.value == 0) {
                session.mediaInformation
            } else {
                Log.e(TAG, "FFprobe failed: ${session.output}")
                null
            }
        } catch (e: Exception) {
            Log.e(TAG, "Error getting media info", e)
            null
        }
    }

    /**
     * 从单词构建句子
     */
    private fun buildSentences(words: List<WordTimestamp>): List<String> {
        val sentences = mutableListOf<String>()
        val currentSentence = mutableListOf<String>()

        words.forEach { wt ->
            currentSentence.add(wt.w)

            // 检查句子结束
            if (wt.w.trim().matches(Regex(".*[.!?。！？]$"))) {
                sentences.add(currentSentence.joinToString(" "))
                currentSentence.clear()
            }
        }

        // 添加最后一个未完成的句子
        if (currentSentence.isNotEmpty()) {
            sentences.add(currentSentence.joinToString(" "))
        }

        return sentences
    }
}

/**
 * 音频分段数据类
 */
data class AudioSegment(
    val index: Int,
    val startTime: Double,  // 段开始时间（秒）
    val duration: Double     // 段持续时间（秒）
)
