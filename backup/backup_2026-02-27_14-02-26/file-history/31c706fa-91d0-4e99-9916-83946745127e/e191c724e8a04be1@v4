<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8F0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 标题栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="配音文字核对宝"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#333" />

            <Button
                android:id="@+id/btnSettings"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="配置"
                android:textSize="14sp"
                android:backgroundTint="#1976D2" />
        </LinearLayout>

        <!-- 微信导入提示 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="从微信导入：长按文件 → 分享 → 选择本应用。本界面自动打开Download目录，请按时间排列选择最新文件。"
            android:textSize="13sp"
            android:textColor="#4CAF50"
            android:background="#E8F5E9"
            android:padding="12dp"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- 模型配置区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#E3F2FD"
            android:padding="12dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="语音识别引擎"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1565C0"
                android:paddingBottom="8dp" />

            <!-- ASR 引擎选择 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="选择引擎："
                android:textSize="13sp"
                android:textColor="#555"
                android:paddingBottom="4dp" />

            <Spinner
                android:id="@+id/spinnerAsrEngine"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="#FFF"
                android:paddingStart="8dp"
                android:paddingEnd="8dp" />

            <!-- 模型状态 -->
            <TextView
                android:id="@+id/tvModelStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="模型状态：检查中..."
                android:textSize="12sp"
                android:textColor="#555"
                android:paddingTop="8dp"
                android:paddingBottom="8dp" />

            <!-- 测试按钮 -->
            <Button
                android:id="@+id/btnTestModel"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="测试连通性"
                android:textSize="14sp"
                android:backgroundTint="#1976D2" />

        </LinearLayout>

        <!-- 选择录音 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">
            <Button
                android:id="@+id/btnPickAudio"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="选择录音"
                android:backgroundTint="#2196F3" />
            <TextView
                android:id="@+id/tvAudioName"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="未选择"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:textColor="#666"
                android:singleLine="true"
                android:ellipsize="middle" />
        </LinearLayout>

        <!-- 选择文档 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">
            <Button
                android:id="@+id/btnPickDoc"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="选择文档"
                android:backgroundTint="#2196F3" />
            <TextView
                android:id="@+id/tvDocName"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="未选择"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:textColor="#666"
                android:singleLine="true"
                android:ellipsize="middle" />
        </LinearLayout>

        <!-- 开始对比 -->
        <Button
            android:id="@+id/btnCompare"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="开始对比"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#F44336" />

        <!-- 仅转写 -->
        <Button
            android:id="@+id/btnTranscribeOnly"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="仅转写（无需文档）"
            android:textSize="15sp"
            android:backgroundTint="#FF9800"
            android:layout_marginTop="8dp" />

        <!-- 进度条 -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:visibility="gone"
            style="?android:attr/progressBarStyleHorizontal"
            android:indeterminate="true" />

        <!-- 状态 -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="就绪"
            android:textColor="#888"
            android:gravity="center"
            android:padding="8dp" />

        <!-- 结果 -->
        <ScrollView
            android:id="@+id/scrollResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginTop="12dp"
            android:background="#FFF"
            android:padding="12dp">
            <TextView
                android:id="@+id/tvResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#333"
                android:lineSpacingMultiplier="1.4" />
        </ScrollView>

        <!-- 报告操作按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/btnGenerateReport"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="生成Word报告"
                android:textSize="14sp"
                android:backgroundTint="#1565C0"
                android:visibility="gone"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btnShare"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="分享到微信"
                android:textSize="14sp"
                android:backgroundTint="#4CAF50"
                android:visibility="gone"
                android:layout_marginStart="4dp" />

            <Button
                android:id="@+id/btnShareTranscript"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="分享转写"
                android:textSize="14sp"
                android:backgroundTint="#FF9800"
                android:visibility="gone"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <!-- 版权声明 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/copyright"
            android:textSize="10sp"
            android:textColor="#BBB"
            android:gravity="center"
            android:paddingTop="16dp"
            android:paddingBottom="8dp" />

    </LinearLayout>
</ScrollView>
