<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 500">
  <defs>
    <linearGradient id="bg4" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#fefce8"/>
      <stop offset="100%" style="stop-color:#fff7ed"/>
    </linearGradient>
    <filter id="s4">
      <feDropShadow dx="1" dy="2" stdDeviation="3" flood-opacity="0.12"/>
    </filter>
  </defs>

  <rect width="800" height="500" rx="16" fill="url(#bg4)"/>

  <!-- 标题 -->
  <text x="400" y="40" text-anchor="middle" font-family="Arial, sans-serif" font-size="22" font-weight="bold" fill="#92400e">Pull Request —— 举手发言请求合并</text>

  <!-- 步骤1：你写代码 -->
  <rect x="50" y="70" width="160" height="130" rx="14" fill="#fff" filter="url(#s4)" stroke="#fbbf24" stroke-width="2"/>
  <text x="130" y="100" text-anchor="middle" font-family="Arial, sans-serif" font-size="28">👩‍💻</text>
  <text x="130" y="125" text-anchor="middle" font-family="Arial, sans-serif" font-size="13" font-weight="bold" fill="#92400e">第1步</text>
  <text x="130" y="145" text-anchor="middle" font-family="Arial, sans-serif" font-size="11" fill="#78350f">在自己的分支上</text>
  <text x="130" y="163" text-anchor="middle" font-family="Arial, sans-serif" font-size="11" fill="#78350f">写好代码</text>
  <text x="130" y="185" text-anchor="middle" font-family="Arial, sans-serif" font-size="9" fill="#a3a3a3">feature-login 分支</text>

  <!-- 箭头1→2 -->
  <line x1="218" y1="135" x2="268" y2="135" stroke="#f59e0b" stroke-width="2.5" marker-end="url(#a4)"/>
  <defs><marker id="a4" markerWidth="8" markerHeight="6" refX="7" refY="3" orient="auto"><polygon points="0 0,8 3,0 6" fill="#f59e0b"/></marker></defs>

  <!-- 步骤2：发起PR -->
  <rect x="275" y="70" width="160" height="130" rx="14" fill="#fff" filter="url(#s4)" stroke="#f59e0b" stroke-width="2"/>
  <text x="355" y="100" text-anchor="middle" font-family="Arial, sans-serif" font-size="28">🙋</text>
  <text x="355" y="125" text-anchor="middle" font-family="Arial, sans-serif" font-size="13" font-weight="bold" fill="#92400e">第2步</text>
  <text x="355" y="145" text-anchor="middle" font-family="Arial, sans-serif" font-size="11" fill="#78350f">发起 Pull Request</text>
  <text x="355" y="163" text-anchor="middle" font-family="Arial, sans-serif" font-size="11" fill="#78350f">"请帮我看看代码"</text>
  <text x="355" y="185" text-anchor="middle" font-family="Arial, sans-serif" font-size="9" fill="#a3a3a3">附上说明和改动内容</text>

  <!-- 箭头2→3 -->
  <line x1="443" y1="135" x2="493" y2="135" stroke="#f59e0b" stroke-width="2.5" marker-end="url(#a4)"/>

  <!-- 步骤3：代码审查 -->
  <rect x="500" y="70" width="160" height="130" rx="14" fill="#fff" filter="url(#s4)" stroke="#fb923c" stroke-width="2"/>
  <text x="580" y="100" text-anchor="middle" font-family="Arial, sans-serif" font-size="28">🔍</text>
  <text x="580" y="125" text-anchor="middle" font-family="Arial, sans-serif" font-size="13" font-weight="bold" fill="#92400e">第3步</text>
  <text x="580" y="145" text-anchor="middle" font-family="Arial, sans-serif" font-size="11" fill="#78350f">队友审查代码</text>
  <text x="580" y="163" text-anchor="middle" font-family="Arial, sans-serif" font-size="11" fill="#78350f">Code Review</text>
  <text x="580" y="185" text-anchor="middle" font-family="Arial, sans-serif" font-size="9" fill="#a3a3a3">提建议、找问题</text>

  <!-- 箭头3→4 -->
  <line x1="668" y1="135" x2="700" y2="135" stroke="#f59e0b" stroke-width="2.5" marker-end="url(#a4)"/>

  <!-- 步骤4：合并 -->
  <rect x="608" y="70" width="160" height="130" rx="14" fill="#fff" filter="url(#s4)" stroke="#ef4444" stroke-width="2" transform="translate(100,0)"/>
  <text x="788" y="100" text-anchor="middle" font-family="Arial, sans-serif" font-size="28" transform="translate(-100,0)">✅</text>
  <text x="788" y="125" text-anchor="middle" font-family="Arial, sans-serif" font-size="13" font-weight="bold" fill="#92400e" transform="translate(-100,0)">第4步</text>
  <text x="788" y="145" text-anchor="middle" font-family="Arial, sans-serif" font-size="11" fill="#78350f" transform="translate(-100,0)">合并到主分支</text>
  <text x="788" y="163" text-anchor="middle" font-family="Arial, sans-serif" font-size="11" fill="#78350f" transform="translate(-100,0)">Merge!</text>

  <!-- 对话气泡区域 -->
  <text x="400" y="240" text-anchor="middle" font-family="Arial, sans-serif" font-size="16" font-weight="bold" fill="#78350f">💬 PR 里的对话长这样：</text>

  <!-- 对话框背景 -->
  <rect x="100" y="260" width="600" height="210" rx="14" fill="#fff" filter="url(#s4)" stroke="#fed7aa" stroke-width="1.5"/>

  <!-- 小红的消息 -->
  <circle cx="140" cy="295" r="16" fill="#fecaca"/>
  <text x="140" y="300" text-anchor="middle" font-family="Arial, sans-serif" font-size="14">👩</text>
  <rect x="168" y="280" width="380" height="35" rx="10" fill="#fef3c7"/>
  <text x="180" y="293" font-family="Arial, sans-serif" font-size="11" fill="#92400e" font-weight="bold">小红（提交者）</text>
  <text x="180" y="308" font-family="Arial, sans-serif" font-size="12" fill="#78350f">我做了一个照片墙功能，请大家帮忙看看！</text>

  <!-- 小明的评论 -->
  <circle cx="140" cy="345" r="16" fill="#bfdbfe"/>
  <text x="140" y="350" text-anchor="middle" font-family="Arial, sans-serif" font-size="14">👨</text>
  <rect x="168" y="330" width="420" height="35" rx="10" fill="#dbeafe"/>
  <text x="180" y="343" font-family="Arial, sans-serif" font-size="11" fill="#1e40af" font-weight="bold">小明（审查者）</text>
  <text x="180" y="358" font-family="Arial, sans-serif" font-size="12" fill="#1e3a5f">代码不错！但第15行的变量名建议改一下 💬</text>

  <!-- 小刚的评论 -->
  <circle cx="140" cy="395" r="16" fill="#bbf7d0"/>
  <text x="140" y="400" text-anchor="middle" font-family="Arial, sans-serif" font-size="14">🧑</text>
  <rect x="168" y="380" width="280" height="35" rx="10" fill="#d1fae5"/>
  <text x="180" y="393" font-family="Arial, sans-serif" font-size="11" fill="#065f46" font-weight="bold">小刚（审查者）</text>
  <text x="180" y="408" font-family="Arial, sans-serif" font-size="12" fill="#064e3b">我觉得可以！LGTM 👍</text>

  <!-- 合并按钮 -->
  <rect x="168" y="425" width="160" height="32" rx="16" fill="#22c55e"/>
  <text x="248" y="446" text-anchor="middle" font-family="Arial, sans-serif" font-size="13" fill="#fff" font-weight="bold">✅ Merge Pull Request</text>
</svg>