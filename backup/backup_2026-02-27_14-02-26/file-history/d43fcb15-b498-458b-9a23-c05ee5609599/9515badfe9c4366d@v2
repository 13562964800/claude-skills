THEME_ORDER = ['summer', 'dark', 'simple']

def get_theme(theme_id: str) -> dict:
    """获取指定主题配置"""
    return THEMES.get(theme_id, THEMES['summer'])

def get_all_themes() -> dict:
    """获取所有主题"""
    return THEMES

def get_theme_id_by_name(name: str) -> str:
    """通过名称获取主题ID"""
    for tid, theme in THEMES.items():
        if theme['name'] == name:
            return tid
    return 'summer'
