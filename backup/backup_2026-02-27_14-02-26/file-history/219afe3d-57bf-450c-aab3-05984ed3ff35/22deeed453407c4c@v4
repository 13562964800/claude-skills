    /**
     * 平台检测 - 参考 Electron 版本的 detectPlatform 函数
     * 支持更多平台和短链接
     */
    fun detectPlatform(url: String): VideoPlatform {
        val lowerUrl = url.lowercase()
        return when {
            // YouTube - 支持主域名和短链接
            lowerUrl.contains("youtube.com") || lowerUrl.contains("youtu.be") -> VideoPlatform.YOUTUBE
            // Bilibili - 支持主域名和 b23.tv 短链接
            lowerUrl.contains("bilibili.com") || lowerUrl.contains("b23.tv") -> VideoPlatform.BILIBILI
            // 抖音 - 支持多种域名
            lowerUrl.contains("douyin.com") || lowerUrl.contains("iesdouyin.com") -> VideoPlatform.DOUYIN
            // TikTok
            lowerUrl.contains("tiktok.com") -> VideoPlatform.TIKTOK
            // 微博
            lowerUrl.contains("weibo.com") -> VideoPlatform.WEIBO
            // 小红书
            lowerUrl.contains("xiaohongshu.com") || lowerUrl.contains("xhslink.com") -> VideoPlatform.XIAOHONGSHU
            // 微信视频号 - 只匹配视频号专用域名
            lowerUrl.contains("channels.weixin.qq.com") -> VideoPlatform.WECHAT
            // 直接视频链接
            lowerUrl.contains(".mp4") || lowerUrl.contains(".m3u8") || lowerUrl.contains(".mpd") -> VideoPlatform.DIRECT
            // 未知平台
            else -> VideoPlatform.UNKNOWN
        }
    }

    /**
     * 获取视频下载链接 - 主入口函数
     * 参考 Electron 版本的 extract-info IPC 处理
     */
    suspend fun getVideoInfo(url: String): Result<VideoDownloadInfo> = withContext(Dispatchers.IO) {
        try {
            withTimeout(DEFAULT_TIMEOUT) {
                val cleanUrl = cleanUrl(url)
                Log.d(TAG, "Processing URL: $cleanUrl")

                val platform = detectPlatform(cleanUrl)
                Log.d(TAG, "Detected platform: $platform")

                when (platform) {
                    VideoPlatform.YOUTUBE -> fetchYoutubeInfo(cleanUrl)
                    VideoPlatform.BILIBILI -> fetchBilibiliInfo(cleanUrl)
                    VideoPlatform.DOUYIN -> fetchDouyinInfo(cleanUrl)
                    VideoPlatform.TIKTOK -> fetchTiktokInfo(cleanUrl)
                    VideoPlatform.XIAOHONGSHU -> fetchXiaohongshuInfo(cleanUrl)
                    VideoPlatform.WECHAT -> fetchWechatChannelsInfo(cleanUrl)
                    VideoPlatform.DIRECT -> Result.success(
                        VideoDownloadInfo(
                            title = "直接视频链接",
                            downloadUrl = cleanUrl,
                            cover = null,
                            duration = 0L,
                            author = null,
                            platform = VideoPlatform.DIRECT
                        )
                    )
                    else -> Result.failure(
                        Exception(
                            "❌ 不支持的平台\n\n当前链接: $cleanUrl\n\n支持的平台:\n• YouTube (youtube.com, youtu.be)\n• B站 (bilibili.com, b23.tv)\n• 抖音 (douyin.com)\n• TikTok (tiktok.com)\n• 小红书 (xiaohongshu.com, xhslink.com)\n• 微信视频号 (channels.weixin.qq.com)\n\n建议: 请使用「导入本地视频」功能"
                        )
                    )
                }
            }
        } catch (e: Throwable) {
            Log.e(TAG, "Error fetching video info", e)
            val message = if (e is kotlinx.coroutines.TimeoutCancellationException) {
                "解析超时，请检查网络连接后重试"
            } else {
                "获取视频信息失败: ${e.message}"
            }
            Result.failure(Exception(message, e))
        }
    }

    /**
     * 清理 URL - 移除多余空格和无效字符
     * 参考 Electron 版本的 cleanUrl 函数
     */
    private fun cleanUrl(url: String): String {
        val trimmed = url.trim()
        // 提取第一个有效的 HTTP/HTTPS 链接
        val match = Regex("(https?://[^\\s\"'<>]+)").find(trimmed)
        return match?.value ?: trimmed
    }

    /**
     * 获取 YouTube 视频信息 - 改进版，使用 InnerTube API
     * 基于 GitHub 研究：
     * - ViMusic: https://github.com/vfsfitvnm/ViMusic (InnerTube 实现)
     * - NewPipeExtractor: https://github.com/TeamNewPipe/NewPipeExtractor
     */
    private suspend fun fetchYoutubeInfo(url: String): Result<VideoDownloadInfo> {
        Log.d(TAG, "Fetching YouTube info for: $url")

        // 策略1: 尝试 NewPipeExtractor（需要 API 33+，低版本 URLDecoder.decode(String,Charset) 不存在）
        if (android.os.Build.VERSION.SDK_INT >= 33) {
            val newPipeResult = fetchYoutubeNewPipe(url)
            if (newPipeResult.isSuccess) {
                Log.d(TAG, "NewPipeExtractor success")
                return newPipeResult
            }
            Log.w(TAG, "NewPipeExtractor failed: ${newPipeResult.exceptionOrNull()?.message}")
        } else {
            Log.d(TAG, "Skipping NewPipeExtractor on API ${android.os.Build.VERSION.SDK_INT} (requires 33+)")
        }

        // 策略2: 尝试 InnerTube API（备用）
        val innertubeResult = fetchYouTubeInnerTubeAPI(url)
        if (innertubeResult.isSuccess) {
            Log.d(TAG, "InnerTube API success")
            return innertubeResult
        }
        Log.w(TAG, "InnerTube API failed: ${innertubeResult.exceptionOrNull()?.message}")

        // 策略3: 尝试第三方API（最后备用）
        return fetchYouTubeThirdPartyAPI(url)
    }

    /**
     * 使用 NewPipeExtractor 解析 YouTube 视频
     * 这是专门为 Android 设计的库，不依赖 YouTube API
     */
    private suspend fun fetchYoutubeNewPipe(url: String): Result<VideoDownloadInfo> = withContext(Dispatchers.IO) {
        try {
            val videoId = extractYoutubeVideoId(url)
                ?: return@withContext Result.failure(Exception("无法提取 YouTube 视频 ID"))

            Log.d(TAG, "Using NewPipeExtractor for YouTube: $videoId")

            // 使用标准 YouTube URL 格式
            val standardUrl = "https://www.youtube.com/watch?v=$videoId"
            val streamInfo = org.schabi.newpipe.extractor.stream.StreamInfo.getInfo(standardUrl)

            // 获取最佳视频流
            val videoStream = streamInfo.videoStreams
                .filter { !it.isVideoOnly }
                .maxByOrNull { it.getResolution()?.replace("p", "")?.toIntOrNull() ?: 0 }

            // 获取最佳纯视频流（DASH）
            val videoOnlyStream = streamInfo.videoOnlyStreams
                .maxByOrNull { it.getResolution()?.replace("p", "")?.toIntOrNull() ?: 0 }

            // 获取最佳音频流
            val audioStream = streamInfo.audioStreams
                .maxByOrNull { it.averageBitrate }

            // 优先使用 DASH（视频+音频分离，画质更好）
            val bestVideo = videoOnlyStream ?: videoStream
            val bestAudio = if (videoOnlyStream != null) audioStream else null

            if (bestVideo != null) {
                Result.success(VideoDownloadInfo(
                    title = streamInfo.name ?: "YouTube 视频",
                    downloadUrl = bestVideo.content ?: "",
                    cover = streamInfo.thumbnails?.firstOrNull()?.url,
                    duration = streamInfo.duration,
                    author = streamInfo.uploaderName,
                    platform = VideoPlatform.YOUTUBE,
                    audioUrl = bestAudio?.content
                ))
            } else {
                Result.failure(Exception("无法获取视频流"))
            }
        } catch (e: Throwable) {
            // 捕获 Throwable 而非 Exception，因为 NewPipe 可能抛出 NoSuchMethodError 等
            Log.e(TAG, "NewPipeExtractor error", e)
            Result.failure(Exception("NewPipe解析失败: ${e.message}", e))
        }
    }

    /**
     * 使用 YouTube InnerTube API 解析
     * 使用 ANDROID 客户端身份请求 googleapis 端点
     */
    private suspend fun fetchYouTubeInnerTubeAPI(url: String): Result<VideoDownloadInfo> = withContext(Dispatchers.IO) {
        try {
            val videoId = extractYoutubeVideoId(url)
            if (videoId == null) {
                return@withContext Result.failure(Exception("无法提取视频ID"))
            }
            Log.d(TAG, "YouTube video ID: $videoId")

            // InnerTube API 请求 - 使用 ANDROID 客户端
            val requestBody = JSONObject().apply {
                put("context", JSONObject().apply {
                    put("client", JSONObject().apply {
                        put("clientName", "ANDROID")
                        put("clientVersion", "19.29.37")
                        put("androidSdkVersion", 34)
                        put("hl", "en")
                        put("gl", "US")
                        put("userAgent", "com.google.android.youtube/19.29.37 (Linux; U; Android 14) gzip")
                    })
                })
                put("videoId", videoId)
                put("contentCheckOk", true)
                put("racyCheckOk", true)
            }.toString()

            // ANDROID 客户端使用 googleapis 端点
            val request = Request.Builder()
                .url("https://youtubei.googleapis.com/youtubei/v1/player?key=AIzaSyA8eiZmM1FaDVjRy-df2KTyQ_vz_yYM39w")
                .header("Content-Type", "application/json")
                .header("User-Agent", "com.google.android.youtube/19.29.37 (Linux; U; Android 14) gzip")
                .header("X-YouTube-Client-Name", "3")
                .header("X-YouTube-Client-Version", "19.29.37")
                .post(requestBody.toRequestBody("application/json".toMediaType()))
                .build()

            val response = client.newCall(request).execute()
            val body = response.body?.string() ?: return@withContext Result.failure(IOException("空响应"))
            val json = JSONObject(body)

            // 检查播放状态
            val playabilityStatus = json.optJSONObject("playabilityStatus")
            val status = playabilityStatus?.optString("status")
            if (status != "OK") {
                val reason = playabilityStatus?.optString("reason") ?: "视频不可用"
                return@withContext Result.failure(Exception("YouTube: $reason"))
            }

            val videoDetails = json.optJSONObject("videoDetails")
            val title = videoDetails?.optString("title") ?: "YouTube视频"
            val author = videoDetails?.optString("author") ?: ""
            val lengthSeconds = videoDetails?.optLong("lengthSeconds") ?: 0L

            val streamingData = json.optJSONObject("streamingData")

            // 优先使用 adaptiveFormats（分离的音视频流，画质更好）
            val adaptiveFormats = streamingData?.optJSONArray("adaptiveFormats")
            var bestVideoUrl: String? = null
            var bestAudioUrl: String? = null
            var bestVideoBitrate = 0L
            var bestAudioBitrate = 0L

            if (adaptiveFormats != null) {
                for (i in 0 until adaptiveFormats.length()) {
                    val fmt = adaptiveFormats.getJSONObject(i)
                    val mimeType = fmt.optString("mimeType", "")
                    val fmtUrl = fmt.optString("url")
                    val bitrate = fmt.optLong("bitrate", 0)

                    if (fmtUrl.isEmpty()) continue // 跳过加密的流

                    if (mimeType.startsWith("video/") && bitrate > bestVideoBitrate) {
                        bestVideoBitrate = bitrate
                        bestVideoUrl = fmtUrl
                    } else if (mimeType.startsWith("audio/") && bitrate > bestAudioBitrate) {
                        bestAudioBitrate = bitrate
                        bestAudioUrl = fmtUrl
                    }
                }
            }

            // 如果 adaptiveFormats 没有可用的，回退到 formats（混合流）
            if (bestVideoUrl == null) {
                val formats = streamingData?.optJSONArray("formats")
                if (formats != null && formats.length() > 0) {
                    // 选择最高画质的混合流
                    var bestBitrate = 0L
                    for (i in 0 until formats.length()) {
                        val fmt = formats.getJSONObject(i)
                        val fmtUrl = fmt.optString("url")
                        val bitrate = fmt.optLong("bitrate", 0)
                        if (fmtUrl.isNotEmpty() && bitrate > bestBitrate) {
                            bestBitrate = bitrate
                            bestVideoUrl = fmtUrl
                        }
                    }
                }
            }

            val thumbnails = videoDetails?.optJSONObject("thumbnail")?.optJSONArray("thumbnails")
            val cover = thumbnails?.let {
                if (it.length() > 0) it.getJSONObject(it.length() - 1).optString("url") else null
            }

            if (bestVideoUrl != null) {
                return@withContext Result.success(VideoDownloadInfo(
                    title = title,
                    downloadUrl = bestVideoUrl,
                    cover = cover,
                    duration = lengthSeconds,
                    author = author,
                    platform = VideoPlatform.YOUTUBE,
                    audioUrl = bestAudioUrl
                ))
            }

            Result.failure(Exception("无法获取视频流（可能需要签名解密）"))

        } catch (e: Exception) {
            Log.e(TAG, "InnerTube API error", e)
            Result.failure(e)
        }
    }

    /**
     * 使用第三方API解析（备用方案）
     */
    private suspend fun fetchYouTubeThirdPartyAPI(url: String): Result<VideoDownloadInfo> {
        // 尝试多个第三方API
        val apis = listOf(
            YoutubeApiConfig("https://yt.lemnoslife.com/videosPart", "lemnoslife"),
            YoutubeApiConfig("https://noembed.com/embed?url=$url", "noembed")
        )

        for (api in apis) {
            try {
                Log.d(TAG, "Trying YouTube API: ${api.name}")
                val result = fetchYoutubeInfoWithApi(url, api)
                if (result.isSuccess) {
                    return result
                }
            } catch (e: Exception) {
                Log.w(TAG, "YouTube API ${api.name} failed: ${e.message}")
            }
        }

        return Result.failure(
            Exception("❌ YouTube 解析失败\n\n请确认已开启 VPN 后重试\n\n或使用「导入本地视频」功能")
        )
    }

    /**
     * 使用指定 API 获取 YouTube 视频信息
     */
    private suspend fun fetchYoutubeInfoWithApi(
        url: String,
        api: YoutubeApiConfig
    ): Result<VideoDownloadInfo> = withContext(Dispatchers.IO) {
        try {
            when (api.name) {
                "lemnoslife" -> {
                    // 使用 Lemnoslife API
                    val videoId = extractYoutubeVideoId(url)
                        ?: return@withContext Result.failure(Exception("无法提取 YouTube 视频 ID"))

                    val request = Request.Builder()
                        .url("${api.endpoint}?id=$videoId")
                        .header("User-Agent", getUserAgent())
                        .build()

                    val response = client.newCall(request).execute()
                    val responseBody = response.body?.string()
                        ?: return@withContext Result.failure(IOException("空响应"))

                    Log.d(TAG, "Lemnoslife API response: ${responseBody.take(200)}")

                    val json = JSONObject(responseBody)
                    if (!json.has("items") || json.getJSONArray("items").length() == 0) {
                        return@withContext Result.failure(Exception("视频不存在或不可用"))
                    }

                    val items = json.getJSONArray("items")
                    val video = items.getJSONObject(0)

                    // 注意：这个 API 主要提供元数据，不提供下载链接
                    // 实际下载需要使用其他方法
                    Result.success(
                        VideoDownloadInfo(
                            title = video.optString("title", "YouTube 视频"),
                            downloadUrl = url, // 返回原 URL，需要特殊处理
                            cover = video.optJSONArray("thumbnails")
                                ?.optJSONObject(0)
                                ?.optString("url"),
                            duration = video.optLong("durationSeconds", 0L),
                            author = video.optJSONArray("channel")
                                ?.optJSONObject(0)
                                ?.optString("name"),
                            platform = VideoPlatform.YOUTUBE
                        )
                    )
                }
                "noembed" -> {
                    // 使用 NoEmbed API（主要用于获取元数据）
                    val request = Request.Builder()
                        .url(api.endpoint)
                        .header("User-Agent", getUserAgent())
                        .build()

                    val response = client.newCall(request).execute()
                    val responseBody = response.body?.string()
                        ?: return@withContext Result.failure(IOException("空响应"))

                    Log.d(TAG, "NoEmbed API response: ${responseBody.take(200)}")

                    val json = JSONObject(responseBody)
                    val title = json.optString("title", "YouTube 视频")
                    val author = json.optString("author_name")

                    Result.success(
                        VideoDownloadInfo(
                            title = title,
                            downloadUrl = url, // NoEmbed 不提供下载链接
                            cover = json.optString("thumbnail_url"),
                            duration = 0L,
                            author = author,
                            platform = VideoPlatform.YOUTUBE
                        )
                    )
                }
                else -> Result.failure(Exception("未知 API"))
            }
        } catch (e: Exception) {
            Log.e(TAG, "Error fetching YouTube info with ${api.name}", e)
            Result.failure(e)
        }
    }

    /**
     * 提取 B站视频标识（BV号或av号）
     * 支持 BV 号、av 号和 b23.tv 短链接
     */
    private fun extractBVID(url: String): String? {
        // 优先匹配 BV 号
        val bvPattern = Regex("(BV[a-zA-Z0-9]{10})")
        val bvMatch = bvPattern.find(url)
        if (bvMatch != null) return bvMatch.groupValues[1]

        // 匹配 av 号（转换为请求参数用）
        val avPattern = Regex("av(\\d+)", RegexOption.IGNORE_CASE)
        val avMatch = avPattern.find(url)
        if (avMatch != null) return "av${avMatch.groupValues[1]}"

        return null
    }

    /**
     * 解析 b23.tv 短链接，获取真实 URL
     */
    private suspend fun resolveB23ShortLink(url: String): String? = withContext(Dispatchers.IO) {
        try {
            val noRedirectClient = OkHttpClient.Builder()
                .connectTimeout(10, TimeUnit.SECONDS)
                .readTimeout(10, TimeUnit.SECONDS)
                .followRedirects(false)
                .build()

            val request = Request.Builder()
                .url(url)
                .header("User-Agent", getUserAgent())
                .build()

            val response = noRedirectClient.newCall(request).execute()
            val location = response.header("Location")
            response.close()
            location
        } catch (e: Exception) {
            Log.e(TAG, "Failed to resolve b23.tv short link", e)
            null
        }
    }

    /**
     * 提取 YouTube 视频 ID
     * 支持格式: watch?v=, youtu.be/, embed/, shorts/, v/, live/
     */
    private fun extractYoutubeVideoId(url: String): String? {
        val patterns = listOf(
            Regex("(?:youtube\\.com/watch\\?.*v=)([a-zA-Z0-9_-]{11})"),
            Regex("youtu\\.be/([a-zA-Z0-9_-]{11})"),
            Regex("youtube\\.com/embed/([a-zA-Z0-9_-]{11})"),
            Regex("youtube\\.com/shorts/([a-zA-Z0-9_-]{11})"),
            Regex("youtube\\.com/v/([a-zA-Z0-9_-]{11})"),
            Regex("youtube\\.com/live/([a-zA-Z0-9_-]{11})")
        )

        for (pattern in patterns) {
            val match = pattern.find(url)
            if (match != null) {
                return match.groupValues[1]
            }
        }
        return null
    }

